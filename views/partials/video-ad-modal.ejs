<!-- Only render this HTML/JS if the user is supposed to see ads -->
<% if (typeof showAds !== 'undefined' && showAds) { %>

    <!-- 1. Include Fluid Player CDN -->
    <script src="https://cdn.fluidplayer.com/v3/current/fluidplayer.min.js"></script>

    <!-- ======== VIDEO AD MODAL ======== -->
    <!-- Added pointer-events: auto to ensure the background overlay blocks clicks to the site below -->
    <div id="video-ad-modal" class="policy-modal" style="display: flex; align-items: center; justify-content: center; background-color: rgba(0,0,0,0.95); z-index: 10000; pointer-events: auto;">
        
        <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 800px; width: 95%; border-top: 4px solid var(--gold); box-shadow: 0 10px 40px rgba(255, 215, 0, 0.4); display: flex; flex-direction: column; gap: 15px;">
            
            <!-- INTRO SCREEN -->
            <div id="ad-intro-screen">
                <i class="fas fa-play-circle" style="font-size: 4em; color: var(--gold); margin-bottom: 20px; text-shadow: 0 0 15px var(--glow-gold);"></i>
                <h2 style="color: var(--white); margin-bottom: 15px;">Support GPL Mods</h2>
                <p style="color: var(--silver); margin-bottom: 25px; line-height: 1.6; font-size: 1.1em;">
                    Please watch a short sponsor video to help keep our servers running and our mods free for everyone.
                </p>
                
                <button id="watch-video-btn" class="btn btn-primary" style="background: var(--gold); color: var(--black); padding: 15px 30px; border-radius: 25px; font-weight: bold; font-size: 1.1em; border: none; cursor: pointer; box-shadow: 0 0 20px var(--glow-gold); width: 100%; transition: all 0.3s;">
                    Play Sponsor Video
                </button>
            </div>

            <!-- THE FLUID PLAYER CONTAINER (Hidden initially) -->
            <!-- Removing the custom close button means the user relies ENTIRELY on the player UI -->
            <div id="ad-player-container" style="display: none; width: 100%; aspect-ratio: 16 / 9; margin: 0 auto; background: #000; border-radius: 8px; overflow: hidden; position: relative;">
                
                <!-- 
                  Dummy Base64 video prevents 404 errors. 
                  The VAST preRoll ad will intercept this immediately.
                -->
                <video id="fluid-video-id" style="width: 100%; height: 100%;">
                    <source src="data:video/mp4;base64,AAAAHGZ0eXBpc29tAAACAGlzb21pc28ybXA0MQAAAAhmcmVlAAAAG21kYXQAAAGzABAHAAABthkEAAAAACkQAAA=" type="video/mp4" />
                </video>
                
            </div>

            <!-- Removed your custom skip/close button. -->
            
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const videoModal = document.getElementById('video-ad-modal');
            const introScreen = document.getElementById('ad-intro-screen');
            const watchBtn = document.getElementById('watch-video-btn');
            const playerContainer = document.getElementById('ad-player-container');

            if (!videoModal || !watchBtn || !playerContainer) return;

            let myFP = null;

            // 1. Show the modal smoothly
            setTimeout(() => { 
                videoModal.classList.add('show'); 
                document.body.style.overflow = 'hidden'; // Stop background scrolling
            }, 500);

            // Function to smoothly close the modal and resume the site
            function closeAdModal() {
                if (myFP) {
                    try { myFP.destroy(); } catch(e) {}
                }
                videoModal.classList.remove('show');
                document.body.style.overflow = 'auto'; // Restore page scrolling
                setTimeout(() => { 
                    videoModal.remove(); // Remove from DOM
                }, 300);
            }

            // 2. Handle the "Play Video" click
            watchBtn.addEventListener('click', () => {
                
                // Hide intro, show player
                introScreen.style.display = 'none';
                playerContainer.style.display = 'block';

                // 3. Initialize Fluid Player using your EXACT config
                myFP = fluidPlayer('fluid-video-id', {
                    "layoutControls": {
                        "controlBar": {
                            "autoHideTimeout": 3,
                            "animated": true,
                            "autoHide": true
                        },
                        "htmlOnPauseBlock": {
                            "html": null,
                            "height": null,
                            "width": null
                        },
                        "autoPlay": true, // Automatically start
                        "mute": false,
                        "allowTheatre": true,
                        "playPauseAnimation": false,
                        "playbackRateEnabled": false,
                        "allowDownload": false,
                        "playButtonShowing": false,
                        "fillToContainer": true, // Perfect for our aspect-ratio box
                        "primaryColor": "#FFD700", // GPL Mods Gold!
                        "posterImage": ""
                    },
                    "vastOptions": {
                        "adList":[
                            {
                                "roll": "preRoll",
                                "vastTag": "https://fluffy-management.com/dmmOF.zmdUG/N/vCZFGAUZ/NeWmc9Au/Z/UclMkGPATyYa5_N/jOgK5/M/jTkdtHN/jok/2/OGDzkhzrMbwZ",
                                "adText": ""
                            },
                            {
                                "roll": "midRoll",
                                "vastTag": "https://fluffy-management.com/dmmOF.zmdUG/N/vCZFGAUZ/NeWmc9Au/Z/UclMkGPATyYa5_N/jOgK5/M/jTkdtHN/jok/2/OGDzkhzrMbwZ",
                                "adText": ""
                            },
                            {
                                "roll": "postRoll",
                                "vastTag": "https://fluffy-management.com/dmmOF.zmdUG/N/vCZFGAUZ/NeWmc9Au/Z/UclMkGPATyYa5_N/jOgK5/M/jTkdtHN/jok/2/OGDzkhzrMbwZ",
                                "adText": ""
                            }
                        ],
                        "adCTAText": false,
                        "adCTATextPosition": ""
                    }
                });

                // ========================================================
                // CRITICAL LOGIC: Auto-Close when the main content finishes
                // ========================================================
                
                // Fluid Player will play the preRoll ad, then play the main video, 
                // then play the postRoll ad.
                
                // We listen for the 'ended' event on the HTML5 video element itself.
                // Because our main video is just a 1-byte dummy file, it "ends" instantly
                // as soon as the pre/mid/post-roll ads are finished playing or skipping.
                
                const videoElement = document.getElementById('fluid-video-id');
                
                if (videoElement) {
                    videoElement.addEventListener('ended', function() {
                        // All ads and content are finished. Close the modal automatically!
                        console.log("Ads finished, closing modal.");
                        closeAdModal();
                    });
                }

                // SAFETY FALLBACK: Ad Blockers
                // If an ad blocker blocks the VAST request, the dummy video will just play and instantly end, 
                // triggering the 'ended' event above and closing the modal. The user won't get stuck.
                
                // SECONDARY FALLBACK: VAST Error
                // If HilltopAds throws an error (e.g. no fill), we must close the modal so the user isn't trapped.
                myFP.on('vastAdError', function() {
                    console.log("VAST Error (likely no fill or blocked). Continuing to site.");
                    closeAdModal();
                });
            });
        });
    </script>
<% } %>