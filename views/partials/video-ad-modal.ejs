<!-- Only render this HTML/JS if the user is supposed to see ads -->
<% if (typeof showAds !== 'undefined' && showAds) { %>

    <!-- 1. Include Fluid Player CDN -->
    <script src="https://cdn.fluidplayer.com/v3/current/fluidplayer.min.js"></script>

    <!-- ======== VIDEO AD MODAL ======== -->
    <div id="video-ad-modal" class="policy-modal" style="display: none; align-items: center; justify-content: center; background-color: rgba(0,0,0,0.95); z-index: 10000; pointer-events: auto;">
        
        <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 800px; width: 95%; border-top: 4px solid var(--gold); box-shadow: 0 10px 40px rgba(255, 215, 0, 0.4); display: flex; flex-direction: column; gap: 15px;">
            
            <!-- INTRO SCREEN -->
            <div id="ad-intro-screen">
                <i class="fas fa-play-circle" style="font-size: 4em; color: var(--gold); margin-bottom: 20px; text-shadow: 0 0 15px var(--glow-gold);"></i>
                <h2 style="color: var(--white); margin-bottom: 15px;">Support GPL Mods</h2>
                <p style="color: var(--silver); margin-bottom: 25px; line-height: 1.6; font-size: 1.1em;">
                    Please watch a short sponsor video to help keep our servers running and our mods free for everyone.
                </p>
                
                <button id="watch-video-btn" class="btn btn-primary" style="background: var(--gold); color: var(--black); padding: 15px 30px; border-radius: 25px; font-weight: bold; font-size: 1.1em; border: none; cursor: pointer; box-shadow: 0 0 20px var(--glow-gold); width: 100%; transition: all 0.3s;">
                    Play Sponsor Video
                </button>
            </div>

            <!-- THE FLUID PLAYER CONTAINER -->
            <div id="ad-player-container" style="display: none; width: 100%; aspect-ratio: 16 / 9; margin: 0 auto; background: #000; border-radius: 8px; overflow: hidden; position: relative;">
                
                <!-- A simple 10-second silent video to hold the player open while the ad loads -->
                <video id="fluid-video-id" style="width: 100%; height: 100%;">
                    <source src="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4" type="video/mp4" />
                </video>
                
            </div>

            <!-- ✅ FIX: Reliable Close Button (Hidden initially) -->
            <button id="manual-close-btn" class="btn btn-secondary" style="display: none; margin-top: 15px; border: 1px solid #555; background: transparent; color: var(--silver); padding: 10px 20px; border-radius: 8px; cursor: pointer;">
                Close & Continue
            </button>
            
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const videoModal = document.getElementById('video-ad-modal');
            const introScreen = document.getElementById('ad-intro-screen');
            const watchBtn = document.getElementById('watch-video-btn');
            const playerContainer = document.getElementById('ad-player-container');
            const manualCloseBtn = document.getElementById('manual-close-btn');
            const backgroundAudio = document.getElementById('background-audio');

            if (!videoModal || !watchBtn || !playerContainer) return;

            // --- 1. COOKIE LOGIC (30 Minute Cooldown) ---
            const adCookieName = 'gplmods_video_ad_watched';
            
            function getCookie(name) {
                const value = `; ${document.cookie}`;
                const parts = value.split(`; ${name}=`);
                if (parts.length === 2) return parts.pop().split(';').shift();
                return null;
            }

            function setAdCookie() {
                const date = new Date();
                date.setTime(date.getTime() + (30 * 60 * 1000)); // 30 mins
                document.cookie = `${adCookieName}=true;expires=${date.toUTCString()};path=/`;
            }

            if (getCookie(adCookieName) === 'true') {
                console.log("User watched video ad recently. Skipping.");
                return; 
            }

            let myFP = null;

            // --- 2. SHOW MODAL & PAUSE MUSIC ---
            setTimeout(() => { 
                videoModal.style.display = 'flex';
                setTimeout(() => videoModal.classList.add('show'), 10);
                document.body.style.overflow = 'hidden'; 
                
                if (backgroundAudio && !backgroundAudio.paused) {
                    backgroundAudio.dataset.adPaused = 'true';
                    backgroundAudio.pause();
                }
            }, 500);

            // --- 3. CLOSE MODAL LOGIC ---
            function closeAdModal() {
                if (myFP) {
                    try { myFP.destroy(); } catch(e) {}
                }
                videoModal.classList.remove('show');
                document.body.style.overflow = 'auto'; 
                
                setAdCookie(); // Set cookie when closed
                
                setTimeout(() => { 
                    videoModal.style.display = 'none';
                    if (backgroundAudio && backgroundAudio.dataset.adPaused === 'true') {
                        backgroundAudio.play();
                        backgroundAudio.dataset.adPaused = 'false';
                    }
                }, 300);
            }

            // Bind the close function to the new manual button
            manualCloseBtn.addEventListener('click', closeAdModal);

            // --- 4. HANDLE "PLAY VIDEO" CLICK ---
            watchBtn.addEventListener('click', () => {
                
                introScreen.style.display = 'none';
                playerContainer.style.display = 'block';

                myFP = fluidPlayer('fluid-video-id', {
                    "layoutControls": {
                        "controlBar": { "autoHideTimeout": 3, "animated": true, "autoHide": true },
                        "autoPlay": true, 
                        "mute": false,
                        "allowTheatre": false,
                        "playPauseAnimation": false,
                        "playbackRateEnabled": false,
                        "allowDownload": false,
                        "playButtonShowing": false,
                        "fillToContainer": true, 
                        "primaryColor": "#FFD700" 
                    },
                    "vastOptions": {
                        "adList":[
                            {
                                "roll": "preRoll",
                                "vastTag": "https://fluffy-management.com/dmmOF.zmdUG/N/vCZFGAUZ/NeWmc9Au/Z/UclMkGPATyYa5_N/jOgK5/M/jTkdtHN/jok/2/OGDzkhzrMbwZ",
                                "adText": ""
                            }
                        ],
                        "adCTAText": false
                    }
                });

                // ✅ FIX: Show the Close button after 8 seconds, regardless of what the ad is doing.
                // This guarantees the user is never trapped, even if the ad throws a DOMException or fails to load.
                setTimeout(() => {
                    manualCloseBtn.style.display = 'inline-block';
                }, 8000);
            });
        });
    </script>
<% } %>