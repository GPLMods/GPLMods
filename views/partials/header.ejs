<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPL Mods - Safe & Working Mods For All Your Devices!</title>
    
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    <!-- PWA Meta Tags -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0a0a0a">
    
    <!-- iOS Support -->
    <link rel="apple-touch-icon" href="/images/icon-192x192.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="GPL Mods">
    
    <!-- Android/Chrome Support -->
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/image-fallback.js"></script>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

    <!-- ====================================================================== -->
    <!-- ✅ FIX: BULLETPROOF HEADER & SEARCH BAR LAYOUT -->
    <!-- ====================================================================== -->
    <style>
        /* Ensure header stretches to hold everything on mobile */
        .main-header { height: auto !important; padding: 15px 0 20px 0 !important; }
        
        .header-content { 
            display: flex; 
            flex-wrap: wrap; /* Allows search bar to drop down on mobile */
            justify-content: space-between; 
            align-items: center; 
            gap: 15px; 
        }
        
        .logo { order: 1; }
        .header-right-actions { order: 2; display: flex; align-items: center; gap: 15px; }
        
        /* Search Bar Base (Mobile First) */
        .search-bar { 
            order: 3; /* Pushes to bottom row on mobile */
            width: 100%; /* Takes full width of the bottom row */
            position: relative; 
            z-index: 1001; 
        }
        
        .search-form { position: relative; width: 100%; display: block; }
        
        /* ✅ FIX: Added padding-left: 45px to prevent text from overlapping the SVG */
        #searchInput { 
            width: 100%; 
            padding: 12px 15px 12px 45px !important; 
            box-sizing: border-box; 
            border-radius: 25px; 
            border: 1px solid #333;
            background-color: var(--dark-gray, #1a1a1a);
            color: var(--white, #fff);
            font-size: 1em;
            outline: none;
            transition: border-color 0.3s ease;
        }
        #searchInput:focus { border-color: var(--gold, #FFD700); }
        
        /* ✅ FIX: Dropdown Results perfectly aligned under the bar */
        .search-suggestions, .search-history {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            width: 100%;
            background-color: var(--dark-gray, #1a1a1a);
            border: 1px solid #333;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
            max-height: 350px;
            overflow-y: auto;
            z-index: 9999;
        }

/* Desktop & Tablet Adjustments */
        @media (min-width: 992px) {
            .header-content { 
                /* ✅ FIX: Force the middle column (search bar) to take ALL available space */
                grid-template-columns: auto 1fr auto; 
                flex-wrap: nowrap; 
            }
            .header-right-actions { order: 3; }            
            .search-bar { 
                order: 2; /* Moves to middle */
                width: 100%; 
                max-width: 500px; /* Limits maximum stretch */
                /* ✅ FIX: Centers the element itself within the middle grid column */
                margin: 0 auto; 
            }
        }
    </style>
</head>
<body>

    <header class="main-header">
        <div class="container header-content">
            
            <!-- Grid Area: Logo -->
            <a href="<%- user ? '/home' : '/' %>" class="logo">GPL <span>Mods</span></a>
            
            <!-- Grid Area: Search Bar -->
            <div class="search-bar" id="animatedSearchBar">
                <form action="/search" method="GET" class="search-form">
                    <!-- Custom SVG Icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; fill: var(--silver); pointer-events: none; z-index: 10;">
                        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                    
                    <input type="search" id="searchInput" name="q" placeholder="" autocomplete="off">
                </form>
                
                <!-- Dropdown Containers -->
                <div id="searchSuggestions" class="search-suggestions"></div>
                <div id="searchHistory" class="search-history"></div>
            </div>
            
            <!-- ========================================== -->
            <!-- UNIFIED USER ACTIONS (All Devices)         -->
            <!-- ========================================== -->
            <div class="header-right-actions">
                
                <!-- Language Selector -->
                <div class="lang-dropdown-wrapper" style="position: relative; display: flex; align-items: center;">
                    <button id="lang-btn" class="nav-bell" title="Change Language" style="background:none; border:none; cursor:pointer; font-size: 1.6em; padding: 0; line-height: 0;">
                        <i class="fas fa-globe"></i>
                    </button>
                    <div id="lang-menu" class="lang-dropdown-content">
                        <a href="#" data-lang="en">🇺🇸 English (Default)</a>
                        <a href="#" data-lang="es">🇪🇸 Español</a>
                        <a href="#" data-lang="fr">🇫🇷 Français</a>
                        <a href="#" data-lang="hi">🇮🇳 हिन्दी</a>
                        <a href="#" data-lang="ar">🇸🇦 العربية</a>
                        <a href="#" data-lang="zh-CN">🇨🇳 中文</a>
                        <a href="#" data-lang="pt">🇧🇷 Português</a>
                        <a href="#" data-lang="ru">🇷🇺 Русский</a>
                        <a href="#" data-lang="id">🇮🇩 Indonesia</a>
                    </div>
                </div>
                <div id="google_translate_element" style="display:none;"></div>
                
                <!-- Notification Bell -->
                <a href="/notifications" class="nav-bell" title="Site Updates" id="nav-bell-link" 
                   data-updates="<%= typeof totalUpdatesCount !== 'undefined' ? totalUpdatesCount : 0 %>"
                   data-uploads="<%= typeof newUploadsCount !== 'undefined' ? newUploadsCount : 0 %>"
                   data-modsupdates="<%= typeof newUpdatesCount !== 'undefined' ? newUpdatesCount : 0 %>"
                   data-personal="<%= typeof unreadPersonalCount !== 'undefined' ? unreadPersonalCount : 0 %>">
                    <i class="fas fa-bell"></i>
                    <span id="notification-badge" class="update-badge" style="display: none;"></span>
                </a>
                
                <!-- Mobile Only Items -->
                <div class="header-mobile-actions">
                    <% if (user) { %>
                        <a href="/profile" style="margin-right: 0px; display: flex; align-items: center;">
                            <img src="<%= user.signedAvatarUrl %>" alt="User Avatar" style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover; border: 2px solid var(--silver);">
                        </a>
                    <% } %>
                    <div class="hamburger-menu" id="hamburger">&#9776;</div>
                </div>
                
                <!-- Desktop Only Items -->
                <div class="desktop-text-buttons">
                    <% if (user) { %>
                        <a href="/docs" class="btn btn-login" style="border: none; padding: 8px 15px;">Docs</a>
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/logout" class="btn btn-signup">Logout</a>
                    <% } else { %>
                        <a href="/docs" class="btn btn-login" style="border: none; padding: 8px 15px;">Docs</a>                    
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/login" class="btn btn-login">Login</a>
                        <a href="/register" class="btn btn-signup">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div> 
    </header>

    <!-- Mobile Sidebar Navigation -->
