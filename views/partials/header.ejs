                <li><a href="/community">Community Forums</a></li>
                <li><a href="/my-uploads">My Uploads</a></li>
                <li><a href="/upload">Upload A New Mod</a></li>
                <li><a href="/community-chat">Community Chat</a></li>
                <li><a href="/membership">Membership</a></li>
                <li><a href="/about">About Us!</a></li>
                <li><a href="/leaderboard">Leaderboard!</a></li>
                <li><a href="/donate">Donate Us!</a></li>
                <li><a href="/request-mod">Required New Mods</a></li>
                <li><a href="/support">Support Tickets</a></li>
            <% } else { %>
                <li><a href="/docs" style="color: var(--gold);"><i class="fas fa-book"></i> Documentation</a></li>
                <li><a href="/community">Community Forums</a></li>
                <li><a href="/upload">Upload A New Mod</a></li>
                <li><a href="/about">About Us!</a></li>
                <li><a href="/leaderboard">Leaderboard!</a></li>
                <li><a href="/donate">Donate Us!</a></li>
                <li><a href="/login">Login</a></li>
                <li><a href="/register">Sign Up</a></li>               
            <% } %>        
        </ul>
    </nav>    
    <main>