<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPL Mods - Safe & Working Mods For All Your Devices!</title>
    
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <link rel="stylesheet" href="/css/style.css">

    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</head>
<body>

    <header class="main-header">
        <div class="container header-content">
            <a href="/" class="logo">GPL <span>Mods</span></a>
            
            <div class="search-bar" id="animatedSearchBar">
                <form action="/search" method="GET" class="search-form">
                    <input type="search" id="searchInput" name="q" placeholder="">
                </form>
                <div id="searchSuggestions" class="search-suggestions"></div>
                <div id="searchHistory" class="search-history"></div>
            </div>
            
            <!-- ========================================== -->
            <!-- UNIFIED USER ACTIONS (All Devices)         -->
            <!-- ========================================== -->
            <div class="header-right-actions">
                
                <!-- 1. Notification Bell (Always Visible) -->
                <a href="/updates" class="nav-bell" title="Site Updates">
                    <i class="fas fa-bell"></i>
                </a>
                
                <!-- 2. User Avatar (Always Visible if Logged In) -->
                <% if (user) { %>
                    <a href="/profile" class="avatar-placeholder">
                        <img src="<%= user.signedAvatarUrl %>" alt="User Avatar">
                    </a>
                <% } %>
                
                <!-- 3. Text Buttons (Hidden on Phones/Tablets, Visible on Desktop) -->
                <div class="desktop-text-buttons">
                    <% if (user) { %>
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/logout" class="btn btn-signup">Logout</a>
                    <% } else { %>
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/login" class="btn btn-login">Login</a>
                        <a href="/register" class="btn btn-signup">Sign Up</a>
                    <% } %>
                </div>

                <!-- 4. Hamburger Menu (Always Visible on all devices!) -->
                <div class="hamburger-menu" id="hamburger">&#9776;</div>
                
            </div>
            <!-- ========================================== -->
        </div> 
    </header>

    <!-- Mobile Sidebar Navigation -->
    <nav class="mobile-nav" id="mobileNav">
        <ul>
            <!-- Sidebar Music Player -->
            <div class="music-player" style="text-align: center; padding-top: 10px;">
                <span id="music-track-name" style="color: var(--silver); display: block; margin-bottom: 15px; font-weight: 600;">Select a track</span>
                
                <div class="music-controls" style="display: flex; justify-content: center; gap: 20px; align-items: center;">
                    <button id="music-prev-btn" title="Previous Track" style="background:none; border:none; cursor:pointer; width:30px; fill:var(--silver); transition: fill 0.3s;">
                        <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6l-8.5 6z"></path></svg>
                    </button>
                    
                    <button id="music-play-pause-btn" title="Play/Pause" style="background:none; border:none; cursor:pointer; width:35px; fill:var(--silver); transition: fill 0.3s;">
                        <!-- JS injects the icon here -->
                    </button>
                    
                    <button id="music-next-btn" title="Next Track" style="background:none; border:none; cursor:pointer; width:30px; fill:var(--silver); transition: fill 0.3s;">
                        <svg viewBox="0 0 24 24"><path d="M16 6h2v12h-2zm-4.5 6l-8.5 6V6l8.5 6z"></path></svg>
                    </button>
                </div>
            </div>

            <hr style="border-color: #333; margin: 20px 0;">
            
            <li><a href="/">Home</a></li>
            <li class="has-submenu">
                <a href="#" class="collapsible-trigger">Categories <span class="arrow">▼</span></a>
                <ul class="sub-menu">
                    <li><a href="/category?cat=android">Android</a></li>
                    <li><a href="/category?cat=ios">iOS</a></li>
                    <li><a href="/category?cat=wordpress">WordPress</a></li>
                    <li><a href="/category?cat=windows">Windows</a></li>
                </ul>
            </li>
            
            <% if (user) { %>
                <li><a href="/my-uploads">My Uploads</a></li>
                <li><a href="/upload">Upload A New Mod</a></li>
                <li><a href="/community-chat">Community Chat</a></li>
                <li><a href="/membership">Membership</a></li>
                <li><a href="/about">About Us!</a></li>
                <li><a href="/donate">Donate Us!</a></li>
                <li><a href="/logout">Logout</a></li>
            <% } else { %>
                <li><a href="/upload">Upload A New Mod</a></li>
                <li><a href="/about">About Us!</a></li>
                <li><a href="/donate">Donate Us!</a></li>
                <li><a href="/login">Login</a></li>
                <li><a href="/register">Sign Up</a></li>
            <% } %>        
        </ul>
    </nav>    
    <main>