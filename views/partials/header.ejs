    <!-- ====================================================================== -->
    <!-- ✅ FIX: BULLETPROOF GRID HEADER & SEARCH BAR LAYOUT                    -->
    <!-- ====================================================================== -->
    <style>
        .main-header { padding: 15px 0; background-color: var(--black); border-bottom: 1px solid var(--dark-gray); position: sticky; top: 0; z-index: 1000; }
        
        /* 1. Base Grid Layout (Fixes Button Alignment!) */
        .header-content { 
            display: grid; 
            grid-template-columns: max-content 1fr max-content; /* Logo | Search | Actions */
            align-items: center; 
            gap: 20px; 
        }
        
        .logo { font-size: 1.8em; font-weight: 700; color: var(--gold); text-shadow: 0 0 10px var(--glow-gold); text-decoration: none; white-space: nowrap; justify-self: start; }
        .logo span { color: var(--silver); text-shadow: 0 0 10px var(--glow-silver); }
        
        /* 2. Search Bar */
        .search-bar { 
            width: 100%; 
            max-width: 600px; 
            justify-self: center; /* Centers it within the middle grid column */
            position: relative; 
            z-index: 1001; 
        }
        
        .search-form { position: relative; width: 100%; display: block; }
        
        #searchInput { 
            width: 100%; 
            padding: 12px 15px 12px 45px !important; 
            box-sizing: border-box; 
            border-radius: 25px; 
            border: 1px solid #333;
            background-color: var(--dark-gray, #1a1a1a);
            color: var(--white, #fff);
            font-size: 1em;
            outline: none;
            transition: border-color 0.3s ease;
            --placeholder-color: var(--silver); /* Default color before animation */
        }
        #searchInput:focus { border-color: var(--gold, #FFD700); box-shadow: 0 0 10px var(--glow-gold); }
        #searchInput::placeholder { color: var(--placeholder-color); opacity: 1; transition: color 0.4s ease-in-out; }
        
        /* Custom Silver Close (X) Icon for Search */
        input[type="search"]::-webkit-search-cancel-button {
            -webkit-appearance: none;
            height: 16px;
            width: 16px;
            background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23c0c0c0'><path d='M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z'/></svg>") no-repeat center center;
            background-size: contain;
            cursor: pointer;
            opacity: 0.7;
            transition: opacity 0.2s ease;
        }
        input[type="search"]::-webkit-search-cancel-button:hover { opacity: 1; }
        input[type="search"]::-webkit-search-decoration,
        input[type="search"]::-webkit-search-results-button,
        input[type="search"]::-webkit-search-results-decoration { -webkit-appearance:none; }

        /* Search Dropdown Results */
        .search-suggestions, .search-history {
            display: none; 
            position: absolute;
            top: calc(100% + 10px); 
            left: 0;
            right: 0; 
            background-color: var(--dark-gray, #1a1a1a);
            border: 1px solid #333;
            border-radius: 12px;
            max-height: 350px;
            overflow-y: auto;
            z-index: 1001; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        }
        .search-suggestions::-webkit-scrollbar, .search-history::-webkit-scrollbar { width: 6px; }
        .search-suggestions::-webkit-scrollbar-track, .search-history::-webkit-scrollbar-track { background: transparent; }
        .search-suggestions::-webkit-scrollbar-thumb, .search-history::-webkit-scrollbar-thumb { background: #444; border-radius: 10px; }
        
        .search-suggestions ul, .search-history ul { list-style: none; padding: 0; margin: 0; }
        .search-suggestions li a, .search-history li a {
            display: block; 
            padding: 12px 20px; 
            color: var(--silver, #c0c0c0); 
            text-decoration: none;
            transition: all 0.2s ease; 
            border-bottom: 1px solid #222;
            white-space: nowrap; 
            overflow: hidden; 
            text-overflow: ellipsis;
        }
        .search-suggestions li:last-child a, .search-history li:last-child a { border-bottom: none; }
        .search-suggestions li a:hover, .search-history li a:hover { background-color: #2a2a2a; color: var(--gold, #FFD700); }
        .search-history li a::before { content: '\f017'; font-family: 'Font Awesome 6 Free'; font-weight: 400; margin-right: 10px; color: #555; }
        .search-history h4 { padding: 15px 20px 10px; margin: 0; color: var(--gold, #FFD700); font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid #222; background-color: #111; position: sticky; top: 0; z-index: 2; }

        /* 3. Right Side Actions */
        .header-right-actions { 
            display: flex; 
            align-items: center; 
            gap: 15px; 
            justify-self: end; /* Aligns this whole block to the right */
            flex-shrink: 0; 
        }
        
        .desktop-text-buttons { display: none; }
        
        /* Mobile Avatar Styling */
        .avatar-placeholder {
            display: block; 
            width: 35px !important;  
            height: 35px !important; 
            min-width: 35px; 
            min-height: 35px; 
            border: 2px solid var(--silver, #c0c0c0);
            background-color: var(--black, #000); 
            border-radius: 50%; 
            cursor: pointer; 
            text-decoration: none;
            overflow: hidden; 
        }
        .avatar-placeholder img { width: 100% !important; height: 100% !important; object-fit: cover !important; display: block; }
        
        .hamburger-menu { display: block !important; cursor: pointer; font-size: 2em; color: var(--silver, #c0c0c0); line-height: 1; margin-left: 5px; }
        .hamburger-menu:hover, .hamburger-menu.open { color: var(--gold, #FFD700); transform: scale(1.1); transition: color 0.2s ease, transform 0.2s ease; }
        
        /* Desktop Breakpoint */
        @media (min-width: 1024px) {
            .desktop-text-buttons { display: flex; align-items: center; gap: 10px; }
            /* Keep hamburger visible on desktop as requested */
            .hamburger-menu { display: block !important; font-size: 1.6em; }
            /* Show avatar on desktop too */
            .header-mobile-actions .avatar-placeholder { display: block; }
            /* Slightly reduce spacing so both avatar and desktop buttons fit */
            .header-right-actions { gap: 10px; }
        }

        /* Mobile Breakpoint (Drops Search Bar to bottom row) */
        @media (max-width: 992px) {
            .header-content {
                grid-template-columns: max-content 1fr; /* Logo takes only what it needs */
                grid-template-areas: 
                    "logo actions"
                    "search search"; 
            }
            .logo { grid-area: logo; justify-self: start; }
            .header-right-actions { grid-area: actions; justify-self: end; } /* Push to far right */
            .search-bar { 
                grid-area: search; 
                max-width: 100%; /* Full width on mobile */
                margin-top: 5px;
            }
        }
    </style>
</head>
<body>

    <header class="main-header">
        <div class="container header-content">
            
            <!-- Grid Area: Logo -->
            <a href="<%- user ? '/home' : '/' %>" class="logo">GPL <span>Mods</span></a>
            
            <!-- Grid Area: Search Bar -->
            <div class="search-bar" id="animatedSearchBar">
                <form action="/search" method="GET" class="search-form">
                    <!-- Custom SVG Icon -->
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; fill: var(--silver); pointer-events: none; z-index: 10;">
                        <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                    
                    <input type="search" id="searchInput" name="q" placeholder="" autocomplete="off">
                </form>
                
                <!-- Dropdown Containers -->
                <div id="searchSuggestions" class="search-suggestions"></div>
                <div id="searchHistory" class="search-history"></div>
            </div>
            
            <!-- ========================================== -->
            <!-- UNIFIED USER ACTIONS (All Devices)         -->
            <!-- ========================================== -->
            <div class="header-right-actions">
                
                <!-- Language Selector -->
                <div class="lang-dropdown-wrapper" style="position: relative; display: flex; align-items: center;">
                    <button id="lang-btn" class="nav-bell" title="Change Language" style="background:none; border:none; cursor:pointer; font-size: 1.6em; padding: 0; line-height: 0;">
                        <i class="fas fa-globe"></i>
                    </button>
                    <div id="lang-menu" class="lang-dropdown-content">
                        <a href="#" data-lang="en">🇺🇸 English (Default)</a>
                        <a href="#" data-lang="es">🇪🇸 Español</a>
                        <a href="#" data-lang="fr">🇫🇷 Français</a>
                        <a href="#" data-lang="hi">🇮🇳 हिन्दी</a>
                        <a href="#" data-lang="ar">🇸🇦 العربية</a>
                        <a href="#" data-lang="zh-CN">🇨🇳 中文</a>
                        <a href="#" data-lang="pt">🇧🇷 Português</a>
                        <a href="#" data-lang="ru">🇷🇺 Русский</a>
                        <a href="#" data-lang="id">🇮🇩 Indonesia</a>
                    </div>
                </div>
                <!-- Notification Bell -->
                <a href="/notifications" class="nav-bell" title="Site Updates" id="nav-bell-link" 
                   data-user-id="<%= user ? user._id : '' %>"
                   data-updates="<%= typeof recentAnnouncementsCount !== 'undefined' ? recentAnnouncementsCount : 0 %>"
                   data-uploads="<%= typeof newUploadsCount !== 'undefined' ? newUploadsCount : 0 %>"
                   data-modsupdates="<%= typeof newUpdatesCount !== 'undefined' ? newUpdatesCount : 0 %>"
                   data-personal="<%= typeof unreadPersonalCount !== 'undefined' ? unreadPersonalCount : 0 %>">
                    <i class="fas fa-bell"></i>
                    <span id="notification-badge" class="update-badge" style="display: none;"></span>
                </a>
                
               <!-- Mobile Only Items -->
                <div class="header-mobile-actions" style="display: flex; align-items: center; gap: 15px;">
                    <% if (user) { %>
                        <!-- ✅ FIX: Restored the "avatar-placeholder" class and removed inline styles! -->
                        <a href="/dashboard" class="avatar-placeholder">
                            <img src="<%= user.signedAvatarUrl %>" alt="User Avatar">
                        </a>
                    <% } %>
                    <div class="hamburger-menu" id="hamburger">&#9776;</div>
                </div>
                
                <!-- Desktop Only Items -->
                <div class="desktop-text-buttons">
                    <% if (user) { %>
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/logout" class="btn btn-signup">Logout</a>
                    <% } else { %>
                        <a href="/upload" class="btn btn-login">Upload A New Mod</a>
                        <a href="/login" class="btn btn-login">Login</a>
                        <a href="/register" class="btn btn-signup">Sign Up</a>
                    <% } %>
                </div>
            </div>
        </div> 
    </header>

