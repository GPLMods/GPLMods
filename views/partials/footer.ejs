    <% if (typeof showModals !== 'undefined' && showModals) { %>

        <!-- ======== ANTI-ADBLOCK MODAL ======== -->
        <% if (typeof showAds !== 'undefined' && showAds) { %>
            <div id="adblock-modal" class="policy-modal" style="display: none; align-items: center; justify-content: center; background-color: rgba(0,0,0,0.95); z-index: 100000;">
                <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 40px; text-align: center; border-radius: 15px; max-width: 500px; border-top: 4px solid var(--red); box-shadow: 0 10px 40px rgba(229, 57, 53, 0.3);">
                    <lottie-player src="<%= cdnUrl %>/animations/ad.json" background="transparent" speed="1" style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(225, 225, 225, 0.5));" loop autoplay></lottie-player>
                    <h2 style="color: var(--white); margin-bottom: 15px;">Ad Blocker Detected</h2>
                    <p style="color: var(--silver); font-size: 1.1em; line-height: 1.6; margin-bottom: 25px;">It looks like you are using an ad blocker or privacy shield. GPL Mods relies on ad revenue to pay for our servers and keep the platform free.</p>
                    <p style="color: var(--silver); margin-bottom: 30px;">Please disable your ad blocker for this domain, or <a href="/membership" style="color: var(--gold); font-weight: bold;">upgrade to Premium</a> for an ad-free experience.</p>
                    <button onclick="window.location.reload()" class="btn btn-primary" style="width: 100%; padding: 15px; font-size: 1.1em; box-shadow: 0 0 15px var(--glow-gold); border: none; border-radius: 25px; background: var(--gold); color: var(--black); font-weight: bold; cursor: pointer;">I have disabled my Ad Blocker</button>
                </div>
            </div>

            <script src="/js/adblock-checker.min.js"></script>
            <script>
                async function checkUserAdblockStatus() {
                    const currentPath = window.location.pathname;
                    const isExemptPage = currentPath === '/membership' || currentPath === '/login' || currentPath === '/register';

                    if (!isExemptPage) {
                        try {
                            let isEnabled = await AdBlockChecker.checkAdBlock();
                            if (isEnabled) {
                                console.log("AdBlocker detected! Springing the trap.");
                                const abModal = document.getElementById('adblock-modal');
                                if (abModal) {
                                    abModal.style.display = 'flex';
                                    setTimeout(() => abModal.classList.add('show'), 10);
                                    document.body.style.overflow = 'hidden'; 
                                }
                            }
                        } catch (err) { console.error("AdBlock checker error:", err); }
                    }
                }
                window.addEventListener("load", checkUserAdblockStatus);
            </script>
        <% } %> 

        <!-- ======== UNIFIED POLICY MODAL ======== -->
        <div id="policy-modal-container" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 9999; align-items: center; justify-content: center; background-color: rgba(0, 0, 0, 0.8);">
            <div class="policy-modal-content" style="background-color: var(--dark-gray); color: var(--white); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--gold); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                <h2 style="color: var(--gold); margin-bottom: 15px;">Welcome to GPL Mods</h2>
                <p style="margin-bottom: 20px; color: var(--silver); line-height: 1.6;">To continue using GPL Mods, you must accept our <a href="/tos" target="_blank" style="color: var(--gold);">Terms of Service</a>. We use cookies to ensure you get the best experience on our website.</p>
                <div class="policy-buttons" style="display: flex; gap: 15px; justify-content: center;">
                    <button class="policy-button" id="acceptPolicy" style="background-color: var(--gold); color: var(--black); padding: 10px 25px; border-radius: 20px; font-weight: bold; border: none; cursor: pointer; font-size: 1em;">Accept</button>
                    <button class="policy-button decline" id="declinePolicy" style="background-color: transparent; color: var(--silver); border: 2px solid var(--silver); padding: 10px 25px; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 1em;">Decline</button>
                </div>
            </div>
        </div>
