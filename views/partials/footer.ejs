<!-- 1. LOAD THE LOCAL LIBRARY SCRIPT FIRST -->
<!-- This matches <script src="adblock-checker.min.js"></script> from the video -->
<script src="/js/adblock-checker.min.js"></script>

<!-- 2. RUN THE CHECKER LOGIC -->
<!-- This matches the logic from the video's script.js file -->
<script>
    // Define the async function exactly as shown in the video
    async function checkUserAdblockStatus() {
        const currentPath = window.location.pathname;
        const isExemptPage = currentPath === '/membership' || currentPath === '/login' || currentPath === '/register';

        if (!isExemptPage) {
            try {
                // Call the library method precisely as instructed: AdBlockChecker.checkAdBlock()
                let isEnabled = await AdBlockChecker.checkAdBlock();
                
                if (isEnabled) {
                    console.log("AdBlocker detected! Springing the trap.");
                    const abModal = document.getElementById('adblock-modal');
                    if (abModal) {
                        abModal.style.display = 'flex';
                        // Tiny delay ensures CSS transitions apply correctly
                        setTimeout(() => abModal.classList.add('show'), 10);
                        document.body.style.overflow = 'hidden'; 
                    }
                } else {
                     console.log("No AdBlocker active. Continuing normally.");
                }
            } catch (err) {
                console.error("AdBlock checker script error:", err);
            }
        }
    }

    // Run the check on page load, exactly like: window.addEventListener("load", updateStatus);
    window.addEventListener("load", checkUserAdblockStatus);

</script>
<% } %>

