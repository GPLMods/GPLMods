<style>
    .newsletter-popup {
        position: fixed;
        bottom: 20px;
        left: 20px; /* Positioned on the bottom left */
        background-color: var(--dark-gray);
        border: 1px solid var(--gold);
        border-radius: 12px;
        padding: 25px;
        width: 90%;
        max-width: 350px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        z-index: 9998; /* Just below the policy modal */
        transform: translateX(-150%); /* Hidden off-screen initially */
        transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .newsletter-popup.show {
        transform: translateX(0); /* Slides in */
    }
    .newsletter-close {
        position: absolute;
        top: 10px;
        right: 15px;
        color: var(--silver);
        cursor: pointer;
        font-size: 1.5em;
        line-height: 1;
        transition: color 0.2s;
    }
    .newsletter-close:hover { color: var(--red); }
    .newsletter-popup h3 { color: var(--gold); margin-bottom: 10px; font-size: 1.4em; }
    .newsletter-popup p { color: var(--silver); font-size: 0.9em; margin-bottom: 15px; line-height: 1.5; }
    .newsletter-form { display: flex; flex-direction: column; gap: 10px; }
    .newsletter-input {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #444;
        background-color: var(--black);
        color: var(--white);
        outline: none;
        font-family: 'Poppins', sans-serif;
    }
    .newsletter-input:focus { border-color: var(--gold); box-shadow: 0 0 8px var(--glow-gold); }
    .newsletter-btn {
        background-color: var(--gold);
        color: var(--black);
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .newsletter-btn:hover { transform: translateY(-2px); box-shadow: 0 0 15px var(--glow-gold); }
    .newsletter-msg { margin-top: 10px; font-size: 0.85em; font-weight: bold; text-align: center; display: none; }
    .newsletter-msg.success { color: var(--green); display: block; }
    .newsletter-msg.error { color: var(--red); display: block; }
</style>
