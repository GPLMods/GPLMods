<!-- ======== PWA INSTALL BANNER ======== -->
    <div id="pwa-install-banner" class="pwa-banner">
        <div class="pwa-banner-content">
            <h4>Install GPL Mods App</h4>
            <p>Add to your home screen for a faster, full-screen experience!</p>
        </div>
        <div class="pwa-buttons">
            <button id="pwa-install" class="pwa-btn pwa-install-btn">Install</button>
            <button id="pwa-dismiss" class="pwa-btn pwa-dismiss-btn">Later</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
           // --- 1. NOTIFICATION BADGE LOGIC (WITH NUMBERS) ---
            const bellLink = document.getElementById('nav-bell-link');
            const badge = document.getElementById('notification-badge');
            
            if (bellLink && badge) {
                // Get the total number of updates currently on the server
                const currentTotalUpdates = parseInt(bellLink.getAttribute('data-total-updates'), 10);
                
                // Get the number of updates the user had seen the last time they clicked the bell
                const lastSeenTotal = parseInt(localStorage.getItem('lastSeenTotalUpdates') || '0', 10);
                
                // Calculate how many NEW updates there are
                const unreadCount = currentTotalUpdates - lastSeenTotal;
                
                if (unreadCount > 0) {
                    // Show the badge
                    badge.style.display = 'flex';
                    
                    // Set the number. If it's more than 9, show "9+" to keep the UI clean
                    badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
                }
                
                // When they click the bell, update their 'last seen' count to the current total
                bellLink.addEventListener('click', () => {
                    localStorage.setItem('lastSeenTotalUpdates', currentTotalUpdates.toString());
                    // The badge will disappear on the next page load (when they land on /updates)
                });
            }

            // --- 2. PWA INSTALL LOGIC ---
            let deferredPrompt;
            const pwaBanner = document.getElementById('pwa-install-banner');
            const installBtn = document.getElementById('pwa-install');
            const dismissBtn = document.getElementById('pwa-dismiss');

            // Register Service Worker
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW failed: ', err));
            }

            // Intercept the browser's default install prompt
            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault(); // Prevent the default mini-infobar
                deferredPrompt = e; // Save the event
                
                // If the user hasn't dismissed it recently, show our custom beautiful banner
                if (localStorage.getItem('pwaDismissed') !== 'true') {
                    setTimeout(() => {
                        pwaBanner.classList.add('show');
                    }, 3000); // Wait 3 seconds after page load to show it
                }
            });

            // When user clicks our custom Install button
            installBtn.addEventListener('click', async () => {
                pwaBanner.classList.remove('show');
                if (deferredPrompt) {
                    deferredPrompt.prompt(); // Show the native browser install prompt
                    const { outcome } = await deferredPrompt.userChoice;
                    deferredPrompt = null;
                }
            });

            // When user clicks Later
            dismissBtn.addEventListener('click', () => {
                pwaBanner.classList.remove('show');
                // Hide it for 7 days so we don't annoy them
                localStorage.setItem('pwaDismissed', 'true');
                setTimeout(() => localStorage.removeItem('pwaDismissed'), 7 * 24 * 60 * 60 * 1000); 
            });
            
            // Hide banner if successfully installed
            window.addEventListener('appinstalled', () => {
                pwaBanner.classList.remove('show');
            });
        });
    </script>

