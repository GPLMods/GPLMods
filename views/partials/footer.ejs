        <p style="color: var(--silver); font-size: 1.1em; line-height: 1.6; margin-bottom: 25px;">
            It looks like you are using an ad blocker. GPL Mods relies on ad revenue to pay for our servers and keep the platform free.
        </p>
        <p style="color: var(--silver); margin-bottom: 30px;">
            Please disable your ad blocker for this domain, or <a href="/membership" style="color: var(--gold); font-weight: bold;">upgrade to Premium</a> for an ad-free experience.
        </p>
        <button onclick="window.location.reload()" class="btn btn-primary" style="width: 100%; padding: 15px; font-size: 1.1em; box-shadow: 0 0 15px var(--glow-gold);">I have disabled my Ad Blocker</button>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Check if we should enforce adblock rules for this specific user
        const userNeedsAds = <%= typeof showAds !== 'undefined' ? showAds : true %>;
        const currentPath = window.location.pathname;
        
        // ✅ FIX: Do NOT show the adblock modal on the membership, login, or register pages!
        const isExemptPage = currentPath === '/membership' || currentPath === '/login' || currentPath === '/register';
        
        if (userNeedsAds && !isExemptPage) {
            // Create a fake "ad" element
            const adTest = document.createElement('div');
            adTest.innerHTML = '&nbsp;';
            // These class names are universally targeted by AdBlock, uBlock Origin, Brave Shields, etc.
            adTest.className = 'adsbox ad-placement doubleclick ad-placeholder adsbygoogle';
            adTest.style.position = 'absolute';
            adTest.style.top = '-10000px';
            document.body.appendChild(adTest);

            setTimeout(() => {
                // If the element's height is 0 or it's hidden, an ad blocker is active!
                const isBlocked = adTest.offsetHeight === 0 || window.getComputedStyle(adTest).display === 'none';
                
                if (isBlocked) {
                    const abModal = document.getElementById('adblock-modal');
                    if (abModal) {
                        abModal.style.display = 'flex';
                        // Tiny delay to allow CSS transition to work
                        setTimeout(() => abModal.classList.add('show'), 10);
                        document.body.style.overflow = 'hidden'; // Stop background scrolling
                    }
                }
                
                // Clean up the test element
                adTest.remove();
            }, 500); // 500ms delay gives the adblocker time to process the DOM
        }
    });
</script>

