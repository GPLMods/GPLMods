<%- include('../partials/header') %>

<style>
    /* Most styles are now in global style.css, but we can keep page-specific ones here */
    
    /* --- ✅ NEW: CUSTOM SELECT DROPDOWN CSS FOR REPORT MODAL --- */
    .custom-select-wrapper {
        position: relative;
        user-select: none;
        width: 100%;
    }
    .custom-select {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 15px; /* Matched the padding of the original textarea/select */
        background-color: var(--black);
        border: 1px solid #333;
        border-radius: 8px;
        cursor: pointer;
        color: var(--silver);
        font-size: 1em;
        transition: all 0.3s ease;
    }
    /* When the dropdown is open */
    .custom-select-wrapper.open .custom-select {
        border-color: var(--gold);
        box-shadow: 0 0 10px var(--glow-gold);
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
    }
    .custom-select-wrapper.open .custom-select-arrow {
        transform: rotate(180deg);
        color: var(--gold);
    }
    /* The dropdown menu */
    .custom-options {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: var(--dark-gray);
        border: 1px solid var(--gold);
        border-top: none;
        border-radius: 0 0 8px 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        z-index: 100;
        display: none; /* Hidden by default */
        max-height: 200px;
        overflow-y: auto;
    }
    .custom-select-wrapper.open .custom-options {
        display: block; /* Shown when open */
    }
    .custom-option {
        padding: 10px 15px;
        cursor: pointer;
        color: var(--white);
        transition: background-color 0.2s;
        border-bottom: 1px solid #2a2a2a;
    }
    .custom-option:last-child { border-bottom: none; }
    .custom-option:hover { background-color: var(--black); color: var(--gold); }
    .custom-option.selected { background-color: var(--black); color: var(--gold); font-weight: bold; }
    /* --- Ultimate Fix for Long Text Breaking the Download Page Layout --- */
.details-panel {
    max-width: 100%;
    overflow-x: hidden; /* Absolutely prevents horizontal scrolling/breaking */
}
/* Target every possible container generated by Quill */
.tab-content p, 
.tab-content ul, 
.tab-content ol, 
.tab-content li, 
.app-description-content, 
.info-box,
.info-box p,
.feature-text span {
    word-wrap: break-word !important;
    overflow-wrap: break-word !important;
    word-break: break-word !important; /* Force breaks long continuous text */
    max-width: 100% !important;
    box-sizing: border-box !important;
}

/* Ensure images inside rich text don't blow out the layout */
.tab-content img {
    max-width: 100%;
    height: auto;
}
        /* ✅ FIX 2.0: Ultra-Robust Grid layout for the Meta Info list */
        .meta-info { list-style: none; padding: 0; margin: 0; }
        
        .meta-info li { 
            padding: 15px 0; /* Slightly more padding for breathing room */
            border-bottom: 1px solid #2a2a2a;
            
            /* Use CSS Grid for perfect two-column alignment */
            display: grid;
            grid-template-columns: auto 1fr; /* Label takes what it needs, value takes the rest */
            gap: 15px; 
            align-items: center; /* Vertically centers single-line items */
        }
        
        /* The Label (e.g., "Developer:", "Version:") */
        .meta-info li > span:first-child {
            color: var(--silver);
            white-space: nowrap; /* Prevents the label itself from breaking into two lines */
            /* If the value on the right wraps to multiple lines, align the label to the top */
            align-self: start; 
            margin-top: 2px; /* Tiny tweak to align the label perfectly with the first line of text */
        }

        /* The Value (e.g., the long developer name) */
        .meta-info li .meta-value, 
        .meta-info li a.meta-link {
            text-align: right;
            color: var(--white);
            font-weight: 600;
            line-height: 1.4; /* Improve readability for wrapped text */
            
            /* The Magic Formula to force wrapping */
            word-wrap: break-word;
            overflow-wrap: break-word;
            word-break: break-word;
            
            /* Optional: Add a subtle transition for links */
            transition: color 0.2s;
            display: block; /* Ensures links behave properly in the grid */
            justify-self: end; /* Pushes the text to the far right edge */
        }

        .meta-link:hover { color: var(--gold); }
        
        /* Specifically fix the Voting row which has a complex nested layout */
        .meta-info li:has(.voting-system) {
             align-items: center; /* Keep voting system perfectly centered vertically */
        }
        .meta-info li:has(.voting-system) > span:first-child {
             align-self: center;
             margin-top: 0;
        }
    /* --- ✅ NEW: Styles for 1-Click Install Buttons & PNG Icons --- */
    .install-btn {
        padding: 8px 12px; 
        font-size: 0.85em; 
        border: 1px solid #333; 
        color: var(--silver); 
        background: #1a1a1a; 
        border-radius: 8px;
        display: flex; 
        align-items: center; 
        justify-content: center; 
        gap: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .install-btn:hover {
        background: var(--dark-gray);
        color: var(--white);
        border-color: var(--gold);
        transform: translateY(-2px);
    }
    .repo-icon-small {
        width: 18px; 
        height: 18px;
        min-width: 18px;
        max-width: 18px;
        object-fit: contain;
        display: block;
        filter: drop-shadow(0 2px 3px rgba(0,0,0,0.5));
    }
</style>

<main class="container">
    <div class="download-layout">

        <!-- ============================ -->
        <!-- Left Info Panel -->
        <!-- ============================ -->
        <aside class="info-panel">
            <img src="<%= file.iconUrl %>" alt="<%= file.name %> Icon" class="app-icon">
            <h1><%= file.name %></h1>
            
            <div class="rating">
                <div class="stars-outer">
                    <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                </div>
                <span class="rating-text"><%= file.averageRating.toFixed(1) %> (<%= file.ratingCount %> reviews)</span>
            </div>

            <% if (file.certification === 'certified') { %>
            <div class="safety-badge">
                <lottie-player src="/animations/shield.json" background="transparent" speed="1" style="width: 28px; height: 28px;" loop autoplay></lottie-player>
                <span class="badge-text">100% Safe & Admin Certified</span>
            </div>
            <% } %>

           <% if (file.certification === 'community-tested') { %>
            <div class="safety-badge">
                <lottie-player src="/animations/heart.json" background="transparent" speed="1" style="width: 28px; height: 28px;" loop autoplay></lottie-player>
                <span class="badge-text">Highly Rated By Community</span>
            </div>
            <% } %>
            
            <!-- ======== DYNAMIC MAIN DOWNLOAD BUTTON & AGE GATE ======== -->
            
            <% 
                // Calculate User Age from DOB
                let userAge = 0;
                let hasDOB = false;
                if (user && user.dateOfBirth) {
                    hasDOB = true;
                    const diff_ms = Date.now() - new Date(user.dateOfBirth).getTime();
                    const age_dt = new Date(diff_ms);
                    userAge = Math.abs(age_dt.getUTCFullYear() - 1970);
                }
            %>

            <% if (file.ageRating === '18+') { %>
                <!-- === IT IS AN 18+ FILE === -->
                
                <% if (user) { %>
                    <!-- LOGGED IN USER -->
                    <% if (hasDOB && userAge >= 18) { %>
                        <!-- THEY ARE 18+: Show Download Buttons -->
            <!-- Pre-calculate the main download URL and whether it's wrapped in ads -->
            <%
                let mainDownloadUrl = `/download-file/${file._id}`;
                let isMainAdSupported = false;

                if (showAds) {
                    if (file.customAdLink) {
                        // 1. Manual Admin Override
                        mainDownloadUrl = file.customAdLink;
                        isMainAdSupported = true;
                    } else if (linkvertiseEnabled && !isUploaderDistributor && !file.isMultiPart) {
                        // ✅ FIX: Use our new global helper
                        const fullDownloadRoute = `${baseUrl}/download-file/${file._id}`;
                        mainDownloadUrl = generateAdLink(fullDownloadRoute);
                        isMainAdSupported = true;
                    }
                }
            %>

            <!-- Standard Download Button Logic (Inside your Age Gate checks) -->
            <% if (file.isMultiPart) { %>
                <a href="/mods/<%= file._id %>/parts" class="download-button" style="text-align: center;">
                    <i class="fas fa-layer-group" style="margin-right: 10px;"></i> View Download Links
                    <span style="display: block; font-size: 0.6em; font-weight: normal; margin-top: 5px;">(File is split into <%= file.downloadParts.length %> parts)</span>
                </a>
                        <% } else { %>
                            <a href="/download-file/<%= file._id %>" class="download-button" style="text-align: center;">
                                <i class="fas fa-download" style="margin-right: 10px;"></i> Download (<%= formatBytes(file.fileSize) %>)
                            </a>
                        <% } %>
                    <% } else { %>
                        <!-- THEY ARE TOO YOUNG OR NO DOB SET -->
                        <div style="background-color: rgba(229, 57, 53, 0.1); border: 1px solid var(--red); padding: 15px; border-radius: 10px; text-align: center; margin-bottom: 20px;">
                            <i class="fas fa-exclamation-triangle" style="color: var(--red); font-size: 2em; margin-bottom: 10px;"></i>
                            <h3 style="color: var(--white); margin-bottom: 5px;">18+ Age Restricted</h3>
                            <% if (!hasDOB) { %>
                                <p style="color: var(--silver); font-size: 0.9em; margin-bottom: 10px;">Please set your Date of Birth in your profile to verify your age.</p>
                                <a href="/profile" class="btn btn-secondary" style="border-color: var(--red); color: var(--red); width: 100%;">Update Profile</a>
                            <% } else { %>
                                <p style="color: var(--silver); font-size: 0.9em;">You do not meet the age requirement (18+) to access this content.</p>
                            <% } %>
                        </div>
                    <% } %>

                <% } else { %>
                    <!-- GUEST USER: Show Verify Button to trigger JS Modal -->
                    <div id="guest-age-gate-container">
                        <button type="button" id="verify-age-btn" class="download-button" style="text-align: center; background-color: #333; color: var(--white); box-shadow: none; border: 2px dashed var(--red);">
                            <i class="fas fa-lock" style="margin-right: 10px; color: var(--red);"></i>
                            Verify Age to Download (18+)
                        </button>
                    </div>
                    
                    <!-- Hidden Buttons for guests who pass the check -->
                    <div id="hidden-download-buttons" style="display: none;">
                        <% if (file.isMultiPart) { %>
                            <a href="/mods/<%= file._id %>/parts" class="download-button" style="text-align: center;">
                                <i class="fas fa-layer-group" style="margin-right: 10px;"></i> View Download Links
                                <span style="display: block; font-size: 0.6em; font-weight: normal; margin-top: 5px;">(File is split into <%= file.downloadParts.length %> parts)</span>
                            </a>
                        <% } else { %>
                            <a href="/download-file/<%= file._id %>" class="download-button" style="text-align: center;">
                                <i class="fas fa-download" style="margin-right: 10px;"></i> Download (<%= formatBytes(file.fileSize) %>)
                            </a>
                        <% } %>
                    </div>
                <% } %>

            <% } else { %>
                <!-- === NOT AN 18+ FILE: Just show normal buttons === -->
                <% if (file.isMultiPart) { %>
                    <a href="/mods/<%= file._id %>/parts" class="download-button" style="text-align: center;">
                        <i class="fas fa-layer-group" style="margin-right: 10px;"></i> View Download Links
                        <span style="display: block; font-size: 0.6em; font-weight: normal; margin-top: 5px;">(File is split into <%= file.downloadParts.length %> parts)</span>
                    </a>
                <% } else { %>
                    <a href="/download-file/<%= file._id %>" class="download-button" style="text-align: center;">
                        <i class="fas fa-download" style="margin-right: 10px;"></i> Download (<%= formatBytes(file.fileSize) %>)
                    </a>
                <% } %>
            <% } %>

            <!-- ========================================================= -->

            <!-- ======== NEW: ALTERNATIVE LINKS (MIRRORS) ======== -->
            <% if (file.alternativeLinks && file.alternativeLinks.length > 0) { %>
                <div style="background-color: #222; border-radius: 10px; padding: 15px; margin-bottom: 20px; border: 1px solid #333; text-align: left;">
                    <span style="color: var(--silver); font-size: 0.85em; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 10px;">
                        <i class="fas fa-link" style="margin-right: 5px; color: var(--gold);"></i> Alternative Mirrors
                    </span>
                    
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <% file.alternativeLinks.forEach(mirror => { %>
                            
                            <% 
                                // --- DYNAMIC AD NETWORK ROUTING LOGIC ---
                                let finalMirrorUrl = mirror.url;
                                
                                // If Viewer sees ads AND System is Enabled AND Uploader isn't a distributor
                                if (showAds && linkvertiseEnabled && !isUploaderDistributor) {
                                    // ✅ FIX: Use our new global helper
                                    finalMirrorUrl = generateAdLink(mirror.url);
                                }
                            %>
               
                           <a href="<%= finalMirrorUrl %>" target="_blank" rel="noopener noreferrer" 
                               style="display: flex; justify-content: space-between; align-items: center; background: var(--black); padding: 10px 15px; border-radius: 6px; text-decoration: none; color: var(--white); font-size: 0.9em; border: 1px solid #333; transition: all 0.2s;">
                                
                                <span>
                                    <% 
                                    const lowerName = mirror.providerName.toLowerCase();
                                    let icon = 'fas fa-cloud-download-alt';
                                    let iconColor = 'var(--silver)';
                                    if (lowerName.includes('mega')) { icon = 'fas fa-m'; iconColor = '#D9272E'; }
                                    if (lowerName.includes('drive') || lowerName.includes('google')) { icon = 'fab fa-google-drive'; iconColor = '#FFD700'; }
                                    if (lowerName.includes('mediafire')) { icon = 'fas fa-fire'; iconColor = '#007FFF'; }
                                    if (lowerName.includes('dropbox')) { icon = 'fab fa-dropbox'; iconColor = '#0061FF'; }
                                    %>
                                    <i class="<%= icon %>" style="margin-right: 8px; color: <%= iconColor %>;"></i>
                                    <%= mirror.providerName %>
                                </span>
                                
                                 <!-- Show a lock icon if it's a monetized link -->
                                <% if (showAds) { %>
                                    <i class="fas fa-ad" style="font-size: 0.8em; color: var(--silver);" title="Ad-supported link. Get Premium for direct access."></i>
                                <% } else { %>
                                    <i class="fas fa-external-link-alt" style="font-size: 0.8em; color: var(--gold);" title="Direct Premium Access"></i>
                                <% } %>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>
            <!-- =================================================== -->
            <!-- ======== 1-CLICK IOS INSTALLERS (Jailed & Jailbroken) ======== -->
            <% 
                const isIosDirect = (file.category === 'ios-jailed' || file.category === 'ios-jailbroken');
                const hasDirectLink = !!file.directDownloadUrl;
                
                let hasSideloadPermission = false;
                if (user && (user.membership === 'premium' || user.role === 'admin' || user.role === 'distributor')) {
                    hasSideloadPermission = true;
                }

                if (isIosDirect && hasDirectLink) { 
            %>
                <div style="background-color: var(--black); border: 1px solid #333; border-radius: 12px; padding: 20px; margin-top: 15px; margin-bottom: 25px; text-align: left;">
                    
                    <h3 style="color: var(--white); font-size: 1.1em; margin-bottom: 5px; display: flex; align-items: center; gap: 8px;">
                        <i class="fab fa-apple"></i> 1-Click Direct Install
                    </h3>
                    
                    <% if (hasSideloadPermission) { %>
                        <p style="color: var(--silver); font-size: 0.85em; margin-bottom: 15px;">Send directly to your device's package manager.</p>
                        
                        <% 
                            const rawUrl = file.directDownloadUrl;
                            const base64Url = Buffer.from(rawUrl).toString('base64');
                        %>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            
                            <% if (file.category === 'ios-jailed') { %>
                                <!-- JAILED IPA APPS -->
                                <a href="apple-magnifier://install?url=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/trollstore.png" alt="TrollStore" class="repo-icon-small"> TrollStore
                                </a>
                                <a href="sidestore://install?url=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/sidestore.png" alt="SideStore" class="repo-icon-small"> SideStore
                                </a>
                                <a href="altstore://install?url=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/altstore.png" alt="AltStore" class="repo-icon-small"> AltStore
                                </a>
                                <a href="esign://import?url=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/esign.png" alt="E-Sign" class="repo-icon-small"> E-Sign
                                </a>
                                <a href="feather://import/<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/feather.png" alt="Feather" class="repo-icon-small"> Feather
                                </a>
                                <a href="scarlet://install=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/scarlet.png" alt="Scarlet" class="repo-icon-small"> Scarlet
                                </a>
                                <a href="purepkg://install?url=<%= rawUrl %>" class="install-btn">
                                    <img src="/images/icons/purepkg.png" alt="PurePKG" class="repo-icon-small"> PurePKG
                                </a>
                                <a href="livecontainer://install-ipa?url=<%= base64Url %>" class="install-btn">
                                    <img src="/images/icons/livecontainer.png" alt="LiveContainer" class="repo-icon-small"> LiveContainer
                                </a>
                                <a href="ksign://import?url=<%= rawUrl %>" class="install-btn" style="grid-column: 1 / -1;">
                                    <img src="/images/icons/ksign.png" alt="Ksign" class="repo-icon-small"> Ksign
                                </a>

                            <% } else if (file.category === 'ios-jailbroken') { %>
                                <!-- JAILBROKEN REPO / DEB APPS -->
                                <% const hostDomain = "https://gplmods.webredirect.org/ios-repo"; %>

                                <% if (file.iosPackageId) { %>
                                    <a href="sileo://package/<%= file.iosPackageId %>" class="install-btn">
                                        <img src="/images/icons/sileo.png" alt="Sileo" class="repo-icon-small"> Sileo
                                    </a>
                                    <a href="zbra://package/<%= file.iosPackageId %>?source=<%= hostDomain %>" class="install-btn">
                                        <img src="/images/icons/zebra.png" alt="Zebra" class="repo-icon-small"> Zebra
                                    </a>
                                    <a href="saily://package/<%= file.iosPackageId %>" class="install-btn">
                                        <img src="/images/icons/saily.png" alt="Saily" class="repo-icon-small"> Saily
                                    </a>
                                    <a href="cydia://package/<%= file.iosPackageId %>" class="install-btn">
                                        <img src="/images/icons/cydia.png" alt="Cydia" class="repo-icon-small"> Cydia
                                    </a>
                                    <a href="installer://package/<%= file.iosPackageId %>" class="install-btn" style="grid-column: 1 / -1;">
                                        <img src="/images/icons/installer.png" alt="Installer" class="repo-icon-small"> Installer
                                    </a>
                                <% } else { %>
                                    <p style="color: var(--silver); font-size: 0.85em; grid-column: 1 / -1; margin: 0;">Add our repo to your package manager to install this tweak.</p>
                                <% } %>
                            <% } %>
                        </div>

                    <% } else { %>
                        <div style="background-color: #1a1a1a; padding: 15px; border-radius: 8px; border: 1px dashed var(--gold); text-align: center; margin-top: 10px;">
                            <i class="fas fa-crown" style="font-size: 1.5em; color: var(--gold); margin-bottom: 10px;"></i>
                            <p style="color: var(--white); font-weight: bold; font-size: 0.9em; margin-bottom: 5px;">Premium Feature</p>
                            <p style="color: var(--silver); font-size: 0.8em; line-height: 1.4; margin-bottom: 15px;">Unlock 1-Click direct installations to Sileo, Zebra, TrollStore, and more!</p>
                            <a href="/membership" class="btn btn-primary" style="padding: 8px 15px; font-size: 0.85em; width: 100%;">Upgrade to Premium</a>
                        </div>
                    <% } %>
                </div>
            <% } %>
            <!-- ======================================================== -->
            
            <!-- ============================ -->
            <!-- Updated Action Buttons Start -->
            <!-- ============================ -->
            <div class="action-buttons">
                <% if (user) { %>
                    <form action="/files/<%= file._id %>/whitelist" method="POST" style="margin:0;">
                        <button type="submit" class="action-btn">
                            <i class="fas fa-heart"></i>
                            <%= userHasWhitelisted ? 'In Wishlist' : 'Add to Wishlist' %>
                        </button>
                    </form>
                    <button type="button" id="reportModalBtn" class="action-btn">
                        <i class="fas fa-flag"></i>
                        Report File
                    </button>
                <% } else { %>
                    <a href="/login" class="action-btn">Login to Interact</a>
                <% } %>

        <!-- ======== DYNAMIC SECURITY SCANS ======== -->
        <% if (file.virusTotalId || file.virusTotalAnalysisId || file.manualFileScanUrl || file.manualSiteScanUrl) { %>
            <div class="safety-badge" style="flex-direction: column; align-items: flex-start; padding: 15px; border-color: var(--silver);">
                
                <!-- If Automated Scan is Complete -->
                <% if (file.virusTotalScanDate) { %>
                    <div style="display: flex; align-items: center; gap: 10px; width: 100%; margin-bottom: 10px;">
                        <i class="fas fa-shield-virus" style="color: <%= file.virusTotalPositiveCount > 0 ? 'var(--red)' : 'var(--green)' %>; font-size: 1.5em;"></i>
                        <span style="font-weight: bold; color: var(--white); flex-grow: 1;">Automated Scan</span>
                        <span style="font-weight: bold; font-size: 1.2em; color: <%= file.virusTotalPositiveCount > 0 ? 'var(--red)' : 'var(--green)' %>;">
                            <%= file.virusTotalPositiveCount %> / <%= file.virusTotalTotalScans %>
                        </span>
                    </div>
                <% } else if (file.virusTotalAnalysisId) { %>
                    <!-- If Automated Scan is Pending -->
                    <div style="display: flex; align-items: center; gap: 10px; width: 100%; margin-bottom: 10px;">
                        <i class="fas fa-hourglass-half" style="color: var(--gold); font-size: 1.2em;"></i>
                        <span style="font-weight: bold; color: var(--white); flex-grow: 1;">Scan Pending...</span>
                        <button onclick="refreshVTScan('<%= file._id %>')" class="btn btn-secondary" style="padding: 4px 8px; font-size: 0.8em;"><i class="fas fa-sync-alt"></i></button>
                    </div>
                <% } %>

                <!-- Scan Link Buttons Container -->
                <div style="display: flex; flex-direction: column; gap: 8px; width: 100%; margin-top: 5px;">
                    
                    <!-- 1. Manual File Scan -->
                    <% if (file.manualFileScanUrl) { %>
                        <a href="<%= file.manualFileScanUrl %>" target="_blank" class="full-width-btn btn btn-secondary" style="text-align: left; padding: 8px 12px; font-size: 0.9em; background: #111 !important;">
                            <i class="fas fa-file-shield" style="color: var(--green); margin-right: 8px;"></i> View True File Scan
                        </a>
                    <% } %>

                    <!-- 2. Manual Site/URL Scan -->
                    <% if (file.manualSiteScanUrl) { %>
                        <a href="<%= file.manualSiteScanUrl %>" target="_blank" class="full-width-btn btn btn-secondary" style="text-align: left; padding: 8px 12px; font-size: 0.9em; background: #111 !important;">
                            <i class="fas fa-globe" style="color: var(--gold); margin-right: 8px;"></i> View Host Site Scan
                        </a>
                    <% } %>

                    <!-- 3. Automated VT Scan Link -->
                    <% if (file.virusTotalId || file.virusTotalAnalysisId) { 
                        const vtUrl = file.virusTotalId ? `https://www.virustotal.com/gui/file/${file.virusTotalId}` : `https://www.virustotal.com/gui/file-analysis/${file.virusTotalAnalysisId}`;
                    %>
                        <a href="<%= vtUrl %>" target="_blank" class="full-width-btn btn btn-secondary" style="text-align: left; padding: 8px 12px; font-size: 0.9em; border-color: #333; background: transparent !important;">
                            <i class="fas fa-robot" style="color: var(--silver); margin-right: 8px;"></i> View Automated Scan
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
        <!-- ============================================== -->
                
                <% if (user && user.username.toLowerCase() === file.uploader.toLowerCase()) { %>
                    <a href="/mods/<%= file._id %>/add-version" class="action-btn">
                        <i class="fas fa-plus"></i>
                        Add New Version
                    </a>
                <% } %>
            </div>
            <!-- ============================ -->
            <!--  Updated Action Buttons End  -->
            <!-- ============================ -->

            <ul class="meta-info">
                <li><span>Version:</span> <span class="meta-value"><%= file.version %></span></li>
                <li><span>Category:</span> <span class="meta-value"><%= file.platforms[0] || 'N/A' %></span></li>
                <li>Sutible For:<span><%=file.ageRating%></span></li>
                <li>
                <!-- ======== NEW: DEPENDENCY DISPLAYS ======== -->
                <% if (file.minOsVersion && file.minOsVersion.trim() !== '') { %>
                    <li>Requires: <span style="color: var(--gold);"><%= file.minOsVersion %>+</span></li>
                <% } %>
                
                <% if (file.architectures && file.architectures.length > 0) { %>
                    <li>Architecture: 
                        <span style="display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 5px; margin-top: 5px;">
                            <% file.architectures.forEach(arch => { %>
                                <span style="background: #222; border: 1px solid #444; padding: 2px 8px; border-radius: 4px; font-size: 0.85em; color: var(--silver);"><%= arch %></span>
                            <% }) %>
                        </span>
                    </li>
                <% } %>
                <!-- ======================================== -->
                    <span>Developer:</span> 
                    <% if (file.developer && file.developer !== 'N/A') { %>
                        <a href="/developer?name=<%= slugify(file.developer) %>" class="meta-link"><%= file.developer %> <span class="arrow">›</span></a>
                    <% } else { %>
                        <span class="meta-value">N/A</span>
                    <% } %>
                </li>
                
                <li>
                    <span>Uploaded by:</span> 
                    <a href="/users/<%= slugify(file.uploader) %>" class="meta-link"><%= file.uploader %> <span class="arrow">›</span></a>
                </li>
                
                <li><span>Downloads:</span> <span class="meta-value"><%= file.downloads.toLocaleString() %></span></li>
                
                <li><span>Updated:</span> <span class="meta-value"><%= new Date(file.updatedAt).toLocaleDateString() %></span></li>
                
                <li>Working?:
                    <% const totalVotes = file.workingVoteCount + file.notWorkingVoteCount; %>
                    <!-- ✅ FIX: Moved the % sign inside the logic so it doesn't show N/A% -->
                    <% const workingPercentage = totalVotes > 0 ? Math.round((file.workingVoteCount / totalVotes) * 100) + '%' : 'N/A'; %>
                    <div class="voting-system">
                        <span class="working-percentage"><%= workingPercentage %></span>
                        
                        <% if(user) { %>
                        <div class="vote-buttons">
                            <!-- Working Button -->
                            <form action="/files/<%= file._id %>/vote-status" method="POST" style="margin:0;">
                                <input type="hidden" name="voteType" value="working">
                                <!-- If user voted working, make it solid. Otherwise, make it outlined. -->
                                <button type="submit" 
                                    class="vote-btn-working" 
                                    style="<%= userVotedWorking ? 'background-color: var(--green); color: var(--white); box-shadow: 0 0 10px var(--green);' : '' %>"
                                    title="<%= userVotedWorking ? 'Remove vote' : 'Mark as Working' %>">
                                    ✓
                                </button>
                            </form>

                            <!-- Not Working Button -->
                            <form action="/files/<%= file._id %>/vote-status" method="POST" style="margin:0;">
                                <input type="hidden" name="voteType" value="not-working">
                                <!-- If user voted not-working, make it solid. Otherwise, make it outlined. -->
                                <button type="submit" 
                                    class="vote-btn-not-working" 
                                    style="<%= userVotedNotWorking ? 'background-color: var(--red); color: var(--white); box-shadow: 0 0 10px var(--red);' : '' %>"
                                    title="<%= userVotedNotWorking ? 'Remove vote' : 'Mark as Broken' %>">
                                    ✗
                                </button>
                            </form>
                        </div>
                        <% } %>
                    </div>
                </li>
            </ul>
        </aside>

        <!-- ============================ -->
        <!-- Right Details Panel -->
        <!-- ============================ -->
        <section class="details-panel">
            
            <!-- ======== NEW: VARIANTS SELECTOR ======== -->
            <% if (typeof masterFile !== 'undefined' && masterFile.variants && masterFile.variants.filter(v => v.status === 'live').length > 0) { %>
                <div style="background-color: var(--black); border: 1px solid #333; border-radius: 12px; padding: 20px; margin-bottom: 25px;">
                    <h3 style="color: var(--gold); margin-bottom: 15px; font-size: 1.2em;">
                        <i class="fas fa-layer-group" style="margin-right: 10px;"></i>Available Mod Variants
                    </h3>
                    
                    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                        <!-- Button for the Main (Master) Mod -->
                        <a href="/<%= masterFile.category %>/<%= masterFile.slug %>" 
                           class="btn <%= !isViewingVariant ? 'btn-primary' : 'btn-secondary' %>" 
                           style="border-color: <%= !isViewingVariant ? 'var(--gold)' : '#555' %>; padding: 8px 15px; border-radius: 8px;">
                           <%= masterFile.uploader %>'s Mod (Main)
                        </a>

                        <!-- Buttons for each Live Variant -->
                        <% masterFile.variants.forEach(variant => { %>
                            <% if (variant.status === 'live') { %>
                                <a href="/<%= masterFile.category %>/<%= masterFile.slug %>?variant=<%= variant._id %>" 
                                   class="btn <%= (file._id.toString() === variant._id.toString()) ? 'btn-primary' : 'btn-secondary' %>" 
                                   style="border-color: <%= (file._id.toString() === variant._id.toString()) ? 'var(--gold)' : '#555' %>; padding: 8px 15px; border-radius: 8px;">
                                   <%= variant.uploader %>'s Mod
                                </a>
                            <% } %>
                        <% }) %>
                    </div>
                </div>
            <% } %>
            <!-- ======================================== -->
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="description">Description</button>
                <button class="tab-button" data-tab="screenshots">Screenshots</button>
                <button class="tab-button" data-tab="versions">Versions</button>
                <button class="tab-button" data-tab="comments">Comments</button>
            </div>

<!-- Description Tab -->
            <div id="description" class="tab-content active">
                
                 <!-- 1. Mod Information Box -->
                <div class="info-box gold">
                    <h2>Mod Information</h2>
                    
                    <!-- Description -->
                    <div style="margin-bottom: 1.5rem;"><%- file.modDescription %></div>

                    <!-- ✅ FIX: Smart Lottie Animation Logic -->
                    <% if (file.modFeatures && file.modFeatures.trim() !== '') { %>
                        <% 
                            // Check if the user used bullet points (Quill outputs <li> tags)
                            const isList = file.modFeatures.includes('<li'); 
                        %>
                        
                        <% if (isList) { %>
                            <!-- If it's a list, inject the Lottie icons -->
                            <ul class="features-list">
                                <% 
                                // A clever trick: split the HTML by <li> tags to isolate the list items
                                const listItems = file.modFeatures.split(/<li[^>]*>/);
                                
                                listItems.forEach(item => {
                                    if (item.trim() !== '' && !item.startsWith('<ul') && !item.startsWith('<ol')) {
                                        // Clean up the closing </li> tag
                                        let cleanText = item.replace('</li>', '').replace('</ul>', '').replace('</ol>', '');
                                %>
                                    <li>
                                        <!-- The Lottie Animation -->
                                        <div class="lottie-icon-wrapper">
                                            <lottie-player src="/animations/ticmark.json" background="transparent" speed="1" loop autoplay></lottie-player>
                                        </div>
                                        <div class="feature-text">
                                            <!-- Output the raw HTML of the list item so bolding/italics still work -->
                                            <span><%- cleanText %></span>
                                        </div>
                                    </li>
                                <% 
                                    } 
                                }); 
                                %>
                            </ul>
                        <% } else { %>
                            <!-- If they didn't use bullet points, just output the raw HTML safely -->
                            <div class="raw-features-text">
                                <%- file.modFeatures %>
                            </div>
                        <% } %>
                    <% } %>
                </div>
<!-- ======== NEW: IMPORTANT NOTE BOX (ANIMATED LIST) ======== -->
                <% if (file.importantNote && file.importantNote.trim() !== '' && file.importantNote !== '<p><br></p>') { %>
                <div class="info-box" style="border-left: 3px solid var(--red); box-shadow: 0 0 15px rgba(229, 57, 53, 0.05);">
                    <h2 style="color: var(--red);">Important Note:</h2>
                    
                    <% 
                        // Check if the admin used bullet points (Quill outputs <li> tags)
                        const isNoteList = file.importantNote.includes('<li'); 
                    %>
                    
                    <% if (isNoteList) { %>
                        <ul class="features-list">
                            <% 
                            // Split the HTML by <li> tags to isolate the list items
                            const noteItems = file.importantNote.split(/<li[^>]*>/);
                            
                            noteItems.forEach(item => {
                                if (item.trim() !== '' && !item.startsWith('<ul') && !item.startsWith('<ol')) {
                                    // Clean up the closing tags
                                    let cleanText = item.replace('</li>', '').replace('</ul>', '').replace('</ol>', '');
                            %>
                                <li>
                                    <!-- The Red Lottie Arrow Wrapper -->
                                    <div class="lottie-icon-wrapper">
                                        <lottie-player src="/animations/arrow.json" background="transparent" speed="1" loop autoplay style="width: 100%; height: 100%; transform: scale(1.8);"></lottie-player>
                                    </div>
                                    <div class="feature-text" style="color: var(--white); font-weight: 500;">
                                        <!-- Output the raw HTML of the list item so bolding/italics still work -->
                                        <span><%- cleanText %></span>
                                    </div>
                                </li>
                            <% 
                                } 
                            }); 
                            %>
                        </ul>
                    <% } else { %>
                        <!-- If they didn't use bullet points, just output the raw HTML safely -->
                        <div class="raw-features-text" style="color: var(--silver);">
                            <%- file.importantNote %>
                        </div>
                    <% } %>
                </div>
                <% } %>
                <!-- ========================================= -->
            
                                <!-- 2. What's New Box -->
                <% if (file.whatsNew && file.whatsNew.trim() !== '' && file.whatsNew !== '<p><br></p>') { %>
                <div class="info-box silver">
                    <h2>What's New</h2>
                    
                    <% const isUpdateList = file.whatsNew.includes('<li'); %>
                    
                    <% if (isUpdateList) { %>
                        <ul class="features-list">
                            <% 
                            const updateItems = file.whatsNew.split(/<li[^>]*>/);
                            updateItems.forEach(item => { 
                                if (item.trim() !== '' && !item.startsWith('<ul') && !item.startsWith('<ol')) { 
                                    let cleanUpdateText = item.replace('</li>', '').replace('</ul>', '').replace('</ol>', '');
                            %>
                                <li>
                                    <div class="lottie-icon-wrapper">
                                        <lottie-player src="/animations/dot.json" background="transparent" speed="1" loop autoplay></lottie-player>
                                    </div>
                                    <div class="feature-text">
                                        <span><%- cleanUpdateText %></span>
                                    </div>
                                </li>
                            <% }}); %>
                        </ul>
                    <% } else { %>
                        <div class="raw-features-text">
                            <%- file.whatsNew %>
                        </div>
                    <% } %>
                </div>
                <% } %>

                <!-- 3. Official Description -->
                <% if (file.officialDescription && file.officialDescription.trim() !== '') { %>
                <div class="app-description-content" style="margin-top: 2rem;">
                    <h2>About This App/Game</h2>
                    <p><%- file.officialDescription.replace(/\r?\n/g, '<br>') %></p>
                </div>
                <% } %>
            </div>
            <!-- Screenshots Tab -->
            <div id="screenshots" class="tab-content">
                <h2>Screenshots</h2>
                <div class="screenshot-gallery">
                    <% file.screenshotUrls.forEach(url => { %>
                        <a href="<%= url %>" target="_blank"><img src="<%= url %>" alt="Screenshot of <%= file.name %>"></a>
                    <% }) %>
                </div>
            </div>
            
            <!-- Versions & Variants Tab -->
            <div id="versions" class="tab-content">
                
                <!-- Section 1: Previous Versions (Same Uploader) -->
                <h2>Version History</h2>
                <table class="versions-table" style="margin-bottom: 40px;">
                    <thead><tr><th>Version</th><th>Size</th><th>Date</th><th>Download</th></tr></thead>
                    <tbody>
                        <% versionHistory.forEach(version => { %>
                            <tr>
                                <td data-label="Version"><%= version.version %> <% if(version._id.equals(file._id)) { %>(Latest)<% } %></td>
                                <td data-label="Size"><%= formatBytes(version.fileSize) %></td> <!-- ADDED THIS -->
                                <td data-label="Date"><%= new Date(version.createdAt).toLocaleDateString() %></td>
                                <td data-label="Link"><a href="/download-file/<%= version._id %>">Download</a></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Comments/Reviews Tab -->
            <div id="comments" class="tab-content">
                <h2>Community Comments</h2>
                <% if (user) { %>
                <div class="comment-form">
                    <h3>Leave a Review</h3>
                    <form action="/reviews/add/<%= file._id %>" method="POST">
                        <textarea name="comment" placeholder="Share your experience..." required></textarea>
                        <div class="form-footer">
                            <div class="rating-input">
                                <input type="radio" id="star5" name="rating" value="5" required><label for="star5" title="5 stars">☆</label>
                                <input type="radio" id="star4" name="rating" value="4"><label for="star4">☆</label>
                                <input type="radio" id="star3" name="rating" value="3"><label for="star3">☆</label>
                                <input type="radio" id="star2" name="rating" value="2"><label for="star2">☆</label>
                                <input type="radio" id="star1" name="rating" value="1"><label for="star1">☆</label>
                            </div>
                            <button type="submit">Post Comment</button>
                        </div>
                    </form>
                </div>
                <% } %>

                <div class="comment-list">
                    <% if(reviews && reviews.length > 0) { %>
                        <% reviews.forEach((review, index) => { %>
                        <div class="comment-item" style="position: relative;">
                            
                            <!-- If it's the current user's comment, show a tiny 'Your Review' badge -->
                            <% if (user && user._id.toString() === review.user._id.toString()) { %>
                                <span style="position: absolute; top: -10px; right: 20px; background: var(--gold); color: var(--black); font-size: 0.7em; font-weight: bold; padding: 2px 8px; border-radius: 10px;">Your Review</span>
                            <% } %>

                            <div class="comment-header">
                                <div class="avatar-wrapper">
                                    <img src="<%= review.user.signedAvatarUrl || '/images/default-avatar.png' %>" alt="User Avatar">
                                </div>
                                <span class="comment-author notranslate"><%= review.username %></span>
                                <div class="comment-rating rating" id="display-stars-<%= review._id %>">
                                    <div class="stars-outer">
                                        <div class="stars-inner" style="width: <%= (review.rating / 5) * 100 %>%;"></div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Static Display -->
                            <p class="comment-body" id="display-text-<%= review._id %>"><%- review.comment.replace(/\n/g, '<br>') %></p>

                            <!-- Edit Form (Hidden by Default) -->
                            <% if (user && user._id.toString() === review.user._id.toString()) { %>
                                <form action="/reviews/<%= review._id %>/edit" method="POST" id="edit-form-<%= review._id %>" style="display:none; margin-top: 15px; background: #0a0a0a; padding: 15px; border-radius: 8px; border: 1px dashed var(--gold);">
                                    <textarea name="comment" required style="width: 100%; background: #1a1a1a; border: 1px solid #333; color: white; padding: 10px; border-radius: 5px;"><%= review.comment %></textarea>
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                                        <div class="rating-input" style="flex-direction: row-reverse;">
                                            <input type="radio" id="e-star5-<%= review._id %>" name="rating" value="5" <%= review.rating === 5 ? 'checked' : '' %> required><label for="e-star5-<%= review._id %>">☆</label>
                                            <input type="radio" id="e-star4-<%= review._id %>" name="rating" value="4" <%= review.rating === 4 ? 'checked' : '' %>><label for="e-star4-<%= review._id %>">☆</label>
                                            <input type="radio" id="e-star3-<%= review._id %>" name="rating" value="3" <%= review.rating === 3 ? 'checked' : '' %>><label for="e-star3-<%= review._id %>">☆</label>
                                            <input type="radio" id="e-star2-<%= review._id %>" name="rating" value="2" <%= review.rating === 2 ? 'checked' : '' %>><label for="e-star2-<%= review._id %>">☆</label>
                                            <input type="radio" id="e-star1-<%= review._id %>" name="rating" value="1" <%= review.rating === 1 ? 'checked' : '' %>><label for="e-star1-<%= review._id %>">☆</label>
                                        </div>
                                        <div>
                                            <button type="button" onclick="toggleEdit('<%= review._id %>')" style="background: none; border: none; color: var(--silver); cursor: pointer; margin-right: 10px;">Cancel</button>
                                            <button type="submit" class="btn btn-primary" style="padding: 5px 15px; font-size: 0.9em;">Save</button>
                                        </div>
                                    </div>
                                </form>
                            <% } %>

                            <!-- User & Uploader Action Buttons -->
                            <div style="margin-top: 10px; display: flex; gap: 15px; font-size: 0.85em;">
                                <!-- If current user is the author of the comment -->
                                <% if (user && user._id.toString() === review.user._id.toString()) { %>
                                    <button onclick="toggleEdit('<%= review._id %>')" style="background:none; border:none; color: var(--gold); cursor:pointer;"><i class="fas fa-edit"></i> Edit</button>
                                    <button onclick="openCommentDelete('<%= review._id %>')" style="background:none; border:none; color: var(--red); cursor:pointer;"><i class="fas fa-trash"></i> Delete</button>
                                <% } %>
                                
                                <!-- If current user is the uploader of the FILE -->
                                <% if (user && user.username === file.uploader) { %>
                                    <% if (!review.uploaderReply) { %>
                                        <button onclick="toggleReplyForm('<%= review._id %>')" style="background:none; border:none; color: var(--blue); cursor:pointer;"><i class="fas fa-reply"></i> Reply as Uploader</button>
                                    <% } %>
                                <% } %>
                            </div>

                            <!-- Uploader Reply Form (Hidden) -->
                            <% if (user && user.username === file.uploader && !review.uploaderReply) { %>
                                <form action="/reviews/<%= review._id %>/reply" method="POST" id="reply-form-<%= review._id %>" style="display:none; margin-top: 15px; background: #0a0a0a; padding: 15px; border-left: 3px solid var(--blue); border-radius: 8px;">
                                    <textarea name="replyText" placeholder="Write your reply as the uploader..." required style="width: 100%; background: #1a1a1a; border: 1px solid #333; color: white; padding: 10px; border-radius: 5px; min-height: 80px;"></textarea>
                                    <div style="text-align: right; margin-top: 10px;">
                                        <button type="button" onclick="toggleReplyForm('<%= review._id %>')" style="background: none; border: none; color: var(--silver); cursor: pointer; margin-right: 10px;">Cancel</button>
                                        <button type="submit" class="btn btn-secondary" style="border-color: var(--blue); color: var(--blue); padding: 5px 15px;">Post Reply</button>
                                    </div>
                                </form>
                            <% } %>

                            <!-- Display Uploader Reply if it exists -->
                            <% if (review.uploaderReply && review.uploaderReply.text) { %>
                                <div style="margin-top: 15px; margin-left: 20px; padding: 15px; background: #0a0a0a; border-left: 3px solid var(--gold); border-radius: 0 8px 8px 0; position: relative;">
                                    <strong style="color: var(--gold); display: flex; align-items: center; gap: 8px; font-size: 0.9em; margin-bottom: 5px;">
                                        <i class="fas fa-crown"></i> Uploader's Response
                                    </strong>
                                    <p style="color: var(--silver); margin: 0; font-size: 0.95em;"><%= review.uploaderReply.text %></p>
                                    
                                    <!-- Edit/Delete Reply actions for uploader -->
                                    <% if (user && user.username === file.uploader) { %>
                                        <div style="margin-top: 10px; display: flex; gap: 15px; font-size: 0.8em;">
                                            <button onclick="toggleReplyForm('<%= review._id %>')" style="background:none; border:none; color: var(--silver); cursor:pointer;">Edit Reply</button>
                                            <form action="/reviews/<%= review._id %>/reply/delete" method="POST" style="margin:0;">
                                                <button type="submit" style="background:none; border:none; color: var(--red); cursor:pointer;">Remove Reply</button>
                                            </form>
                                        </div>

                                        <!-- Form to Edit Reply -->
                                        <form action="/reviews/<%= review._id %>/reply" method="POST" id="reply-form-<%= review._id %>" style="display:none; margin-top: 15px;">
                                            <textarea name="replyText" required style="width: 100%; background: #1a1a1a; border: 1px solid #333; color: white; padding: 10px; border-radius: 5px; min-height: 80px;"><%= review.uploaderReply.text %></textarea>
                                            <div style="text-align: right; margin-top: 10px;">
                                                <button type="button" onclick="toggleReplyForm('<%= review._id %>')" style="background: none; border: none; color: var(--silver); cursor: pointer; margin-right: 10px;">Cancel</button>
                                                <button type="submit" class="btn btn-secondary" style="border-color: var(--gold); color: var(--gold); padding: 5px 15px;">Update Reply</button>
                                            </div>
                                        </form>
                                    <% } %>
                                </div>
                            <% } %>

                        </div>
                        <% }) %>
                    <% } else { %>
                        <p>No reviews yet. Be the first to leave one!</p>
                    <% } %>
                </div>
            </div>
        </section>
    </div>
</main>

<!-- Report Modal (Cleaned up and Styled) -->
<div id="reportModal" class="modal" style="display: none; position: fixed; z-index: 1001; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.8); backdrop-filter: blur(5px);">
    <div class="modal-content" style="background-color: var(--dark-gray); margin: 10% auto; padding: 2.5rem; border: 1px solid #333; width: 90%; max-width: 500px; border-radius: 12px; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        
        <span class="close-modal" style="color: var(--silver); position: absolute; top: 15px; right: 20px; font-size: 28px; font-weight: bold; cursor: pointer; transition: color 0.3s;">&times;</span>
        
        <h3 style="color: var(--gold); margin-bottom: 20px; font-size: 1.5em;">Report "<%= file.name %>"</h3>
        
        <form action="/files/<%= file._id %>/report" method="POST" id="reportForm">
            
            <div class="form-group" style="margin-bottom: 20px; text-align: left;">
                <label style="display: block; margin-bottom: 8px; color: var(--silver);">Reason for reporting*</label>
                
                <!-- 1. The Hidden Native Select -->
                <select name="reason" id="reason" required style="display: none;">
                    <option value="" disabled selected>Select a reason...</option>
                    <option value="malware">Contains malware/virus</option>
                    <option value="broken-file">File is broken or does not work</option>
                    <option value="incorrect-info">Description or screenshots are incorrect</option>
                    <option value="copyright">Copyright infringement</option>
                    <option value="other">Other</option>
                </select>

                <!-- 2. The Custom Interactive UI -->
                <div class="custom-select-wrapper" id="wrapper-report-reason">
                    <div class="custom-select">
                        <span class="selected-text">Select a reason...</span>
                        <i class="fas fa-chevron-down custom-select-arrow"></i>
                    </div>
                    <div class="custom-options">
                        <div class="custom-option" data-value="malware">Contains malware/virus</div>
                        <div class="custom-option" data-value="broken-file">File is broken or does not work</div>
                        <div class="custom-option" data-value="incorrect-info">Description or screenshots are incorrect</div>
                        <div class="custom-option" data-value="copyright">Copyright infringement</div>
                        <div class="custom-option" data-value="other">Other</div>
                    </div>
                </div>
