<%- include('../partials/header') %>

<style>
    /* Most styles are now in global style.css, but we can keep page-specific ones here */
</style>

<main class="container">
    <div class="download-layout">

        <!-- ============================ -->
        <!-- Left Info Panel -->
        <!-- ============================ -->
        <aside class="info-panel">
            <img src="<%= file.iconUrl %>" alt="<%= file.name %> Icon" class="app-icon">
            <h1><%= file.name %></h1>
            
            <div class="rating">
                <div class="stars-outer">
                    <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                </div>
                <span class="rating-text"><%= file.averageRating.toFixed(1) %> (<%= file.ratingCount %> reviews)</span>
            </div>

            <% if (file.certification === 'certified') { %>
            <div class="safety-badge">
                <lottie-player src="/animations/shield.json" background="transparent" speed="1" style="width: 28px; height: 28px;" loop autoplay></lottie-player>
                <span class="badge-text">100% Safe & Admin Certified</span>
            </div>
            <% } %>

           <% if (file.certification === 'community-tested') { %>
            <div class="safety-badge">
                <lottie-player src="/animations/heart.json" background="transparent" speed="1" style="width: 28px; height: 28px;" loop autoplay></lottie-player>
                <span class="badge-text">Highly Rated By Community</span>
            </div>
            <% } %>
            
            <!-- ======== DYNAMIC DOWNLOAD BUTTON ======== -->
            <% if (file.isMultiPart) { %>
                <!-- Redirects to the new Multi-Part page -->
                <a href="/mods/<%= file._id %>/parts" class="download-button" style="text-align: center;">
                    <i class="fas fa-layer-group" style="margin-right: 10px;"></i>
                    View Download Links
                    <span style="display: block; font-size: 0.6em; font-weight: normal; margin-top: 5px;">(File is split into <%= file.downloadParts.length %> parts)</span>
                </a>
            <% } else { %>
                <!-- Standard Single-File Download -->
                <a href="/download-file/<%= file._id %>" class="download-button" style="text-align: center;">
                    <i class="fas fa-download" style="margin-right: 10px;"></i>
                    Download (<%= formatBytes(file.fileSize) %>)
                </a>
            <% } %>
            
            <!-- ============================ -->
            <!-- Updated Action Buttons Start -->
            <!-- ============================ -->
            <div class="action-buttons">
                <% if (user) { %>
                    <form action="/files/<%= file._id %>/whitelist" method="POST" style="margin:0;">
                        <button type="submit" class="action-btn">
                            <i class="fas fa-heart"></i>
                            <%= userHasWhitelisted ? 'In Wishlist' : 'Add to Wishlist' %>
                        </button>
                    </form>
                    <button type="button" id="reportModalBtn" class="action-btn">
                        <i class="fas fa-flag"></i>
                        Report File
                    </button>
                <% } else { %>
                    <a href="/login" class="action-btn">Login to Interact</a>
                <% } %>

<!-- ======== VIRUSTOTAL LOGIC ======== -->
<% if (file.virusTotalId || file.virusTotalAnalysisId) { %>
    
    <% if (file.virusTotalScanDate) { %>
        <!-- The scan is COMPLETE. Show the results block! -->
        <div class="safety-badge" style="flex-direction: column; align-items: flex-start; padding: 15px; border-color: <%= file.virusTotalPositiveCount > 0 ? 'var(--red)' : 'var(--green)' %>;">
            <div style="display: flex; align-items: center; gap: 10px; width: 100%;">
                <i class="fas fa-shield-virus" style="color: <%= file.virusTotalPositiveCount > 0 ? 'var(--red)' : 'var(--green)' %>; font-size: 1.5em;"></i>
                <span style="font-weight: bold; color: var(--white); flex-grow: 1;">Security Scan</span>
                <span style="font-weight: bold; font-size: 1.2em; color: <%= file.virusTotalPositiveCount > 0 ? 'var(--red)' : 'var(--green)' %>;">
                    <%= file.virusTotalPositiveCount %> / <%= file.virusTotalTotalScans %>
                </span>
            </div>
            
            <% 
               // Determine the correct URL. If we have the true hash (virusTotalId), use it.
               // Otherwise, use the analysis ID.
               const vtUrl = file.virusTotalId 
                   ? `https://www.virustotal.com/gui/file/${file.virusTotalId}` 
                   : `https://www.virustotal.com/gui/file-analysis/${file.virusTotalAnalysisId}`;
            %>
            <a href="<%= vtUrl %>" target="_blank" class="full-width-btn" style="text-align: center; display: block; margin-top: 10px; font-size: 0.85em; color: var(--silver); text-decoration: underline;">View Full Report</a>
        </div>
        
    <% } else { %>
        <!-- The scan is PENDING. Show the refresh button. -->
        <div class="safety-badge" style="flex-direction: column; align-items: flex-start; padding: 15px; border-color: var(--gold);">
            <div style="display: flex; align-items: center; gap: 10px; width: 100%;">
                <i class="fas fa-hourglass-half" style="color: var(--gold); font-size: 1.5em;"></i>
                <span style="font-weight: bold; color: var(--white);">Scan in Progress...</span>
            </div>
            <button onclick="refreshVTScan('<%= file._id %>')" class="btn btn-secondary full-width-btn" style="margin-top: 10px; padding: 8px; border-color: var(--gold); color: var(--gold);">
                <i class="fas fa-sync-alt"></i> Check Results Now
            </button>
        </div>
    <% } %>
<% } %>
<!-- ======================================= -->
                
                <% if (user && user.username.toLowerCase() === file.uploader.toLowerCase()) { %>
                    <a href="/mods/<%= file._id %>/add-version" class="action-btn">
                        <i class="fas fa-plus"></i>
                        Add New Version
                    </a>
                <% } %>
            </div>
            <!-- ============================ -->
            <!--  Updated Action Buttons End  -->
            <!-- ============================ -->

            <ul class="meta-info">
                <li>Version: <span><%= file.version %></span></li>
                <li>Category: <span><%= file.platforms[0] || 'N/A' %></span></li>
                <li>
                    Developer: 
                    <% if (file.developer && file.developer !== 'N/A') { %>
                        <!-- ✅ CHANGED: Now using slugify -->
                        <a href="/developer?name=<%= slugify(file.developer) %>" class="meta-link"><%= file.developer %> <span class="arrow">›</span></a>
                    <% } else { %>
                        <span>N/A</span>
                    <% } %>
                </li>
                <li>
                    Uploaded by: 
                    <!-- ✅ CHANGED: Now using slugify -->
                    <a href="/users/<%= slugify(file.uploader) %>" class="meta-link"><%= file.uploader %> <span class="arrow">›</span></a>
                </li>
                <li>Downloads: <span><%= file.downloads.toLocaleString() %></span></li>
                <li>Updated: <span><%= new Date(file.updatedAt).toLocaleDateString() %></span></li>
                <li>Working?:
                    <% const totalVotes = file.workingVoteCount + file.notWorkingVoteCount; %>
                    <!-- ✅ FIX: Moved the % sign inside the logic so it doesn't show N/A% -->
                    <% const workingPercentage = totalVotes > 0 ? Math.round((file.workingVoteCount / totalVotes) * 100) + '%' : 'N/A'; %>
                    <div class="voting-system">
                        <span class="working-percentage"><%= workingPercentage %></span>
                        <% if(user && !userHasVotedOnStatus) { %>
                        <div class="vote-buttons">
                            <!-- ✅ FIX: Applied the new Green and Red button classes -->
                            <form action="/files/<%= file._id %>/vote-status" method="POST" style="margin:0;">
                                <input type="hidden" name="voteType" value="working">
                                <button type="submit" class="vote-btn-working" title="It works!">✓</button>
                            </form>
                            <form action="/files/<%= file._id %>/vote-status" method="POST" style="margin:0;">
                                <input type="hidden" name="voteType" value="not-working">
                                <button type="submit" class="vote-btn-not-working" title="It doesn't work!">✗</button>
                            </form>
                        </div>
                        <% } %>
                    </div>
                </li>
            </ul>
        </aside>

        <!-- ============================ -->
        <!-- Right Details Panel -->
        <!-- ============================ -->
        <section class="details-panel">
            
            <!-- ======== NEW: VARIANTS SELECTOR ======== -->
            <% if (masterFile.variants && masterFile.variants.filter(v => v.status === 'live').length > 0) { %>
                <div style="background-color: var(--black); border: 1px solid #333; border-radius: 12px; padding: 20px; margin-bottom: 25px;">
                    <h3 style="color: var(--gold); margin-bottom: 15px; font-size: 1.2em;">
                        <i class="fas fa-layer-group" style="margin-right: 10px;"></i>Available Mod Variants
                    </h3>
                    
                    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                        <!-- Button for the Main (Master) Mod -->
                        <a href="/<%= masterFile.category %>/<%= masterFile.slug %>" 
                           class="btn <%= !isViewingVariant ? 'btn-primary' : 'btn-secondary' %>" 
                           style="border-color: <%= !isViewingVariant ? 'var(--gold)' : '#555' %>; padding: 8px 15px; border-radius: 8px;">
                           <%= masterFile.uploader %>'s Mod (Main)
                        </a>

                        <!-- Buttons for each Live Variant -->
                        <% masterFile.variants.forEach(variant => { %>
                            <% if (variant.status === 'live') { %>
                                <a href="/<%= masterFile.category %>/<%= masterFile.slug %>?variant=<%= variant._id %>" 
                                   class="btn <%= (file._id.toString() === variant._id.toString()) ? 'btn-primary' : 'btn-secondary' %>" 
                                   style="border-color: <%= (file._id.toString() === variant._id.toString()) ? 'var(--gold)' : '#555' %>; padding: 8px 15px; border-radius: 8px;">
                                   <%= variant.uploader %>'s Mod
                                </a>
                            <% } %>
                        <% }) %>
                    </div>
                </div>
            <% } %>
            <!-- ======================================== -->
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="description">Description</button>
                <button class="tab-button" data-tab="screenshots">Screenshots</button>
                <button class="tab-button" data-tab="versions">Versions</button>
                <button class="tab-button" data-tab="comments">Comments</button>
            </div>

<!-- Description Tab -->
            <div id="description" class="tab-content active">
                
                <!-- 1. Mod Information Box -->
                <div class="info-box gold">
                    <h2>Mod Information</h2>
                    
                    <!-- General Description Paragraph -->
                    <p><%- file.modDescription.replace(/\n/g, '<br>') %></p>

                    <!-- Animated Features List -->
                    <% if (file.modFeatures && file.modFeatures.trim() !== '') { %>
                        <ul class="features-list">
                            <% 
                            file.modFeatures.split(/\r?\n/).forEach(feature => { 
                                if (feature.trim() !== '') { 
                                    // Splits the feature into a Bold Title and normal description
                                    const parts = feature.split(/:(.*)/s);
                                    const title = parts[0].trim();
                                    const description = parts.length > 1 ? parts[1].trim() : '';
                            %>
                                <li>
                                    <!-- Lottie Wrapper keeps it aligned to the top -->
                                    <div class="lottie-icon-wrapper">
                                        <lottie-player src="/animations/ticmark.json" background="transparent" speed="1" loop autoplay></lottie-player>
                                    </div>
                                    <div class="feature-text">
                                        <% if (description) { %>
                                            <strong><%= title %>:</strong> <span><%= description %></span>
                                        <% } else { %>
                                            <span><%= title %></span>
                                        <% } %>
                                    </div>
                                </li>
                            <% }}) %>
                        </ul>
                    <% } %>
                </div>

                <!-- 2. What's New Box -->
                <% if (file.whatsNew && file.whatsNew.trim() !== '') { %>
                <div class="info-box silver">
                    <h2>What's New</h2>
                    <ul class="features-list">
                        <% file.whatsNew.split(/\r?\n/).forEach(updateLine => { if (updateLine.trim() !== '') { %>
                            <li>
                                <div class="lottie-icon-wrapper">
                                    <!-- Using the dot animation here -->
                                    <lottie-player src="/animations/dot.json" background="transparent" speed="1" loop autoplay></lottie-player>
                                </div>
                                <div class="feature-text">
                                    <span><%= updateLine.trim() %></span>
                                </div>
                            </li>
                        <% }}) %>
                    </ul>
                </div>
                <% } %>

                <!-- 3. Official Description -->
                <% if (file.officialDescription && file.officialDescription.trim() !== '') { %>
                <div class="app-description-content" style="margin-top: 2rem;">
                    <h2>About This App/Game</h2>
                    <p><%- file.officialDescription.replace(/\r?\n/g, '<br>') %></p>
                </div>
                <% } %>
            </div>
               <!-- ======== NEW: IMPORTANT NOTE BOX ======== -->
                <% if (file.importantNote && file.importantNote.trim() !== '') { %>
                <div class="info-box" style="border-left: 3px solid var(--red); box-shadow: 0 0 15px rgba(229, 57, 53, 0.05);">
                    <h2 style="color: var(--red);"><i class="fas fa-exclamation-circle" style="margin-right: 10px;"></i>Important Note</h2>
                    <p style="color: var(--white); font-weight: bold;"><%- file.importantNote.replace(/\n/g, '<br>') %></p>
                </div>
                <% } %>
                <!-- ========================================= -->
            
            <!-- Screenshots Tab -->
            <div id="screenshots" class="tab-content">
                <h2>Screenshots</h2>
                <div class="screenshot-gallery">
                    <% file.screenshotUrls.forEach(url => { %>
                        <a href="<%= url %>" target="_blank"><img src="<%= url %>" alt="Screenshot of <%= file.name %>"></a>
                    <% }) %>
                </div>
            </div>
            
            <!-- Versions & Variants Tab -->
            <div id="versions" class="tab-content">
                
                <!-- Section 1: Previous Versions (Same Uploader) -->
                <h2>Version History</h2>
                <table class="versions-table" style="margin-bottom: 40px;">
                    <thead><tr><th>Version</th><th>Size</th><th>Date</th><th>Download</th></tr></thead>
                    <tbody>
                        <% versionHistory.forEach(version => { %>
                            <tr>
                                <td data-label="Version"><%= version.version %> <% if(version._id.equals(file._id)) { %>(Latest)<% } %></td>
                                <td data-label="Size"><%= formatBytes(version.fileSize) %></td>
                                <td data-label="Date"><%= new Date(version.createdAt).toLocaleDateString() %></td>
                                <td data-label="Link"><a href="/download-file/<%= version._id %>">Download</a></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

                <!-- Section 2: Alternative Variants (Different Uploaders/Distributors) -->
                <% if (file.variants && file.variants.length > 0) { %>
                    <h2 style="color: var(--blue);">Alternative Variants</h2>
                    <p style="color: var(--silver); margin-bottom: 20px;">Other versions or mods for this app uploaded by the community.</p>
                    
                    <table class="versions-table">
                        <thead><tr><th>Version</th><th>Uploaded By</th><th>Size</th><th>Download</th></tr></thead>
                        <tbody>
                            <% file.variants.forEach(variant => { %>
                                <!-- Only show variants that are 'live' -->
                                <% if (variant.status === 'live') { %>
                                    <tr>
                                        <td data-label="Version"><%= variant.version %></td>
                                        <td data-label="Uploader">
                                            <a href="/users/<%= slugify(variant.uploader) %>" style="color: var(--silver);"><%= variant.uploader %></a>
                                        </td>
                                        <td data-label="Size"><%= formatBytes(variant.fileSize) %></td>
                                        <td data-label="Link"><a href="/download-file/<%= variant._id %>">Download</a></td>
                                    </tr>
                                <% } %>
                            <% }) %>
                        </tbody>
                    </table>
                <% } %>

            </div>

            <!-- Comments/Reviews Tab -->
            <div id="comments" class="tab-content">
                <h2>Community Comments</h2>
                <% if (user) { %>
                <div class="comment-form">
                    <h3>Leave a Review</h3>
                    <form action="/reviews/add/<%= file._id %>" method="POST">
                        <textarea name="comment" placeholder="Share your experience..." required></textarea>
                        <div class="form-footer">
                            <div class="rating-input">
                                <input type="radio" id="star5" name="rating" value="5" required><label for="star5" title="5 stars">☆</label>
                                <input type="radio" id="star4" name="rating" value="4"><label for="star4">☆</label>
                                <input type="radio" id="star3" name="rating" value="3"><label for="star3">☆</label>
                                <input type="radio" id="star2" name="rating" value="2"><label for="star2">☆</label>
                                <input type="radio" id="star1" name="rating" value="1"><label for="star1">☆</label>
                            </div>
                            <button type="submit">Post Comment</button>
                        </div>
                    </form>
                </div>
                <% } %>

                <div class="comment-list">
                    <% if(reviews && reviews.length > 0) { %>
                        <% reviews.forEach(review => { %>
                        <div class="comment-item">
                            <div class="comment-header">
                                <div class="avatar-wrapper">
                                    <img src="<%= (review.user && review.user.signedAvatarUrl) ? review.user.signedAvatarUrl : '/images/default-avatar.png' %>" alt="User Avatar">
                                </div>
                                <span class="comment-author"><%= review.username %></span>
                                <div class="comment-rating rating">
                                    <div class="stars-outer">
                                        <div class="stars-inner" style="width: <%= (review.rating / 5) * 100 %>%;"></div>
                                    </div>
                                </div>
                            </div>
                            <p class="comment-body"><%- review.comment.replace(/\n/g, '<br>') %></p>
                        </div>
                        <% }) %>
                    <% } else { %>
                        <p>No reviews yet. Be the first to leave one!</p>
                    <% } %>
                </div>
            </div>
        </section>
    </div>
</main>

<!-- Report Modal (Cleaned up and Styled) -->
<div id="reportModal" class="modal" style="display: none; position: fixed; z-index: 1001; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.8); backdrop-filter: blur(5px);">
    <div class="modal-content" style="background-color: var(--dark-gray); margin: 10% auto; padding: 2.5rem; border: 1px solid #333; width: 90%; max-width: 500px; border-radius: 12px; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        
        <span class="close-modal" style="color: var(--silver); position: absolute; top: 15px; right: 20px; font-size: 28px; font-weight: bold; cursor: pointer; transition: color 0.3s;">&times;</span>
        
        <h3 style="color: var(--gold); margin-bottom: 20px; font-size: 1.5em;">Report "<%= file.name %>"</h3>
        
        <form action="/files/<%= file._id %>/report" method="POST">
            <div class="form-group" style="margin-bottom: 20px;">
                <label for="reason" style="display: block; margin-bottom: 8px; color: var(--silver);">Reason for reporting*</label>
                <select name="reason" id="reason" required>
                    <option value="" disabled selected>Select a reason...</option>
                    <option value="malware">Contains malware/virus</option>
                    <option value="broken-file">File is broken or does not work</option>
                    <option value="incorrect-info">Description or screenshots are incorrect</option>
                    <option value="copyright">Copyright infringement</option>
                    <option value="other">Other</option>
                </select>
            </div>
            
            <div class="form-group" style="margin-bottom: 20px;">
                <label for="additionalComments" style="display: block; margin-bottom: 8px; color: var(--silver);">Additional Comments (Optional)</label>
                <textarea name="additionalComments" id="additionalComments" placeholder="Please provide more details..."></textarea>
            </div>
            
            <button type="submit" class="btn btn-primary" style="margin-top: 10px;">Submit Report</button>
        </form>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Tab Functionality
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabContents = document.querySelectorAll('.tab-content');
        tabButtons.forEach(button => {
            button.addEventListener('click', () => {
                const targetTabId = button.getAttribute('data-tab');
                tabButtons.forEach(btn => btn.classList.remove('active'));
                tabContents.forEach(content => content.classList.remove('active'));
                button.classList.add('active');
                document.getElementById(targetTabId).classList.add('active');
            });
        });

        // Report Modal JS Logic
        const modal = document.getElementById('reportModal');
        const btn = document.getElementById('reportModalBtn');
        const span = document.querySelector('.close-modal');

        if (btn) {
            btn.onclick = function() {
                if (modal) modal.style.display = 'block';
            }
        }
        if (span) {
            span.onclick = function() {
                if (modal) modal.style.display = 'none';
            }
        }
        window.onclick = function(event) {
            if (event.target == modal) {
                if (modal) modal.style.display = 'none';
            }
        }
    });
</script>

<script>
    async function refreshVTScan(fileId) {
        try {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';
            btn.disabled = true;

            const response = await fetch(`/api/refresh-vt-scan/${fileId}`, { method: 'POST' });
            const data = await response.json();

            if (data.status === 'completed') {
                // Reload the page to show the new colorful badge!
                window.location.reload();
            } else {
                alert('Scan is still ' + data.status + '. Please check back in a few minutes.');
                btn.innerHTML = '<i class="fas fa-sync-alt"></i> Check Results Now';
                btn.disabled = false;
            }
        } catch (error) {
            alert('Failed to check status.');
        }
    }
</script>

<%- include('../partials/footer') %>