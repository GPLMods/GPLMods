        <i class="fas fa-calendar-alt" style="font-size: 3em; color: var(--red); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Age Verification</h2>
        
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            This content is intended for mature audiences. Please enter your Date of Birth to confirm you are 18 or older.
        </p>
        
        <div style="margin-bottom: 20px;">
            <input type="date" id="guest-dob-input" style="padding: 12px; border-radius: 8px; border: 1px solid #444; background: var(--black); color: white; width: 100%; text-align: center; font-size: 1.1em; outline: none; color-scheme: dark;">
        </div>

        <div class="policy-buttons" style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" id="confirmAgeBtn" class="policy-button" style="background-color: var(--red); color: var(--white); border: none;">Verify</button>
            <button type="button" id="cancelAgeBtn" class="policy-button decline">Cancel</button>
        </div>
        <p id="age-error-msg" style="color: var(--red); margin-top: 15px; display: none; font-size: 0.9em; font-weight: bold;"></p>
    </div>
