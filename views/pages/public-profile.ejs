        </header>

        <section class="profile-content">
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="overview">Overview</button>
                <button class="tab-button" data-tab="uploads">Uploads</button>
                <button class="tab-button" data-tab="community">Community</button>
            </div>

            <!-- Bio Tab -->
            <div id="overview" class="tab-content active">
                <h2>About Me</h2>
                <% if (profileUser.bio) { %>
                    <p>"<%- profileUser.bio.replace(/\n/g, '<br>') %>"</p>
                <% } else { %>
                    <p>This user hasn't written a bio yet. They are a valued member of the GPL Mods community.</p>
                <% } %>
            </div>

            <!-- Uploads Tab -->
            <div id="uploads" class="tab-content">
                <h2 style="border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 20px;">Uploaded Mods</h2>
                <% if (uploads && uploads.length > 0) { %>
                    <section class="mod-grid">
                        <% uploads.forEach(file => { %>
                            <%- include('../partials/mod-card', { file: file, showUploaderInfo: false }) %>
                        <% }) %>
                    </section>
                <% } else { %>
                    <p style="color: var(--silver);"><%= profileUser.username %> hasn't uploaded any mods yet.</p>
                <% } %>
            </div>

            <!-- Community Tab (Followers/Following) -->
            <div id="community" class="tab-content">
                <div style="display: flex; flex-wrap: wrap; gap: 40px;">
                    
                    <!-- Followers List -->
                    <div style="flex: 1; min-width: 250px;">
                        <h2 style="border-bottom: 1px solid #333; padding-bottom: 10px;">Followers (<%= followersList.length %>)</h2>
                        <% if (followersList && followersList.length > 0) { %>
                            <ul style="list-style: none; padding: 0;">
                                <% followersList.forEach(follower => { %>
                                    <li style="margin-bottom: 15px;">
                                        <a href="/users/<%= slugify(follower.username) %>" style="display: flex; align-items: center; gap: 15px; text-decoration: none; color: var(--white); background: var(--dark-gray); padding: 10px; border-radius: 8px; border: 1px solid #333; transition: border-color 0.2s;">
                                            <img src="<%= follower.signedAvatarUrl %>" alt="Avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                                            <div>
                                                <strong style="display: block;"><%= follower.username %></strong>
                                                <span style="font-size: 0.8em; color: var(--silver);"><%= follower.role %></span>
                                            </div>
                                        </a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p style="color: var(--silver);">No followers yet.</p>
                        <% } %>
                    </div>

                    <!-- Following List -->
                    <div style="flex: 1; min-width: 250px;">
                        <h2 style="border-bottom: 1px solid #333; padding-bottom: 10px;">Following (<%= followingList.length %>)</h2>
                        <% if (followingList && followingList.length > 0) { %>
                            <ul style="list-style: none; padding: 0;">
                                <% followingList.forEach(followingUser => { %>
                                    <li style="margin-bottom: 15px;">
                                        <a href="/users/<%= slugify(followingUser.username) %>" style="display: flex; align-items: center; gap: 15px; text-decoration: none; color: var(--white); background: var(--dark-gray); padding: 10px; border-radius: 8px; border: 1px solid #333; transition: border-color 0.2s;">
                                            <img src="<%= followingUser.signedAvatarUrl %>" alt="Avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                                            <div>
                                                <strong style="display: block;"><%= followingUser.username %></strong>
                                                <span style="font-size: 0.8em; color: var(--silver);"><%= followingUser.role %></span>
                                            </div>
                                        </a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
