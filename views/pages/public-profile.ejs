<%- include('../partials/header') %>

<title><%= profileUser.username %> - GPL Mods</title>

<main>
    <div class="container">
        <header class="profile-header">
            <!-- Avatar with Share Button -->
            <div class="avatar-container">
                <img src="<%= profileUser.signedAvatarUrl %>" alt="<%= profileUser.username %>'s Avatar" class="profile-avatar">
                <button class="share-btn" onclick="shareProfile()" title="Share Profile">
                    <svg viewBox="0 0 24 24"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92c0-1.61-1.31-2.92-2.92-2.92z"/></svg>
                </button>
            </div>

            <h1><%= profileUser.username %></h1>
            <p class="user-role"><%= profileUser.role.charAt(0).toUpperCase() + profileUser.role.slice(1) %></p>
            
            <!-- ======== NEW: FOLLOW BUTTON ======== -->
            <% if (user && user._id.toString() !== profileUser._id.toString()) { %>
                <form action="/users/<%= profileUser._id %>/follow" method="POST" style="margin-bottom: 20px;">
                    <% if (isFollowing) { %>
                        <button type="submit" class="btn btn-secondary" style="border-color: var(--silver); color: var(--silver);">Unfollow</button>
                    <% } else { %>
                        <button type="submit" class="btn btn-primary" style="box-shadow: 0 0 10px var(--glow-gold);">Follow</button>
                    <% } %>
                </form>
            <% } else if (!user) { %>
                <!-- ✅ FIX 2: Styled the Login to Follow button -->
                <a href="/login" class="btn" style="margin-bottom: 20px; display: inline-block; background: transparent; border: 2px solid var(--silver); color: var(--silver); padding: 10px 25px; border-radius: 20px;">Login to Follow</a>
            <% } %>

            <div class="profile-stats">
                <div class="stat-item">
                    <div class="stat-number"><%= uploads.length %></div>
                    <div class="stat-label">Uploads</div>
                </div>
                <!-- ======== NEW: FOLLOW STATS ======== -->
                <div class="stat-item">
                    <div class="stat-number"><%= profileUser.followers.length %></div>
                    <div class="stat-label">Followers</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number"><%= profileUser.following.length %></div>
                    <div class="stat-label">Following</div>
                </div>
                <!-- ==================================== -->
                <div class="stat-item">
                    <div class="stat-number"><%= timeAgo(profileUser.lastSeen) %></div>
                    <div class="stat-label">Last Online</div>
                </div>
            </div>
        </header>

        <section class="profile-content">
            <div class="tabs-nav">
                <button class="tab-button active" data-tab="overview">Overview</button>
                <button class="tab-button" data-tab="uploads">Uploads</button>
                <!-- NEW TAB -->
                <button class="tab-button" data-tab="community">Community</button>
            </div>

            <!-- Bio Tab -->
            <div id="overview" class="tab-content active">
                <h2>About Me</h2>
                <% if (profileUser.bio) { %>
                    <p>"<%- profileUser.bio.replace(/\n/g, '<br>') %>"</p>
                <% } else { %>
                    <p>This user hasn't written a bio yet. They are a valued member of the GPL Mods community.</p>
                <% } %>
            </div>

            <!-- Uploads Tab -->
            <div id="uploads" class="tab-content">
                <h2>Uploaded Mods</h2>
                <% if (uploads && uploads.length > 0) { %>
                    <div class="mod-grid">
                        <% uploads.forEach(file => { %>
                            
                            <!-- UNIVERSAL MOD CARD -->
                           <a href="/<%= file.category %>/<%= file.slug || file._id %>" class="mod-card-link">
                                <div class="mod-card">
                                    
                                    <!-- Certification Tag -->
                                    <% if (file.certification === 'certified') { %>
                                        <div class="app-feature-tag">✔ Certified</div>
                                    <% } else if (file.certification === 'community-tested') { %>
                                        <div class="app-feature-tag" style="background-color: var(--silver);">Community Tested</div>
                                    <% } %>
                                    
                                    <!-- Version Tag -->
                                    <div class="mod-type-tag"><%= file.version %></div>
                                    
                                    <!-- Image Container Logic (Prevents Cropping) -->
                                    <div class="mod-card-image">
                                        <img src="<%= file.iconUrl %>" alt="<%= file.name %>">
                                    </div>
                                    
                                    <div class="mod-card-content">
                                        <h3><%= file.name %></h3>
                                        <p><%= file.modDescription.substring(0, 50) %>...</p> 
                                        
                                        <!-- Star Rating -->
                                        <div class="rating" style="margin-bottom: 10px;">
                                            <div class="stars-outer">
                                                <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                                            </div>
                                            <span class="rating-text"><%= file.averageRating.toFixed(1) %></span>
                                        </div>

                                        <!-- Platform Tag -->
                                        <div class="card-footer">
                                            <span class="platform-tag <%= file.category.replace('-jailed', '-ipa').replace('-jailbroken', '-deb') %>">
                                                <%= file.category.toUpperCase().replace('-', ' ') %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                            <!-- END UNIVERSAL MOD CARD -->

                        <% }) %>
                    </div>
                <% } else { %>
                    <p><%= profileUser.username %> hasn't uploaded any mods yet.</p>
                <% } %>
            </div>

            <!-- ======== NEW: Community Tab (Followers/Following) ======== -->
            <div id="community" class="tab-content">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
                    
                    <!-- Followers List -->
                    <div>
                        <h2 style="border-bottom: 1px solid #333; padding-bottom: 10px;">Followers (<%= profileUser.followers.length %>)</h2>
                        <% if (profileUser.followers.length > 0) { %>
                            <ul style="list-style: none; padding: 0;">
                                <% profileUser.followers.forEach(follower => { %>
                                    <li style="margin-bottom: 15px;">
                                        <a href="/users/<%= follower.username %>" style="display: flex; align-items: center; gap: 15px; text-decoration: none; color: var(--white); background: var(--dark-gray); padding: 10px; border-radius: 8px; border: 1px solid #333; transition: border-color 0.2s;">
                                            <!-- Assuming you have a fallback for missing avatars in the UI -->
                                            <img src="/images/default-avatar.png" style="width: 40px; height: 40px; border-radius: 50%;">
                                            <div>
                                                <strong style="display: block;"><%= follower.username %></strong>
                                                <span style="font-size: 0.8em; color: var(--silver);"><%= follower.role %></span>
                                            </div>
                                        </a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p style="color: var(--silver);">No followers yet.</p>
                        <% } %>
                    </div>

                    <!-- Following List -->
                    <div>
                        <h2 style="border-bottom: 1px solid #333; padding-bottom: 10px;">Following (<%= profileUser.following.length %>)</h2>
                        <% if (profileUser.following.length > 0) { %>
                            <ul style="list-style: none; padding: 0;">
                                <% profileUser.following.forEach(followingUser => { %>
                                    <li style="margin-bottom: 15px;">
                                        <a href="/users/<%= followingUser.username %>" style="display: flex; align-items: center; gap: 15px; text-decoration: none; color: var(--white); background: var(--dark-gray); padding: 10px; border-radius: 8px; border: 1px solid #333; transition: border-color 0.2s;">
                                            <img src="/images/default-avatar.png" style="width: 40px; height: 40px; border-radius: 50%;">
                                            <div>
                                                <strong style="display: block;"><%= followingUser.username %></strong>
                                                <span style="font-size: 0.8em; color: var(--silver);"><%= followingUser.role %></span>
                                            </div>
                                        </a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p style="color: var(--silver);">Not following anyone yet.</p>
                        <% } %>
                    </div>

                </div>
            </div>

        </section> <!-- Properly closing the profile-content section here -->
    </div>
</main>

<script>
    // Tab Functionality
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(button => {
        button.addEventListener('click', () => {
            const targetTabId = button.getAttribute('data-tab');
            tabButtons.forEach(btn => btn.classList.remove('active'));
            tabContents.forEach(content => content.classList.remove('active'));
            button.classList.add('active');
            document.getElementById(targetTabId).classList.add('active');
        });
    });

    // Share Profile Function
    function shareProfile() {
        if (navigator.share) {
            navigator.share({
                title: '<%= profileUser.username %>\'s Profile on GPL Mods',
                text: 'Check out <%= profileUser.username %> on GPL Mods!',
                url: window.location.href
            }).then(() => console.log('Successful share'))
            .catch((error) => console.log('Error sharing', error));
        } else {
            alert("Profile link copied to clipboard: " + window.location.href);
            navigator.clipboard.writeText(window.location.href);
        }
    }
</script>
<%- include('../partials/video-ad-modal') %>
<%- include('../partials/footer') %>