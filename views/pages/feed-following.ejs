<%- include('../partials/header') %>

<main>
    <section class="page-header" style="border-bottom: 1px solid var(--dark-gray); padding-bottom: 30px;">
        <div class="container">
            <h1 style="font-size: 2.5em; color: var(--white); margin-bottom: 10px;">
                <i class="fas fa-users" style="color: var(--blue); margin-right: 15px;"></i>Following <span style="color: var(--blue); text-shadow: 0 0 15px rgba(33, 150, 243, 0.5);">Updates</span>
            </h1>
            <p style="color: var(--silver); font-size: 1.1em;">The latest mods and updates from the creators you follow.</p>
        </div>
    </section>

    <div class="container" style="margin-top: 40px; margin-bottom: 60px;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <a href="/notifications" class="btn btn-secondary" style="border-color: #333; color: var(--silver);">
                <i class="fas fa-arrow-left"></i> Back to Hub
            </a>
            <span style="color: var(--silver); font-weight: bold;"><%= files.length %> Recent Activities</span>
        </div>

        <% if (files && files.length > 0) { %>
            <section class="mod-grid">
                <% files.forEach(file => { %>
                    <!-- UNIVERSAL MOD CARD -->
                    <a href="/<%= file.category %>/<%= file.slug || file._id %>" class="mod-card-link">
                        <div class="mod-card" style="border-color: rgba(33, 150, 243, 0.2);">
                            
                            <% if (file.certification === 'certified') { %>
                                <div class="app-feature-tag">✔ Certified</div>
                            <% } else if (file.certification === 'community-tested') { %>
                                <div class="app-feature-tag" style="background-color: var(--silver);">Community Tested</div>
                            <% } %>
                            
                            <div class="mod-type-tag"><%= file.version %></div>
                            
                            <div class="mod-card-image">
                                <img src="<%= file.iconUrl %>" alt="<%= file.name %>">
                            </div>
                            
                            <div class="mod-card-content">
                                <h3><%= file.name %></h3>
                                
                                <p style="margin-bottom: 10px; border-bottom: 1px solid #333; padding-bottom: 10px;">
                                    <span style="color: var(--silver); font-size: 0.85em;">By: </span>
                                    <!-- Highlight the followed user's name in Blue -->
                                    <strong style="color: var(--blue);">
                                        <a href="/users/<%= slugify(file.uploader) %>" style="color: inherit; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'"><%= file.uploader %></a>
                                    </strong><br>
                                    <span style="color: var(--silver); font-size: 0.8em; font-style: italic;"><%= timeAgo(file.updatedAt) %></span>
                                </p>
                                
                                <div class="rating" style="margin-bottom: 10px;">
                                    <div class="stars-outer">
                                        <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                                    </div>
                                    <span class="rating-text"><%= file.averageRating.toFixed(1) %></span>
                                </div>

                                <div class="card-footer">
                                    <span class="platform-tag <%= file.category.replace('-jailed', '-ipa').replace('-jailbroken', '-deb') %>">
                                        <%= file.category.toUpperCase().replace('-', ' ') %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </section>
        <% } else { %>
            <div style="text-align: center; padding: 60px 20px; background-color: var(--dark-gray); border-radius: 15px; border: 1px solid #333;">
                <!-- ======== CUSTOM LOTTIE ADD USER ANIMATION (PLAY ONCE) ======== -->
            <lottie-player 
                src="/animations/add-user.json" 
                background="transparent" 
                speed="1" 
                style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(192, 192, 192, 0.5));" 
               autoplay>
            </lottie-player>
            <!-- ========================================================== -->
                <h2 style="color: var(--white); margin-bottom: 10px;">Your Feed is Empty</h2>
                <p style="color: var(--silver); font-size: 1.1em;">You aren't following anyone yet, or the people you follow haven't posted anything recently.</p>
                <p style="color: #888; font-size: 0.9em; margin-top: 10px;">Go to a member's profile and click "Follow" to see their updates here!</p>
            </div>
        <% } %>
    </div>
</main>
<%- include('../partials/video-ad-modal') %>
<%- include('../partials/footer') %>