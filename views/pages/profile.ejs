<%- include('../partials/header') %>    

<style>
    /* Custom Dropdown Styles (Reused from forum-ask) */
    .custom-select-wrapper { position: relative; user-select: none; width: 100%; }
    .custom-select { position: relative; display: flex; flex-direction: column; background: var(--black); border: 1px solid #333; border-radius: 8px; cursor: pointer; padding: 12px 15px; color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; transition: border-color 0.3s; }
    .custom-select-wrapper.open .custom-select { border-color: var(--gold); border-bottom-left-radius: 0; border-bottom-right-radius: 0; box-shadow: 0 0 10px rgba(255, 215, 0, 0.3); }
    .custom-select-arrow { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); transition: transform 0.3s; color: var(--silver); }
    .custom-select-wrapper.open .custom-select-arrow { transform: translateY(-50%) rotate(180deg); color: var(--gold); }
    .custom-options { position: absolute; display: none; top: 100%; left: 0; right: 0; background: var(--black); border: 1px solid var(--gold); border-top: none; border-radius: 0 0 8px 8px; z-index: 20; max-height: 250px; overflow-y: auto; box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
    .custom-select-wrapper.open .custom-options { display: block; }
    .custom-option { padding: 12px 15px; color: var(--silver); cursor: pointer; transition: all 0.2s; font-family: 'Poppins', sans-serif; }
    .custom-option:hover { background-color: rgba(255, 215, 0, 0.1); color: var(--white); }
    .custom-option.selected { color: var(--gold); font-weight: bold; }
    
    /* Layout Adjustments */
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); }
    .email-note { font-size: 0.85rem; color: #ffadad; margin-top: 8px; font-style: italic; }
</style>

<main>
    <div class="page-header">
        <div class="container">
            <h1>Edit <span>Your Profile</span></h1>
        </div>
    </div>
    
    <div class="container">
        
        <!-- ✅ ADDED: Dynamic Back Button -->
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-block; margin-bottom: 20px; font-weight: 600; transition: color 0.3s;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Back
        </a>

        <div class="edit-profile-layout">
            <!-- Profile Details Form -->
            <section class="form-section">
                
                <form action="/account/update-profile-image" method="POST" enctype="multipart/form-data" class="avatar-section" id="avatar-form">
                    <div class="avatar-preview-wrapper" style="position: relative; margin: 0 auto 20px auto; width: 150px; height: 150px;">
                        <img src="<%= user.signedAvatarUrl %>" alt="Avatar Preview" class="avatar-preview" id="avatar-preview"
                             style="border-color: <%= user.forumRank ? user.forumRank.color : 'var(--silver)' %>; box-shadow: 0 0 25px <%= user.forumRank ? user.forumRank.color : 'transparent' %>;">
                        
                        <label for="avatar-input" class="avatar-edit-button" title="Change Avatar" style="z-index: 11;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="var(--black)">
                                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                            </svg>
                        </label>
                        <input type="file" id="avatar-input" name="profileImage" accept="image/png, image/jpeg">
                    </div>
                    <button type="submit" id="save-avatar-btn" class="submit-button secondary-button" style="margin-bottom: 20px; display: none;">Save New Avatar</button>
                </form>

                <% if (user.forumRank && user.forumRank.lottie) { %>
                    <div style="display: flex; justify-content: center; align-items: center; margin-bottom: 5px;">
                        <lottie-player src="/animations/<%= user.forumRank.lottie %>" background="transparent" speed="1" style="width: 70px; height: 70px; filter: drop-shadow(0 0 10px <%= user.forumRank.color %>);" loop autoplay></lottie-player>
                    </div>
                <% } %>

                <h3 class="current-username notranslate" style="text-align: center; margin-bottom: 5px; font-size: 2em;"><%= user.username %></h3>
                <p style="text-align: center; color: <%= user.forumRank ? user.forumRank.color : 'var(--silver)' %>; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; font-size: 0.85em; margin-bottom: 30px; text-shadow: 0 0 10px <%= user.forumRank ? user.forumRank.color : 'transparent' %>;">
                    <%= user.forumRank ? user.forumRank.name : 'Novice' %> (<i class="fas fa-star" style="font-size: 0.9em;"></i> <%= user.forumPoints || 0 %> pts)
                </p>

                <form action="/account/update-details" method="POST">
                    
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" name="username" value="<%= user.username %>" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="bio">Your Bio</label>
                        <textarea id="bio" name="bio" placeholder="Tell us a little about yourself..."><%= user.bio || '' %></textarea>
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" required>
                         <p class="email-note"><i class="fas fa-exclamation-triangle"></i> Changing your email will require re-verification and log you out.</p>
                    </div>

                    <div class="form-group">
                        <label for="dateOfBirth">Date of Birth</label>
                        <input type="date" id="dateOfBirth" name="dateOfBirth" value="<%= user.dateOfBirth ? new Date(user.dateOfBirth).toISOString().split('T')[0] : '' %>" style="width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; color-scheme: dark;">
                        <p style="font-size: 0.8rem; color: var(--silver); margin-top: 5px;">Required to access 18+ content.</p>
                    </div>

                    <!-- ======== CUSTOM COUNTRY SELECTOR ======== -->
                    <div class="form-group">
                        <label for="country">Country (Optional)</label>
                        
                        <!-- Hidden native select for form submission -->
                        <select id="country" name="country" style="display: none;">
                            <option value="" <%= !user.country ? 'selected' : '' %>>Select your country...</option>
                            <option value="US" <%= user.country === 'US' ? 'selected' : '' %>>United States 🇺🇸</option>
                            <option value="IN" <%= user.country === 'IN' ? 'selected' : '' %>>India 🇮🇳</option>
                            <option value="GB" <%= user.country === 'GB' ? 'selected' : '' %>>United Kingdom 🇬🇧</option>
                            <option value="BR" <%= user.country === 'BR' ? 'selected' : '' %>>Brazil 🇧🇷</option>
                            <option value="ID" <%= user.country === 'ID' ? 'selected' : '' %>>Indonesia 🇮🇩</option>
                            <option value="RU" <%= user.country === 'RU' ? 'selected' : '' %>>Russia 🇷🇺</option>
                            <option value="GLOBAL" <%= user.country === 'GLOBAL' ? 'selected' : '' %>>Earth 🌍</option>
                        </select>

                        <!-- Custom UI Wrapper -->
                        <div class="custom-select-wrapper" id="wrapper-country">
                            <div class="custom-select">
                                <span class="selected-text">
                                    <% 
                                        let currentDisplay = 'Select your country...';
                                        if (user.country === 'US') currentDisplay = 'United States 🇺🇸';
                                        if (user.country === 'IN') currentDisplay = 'India 🇮🇳';
                                        if (user.country === 'GB') currentDisplay = 'United Kingdom 🇬🇧';
                                        if (user.country === 'BR') currentDisplay = 'Brazil 🇧🇷';
                                        if (user.country === 'ID') currentDisplay = 'Indonesia 🇮🇩';
                                        if (user.country === 'RU') currentDisplay = 'Russia 🇷🇺';
                                        if (user.country === 'GLOBAL') currentDisplay = 'Earth 🌍';
                                    %>
                                    <%= currentDisplay %>
                                </span>
                                <i class="fas fa-chevron-down custom-select-arrow"></i>
                            </div>
                            <div class="custom-options">
                                <div class="custom-option <%= user.country === 'US' ? 'selected' : '' %>" data-value="US">United States 🇺🇸</div>
                                <div class="custom-option <%= user.country === 'IN' ? 'selected' : '' %>" data-value="IN">India 🇮🇳</div>
                                <div class="custom-option <%= user.country === 'GB' ? 'selected' : '' %>" data-value="GB">United Kingdom 🇬🇧</div>
                                <div class="custom-option <%= user.country === 'BR' ? 'selected' : '' %>" data-value="BR">Brazil 🇧🇷</div>
                                <div class="custom-option <%= user.country === 'ID' ? 'selected' : '' %>" data-value="ID">Indonesia 🇮🇩</div>
                                <div class="custom-option <%= user.country === 'RU' ? 'selected' : '' %>" data-value="RU">Russia 🇷🇺</div>
                                <div class="custom-option <%= user.country === 'GLOBAL' ? 'selected' : '' %>" data-value="GLOBAL">Earth 🌍</div>
                            </div>
                        </div>
                    </div>
                    <!-- ======================================= -->

                    <button type="submit" class="submit-button" style="margin-top: 30px;">Save Profile Changes</button>
                </form>
            </section>
            <!-- Change Password Form -->
            <section class="form-section">
                <% if (user.password) { %>
                    <h2>Change Password</h2>
                    <form action="/account/change-password" method="POST">
                        <div class="form-group">
                            <label for="current-password">Current Password</label>
                            <input type="password" id="current-password" name="currentPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="new-password">New Password</label>
                            <input type="password" id="new-password" name="newPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="confirm-password">Confirm New Password</label>
                            <input type="password" id="confirm-password" name="confirmPassword" required>
                        </div>
                        <button type="submit" class="submit-button secondary-button">Update Password</button>
                    </form>
                <% } else { %>
                    <h2>Set Local Password</h2>
                    <p style="color: var(--silver); margin-bottom: 15px; font-size: 0.9em;">Since you signed up with a social account, you can set a password here to allow logging in with your email directly.</p>
                    <form action="/account/change-password" method="POST">
                        <input type="hidden" name="currentPassword" value="social_login_bypass">
                        <div class="form-group">
                            <label for="new-password">Set New Password</label>
                            <input type="password" id="new-password" name="newPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="confirm-password">Confirm Password</label>
                            <input type="password" id="confirm-password" name="confirmPassword" required>
                        </div>
                        <button type="submit" class="submit-button secondary-button">Set Password</button>
                    </form>
                <% } %>
            </section>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- Custom Dropdown Logic ---
        const wrapper = document.getElementById('wrapper-country');
        const nativeSelect = document.getElementById('country');
        
        if (wrapper && nativeSelect) {
            const customSelect = wrapper.querySelector('.custom-select');
            const selectedText = wrapper.querySelector('.selected-text');
            const optionsContainer = wrapper.querySelector('.custom-options');

            customSelect.addEventListener('click', (e) => {
                wrapper.classList.toggle('open');
                e.stopPropagation(); 
            });

            optionsContainer.addEventListener('click', (e) => {
                const optionEl = e.target.closest('.custom-option');
                if (!optionEl) return;
                
                // Update UI text
                selectedText.textContent = optionEl.textContent;
                // Update hidden select value
                nativeSelect.value = optionEl.getAttribute('data-value');
                
                // Update styling
                wrapper.querySelectorAll('.custom-option').forEach(opt => opt.classList.remove('selected'));
                optionEl.classList.add('selected');
                wrapper.classList.remove('open');
            });

            // Close dropdown if clicking outside
            document.addEventListener('click', () => {
                wrapper.classList.remove('open');
            });
        }

        // --- Live Avatar Preview Logic ---
        const avatarInput = document.getElementById('avatar-input');
        const avatarPreview = document.getElementById('avatar-preview');
        const saveAvatarBtn = document.getElementById('save-avatar-btn');
        const avatarForm = document.getElementById('avatar-form');

        avatarInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => { 
                    avatarPreview.src = e.target.result; 
                    saveAvatarBtn.style.display = 'block'; 
                }
                reader.readAsDataURL(this.files[0]);
            } else {
                 saveAvatarBtn.style.display = 'none';
            }
        });
        
        if(avatarForm) {
            avatarForm.addEventListener('submit', function() {
                 saveAvatarBtn.disabled = true;
                 saveAvatarBtn.textContent = 'Uploading...';
            });
        }
    });
</script>

<%- include('../partials/footer') %>