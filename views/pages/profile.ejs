<%- include('../partials/header') %>    

<main>
    <div class="page-header">
        <div class="container">
            <h1>Edit <span>Your Profile</span></h1>
        </div>
    </div>
    
    <div class="container">
        <div class="edit-profile-layout">
            <!-- Profile Details Form -->
            <section class="form-section">
                <h2>Profile Details</h2>
                
                <!-- ✅ ADDED: The Missing Public Profile Link -->
                <p style="text-align: center; font-size: 0.9em; color: var(--silver); margin-bottom: 20px;">
                    Your public profile is available at:<br>
                    <a href="/users/<%= slugify(user.username) %>" target="_blank" style="color: var(--gold); text-decoration: underline;">
                        gplmods.webredirect.org/users/<%= slugify(user.username) %>
                    </a>
                </p>

                <form action="/account/update-profile-image" method="POST" enctype="multipart/form-data" class="avatar-section" id="avatar-form">
                    <div class="avatar-preview-wrapper">
                        <img src="<%= user.signedAvatarUrl %>" alt="Avatar Preview" class="avatar-preview" id="avatar-preview">
                        
                        <label for="avatar-input" class="avatar-edit-button" title="Change Avatar">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="var(--black)">
                                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                            </svg>
                        </label>
                        <input type="file" id="avatar-input" name="profileImage" accept="image/png, image/jpeg">
                    </div>
                    
                    <button type="submit" id="save-avatar-btn" class="submit-button secondary-button" style="margin-bottom: 20px; display: none;">Save New Avatar</button>
                </form>

                <h3 class="current-username" style="text-align: center;"><%= user.username %></h3>
                <div class="profile-actions">
                    <a href="/my-uploads" class="submit-button secondary-button" style="text-align: center; text-decoration: none;">View Your Mod Upload History</a>
                    <a href="/users/<%= slugify(user.username) %>" class="submit-button secondary-button" style="text-align: center; text-decoration: none;">View Your Public User Profile</a>
                    
                    <button type="button" id="logout-btn" class="submit-button" style="text-align: center; text-decoration: none; background: transparent; border: 2px solid var(--red); color: var(--red); box-shadow: none; margin-top: 10px; font-family: inherit; cursor: pointer;">
                        <i class="fas fa-sign-out-alt" style="margin-right: 8px;"></i> Log Out Securely
                    </button>
                </div>
                
                <hr style="border-color: #333; margin: 30px 0;">

                <form action="/account/update-details" method="POST">
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" name="username" value="<%= user.username %>" required>
                    </div>
                    <div class="form-group">
                        <label for="bio">Your Bio</label>
                        <textarea id="bio" name="bio" placeholder="Tell us a little about yourself..."><%= user.bio || '' %></textarea>
                    </div>
                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" required>
                         <p class="email-note">Note: Changing your email will require re-verification and you will be logged out.</p>
                    </div>
                    <button type="submit" class="submit-button">Save Profile Changes</button>
                </form>
            </section>

            <!-- Change Password Form -->
            <section class="form-section">
                <% if (user.password) { %>
                    <h2>Change Password</h2>
                    <form action="/account/change-password" method="POST">
                        <div class="form-group">
                            <label for="current-password">Current Password</label>
                            <input type="password" id="current-password" name="currentPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="new-password">New Password</label>
                            <input type="password" id="new-password" name="newPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="confirm-password">Confirm New Password</label>
                            <input type="password" id="confirm-password" name="confirmPassword" required>
                        </div>
                        <button type="submit" class="submit-button secondary-button">Update Password</button>
                    </form>
                <% } else { %>
                    <h2>Set Local Password</h2>
                    <p style="color: var(--silver); margin-bottom: 15px; font-size: 0.9em;">Since you signed up with a social account, you can set a password here to allow logging in with your email directly.</p>
                    <form action="/account/change-password" method="POST">
                        <input type="hidden" name="currentPassword" value="social_login_bypass">
                        <div class="form-group">
                            <label for="new-password">Set New Password</label>
                            <input type="password" id="new-password" name="newPassword" required>
                        </div>
                        <div class="form-group">
                            <label for="confirm-password">Confirm Password</label>
                            <input type="password" id="confirm-password" name="confirmPassword" required>
                        </div>
                        <button type="submit" class="submit-button secondary-button">Set Password</button>
                    </form>
                <% } %>
            </section>

 <!-- ======== NEW: WHITELIST / FAVORITES SECTION ======== -->
            <section class="form-section" style="grid-column: 1 / -1; padding-bottom: 40px;">
                <h2>Your Whitelist</h2>
                <p style="color: var(--silver); margin-bottom: 20px;">Mods you have saved for later.</p>
                
                <% if (user.whitelist && user.whitelist.length > 0) { %>
                    <!-- Reusing the horizontal carousel from the homepage -->
                    <div class="mod-carousel" style="padding-bottom: 20px;">
                        <% user.whitelist.forEach(file => { %>
                            
                            <div class="mod-card" style="flex: 0 0 250px; max-width: 250px;">
                                
                                <% if (file.certification === 'certified') { %>
                                    <div class="app-feature-tag">✔ Certified</div>
                                <% } else if (file.certification === 'community-tested') { %>
                                    <div class="app-feature-tag" style="background-color: var(--silver);">Community Tested</div>
                                <% } %>
                                
                                <div class="mod-type-tag"><%= file.version %></div>
                                
                                <div class="mod-card-image">
                                    <img src="<%= file.iconUrl %>" alt="<%= file.name %>">
                                </div>
                                
                                <div class="mod-card-content">
                                    <h3>
                                        <a href="/<%= file.category %>/<%= file.slug || file._id %>" class="full-card-link"><%= file.name %></a>
                                    </h3>
                                    <p><%= file.developer %></p>
                                    <div class="rating">
                                        <div class="stars-outer">
                                            <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                                        </div>
                                        <span class="rating-text"><%= file.averageRating.toFixed(1) %></span>
                                    </div>
                                    
                                    <div class="card-footer">
                                        <span class="platform-tag <%= file.category.replace('-jailed', '-ipa').replace('-jailbroken', '-deb') %>">
                                            <%= file.category.toUpperCase().replace('-', ' ') %>
                                        </span>
                                    </div>
                                </div>
                                
                                <div class="download-overlay">
                                    <a href="/<%= file.category %>/<%= file.slug || file._id %>" class="overlay-button overlay-btn-primary" style="position: relative; z-index: 10;">View Mod</a>
                                    <form action="/files/<%= file._id %>/whitelist" method="POST" style="margin: 0; width: 100%; position: relative; z-index: 10;">
                                        <button type="submit" class="overlay-button overlay-btn-secondary" style="width: 100%; border: none; cursor: pointer; font-family: inherit; color: var(--red); border-color: var(--red);">
                                            Remove from Whitelist
                                        </button>
                                    </form>
                                </div>
                            </div>
                            
                        <% }) %>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 40px; background: rgba(0,0,0,0.2); border-radius: 12px; border: 1px dashed #444;">
                        <!-- ======== CUSTOM LOTTIE BROKEN HEART ANIMATION ======== -->
            <lottie-player 
                src="/animations/broken-heart.json" 
                background="transparent" 
                speed="1" 
                style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(225, 225, 0, 0.5));" 
               loop autoplay>
            </lottie-player>
            <!-- ========================================================== -->
                        <h3 style="color: var(--silver);">Your Whitelist is Empty</h3>
                        <p style="color: #777; font-size: 0.9em;">Explore the site and click "Add to Whitelist" on any mod to save it here!</p>
                    </div>
                <% } %>
            </section>

            <!-- Danger Zone for Deleting Account -->
            <section class="form-section danger-zone">
                <h2>Danger Zone</h2>
                <p>Deleting your account is a permanent action. All of your uploaded mods, comments, and personal data will be removed forever. This action cannot be undone.</p>
                <form action="/account/delete" method="POST" id="delete-account-form">
                    
                    <div class="checkbox-group" style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px;">
                        <label class="switch">
                            <input type="checkbox" id="preserve-mods" name="preserveMods" value="true">
                            <span class="slider round"></span>
                        </label>
                        <label for="preserve-mods" style="margin-bottom: 0; cursor: pointer; color: var(--white);">Preserve my uploaded mods.</label>
                    </div>
                    
                    <p>If checked, your uploads will remain on the site and the author will be changed to "GPL Community". Otherwise, all your uploads will be deleted with your account.</p>
                    
                    <!-- Moved the button OUTSIDE the checkbox group -->
                    <button type="submit" class="submit-button delete-button" style="margin-top: 20px;">Delete My Account</button>
                </form>
            </section>
        </div>
    </div>
</main>

<!-- ======== CUSTOM LOGOUT MODAL ======== -->
<div id="logout-modal-container" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); color: var(--white); padding: 30px; text-align: center; border-radius: 15px; max-width: 400px; width: 90%; border-top: 3px solid var(--gold); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        
        <i class="fas fa-sign-out-alt" style="font-size: 3em; color: var(--gold); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Ready to leave?</h2>
        
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            Are you sure you want to log out of your account? You will need to enter your credentials next time you visit.
        </p>
        
        <div class="policy-buttons" style="display: flex; gap: 15px; justify-content: center;">
            <a href="/logout" class="policy-button" style="background-color: var(--gold); color: var(--black); padding: 10px 25px; border-radius: 20px; font-weight: bold; text-decoration: none; cursor: pointer; font-size: 1em; box-shadow: 0 0 15px var(--glow-gold);">Yes, Log Out</a>
            <button type="button" class="policy-button decline" id="cancelLogoutBtn" style="background-color: transparent; color: var(--silver); border: 2px solid var(--silver); padding: 10px 25px; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 1em;">Cancel</button>
        </div>
    </div>
</div>

<!-- ======== CUSTOM DELETE MODAL ======== -->
<div id="delete-modal-container" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); color: var(--white); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--red); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <h2 style="color: var(--red); margin-bottom: 15px;">Delete Account?</h2>
        <p style="margin-bottom: 20px; color: var(--silver); line-height: 1.6;">
            Are you absolutely sure you want to delete your account? This is a permanent action and cannot be undone.
        </p>
        <div class="policy-buttons" style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" class="policy-button" id="confirmDeleteBtn" style="background-color: var(--red); color: var(--white); padding: 10px 25px; border-radius: 20px; font-weight: bold; border: none; cursor: pointer; font-size: 1em; box-shadow: 0 0 15px var(--glow-red);">Yes, Delete</button>
            <button type="button" class="policy-button decline" id="cancelDeleteBtn" style="background-color: transparent; color: var(--silver); border: 2px solid var(--silver); padding: 10px 25px; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 1em;">Cancel</button>
        </div>
    </div>
</div>

<script>
    // ✅ FIX: ENTIRE SCRIPT IS NOW PROPERLY NESTED INSIDE ONE DOMContentLoaded FUNCTION
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- 1. Live Avatar Preview Logic ---
        const avatarInput = document.getElementById('avatar-input');
        const avatarPreview = document.getElementById('avatar-preview');
        const saveAvatarBtn = document.getElementById('save-avatar-btn');
        const avatarForm = document.getElementById('avatar-form');

        avatarInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => { 
                    avatarPreview.src = e.target.result; 
                    saveAvatarBtn.style.display = 'block'; 
                }
                reader.readAsDataURL(this.files[0]);
            } else {
                 saveAvatarBtn.style.display = 'none';
            }
        });
        
        if(avatarForm) {
            avatarForm.addEventListener('submit', function() {
                 saveAvatarBtn.disabled = true;
                 saveAvatarBtn.textContent = 'Uploading...';
            });
        }

        // --- 2. Custom Delete Account Modal Logic ---
        const deleteForm = document.getElementById('delete-account-form');
        const deleteModal = document.getElementById('delete-modal-container');
        const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
        const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');

        if (deleteForm && deleteModal) {
            deleteForm.addEventListener('submit', function(e) {
                e.preventDefault(); 
                deleteModal.style.display = 'flex';
                setTimeout(() => { deleteModal.classList.add('show'); }, 10);
            });

            cancelDeleteBtn.addEventListener('click', function() {
                deleteModal.classList.remove('show');
                setTimeout(() => { deleteModal.style.display = 'none'; }, 200); 
            });

            confirmDeleteBtn.addEventListener('click', function() {
                deleteForm.submit(); 
            });
        }

        // --- 3. CUSTOM LOGOUT MODAL LOGIC ---
        const logoutBtn = document.getElementById('logout-btn');
        const logoutModal = document.getElementById('logout-modal-container');
        const cancelLogoutBtn = document.getElementById('cancelLogoutBtn');

        if (logoutBtn && logoutModal) {
            logoutBtn.addEventListener('click', function(e) {
                e.preventDefault(); 
                logoutModal.style.display = 'flex';
                setTimeout(() => { logoutModal.classList.add('show'); }, 10);
            });

            cancelLogoutBtn.addEventListener('click', function() {
                logoutModal.classList.remove('show');
                setTimeout(() => { logoutModal.style.display = 'none'; }, 200);
            });

            window.addEventListener('click', function(event) {
                if (event.target === logoutModal) cancelLogoutBtn.click();
                if (event.target === deleteModal) cancelDeleteBtn.click();
            });
        }
        
    });
</script>

<%- include('../partials/footer') %>