                                const [code, name] = line.split('|');
                                return { code: code.trim(), name: name.trim() };
                            });
                            function flagEmoji(code) {
                                if (!code || code.length !== 2) return '';
                                return String.fromCodePoint(...code.toUpperCase().split('').map(c => 0x1F1E6 + c.charCodeAt(0) - 65));
                            }
                            const selectedCountry = countries.find(c => c.code === user.country);
                            const displayCountry = selectedCountry ? `${selectedCountry.name} ${selectedCountry.code === 'GLOBAL' ? '🌍' : flagEmoji(selectedCountry.code)}` : 'Select your country...';
                        %>
                        
                        <!-- Hidden native select for form submission -->
                        <select id="country" name="country" style="display: none;">
                            <option value="" <%= !user.country ? 'selected' : '' %>>Select your country...</option>
                            <% countries.forEach(country => { %>
                                <option value="<%= country.code %>" <%= user.country === country.code ? 'selected' : '' %>><%= country.name %> <%= country.code === 'GLOBAL' ? '🌍' : flagEmoji(country.code) %></option>
                            <% }) %>
                        </select>

                        <!-- Custom UI Wrapper -->
                        <div class="custom-select-wrapper" id="wrapper-country">
                            <div class="custom-select">
                                <span class="selected-text"><%= displayCountry %></span>
                                <i class="fas fa-chevron-down custom-select-arrow"></i>
                            </div>
                            <div class="custom-options">
                                <% countries.forEach(country => { %>
                                    <div class="custom-option <%= user.country === country.code ? 'selected' : '' %>" data-value="<%= country.code %>"><%= country.name %> <%= country.code === 'GLOBAL' ? '🌍' : flagEmoji(country.code) %></div>
