<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - GPL Mods</title>
    
    <!-- Fonts and Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    
    <!-- ✅ ADDED: Global Stylesheet for Footer & Common Styles -->
    <link rel="stylesheet" href="/css/style.css">
<!-- ✅ FIX 6: Ensure FontAwesome is included so footer icons render! -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Dynamic reCAPTCHA Script -->
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    
    <style>
        /* Local overrides for the Auth Page */
        :root {
            --error: #ff4d4d;
            --success: #2ecc71;
        }

        /* ✅ FIXED: Changed body layout so the footer stays at the bottom */
        body { 
            font-family: 'Poppins', sans-serif; 
            background-color: var(--black); 
            color: var(--white); 
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        /* ✅ FIXED: Created a wrapper to center the form without breaking the footer */
        .auth-page-wrapper {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .auth-container { 
            width: 100%;
            max-width: 450px; 
            background-color: var(--dark-gray); 
            padding: 40px; 
            border-radius: 15px; 
            border: 1px solid #2a2a2a;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .logo-area {
            text-align: center;
            margin-bottom: 20px;
            font-size: 1.8em;
            font-weight: 700;
            color: var(--gold);
            text-decoration: none;
            display: block;
        }
        .logo-area span { color: var(--silver); }

        .form-container h2 { text-align: center; font-size: 1.8em; margin-bottom: 25px; }
        
        .form-group { margin-bottom: 20px; position: relative; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); font-size: 0.9em; }
        .form-group input { width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1em; }
        .form-group input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }

        /* Password Strength Bar */
        .strength-container {
            margin-top: 8px;
            height: 5px;
            width: 100%;
            background-color: #333;
            border-radius: 10px;
            overflow: hidden;
        }
        #strength-bar {
            height: 100%;
            width: 0%;
            transition: all 0.3s ease;
        }
        #strength-text {
            font-size: 0.75em;
            margin-top: 5px;
            display: block;
            text-align: right;
        }

        .submit-button { 
            display: block; 
            width: 100%; 
            background: var(--gold); 
            color: var(--black); 
            padding: 14px 20px; 
            border-radius: 8px; 
            font-size: 1.1em; 
            font-weight: 700; 
            border: none; 
            cursor: pointer; 
            transition: all 0.3s ease; 
            margin-top: 10px;
        }
        .submit-button:hover { transform: translateY(-2px); box-shadow: 0 0 20px var(--glow-gold); }

        .divider {
            text-align: center;
            margin: 20px 0;
            position: relative;
            color: #666;
            font-size: 0.9em;
        }
        .divider::before, .divider::after {
            content: "";
            position: absolute;
            top: 50%;
            width: 40%;
            height: 1px;
            background: #333;
        }
        .divider::before { left: 0; }
        .divider::after { right: 0; }

        /* Custom Social Sign-In Buttons (Ghost Style) */
        .social-signin-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            width: 100%;
            padding: 12px;
            margin-bottom: 12px; /* Reduced slightly to fit 3 buttons nicely */
            background-color: transparent; 
            border: 2px solid var(--silver); 
            color: var(--silver);           
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .social-signin-btn:hover {
            background-color: var(--gold);
            border-color: var(--gold);
            color: var(--black); 
            box-shadow: 0 0 15px var(--glow-gold);
        }

        .social-signin-btn .social-icon {
            width: 24px;
            height: 24px;
            fill: currentColor; /* This makes the SVG inherit the text color! */
        }

        .form-switch { text-align: center; margin-top: 25px; color: var(--silver); font-size: 0.9em; }
        .form-switch a { color: var(--gold); text-decoration: none; font-weight: 600; }
        .form-switch a:hover { text-decoration: underline; }

        @media (max-width: 480px) {
            .auth-container { padding: 25px; border-radius: 0; border: none; box-shadow: none; }
            .auth-page-wrapper { padding: 0; align-items: flex-start; }
        }
/* New Styles for Username Suggestions */
        .username-feedback {
            font-size: 0.85em;
            margin-top: 5px;
            display: block;
            min-height: 18px; /* Keep space even when empty */
        }
        .feedback-available { color: var(--success); }
        .feedback-taken { color: var(--error); }
        
        .suggestion-box {
            display: none;
            margin-top: 10px;
            background: rgba(0,0,0,0.2);
            padding: 10px;
            border-radius: 8px;
            border: 1px dashed #444;
        }
        .suggestion-box p {
            margin: 0 0 8px 0;
            font-size: 0.85em;
            color: var(--silver);
        }
        .suggestion-tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        .suggestion-tag {
            background: var(--dark-gray);
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 4px 10px;
            border-radius: 15px;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.2s;
        }
        .suggestion-tag:hover {
            background: var(--gold);
            color: var(--black);
        }
    </style>
</head>
<body>

    <!-- Wrapper that takes up the remaining space, pushing footer down -->
    <main class="auth-page-wrapper">
        <div class="auth-container">
            <a href="/" class="logo-area">GPL <span>Mods</span></a>
            
           <section class="form-container">
                <h2>Create Account</h2>

                <!-- SUCCESS MESSAGE BLOCK -->
                <% if (typeof message !== 'undefined' && message) { %>
                    <p style="padding: 10px; background-color: rgba(46, 204, 113, 0.1); border: 1px solid #2ecc71; text-align: center; margin-bottom: 1rem; border-radius: 8px; font-size: 0.9em; color: #2ecc71; font-weight: bold;">
                        <%= message %>
                    </p>
                <% } %>

                <!-- ERROR MESSAGE BLOCK -->
                <% if (typeof error !== 'undefined' && error) { %>
                    <p style="padding: 10px; background-color: rgba(229, 57, 53, 0.1); border: 1px solid var(--red); text-align: center; margin-bottom: 1rem; border-radius: 8px; font-size: 0.9em; color: var(--red); font-weight: bold;">
                        <%= error %>
                    </p>
                <% } %>

                <form id="signup-form" action="/register" method="POST">
                    <!-- UPDATED Username Group -->
                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" name="username" placeholder="e.g. YourName" required autocomplete="off">
                        
                        <!-- NEW: Feedback and Suggestions -->
                        <span id="username-msg" class="username-feedback"></span>
                        <div id="suggestion-container" class="suggestion-box">
                            <p>Try one of these instead:</p>
                            <div id="suggestion-list" class="suggestion-tags"></div>
                        </div>
                    </div>


                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="youremail@example.com" required>
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" placeholder="********" required>
                        <div class="strength-container">
                            <div id="strength-bar"></div>
                        </div>
                        <span id="strength-text">Strength: Too short</span>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="********" required>
                    </div>

                    <!-- UPDATED: ReCAPTCHA and Terms -->
                    <div class="form-group">
                        <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
                    </div>
                    
                    <!-- NEW: Privacy Policy Link added -->
                    <p style="font-size: 0.8em; color: var(--silver); text-align: center; margin-bottom: 15px;">
                        By registering, you agree to our <a href="/tos" style="color: var(--gold);">Terms of Service</a> and <a href="/privacy-policy" style="color: var(--gold);">Privacy Policy</a>.
                    </p>

                    <button type="submit" class="submit-button">Sign Up</button>
                </form>

                <div class="divider">or</div>

                <!-- Google Login -->
                <a href="/auth/google" class="social-signin-btn">
                    <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M21.35,11.1H12.18V13.83H18.69C18.36,17.64 15.19,19.27 12.19,19.27C8.36,19.27 5,16.25 5,12C5,7.9 8.2,4.73 12,4.73C15.29,4.73 17.1,6.7 17.1,6.7L19,4.72C19,4.72 16.56,2 12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,11.63 21.95,11.36 21.89,11.1H21.35Z"/>
                    </svg>
                    <span>Continue with Google</span>
                </a>

                <!-- GitHub Login -->
                <a href="/auth/github" class="social-signin-btn">
                    <svg class="social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
                    </svg>
                    <span>Continue with GitHub</span>
                </a>

                <p class="form-switch">Already have an account? <a href="/login">Login</a></p>
            </section>
        </div>
    </main>

    <script>
        const passwordInput = document.getElementById('password');
        const strengthBar = document.getElementById('strength-bar');
        const strengthText = document.getElementById('strength-text');

        passwordInput.addEventListener('input', () => {
            const val = passwordInput.value;
            let strength = 0;
            if (val.length >= 6) strength += 25;
            if (val.match(/[a-z]/) && val.match(/[A-Z]/)) strength += 25;
            if (val.match(/\d/)) strength += 25;
            if (val.match(/[^a-zA-Z\d]/)) strength += 25;

            strengthBar.style.width = strength + '%';
            if (strength <= 25) {
                strengthBar.style.backgroundColor = '#ff4d4d';
                strengthText.innerText = 'Strength: Weak';
                strengthText.style.color = '#ff4d4d';
            } else if (strength <= 75) {
                strengthBar.style.backgroundColor = '#ffa500';
                strengthText.innerText = 'Strength: Medium';
                strengthText.style.color = '#ffa500';
            } else {
                strengthBar.style.backgroundColor = '#2ecc71';
                strengthText.innerText = 'Strength: Strong';
                strengthText.style.color = '#2ecc71';
            }
        });
// --- NEW: Live Username Suggestions Logic ---
        const usernameInput = document.getElementById('username');
        const usernameMsg = document.getElementById('username-msg');
        const suggestionContainer = document.getElementById('suggestion-container');
        const suggestionList = document.getElementById('suggestion-list');
        const submitBtn = document.getElementById('register-submit-btn');
        let typingTimer;

        usernameInput.addEventListener('input', function() {
            clearTimeout(typingTimer);
            const val = this.value.trim();

            // Reset UI
            usernameMsg.textContent = '';
            usernameMsg.className = 'username-feedback';
            suggestionContainer.style.display = 'none';
            suggestionList.innerHTML = '';
            submitBtn.disabled = false; // Assume okay until checked

            if (val.length < 3) {
                if (val.length > 0) {
                    usernameMsg.textContent = 'Username must be at least 3 characters.';
                    usernameMsg.classList.add('feedback-taken');
                    submitBtn.disabled = true;
                }
                return;
            }

            // Show checking status
            usernameMsg.textContent = 'Checking availability...';
            usernameMsg.style.color = 'var(--silver)';

            // Wait 500ms after user stops typing before making the API call (debounce)
            typingTimer = setTimeout(async () => {
                try {
                    const response = await fetch(`/api/check-username?username=${encodeURIComponent(val)}`);
                    const data = await response.json();

                    if (data.available) {
                        usernameMsg.textContent = data.message;
                        usernameMsg.classList.add('feedback-available');
                        submitBtn.disabled = false;
                    } else {
                        usernameMsg.textContent = data.message;
                        usernameMsg.classList.add('feedback-taken');
                        // Optional: You could disable the button here, but our backend
                        // generateUniqueUsername helper will automatically fix it anyway.
                        // Letting them submit is fine, it will just append #1 automatically.

                        if (data.suggestions && data.suggestions.length > 0) {
                            suggestionContainer.style.display = 'block';
                            data.suggestions.forEach(suggestion => {
                                const tag = document.createElement('span');
                                tag.className = 'suggestion-tag';
                                tag.textContent = suggestion;
                                // If they click a suggestion, fill the input and re-check
                                tag.addEventListener('click', () => {
                                    usernameInput.value = suggestion;
                                    // Manually trigger the input event to re-validate
                                    usernameInput.dispatchEvent(new Event('input'));
                                });
                                suggestionList.appendChild(tag);
                            });
                        }
                    }
                } catch (err) {
                    usernameMsg.textContent = 'Error checking username.';
                    usernameMsg.classList.add('feedback-taken');
                }
            }, 500); // 500ms delay
        });
    </script>

    <!-- ✅ FIXED: Footer is now safely inside the body tag! -->
    <%- include('../partials/footer') %>
</body>
</html>