<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coming Soon - GPL Mods</title>
    <!-- Link to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --black: #0a0a0a;
            --dark-gray: #1a1a1a;
            --white: #ffffff;
            --gold: #FFD700;
            --silver: #c0c0c0;
            --glow-gold: rgba(255, 215, 0, 0.5);
            --glow-silver: rgba(192, 192, 192, 0.5);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; }
        body { font-family: 'Poppins', sans-serif; background-color: var(--black); color: var(--white); display: flex; flex-direction: column; text-align: center; }
        .container { width: 90%; max-width: 1200px; margin: auto; }
        
        /* Minimal Header */
        .main-header { padding: 15px 0; background-color: var(--black); flex-shrink: 0; }
        .header-content { display: flex; justify-content: center; align-items: center; }
        .logo { font-size: 1.8em; font-weight: 700; color: var(--gold); text-shadow: 0 0 10px var(--glow-gold); text-decoration: none; }
        .logo span { color: var(--silver); text-shadow: 0 0 10px var(--glow-silver); }

        /* Main Content */
        .main-content {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            flex-grow: 1;
            padding: 40px 20px;
        }
        .main-content h1 {
            font-size: 3em;
            font-weight: 700;
            margin-bottom: 20px;
        }
        .main-content h1 span {
            color: var(--gold);
            text-shadow: 0 0 15px var(--glow-gold);
        }
        .main-content p {
            color: var(--silver);
            font-size: 1.2em;
            max-width: 600px;
            margin-bottom: 40px;
        }

        /* Countdown Timer */
        #countdown {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
        }
        .time-block {
            background-color: var(--dark-gray);
            padding: 15px 25px;
            border-radius: 10px;
            min-width: 100px;
        }
        .time-block .number {
            font-size: 3em;
            font-weight: 600;
            line-height: 1.1;
            color: var(--gold);
        }
        .time-block .label {
            font-size: 0.9em;
            color: var(--silver);
        }

        /* Subscription Form */
        .subscription-form {
            max-width: 500px;
            width: 100%;
            margin-bottom: 30px;
        }
        .subscription-form h3 {
            font-size: 1.3em;
            margin-bottom: 15px;
            color: var(--white);
        }
        .form-group {
            display: flex;
            gap: 10px;
        }
        .form-group input {
            flex-grow: 1;
            padding: 12px 15px;
            border-radius: 25px;
            border: 1px solid var(--dark-gray);
            background-color: var(--dark-gray);
            color: var(--white);
            font-size: 1em;
            outline: none;
            transition: all 0.3s ease;
        }
        .form-group input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 10px var(--glow-gold);
        }
        .form-group button {
            background: var(--gold);
            color: var(--black);
            padding: 12px 25px;
            border-radius: 25px;
            border: none;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .form-group button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px var(--glow-gold);
        }
        
        /* Back to Home Link */
        .home-link {
            color: var(--silver);
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .home-link:hover {
            color: var(--gold);
        }
        
        /* Minimal Footer */
        .main-footer { padding: 40px 20px; color: var(--silver); flex-shrink: 0; font-size: 0.9em; }
        
        /* Responsive */
        @media (max-width: 768px) {
            .main-content h1 { font-size: 2.2em; }
            .main-content p { font-size: 1em; }
            #countdown { gap: 10px; }
            .time-block { min-width: 70px; padding: 10px; }
            .time-block .number { font-size: 2em; }
            .form-group { flex-direction: column; }
        }
    </style>
</head>
<body>

    <header class="main-header">
        <div class="container header-content">
            <!-- Updated link to point to the site's root -->
            <a href="/" class="logo">GPL <span>Mods</span></a>
        </div>
    </header>

    <main class="main-content container">
        <h1><span>Something Awesome</span> is Coming Soon</h1>
        <p>We're working hard to bring you a new and exciting feature. Stay tuned for the big reveal!</p>

        <div id="countdown">
            <div class="time-block">
                <div id="days" class="number">00</div>
                <div class="label">Days</div>
            </div>
            <div class="time-block">
                <div id="hours" class="number">00</div>
                <div class="label">Hours</div>
            </div>
            <div class="time-block">
                <div id="minutes" class="number">00</div>
                <div class="label">Minutes</div>
            </div>
            <div class="time-block">
                <div id="seconds" class="number">00</div>
                <div class="label">Seconds</div>
            </div>
        </div>

        <!-- We'll make this form functional -->
        <form class="subscription-form" id="notify-form" action="/notify-launch" method="POST">
            <h3>Get Notified When We Launch</h3>
            <div class="form-group">
                <input type="email" name="email" placeholder="Enter your email address" required>
                <button type="submit">Notify Me</button>
            </div>
        </form>

        <!-- ✅ FIX: Updated button classes and styles to match the golden theme -->
<a href="<%= user ? '/home' : '/' %>" class="btn" style="margin-top: 2rem; display: inline-block; background: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 25px; font-weight: bold; text-decoration: none; box-shadow: 0 0 15px var(--glow-gold); transition: transform 0.3s ease;">Go to Homepage</a>
    </main>
    
    <footer class="main-footer">
        <div class="container">
            <p>&copy; 2025 GPL Mods. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // --- Countdown Timer Logic ---
            // You can dynamically pass this date from your route if you want
            const countDownDate = new Date();
            countDownDate.setDate(countDownDate.getDate() + 30); // Example: 30 days from now

            const daysEl = document.getElementById('days');
            const hoursEl = document.getElementById('hours');
            const minutesEl = document.getElementById('minutes');
            const secondsEl = document.getElementById('seconds');

            const timer = setInterval(function() {
                const now = new Date().getTime();
                const distance = countDownDate - now;

                if (distance < 0) {
                    clearInterval(timer);
                    document.getElementById('countdown').innerHTML = "<h2 style='color: var(--gold);'>Feature is Live!</h2>";
                    return;
                }

                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                daysEl.textContent = String(days).padStart(2, '0');
                hoursEl.textContent = String(hours).padStart(2, '0');
                minutesEl.textContent = String(minutes).padStart(2, '0');
                secondsEl.textContent = String(seconds).padStart(2, '0');
            }, 1000);
            
            // --- Form Submission Handler ---
            const notifyForm = document.getElementById('notify-form');
            notifyForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const emailInput = this.querySelector('input[type="email"]');
                const button = this.querySelector('button');

                // In a real app, you would send this to the backend
                // For now, we'll just provide user feedback
                console.log(`Email submitted for notification: ${emailInput.value}`);
                
                button.textContent = 'Submitted!';
                button.disabled = true;
                emailInput.disabled = true;

                // Optionally, save to localStorage to remember submission
                localStorage.setItem('notified_launch', 'true');
            });
            
            // Check if user has already submitted
            if (localStorage.getItem('notified_launch') === 'true') {
                 const button = notifyForm.querySelector('button');
                 const emailInput = notifyForm.querySelector('input[type="email"]');
                 button.textContent = 'Submitted!';
                 button.disabled = true;
                 emailInput.placeholder = 'We will notify you!';
                 emailInput.disabled = true;
            }
        });
    </script>
</body>
</html>