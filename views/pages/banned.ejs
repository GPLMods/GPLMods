<%- include('../partials/header') %>

<style>
    .banned-container {
        max-width: 700px;
        margin: 4rem auto;
        padding: 3rem;
        background-color: var(--dark-gray);
        border-radius: 15px;
        text-align: center;
        border-top: 4px solid var(--red);
        box-shadow: 0 10px 30px rgba(229, 57, 53, 0.15);
    }
    .banned-icon {
        font-size: 5em;
        color: var(--red);
        margin-bottom: 10px;
        text-shadow: 0 0 20px var(--glow-red);
    }
    .banned-title {
        font-size: 2.5em;
        color: var(--white);
        margin-bottom: 10px;
    }
    .banned-reason-box {
        background-color: rgba(229, 57, 53, 0.1);
        border: 1px solid rgba(229, 57, 53, 0.3);
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
        color: #ffadad;
        font-size: 1.1em;
    }
    .contact-info {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin: 30px 0;
        flex-wrap: wrap;
    }
    .contact-card {
        background-color: var(--black);
        padding: 15px 25px;
        border-radius: 8px;
        border: 1px solid #333;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--silver);
        transition: all 0.3s ease;
    }
    .contact-card:hover {
        border-color: var(--gold);
        color: var(--gold);
        transform: translateY(-3px);
    }
    .appeal-form {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #333;
        text-align: left;
    }
    .appeal-form textarea {
        width: 100%;
        min-height: 120px;
        padding: 15px;
        border-radius: 8px;
        background-color: var(--black);
        border: 1px solid #333;
        color: var(--white);
        font-family: 'Poppins', sans-serif;
        margin-top: 10px;
        margin-bottom: 15px;
        resize: vertical;
    }
    .appeal-form textarea:focus {
        outline: none;
        border-color: var(--gold);
    }
    .alert-msg {
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: bold;
    }
    .alert-success { background-color: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid #2ecc71; }
    .alert-error { background-color: rgba(229, 57, 53, 0.1); color: var(--red); border: 1px solid var(--red); }
</style>

<main class="container">
    <div class="banned-container">
        <div style="display: flex; justify-content: center; margin-bottom: 10px;">
            <lottie-player src="/animations/ban.json" background="transparent" speed="1" style="width: 150px; height: 150px; filter: drop-shadow(0 0 20px var(--glow-red));" loop autoplay></lottie-player>
        </div>
        <h1 class="banned-title">Account Suspended</h1>
        <p style="color: var(--silver); font-size: 1.1em;">Your account has been suspended from GPL Mods.</p>

        <div class="banned-reason-box">
            <strong>Reason for suspension:</strong><br>
            <%= banReason %>
        </div>

        <p style="color: var(--silver);">If you believe this was a mistake, you can reach out to our support team or submit an appeal below.</p>

        <div class="contact-info">
            <a href="mailto:admin@gplmods.webredirect.org" class="contact-card">
                <i class="fas fa-envelope" style="color: var(--gold);"></i> admin@gplmods.webredirect.org
            </a>
            <a href="https://discord.gg/frBQ2zTu7" target="_blank" class="contact-card">
                <i class="fab fa-discord" style="color: #5865F2;"></i> Banned Users Discord
            </a>
        </div>

        <div class="appeal-form">
            <h3 style="color: var(--white); margin-bottom: 10px;">Submit an Unban Appeal</h3>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert-msg alert-error"><%= error %></div>
            <% } %>
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="alert-msg alert-success"><%= message %></div>
            <% } %>

            <form action="/unban-request" method="POST">
                <label for="appealMessage" style="color: var(--silver); font-weight: 600;">Please explain why your account should be reinstated:</label>
                <textarea id="appealMessage" name="appealMessage" required placeholder="I believe my account was banned by mistake because..."></textarea>
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 15px; font-size: 1.1em; border-radius: 8px;">Submit Appeal</button>
            </form>
        </div>
        
        <div style="margin-top: 30px;">
            <a href="/logout" style="color: var(--silver); text-decoration: underline;">Logout of this account</a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>