<%- include('../partials/header') %>

<style>
    /* ✅ FIX: Restored Upload Page Textures & Styles */
    .upload-container { 
        max-width: 700px; 
        margin: 4rem auto; 
        padding: 3rem 2rem; 
        background-color: var(--dark-gray); 
        border-radius: 12px; 
        text-align: center;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .form-group { text-align: left; margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); }
    .form-group input[type="text"], .form-group input[type="url"], .form-group textarea {
        width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333;
        background-color: var(--black); color: var(--white); font-size: 1.1em;
        font-family: 'Poppins', sans-serif; transition: all 0.3s ease; outline: none;
    }
    .form-group input:focus, .form-group textarea:focus { border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }
    
    .file-input-label { 
        display: inline-block; padding: 15px 30px; background: transparent; 
        color: var(--gold); border: 2px dashed var(--gold); border-radius: 8px; 
        cursor: pointer; transition: all 0.3s ease; font-size: 1.2em; 
        margin-bottom: 1rem; width: 100%; text-align: center;
    }
    .file-input-label:hover { background: rgba(255, 215, 0, 0.1); }
    
    .submit-button { 
        display: block; width: 100%; background: var(--gold); color: var(--black); 
        padding: 15px 20px; border-radius: 8px; font-weight: 700; font-size: 1.2em; 
        border: none; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 15px var(--glow-gold); 
        margin-top: 2rem; 
    }
    .submit-button:hover { transform: translateY(-2px); box-shadow: 0 0 25px var(--glow-gold); }
    .submit-button:disabled { background-color: #555; color: #aaa; cursor: not-allowed; box-shadow: none; transform: none; }
    
    #file-name-display { margin-top: 15px; color: var(--white); font-weight: 600; font-size: 1.1em; text-align: center; }
    
    /* --- LIVE PROGRESS BAR STYLES --- */
    .progress-wrapper { display: none; margin-top: 25px; text-align: left; }
    .progress-container { width: 100%; background-color: var(--black); border: 1px solid #444; border-radius: 8px; height: 25px; overflow: hidden; position: relative; }
    .progress-bar { height: 100%; width: 0%; background-color: var(--gold); transition: width 0.2s ease; display: flex; align-items: center; justify-content: center; color: var(--black); font-weight: bold; font-size: 0.85em; white-space: nowrap; }
    .status-text { color: var(--silver); margin-top: 10px; font-size: 0.95em; text-align: center; }
    
    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
    .processing-pulse { animation: pulse 1.5s infinite; }
</style>

<div class="container">
    <!-- ======== DYNAMIC GO BACK BUTTON ======== -->
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-flex; align-items: center; font-weight: 600; font-size: 1.05em; transition: color 0.3s ease;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Go Back
        </a>
    </div>
    <!-- ======================================== -->
    <div class="upload-container">
        <h2 style="color: var(--gold); margin-bottom: 10px; font-size: 2.2em;">Upload Mod File</h2>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background-color: rgba(229, 57, 53, 0.1); color: var(--red); border: 1px solid var(--red); padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold;"><%= error %></div>
        <% } %>

        <% if (user && (user.role === 'distributor' || user.role === 'admin')) { %>
            <!-- DISTRIBUTOR / ADMIN FORM -->
            <p style="color: var(--silver); margin-bottom: 1.5rem;">
                <span style="color: var(--gold); font-weight: bold;">★ <%= user.role === 'admin' ? 'Admin' : 'Distributor' %> Account Active ★</span><br>
                Step 1 of 2: Choose your upload method below.
            </p>
            <p style="font-size: 0.85em; color: var(--silver); margin-bottom: 2rem;">By uploading, you agree to our <a href="/upload-policy" target="_blank" style="color: var(--gold); text-decoration: underline;">Upload & Update Policy</a>.</p>
            
            <div style="display: flex; gap: 10px; justify-content: center; margin-bottom: 25px;">
                <button type="button" class="btn btn-primary" id="btn-show-link" style="flex: 1; padding: 10px;">Paste External Link(s)</button>
                <button type="button" class="btn btn-secondary" id="btn-show-file" style="flex: 1; padding: 10px;">Upload to Cloud</button>
            </div>

            <!-- External Link Form -->
            <form action="/upload-initial" method="POST" id="distributorUploadForm">
                <div class="form-group" style="text-align: left; margin-bottom: 15px;">
                    <div class="checkbox-group" style="display: flex; align-items: center; gap: 10px;">
                        <label class="switch">
                            <input type="checkbox" id="isMultiPartDistributor" name="isMultiPart" value="true">
                            <span class="slider round"></span>
                        </label>
                        <label for="isMultiPartDistributor" style="margin-bottom: 0; cursor: pointer; color: var(--silver); font-weight: 600;">This mod requires multiple download links (Multi-Part)</label>
                    </div>
                </div>

                <!-- Single Link Input (Default) -->
                <div id="single-link-group" class="form-group" style="text-align: left;">
                    <label for="externalUrl" style="color: var(--silver); font-weight: 600; margin-bottom: 8px; display: block;">External Download Link*</label>
                    <input type="url" id="externalUrl" name="externalUrl" placeholder="https://linkvertise.com/..." style="width: 100%; padding: 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1.1em; outline: none;">
                </div>
                
                <!-- Multi-Part Info Box (Shown when checked) -->
                <div id="multi-link-group" class="form-group" style="text-align: left; display: none;">
                    <div style="background: rgba(255, 215, 0, 0.1); border: 1px solid var(--gold); padding: 15px; border-radius: 8px;">
                        <p style="color: var(--gold); font-weight: bold; margin: 0; font-size: 1.1em;"><i class="fas fa-layer-group"></i> Multi-Part Configurator</p>
                        <p style="color: var(--silver); margin-top: 5px; margin-bottom: 10px; font-size: 0.95em;">Add parts below. Each part may include mirrors, a direct admin link, and scan references. You can add unlimited parts.</p>
                        <div id="parts-container">
                            <!-- Part template: Part 1 -->
                            <div class="part-block" style="border:1px solid #333; padding:10px; border-radius:8px; margin-bottom:10px;">
                                <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part Name</label>
                                <input type="text" name="partNames[]" placeholder="Part 1 (e.g., main, data)" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part URL*</label>
                                <input type="url" name="partUrls[]" placeholder="https://.../part1" required style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                <div style="display:flex; gap:8px;">
                                    <div style="flex:1;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 1 Provider</label>
                                        <input type="text" name="mirror1Providers[]" placeholder="Google Drive" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                    <div style="flex:2;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 1 URL</label>
                                        <input type="url" name="mirror1Urls[]" placeholder="https://..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                </div>
                                <div style="display:flex; gap:8px;">
                                    <div style="flex:1;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 2 Provider</label>
                                        <input type="text" name="mirror2Providers[]" placeholder="Mega" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                    <div style="flex:2;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 2 URL</label>
                                        <input type="url" name="mirror2Urls[]" placeholder="https://..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                </div>
                                <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Direct Admin Link</label>
                                <input type="url" name="directAdminLinks[]" placeholder="https://admin.example.com/direct/" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                <div style="display:flex; gap:8px;">
                                    <div style="flex:1;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Manual File Scan URL</label>
                                        <input type="url" name="manualFileScanUrls[]" placeholder="https://www.virustotal.com/..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                    <div style="flex:1;">
                                        <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Manual Site Scan URL</label>
                                        <input type="url" name="manualSiteScanUrls[]" placeholder="https://sitecheck.sucuri.net/..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                    </div>
                                </div>
                            </div>
                            <!-- Part template: Part 2 -->
                            <div class="part-block" style="border:1px solid #333; padding:10px; border-radius:8px; margin-bottom:10px;">
                                <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part Name</label>
                                <input type="text" name="partNames[]" placeholder="Part 2 (e.g., split-1)" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                                <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part URL*</label>
                                <input type="url" name="partUrls[]" placeholder="https://.../part2" required style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                            </div>
                        </div>
                        <div style="display:flex; gap:8px;">
                            <button type="button" id="add-part-btn" class="btn btn-secondary" style="padding: 8px 14px; font-size: 0.95em;">+ Add Another Part</button>
                            <button type="button" id="remove-part-btn" class="btn btn-danger" style="padding: 8px 14px; font-size: 0.95em;">- Remove Last Part</button>
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 15px;">
                    <label for="originalFilename" style="color: var(--silver); font-weight: 600; margin-bottom: 8px; display: block;">File Name (for display purposes)*</label>
                    <input type="text" id="originalFilename" name="originalFilename" required placeholder="e.g., Minecraft_Mod_v1.2.apk" style="width: 100%; padding: 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1.1em; outline: none;">
                </div>

                <button type="submit" class="submit-button" id="distributorSubmitBtn">Continue to Details</button>
            </form>
            
            <!-- Standard File Upload Form (Hidden initially for distributors) -->
            <form action="/upload-initial" method="POST" enctype="multipart/form-data" id="initialUploadForm" style="display: none;">
                <p style="color: var(--silver); margin-bottom: 1.5rem; font-size: 0.9em;">Max File Size: Unlimited</p>
                <div class="form-group">
                    <label for="modFile" class="file-input-label" id="drop-zone">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2em; display: block; margin-bottom: 10px;"></i>
                        Click to Choose File
                    </label>
                    <input type="file" id="modFile" name="modFile" required style="display:none;" data-limit="999999999999">
                    <div id="file-name-display">No file selected</div>
                </div>
                
                <div class="progress-wrapper" id="progressWrapper">
                    <div class="progress-container"><div class="progress-bar" id="progressBar">0%</div></div>
                    <p class="status-text" id="statusText">Starting upload...</p>
                </div>
                <button type="submit" class="submit-button" id="submitBtn">Upload & Continue</button>
            </form>

        <% } else { %>
            <!-- STANDARD USER UPLOAD FORM -->
            <% let limitText = (user && user.membership === 'premium') ? "1 GB" : "300 MB"; %>
            <% let limitBytes = (user && user.membership === 'premium') ? 1073741824 : 314572800; %>
            
            <p style="color: var(--silver); margin-bottom: 1rem;">Step 1 of 2: Select the primary mod file (.zip, .apk, .exe).</p>
            <p style="color: var(--gold); font-weight: bold; margin-bottom: 2rem;">Max File Size: <%= limitText %></p>
            
            <form action="/upload-initial" method="POST" enctype="multipart/form-data" id="initialUploadForm">
                <div class="form-group">
                    <label for="modFile" class="file-input-label" id="drop-zone">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2em; display: block; margin-bottom: 10px;"></i>
                        Click to Choose File
                    </label>
                    <input type="file" id="modFile" name="modFile" required style="display:none;" data-limit="<%= limitBytes %>">
                    <div id="file-name-display">No file selected</div>
                </div>
                
                <div class="progress-wrapper" id="progressWrapper">
                    <div class="progress-container"><div class="progress-bar" id="progressBar">0%</div></div>
                    <p class="status-text" id="statusText">Starting upload...</p>
                </div>

                <button type="submit" class="submit-button" id="submitBtn">Upload & Continue</button>
            </form>
        <% } %>
    </div>
</div>

<!-- ======== NEW: CUSTOM ERROR MODAL ======== -->
<div id="error-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 400px; width: 90%; border-top: 3px solid var(--red); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-exclamation-triangle" style="font-size: 3em; color: var(--red); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Upload Error</h2>
        <p id="error-modal-msg" style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;"></p>
        <button type="button" class="btn btn-primary" onclick="closeErrorModal()" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; font-size: 1.1em; background-color: var(--red); border: none; cursor: pointer; color: white;">Okay</button>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    // --- Helper to control the Error Modal ---
    function showErrorModal(message) {
        document.getElementById('error-modal-msg').textContent = message;
        const modal = document.getElementById('error-modal');
        modal.style.display = 'flex';
        setTimeout(() => modal.classList.add('show'), 10);
    }
    function closeErrorModal() {
        const modal = document.getElementById('error-modal');
        modal.classList.remove('show');
        setTimeout(() => modal.style.display = 'none', 200);
    }

    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Role-Based Size Limit Check & Live Progress Bar ---
        const fileInput = document.getElementById('modFile');
        const fileNameDisplay = document.getElementById('file-name-display');
        const form = document.getElementById('initialUploadForm');
        const submitBtn = document.getElementById('submitBtn');
        const dropZone = document.getElementById('drop-zone');
        const progressWrapper = document.getElementById('progressWrapper');
        const progressBar = document.getElementById('progressBar');
        const statusText = document.getElementById('statusText');

        if (fileInput && form && dropZone) {
            fileInput.addEventListener('change', function() {
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
                    const maxLimit = parseInt(this.getAttribute('data-limit') || '999999999999', 10);
                    
                    if (file.size > maxLimit) {
                        // ✅ FIX: Using the Custom Modal instead of alert()
                        showErrorModal(`File is too large! Your limit is ${maxLimit === 314572800 ? '300 MB' : '1 GB'}.`);
                        this.value = ''; 
                        fileNameDisplay.textContent = 'No file selected';
                        dropZone.style.borderColor = 'var(--red)';
                        dropZone.style.backgroundColor = 'rgba(229, 57, 53, 0.05)';
                        return;
                    }

                    fileNameDisplay.textContent = `Ready: ${file.name} (${sizeInMB} MB)`;
                    dropZone.style.borderColor = 'var(--gold)';
                    dropZone.style.backgroundColor = 'rgba(255, 215, 0, 0.05)';
                }
            });

            // AJAX Form Submission for TRUE End-to-End Live Progress
            form.addEventListener('submit', function(e) {
                e.preventDefault(); 
                if (fileInput.files.length === 0) {
                    return showErrorModal("Please select a file to upload first.");
                }
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Uploading... Please wait';
                progressWrapper.style.display = 'block';
                progressBar.style.width = '0%';
                progressBar.textContent = '0%';
                progressBar.classList.remove('processing-pulse');
                
                // ✅ FIX: Simplified, generic status text to hide B2 infrastructure
                statusText.innerHTML = 'Uploading file... Do not close this page.';

                const formData = new FormData(form);
                
                const uploadId = 'up_' + Date.now();
                formData.append('uploadId', uploadId);

                // --- PHASE 2: Listen for Server-to-Cloud progress via Socket.IO ---
                const socket = io();
                socket.on(`b2_progress_${uploadId}`, (data) => {
                    // Map the 0-100% B2 progress to the 50-100% portion of our visual bar
                    const totalPercent = 50 + Math.round(data.percent / 2);
                    
                    progressBar.style.width = totalPercent + '%';
                    progressBar.textContent = totalPercent + '%';
                    
                    // Keep the text generic
                    statusText.innerHTML = `Uploading... ${totalPercent}%`;
                    
                    if (data.percent === 100) {
                        progressBar.classList.add('processing-pulse');
                        statusText.innerHTML = 'Finalizing and scanning... Almost done!';
                    }
                });

                const xhr = new XMLHttpRequest();
                xhr.open('POST', form.action, true);

                // --- PHASE 1: Listen for Browser-to-Server progress via XHR ---
                xhr.upload.addEventListener('progress', function(event) {
                    if (event.lengthComputable) {
                        // Map the 0-100% browser upload to the 0-50% portion of our visual bar
                        const percentComplete = Math.round((event.loaded / event.total) * 50);
                        
                        progressBar.style.width = percentComplete + '%';
                        progressBar.textContent = percentComplete + '%';

                        if (percentComplete === 50) {
                            // When the browser finishes sending, we wait for the Socket.IO events to take over
                            statusText.innerHTML = 'Processing upload... Do not close this page.';
                        } else {
                            statusText.innerHTML = `Uploading... ${percentComplete}%`;
                        }
                    }
                });

                xhr.onload = function() {
                    if (xhr.status >= 200 && xhr.status < 400) {
                        window.location.href = xhr.responseURL; 
                    } else {
                        try {
                            const res = JSON.parse(xhr.responseText);
                            showErrorModal(res.message || 'Upload failed.');
                        } catch(e) {
                            showErrorModal(`Server error (${xhr.status}). The file might be too large or the connection was lost.`);
                        }
                        resetUI();
                    }
                };

                xhr.onerror = function() { 
                    showErrorModal('A network error occurred. Please check your internet connection.'); 
                    resetUI(); 
                };
                
                xhr.send(formData);
            });

            function resetUI() {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Upload & Continue';
                progressWrapper.style.display = 'none';
                progressBar.classList.remove('processing-pulse');
            }
        }

        // --- 2. Distributor Form Toggles ---
        const btnShowLink = document.getElementById('btn-show-link');
        const btnShowFile = document.getElementById('btn-show-file');
        const distLinkLib = document.getElementById('distributorUploadForm');
        
        if (btnShowLink && btnShowFile && distLinkLib && form) {
            btnShowLink.addEventListener('click', () => {
                btnShowLink.classList.replace('btn-secondary', 'btn-primary');
                btnShowFile.classList.replace('btn-primary', 'btn-secondary');
                distLinkLib.style.display = 'block';
                form.style.display = 'none';
            });
            btnShowFile.addEventListener('click', () => {
                btnShowFile.classList.replace('btn-secondary', 'btn-primary');
                btnShowLink.classList.replace('btn-primary', 'btn-secondary');
                form.style.display = 'block';
                distLinkLib.style.display = 'none';
            });
        }

        // --- 3. Distributor Multi-Part Link Logic ---
        const multiPartCheckbox = document.getElementById('isMultiPartDistributor');
        if (multiPartCheckbox) {
            const singleLinkGroup = document.getElementById('single-link-group');
            const multiLinkGroup = document.getElementById('multi-link-group');
            const singleInput = document.getElementById('externalUrl');
            const partsContainer = document.getElementById('parts-container');
            const addPartBtn = document.getElementById('add-part-btn');
            const removePartBtn = document.getElementById('remove-part-btn');

            function setPartsRequired(required) {
                partsContainer.querySelectorAll('input').forEach(i => {
                    // require only the part URL fields, keep mirrors optional
                    if (i.name === 'partUrls[]') i.required = required;
                });
            }

            multiPartCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    singleLinkGroup.style.display = 'none';
                    singleInput.required = false;
                    multiLinkGroup.style.display = 'block';
                    setPartsRequired(true);
                } else {
                    singleLinkGroup.style.display = 'block';
                    singleInput.required = true;
                    multiLinkGroup.style.display = 'none';
                    setPartsRequired(false);
                }
            });

            function createPartBlock(index) {
                const block = document.createElement('div');
                block.className = 'part-block';
                block.style.cssText = 'border:1px solid #333; padding:10px; border-radius:8px; margin-bottom:10px;';
                block.innerHTML = `
                    <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part Name</label>
                    <input type="text" name="partNames[]" placeholder="Part ${index} (optional)" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                    <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Part URL*</label>
                    <input type="url" name="partUrls[]" placeholder="https://.../part${index}" required style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                    <div style="display:flex; gap:8px;">
                        <div style="flex:1;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 1 Provider</label>
                            <input type="text" name="mirror1Providers[]" placeholder="Google Drive" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                        <div style="flex:2;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 1 URL</label>
                            <input type="url" name="mirror1Urls[]" placeholder="https://..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                    </div>
                    <div style="display:flex; gap:8px;">
                        <div style="flex:1;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 2 Provider</label>
                            <input type="text" name="mirror2Providers[]" placeholder="Mega" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                        <div style="flex:2;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Mirror 2 URL</label>
                            <input type="url" name="mirror2Urls[]" placeholder="https://..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                    </div>
                    <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Direct Admin Link</label>
                    <input type="url" name="directAdminLinks[]" placeholder="https://admin.example.com/direct/" style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                    <div style="display:flex; gap:8px;">
                        <div style="flex:1;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Manual File Scan URL</label>
                            <input type="url" name="manualFileScanUrls[]" placeholder="https://www.virustotal.com/..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                        <div style="flex:1;">
                            <label style="color:var(--silver); font-weight:600; display:block; margin-bottom:6px;">Manual Site Scan URL</label>
                            <input type="url" name="manualSiteScanUrls[]" placeholder="https://sitecheck.sucuri.net/..." style="width:100%; margin-bottom:8px; padding:10px; border-radius:6px; border:1px solid #333; background:var(--black); color:var(--white);">
                        </div>
                    </div>
                `;
                return block;
            }

            // Add / Remove handlers
            addPartBtn.addEventListener('click', () => {
                const currentCount = partsContainer.querySelectorAll('.part-block').length;
                const nextIndex = currentCount + 1;
                const blk = createPartBlock(nextIndex);
                partsContainer.appendChild(blk);
                setPartsRequired(true);
            });

            removePartBtn.addEventListener('click', () => {
                const blocks = partsContainer.querySelectorAll('.part-block');
                if (blocks.length > 2) {
                    blocks[blocks.length - 1].remove();
                }
            });
        }
    });
</script>

