<%- include('../partials/header') %>

<style>
    .upload-container { 
        max-width: 700px; 
        margin: 4rem auto; 
        padding: 3rem 2rem; 
        background-color: var(--dark-gray); 
        border-radius: 12px; 
        text-align: center;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .file-input-label { 
        display: inline-block; 
        padding: 15px 30px; 
        background: transparent; 
        color: var(--gold); 
        border: 2px dashed var(--gold); 
        border-radius: 8px; 
        cursor: pointer; 
        transition: all 0.3s ease; 
        font-size: 1.2em; 
        margin-bottom: 1rem; 
        width: 100%;
    }
    .file-input-label:hover { 
        background: rgba(255, 215, 0, 0.1); 
    }
    .submit-button { 
        display: block; 
        width: 100%; 
        background: var(--gold); 
        color: var(--black); 
        padding: 15px 20px; 
        border-radius: 8px; 
        font-weight: 700; 
        font-size: 1.2em; 
        border: none; 
        cursor: pointer; 
        transition: all 0.3s ease; 
        box-shadow: 0 0 15px var(--glow-gold); 
        margin-top: 2rem; 
    }
    .submit-button:hover { 
        transform: translateY(-2px); 
        box-shadow: 0 0 25px var(--glow-gold);
    }
    .submit-button:disabled { 
        background-color: #555; 
        color: #aaa; 
        cursor: not-allowed; 
        box-shadow: none; 
        transform: none; 
    }
    #file-name-display { 
        margin-top: 15px; 
        color: var(--white); 
        font-weight: 600; 
        font-size: 1.1em;
    }
    
    /* --- LIVE PROGRESS BAR STYLES --- */
    .progress-wrapper {
        display: none; /* Hidden initially */
        margin-top: 25px;
        text-align: left;
    }
    .progress-container {
        width: 100%;
        background-color: var(--black);
        border: 1px solid #444;
        border-radius: 8px;
        height: 25px;
        overflow: hidden;
        position: relative;
    }
    .progress-bar {
        height: 100%;
        width: 0%;
        background-color: var(--gold);
        transition: width 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--black);
        font-weight: bold;
        font-size: 0.85em;
        white-space: nowrap;
    }
    .status-text {
        color: var(--silver);
        margin-top: 10px;
        font-size: 0.95em;
        text-align: center;
    }
    
    /* Pulsing animation for when upload hits 100% and is processing */
    @keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.6; }
        100% { opacity: 1; }
    }
    .processing-pulse {
        animation: pulse 1.5s infinite;
    }
</style>

<!-- Inside views/pages/upload.ejs -->

<div class="container">
    <div class="upload-container">
        <h2 style="color: var(--gold); margin-bottom: 10px; font-size: 2.2em;">Upload Mod File</h2>
        
        <% if (user && user.role === 'distributor') { %>
            <!-- ========================================== -->
            <!-- DISTRIBUTOR UPLOAD FORM (External Links)   -->
            <!-- ========================================== -->
            <p style="color: var(--silver); margin-bottom: 2.5rem;">
                <span style="color: var(--gold); font-weight: bold;">★ Distributor Account Active ★</span><br>
                Step 1 of 2: Paste your monetized or external download link below.
            </p>
            
            <form action="/upload-initial" method="POST" id="distributorUploadForm">
                <div class="form-group" style="text-align: left;">
                    <label for="externalUrl" style="color: var(--silver); font-weight: 600; margin-bottom: 8px; display: block;">External Download Link*</label>
                    <input type="url" id="externalUrl" name="externalUrl" required placeholder="https://linkvertise.com/..." style="width: 100%; padding: 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1.1em; outline: none; transition: border-color 0.3s;">
                </div>
                
                <div class="form-group" style="text-align: left; margin-top: 15px;">
                    <label for="originalFilename" style="color: var(--silver); font-weight: 600; margin-bottom: 8px; display: block;">File Name (for display purposes)*</label>
                    <input type="text" id="originalFilename" name="originalFilename" required placeholder="e.g., Minecraft_Mod_v1.2.apk" style="width: 100%; padding: 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1.1em; outline: none; transition: border-color 0.3s;">
                </div>

                <button type="submit" class="submit-button" id="distributorSubmitBtn">Continue to Details</button>
            </form>

        <% } else { %>
            <!-- ========================================== -->
            <!-- STANDARD USER UPLOAD FORM (File Upload)    -->
            <!-- ========================================== -->
            <p style="color: var(--silver); margin-bottom: 2.5rem;">Step 1 of 2: Select the primary mod file (.zip, .apk, .exe). It will be securely uploaded to the cloud and scanned for safety.</p>
            
            <form action="/upload-initial" method="POST" enctype="multipart/form-data" id="initialUploadForm">
                
                <div class="form-group">
                    <label for="modFile" class="file-input-label" id="drop-zone">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2em; display: block; margin-bottom: 10px;"></i>
                        Click to Choose File
                    </label>
                    <input type="file" id="modFile" name="modFile" required style="display:none;">
                    <div id="file-name-display">No file selected</div>
                </div>
                
                <!-- LIVE PROGRESS BAR UI -->
                <div class="progress-wrapper" id="progressWrapper">
                    <div class="progress-container">
                        <div class="progress-bar" id="progressBar">0%</div>
                    </div>
                    <p class="status-text" id="statusText">Starting upload...</p>
                </div>

                <button type="submit" class="submit-button" id="submitBtn">Upload & Continue</button>
            </form>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- Standard Upload Logic (Only runs if the form exists) ---
        const fileInput = document.getElementById('modFile');
        const fileNameDisplay = document.getElementById('file-name-display');
        const form = document.getElementById('initialUploadForm');
        const submitBtn = document.getElementById('submitBtn');
        const dropZone = document.getElementById('drop-zone');
        const progressWrapper = document.getElementById('progressWrapper');
        const progressBar = document.getElementById('progressBar');
        const statusText = document.getElementById('statusText');

        // ✅ FIX: Only attach listeners if the Standard Form elements actually exist
        if (fileInput && form && dropZone) {
            fileInput.addEventListener('change', function() {
                if (this.files && this.files.length > 0) {
                    const fileSize = this.files[0].size;
                    const sizeInMB = (fileSize / (1024 * 1024)).toFixed(2);
                    fileNameDisplay.textContent = `Ready: ${this.files[0].name} (${sizeInMB} MB)`;
                    dropZone.style.borderColor = 'var(--gold)';
                    dropZone.style.backgroundColor = 'rgba(255, 215, 0, 0.05)';
                } else {
                    fileNameDisplay.textContent = 'No file selected';
                    dropZone.style.borderColor = 'var(--gold)';
                    dropZone.style.backgroundColor = 'transparent';
                }
            });

            form.addEventListener('submit', function(e) {
                e.preventDefault(); 
                if (fileInput.files.length === 0) {
                    alert("Please select a file to upload first.");
                    return;
                }
                
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Uploading...';
                progressWrapper.style.display = 'block';
                progressBar.style.width = '0%';
                progressBar.textContent = '0%';
                progressBar.classList.remove('processing-pulse');
                statusText.innerHTML = 'Uploading file to server...';

                const formData = new FormData(form);
                const xhr = new XMLHttpRequest();

                xhr.open('POST', '/upload-initial', true);

                xhr.upload.addEventListener('progress', function(event) {
                    if (event.lengthComputable) {
                        const percentComplete = Math.round((event.loaded / event.total) * 100);
                        progressBar.style.width = percentComplete + '%';
                        progressBar.textContent = percentComplete + '%';

                        if (percentComplete === 100) {
                            progressBar.textContent = 'Processing...';
                            progressBar.classList.add('processing-pulse');
                            statusText.innerHTML = 'Upload complete! <br><span style="color: var(--gold);">Transferring to cloud & initiating safety scan... Please wait.</span>';
                        }
                    }
                });

                xhr.onload = function() {
                    if (xhr.status >= 200 && xhr.status < 400) {
                        window.location.href = xhr.responseURL; 
                    } else {
                        alert('Upload failed. Server responded with an error.');
                        resetUI();
                    }
                };

                xhr.onerror = function() {
                    alert('A network error occurred during the upload.');
                    resetUI();
                };

                xhr.send(formData);
            });

            function resetUI() {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Upload & Continue';
                progressWrapper.style.display = 'none';
                progressBar.classList.remove('processing-pulse');
            }
        } // End of Standard Upload Logic

        // --- Distributor Upload Logic (Only runs if Distributor Form exists) ---
        const distForm = document.getElementById('distributorUploadForm');
        const distSubmitBtn = document.getElementById('distributorSubmitBtn');
        
        // ✅ FIX: Only attach listeners if the Distributor elements exist
        if (distForm && distSubmitBtn) {
            distForm.addEventListener('submit', function() {
                distSubmitBtn.disabled = true;
                distSubmitBtn.textContent = 'Processing...';
            });
        }
    });
</script>
<%- include('../partials/footer') %>