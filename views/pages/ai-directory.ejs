<%- include('../partials/header') %>

<style>
    .ai-dir-container {
        max-width: 1000px;
        margin: 40px auto;
        background: var(--dark-gray);
        padding: 40px;
        border-radius: 12px;
        border: 1px solid #333;
    }
    .ai-dir-container h1 { color: var(--gold); border-bottom: 2px solid #333; padding-bottom: 10px; margin-bottom: 20px;}
    .ai-dir-container h2 { color: var(--silver); margin-top: 40px; text-transform: uppercase; font-size: 1.4em; border-bottom: 1px solid #222; padding-bottom: 5px; margin-bottom: 20px;}
    
    /* Rich Semantic Mod List */
    .ai-dir-rich-list { list-style-type: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: 15px; }
    .ai-dir-item { display: flex; align-items: flex-start; gap: 15px; background: var(--black); padding: 15px; border-radius: 8px; border: 1px solid #222; }
    .ai-dir-item:hover { border-color: var(--gold); }
    .ai-dir-icon { width: 60px; height: 60px; border-radius: 8px; object-fit: contain; background: #111; padding: 5px; flex-shrink: 0; }
    
    .ai-dir-info { flex-grow: 1; }
    .ai-dir-info a { color: var(--white); text-decoration: none; font-weight: 700; font-size: 1.2em; transition: color 0.2s; }
    .ai-dir-info a:hover { color: var(--gold); text-decoration: underline; }
    
    .ai-dir-meta { font-size: 0.85em; color: var(--gold); margin: 5px 0; }
    .ai-dir-meta a { color: var(--silver); font-size: 1em; font-weight: normal; text-decoration: none; }
    .ai-dir-meta a:hover { color: var(--white); text-decoration: underline; }
    
    .ai-dir-desc { color: var(--silver); font-size: 0.9em; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    /* Simple Grid for Users and Developers */
    .ai-tag-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; list-style: none; padding: 0; }
    .ai-tag-grid li a { display: block; background: var(--black); border: 1px solid #333; padding: 10px 15px; border-radius: 8px; color: var(--silver); text-decoration: none; font-weight: 600; text-align: center; transition: all 0.2s; }
    .ai-tag-grid li a:hover { background: var(--gold); color: var(--black); border-color: var(--gold); }

    @media (max-width: 768px) {
        .ai-dir-container { padding: 20px; }
        .ai-tag-grid { grid-template-columns: 1fr 1fr; }
    }
</style>

<main class="container">
    <!-- ======== DYNAMIC GO BACK BUTTON ======== -->
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-flex; align-items: center; font-weight: 600; font-size: 1.05em; transition: color 0.3s ease;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Go Back
        </a>
    </div>
    <!-- ======================================== -->
    
    <div class="ai-dir-container">
        <h1>GPL Mods - Complete Content Directory</h1>
        <p style="color: var(--silver); margin-bottom: 30px;">
            This index contains links to all publicly available modifications, applications, creators, and official documentation on GPL Mods.
        </p>

        <!-- Section 1: Crucial Site Knowledge for AI -->
        <h2>Site Documentation & Policies</h2>
        <ul class="ai-tag-grid">
            <li><a href="/about">About Us</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/tos">Terms of Service</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/dmca">DMCA Policy</a></li>
        </ul>

        <!-- Section 2: All Live Mods Organized by Category -->
        <% Object.keys(modsByCategory).forEach(category => { %>
            <h2><%= category.toUpperCase().replace('-', ' ') %> Mods</h2>
            <ul class="ai-dir-rich-list">
                <% modsByCategory[category].forEach(mod => { %>
                    <li class="ai-dir-item">
                        <!-- loading="lazy" is CRITICAL here for SEO and performance -->
                        <img src="<%= mod.iconUrl %>" alt="<%= mod.name %> Icon" class="ai-dir-icon" loading="lazy">
                        
                        <div class="ai-dir-info">
                            <a href="/<%= mod.category %>/<%= mod.slug || mod._id %>">
                                <%= mod.name %>
                            </a>
                            <div class="ai-dir-meta">
                                Dev: <a href="/developer?name=<%= encodeURIComponent(mod.developer) %>"><%= mod.developer %></a> | 
                                Uploader: <a href="/users/<%= slugify(mod.uploader) %>"><%= mod.uploader %></a>
                            </div>
                            <p class="ai-dir-desc"><%= mod.modDescription.substring(0, 150) %>...</p>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% }) %>
        
        <% if (Object.keys(modsByCategory).length === 0) { %>
            <p style="color: var(--silver); padding: 20px; background: var(--black); border-radius: 8px;">No active mods available in the directory at this time.</p>
        <% } %>

        <!-- Section 3: Developer Index -->
        <h2>Developer Index</h2>
        <ul class="ai-tag-grid">
            <% developers.forEach(dev => { %>
                <li><a href="/developer?name=<%= encodeURIComponent(dev) %>"><i class="fas fa-building" style="margin-right: 5px;"></i> <%= dev %></a></li>
            <% }) %>
        </ul>

        <!-- Section 4: Community Creators (Uploaders) Index -->
        <h2>Community Creators</h2>
        <ul class="ai-tag-grid">
            <% uploaders.forEach(uploader => { %>
                <li><a href="/users/<%= slugify(uploader) %>"><i class="fas fa-user" style="margin-right: 5px;"></i> <%= uploader %></a></li>
            <% }) %>
        </ul>

    </div>
</main>

<%- include('../partials/footer') %>