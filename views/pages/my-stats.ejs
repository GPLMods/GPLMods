<%- include('../partials/header') %>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .stats-container { max-width: 1100px; margin: 4rem auto; padding: 0 20px; }
    .stats-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 20px;}
    .stats-header h1 { font-size: 2.5em; color: var(--white); margin: 0; }
    .stats-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }

    /* Summary Cards */
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: var(--dark-gray); padding: 30px; border-radius: 15px; border: 1px solid #333; display: flex; align-items: center; gap: 20px; transition: transform 0.3s; }
    .stat-card:hover { transform: translateY(-5px); border-color: var(--gold); }
    .stat-icon { font-size: 2.5em; color: var(--gold); background: rgba(255, 215, 0, 0.1); width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .stat-info h3 { color: var(--silver); font-size: 1em; margin: 0 0 5px 0; text-transform: uppercase; letter-spacing: 1px; }
    .stat-info .stat-val { color: var(--white); font-size: 2.2em; font-weight: bold; line-height: 1; }

    /* Chart Area */
    .chart-box { background: var(--dark-gray); padding: 30px; border-radius: 15px; border: 1px solid #333; margin-bottom: 40px; }
    .chart-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 15px; flex-wrap: wrap; gap: 15px;}
    .chart-controls select { background: var(--black); color: var(--gold); border: 1px solid #444; padding: 8px 15px; border-radius: 8px; outline: none; cursor: pointer; font-family: 'Poppins', sans-serif; font-weight: bold;}
    
    /* Table Area */
    .table-container { overflow-x: auto; background: var(--dark-gray); border-radius: 15px; border: 1px solid #333; }
    .file-table { width: 100%; border-collapse: collapse; min-width: 700px; }
    .file-table th, .file-table td { padding: 15px 20px; text-align: left; border-bottom: 1px solid #222; }
    .file-table th { background: #111; color: var(--gold); font-weight: 600; text-transform: uppercase; font-size: 0.9em; letter-spacing: 1px; }
    .file-table tr:hover { background: #1a1a1a; }
    .file-table .file-name { color: var(--white); font-weight: bold; text-decoration: none; }
    .file-table .file-name:hover { color: var(--gold); }
</style>

<main class="stats-container">
    <!-- ======== DYNAMIC GO BACK BUTTON ======== -->
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-flex; align-items: center; font-weight: 600; font-size: 1.05em; transition: color 0.3s ease;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Go Back
        </a>
    </div>
    <!-- ======================================== -->
    <div class="stats-header">
        <h1>Creator <span>Analytics</span></h1>
        <a href="/my-uploads" class="btn btn-secondary" style="border-color: #555; color: var(--silver);">Manage Uploads</a>
    </div>

    <!-- 1. Lifetime Summary Cards -->
    <div class="summary-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-eye"></i></div>
            <div class="stat-info">
                <h3>Lifetime Views</h3>
                <div class="stat-val"><%= formatCompactNumber(totalViews) %></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="color: var(--blue); background: rgba(33, 150, 243, 0.1);"><i class="fas fa-download"></i></div>
            <div class="stat-info">
                <h3>Total Downloads</h3>
                <div class="stat-val"><%= formatCompactNumber(totalDownloads) %></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="color: var(--green); background: rgba(67, 160, 71, 0.1);"><i class="fas fa-box"></i></div>
            <div class="stat-info">
                <h3>Active Mods</h3>
                <div class="stat-val"><%= files.length %></div>
            </div>
        </div>
    </div>

    <!-- 2. Chart.js Graph Area -->
    <div class="chart-box">
        <div class="chart-controls">
            <h2 style="color: var(--white); margin: 0; font-size: 1.5em;">Performance Over Time</h2>
            <select id="timeRangeSelector">
                <option value="7">Last 7 Days</option>
                <option value="30" selected>Last 30 Days</option>
                <option value="365">This Year</option>
                <option value="all">All Time</option>
            </select>
        </div>
        <div style="position: relative; height: 350px; width: 100%;">
            <canvas id="statsChart"></canvas>
        </div>
    </div>

    <!-- 3. Individual File Breakdown Table -->
    <h2 style="color: var(--white); margin-bottom: 20px;">Individual Mod Stats</h2>
    <div class="table-container">
        <table class="file-table">
            <thead>
                <tr>
                    <th>Mod Name</th>
                    <th>Platform</th>
                    <th>Date Uploaded</th>
                    <th>Total Views</th>
                    <th>Total Downloads</th>
                </tr>
            </thead>
            <tbody>
                <% if(files.length > 0) { %>
                    <% files.forEach(file => { %>
                        <tr>
                            <td><a href="/mods/<%= file._id %>" class="file-name"><%= file.name %> (<%= file.version %>)</a></td>
                            <td><span style="background: #333; padding: 4px 10px; border-radius: 12px; font-size: 0.85em; color: var(--silver);"><%= file.category.toUpperCase().replace('-', ' ') %></span></td>
                            <td style="color: var(--silver);"><%= new Date(file.createdAt).toLocaleDateString() %></td>
                            <td style="font-weight: bold; color: var(--gold);"><i class="fas fa-eye" style="font-size: 0.8em; margin-right: 5px;"></i> <%= formatCompactNumber(file.views) %></td>
                            <td style="font-weight: bold; color: var(--blue);"><i class="fas fa-download" style="font-size: 0.8em; margin-right: 5px;"></i> <%= formatCompactNumber(file.downloads) %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" style="text-align: center; color: var(--silver); padding: 30px;">You haven't uploaded any mods yet.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>

<!-- CHART.JS LOGIC -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. Get the raw daily stats injected from the backend
    const rawData = <%- dailyStatsJson %>;
    
    const ctx = document.getElementById('statsChart').getContext('2d');
    let myChart;

    // 2. Helper to filter and group data
    function renderChart(days) {
        // Create an array of the last X days
        const labels = [];
        const viewsData = [];
        const downloadsData = [];
        
        const now = new Date();
        const limit = days === 'all' ? 365 : parseInt(days); // Fallback to 1 year for "all time" visually

        // Generate the date labels backwards from today
        for (let i = limit - 1; i >= 0; i--) {
            const d = new Date();
            d.setDate(now.getDate() - i);
            const dateStr = d.toISOString().split('T')[0]; // YYYY-MM-DD
            
            // Format label for UI (e.g. "May 29")
            labels.push(d.toLocaleDateString('default', { month: 'short', day: 'numeric' }));
            
            // Filter raw data for this specific day across all files
            const dayStats = rawData.filter(stat => stat.dateString === dateStr);
            const dailyViews = dayStats.reduce((sum, stat) => sum + (stat.views || 0), 0);
            const dailyDownloads = dayStats.reduce((sum, stat) => sum + (stat.downloads || 0), 0);
            
            viewsData.push(dailyViews);
            downloadsData.push(dailyDownloads);
        }

        // 3. Destroy old chart if updating
        if (myChart) myChart.destroy();

        // 4. Draw new Chart.js instance
        myChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Views',
                        data: viewsData,
                        borderColor: '#FFD700', // Gold
                        backgroundColor: 'rgba(255, 215, 0, 0.1)',
                        borderWidth: 3,
                        pointRadius: days > 30 ? 0 : 4, // Hide dots on large datasets
                        fill: true,
                        tension: 0.4 // Smooth curves
                    },
                    {
                        label: 'Downloads',
                        data: downloadsData,
                        borderColor: '#2196F3', // Blue
                        backgroundColor: 'rgba(33, 150, 243, 0.1)',
                        borderWidth: 3,
                        pointRadius: days > 30 ? 0 : 4,
                        fill: true,
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { labels: { color: '#c0c0c0', font: { family: 'Poppins' } } },
                    tooltip: { mode: 'index', intersect: false, backgroundColor: '#0a0a0a', titleColor: '#FFD700', bodyFont: { size: 14 } }
                },
                scales: {
                    y: { beginAtZero: true, grid: { color: '#333' }, ticks: { color: '#a0a0a0', precision: 0 } },
                    x: { grid: { display: false }, ticks: { color: '#a0a0a0', maxTicksLimit: 10 } }
                },
                interaction: { mode: 'nearest', axis: 'x', intersect: false }
            }
        });
    }

    // Initialize with 30 days
    renderChart(30);

    // Update chart when dropdown changes
    document.getElementById('timeRangeSelector').addEventListener('change', function() {
        renderChart(this.value);
    });
});
</script>

<%- include('../partials/footer') %>