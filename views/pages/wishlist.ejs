<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/style.css">

<main class="container" style="padding-bottom: 60px;">
    
    <!-- Header Section -->
    <div style="text-align: center; padding: 60px 20px 40px;">
        <h1 style="color: var(--white); font-size: 2.8em; margin-bottom: 10px;">My <span style="color: var(--red); text-shadow: 0 0 15px var(--glow-red);">Wishlist</span></h1>
        <p style="color: var(--silver); font-size: 1.1em;">Mods you have saved for later.</p>
    </div>
    
    <!-- Top Action Bar -->
    <!-- ✅ FIX 1: This div is now properly closed below the Back button -->
    <div style="display: flex; justify-content: flex-start; margin-bottom: 30px;">
        <a href="/dashboard" class="btn btn-secondary" style="background: transparent; border: 2px solid #333; color: var(--silver); padding: 8px 20px; border-radius: 20px; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.borderColor='var(--silver)'; this.style.color='var(--white)';" onmouseout="this.style.borderColor='#333'; this.style.color='var(--silver)';">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Back
        </a>
    </div> <!-- ✅ The critical missing closing div -->

    <!-- Main Content Area -->
    <% if (whitelistedMods && whitelistedMods.length > 0) { %>
        <!-- We use the standard mod-grid layout! -->
        <section class="mod-grid">
            <% whitelistedMods.forEach(file => { %>
                <!-- We inject the Universal Mod Card Partial -->
                <%- include('../partials/mod-card', { file: file, user: user, timeAgo: timeAgo, truncateText: (str, num) => str.length > num ? str.substring(0, num) + '...' : str }) %>
            <% }) %>
        </section>
        
    <% } else { %>
        <!-- Empty State -->
        <div style="text-align: center; padding: 60px 20px; background: var(--dark-gray); border-radius: 15px; border: 1px dashed #444; max-width: 600px; margin: 0 auto;">
            <lottie-player 
                src="/animations/broken-heart.json" 
                background="transparent" 
                speed="1" 
                style="width: 120px; height: 120px; margin: 0 auto 20px auto; filter: drop-shadow(0 0 15px rgba(229, 57, 53, 0.3));" 
                loop autoplay>
            </lottie-player>
            <h2 style="color: var(--white); margin-bottom: 10px;">Your Wishlist is Empty</h2>
            <p style="color: var(--silver); font-size: 1.1em; margin-bottom: 25px;">Explore the site and click "Add to Wishlist" on any mod to save it here!</p>
            
            <!-- ✅ FIX 2: Added explicit color override so it doesn't look like standard link text -->
            <a href="/category" class="btn btn-primary" style="padding: 12px 30px; font-size: 1.1em; border-radius: 25px; background-color: var(--gold); color: var(--black) !important; text-decoration: none; font-weight: bold; box-shadow: 0 0 15px var(--glow-gold); display: inline-block;">Browse Mods</a>
        </div>
    <% } %>
</main>

<%- include('../partials/footer') %>