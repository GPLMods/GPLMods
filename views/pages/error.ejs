<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= errorCode %> Error - GPL Mods</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/error-pages.css">
    
    <!-- We inline some CSS variables just in case the main CSS fails to load during a 500 error -->
    <style>
        :root {
            --gold: #FFD700;
            --black: #0a0a0a;
            --glow-gold: rgba(255, 215, 0, 0.5);
            /* Dynamic colors based on error code */
            --error-color: <%= errorCode == 500 || errorCode == 403 ? '#e53935' : 'var(--gold)' %>;
            --glow-error: <%= errorCode == 500 || errorCode == 403 ? 'rgba(229, 57, 53, 0.5)' : 'var(--glow-gold)' %>;
        }
        
        .error-code { color: var(--error-color); text-shadow: 0 0 20px var(--glow-error); }
        .error-title span { color: var(--error-color); text-shadow: 0 0 15px var(--glow-error); }
    </style>
</head>
<body>

    <main class="error-container container">
        <div class="error-code"><%= errorCode %></div>
        <h1 class="error-title"><%- errorTitle %></h1> <!-- Using <%- %> in case we pass HTML like spans -->
        <p class="error-message"><%= errorMessage %></p>
        
        <!-- Only show the go home button if it's NOT a ban message (or show a different button) -->
        <a href="<%= user ? '/home' : '/' %>" class="btn" style="margin-top: 2rem; display: inline-block; background: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 25px; font-weight: bold; text-decoration: none; box-shadow: 0 0 15px var(--glow-gold); transition: transform 0.3s ease;">
            Go to Homepage
        </a>
    </main>

</body>
</html>