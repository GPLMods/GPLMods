<%- include('../partials/header') %>

<style>
    /* Most of your styles are moving to style.css, but we keep page-specific ones here */
    .page-header { text-align: center; padding: 60px 20px; }
    .page-header h1 { font-size: 3em; color: var(--white); }
    .page-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .page-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap; gap: 15px; }
    .upload-cta-button { display: inline-block; background: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 30px; text-decoration: none; font-size: 1.1em; font-weight: 600; transition: all 0.3s ease; box-shadow: 0 0 15px var(--glow-gold); }
    .upload-cta-button:hover { transform: translateY(-3px); box-shadow: 0 0 25px var(--glow-gold); }
    .filter-tabs { display: flex; flex-wrap: wrap; gap: 10px; }
    .filter-btn { background-color: var(--dark-gray); color: var(--silver); padding: 10px 20px; border: 1px solid var(--dark-gray); border-radius: 20px; cursor: pointer; transition: all 0.3s ease; font-size: 0.9em; font-family: inherit; }
    .filter-btn:hover, .filter-btn.active { background-color: var(--gold); color: var(--black); border-color: var(--gold); font-weight: 600; }
    .uploads-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px; }
    .upload-item { background-color: var(--dark-gray); border-radius: 15px; overflow: hidden; position: relative; display: flex; flex-direction: column; transition: transform 0.3s ease, box-shadow 0.3s ease; border: 1px solid #2a2a2a; }
    .upload-item:hover { transform: translateY(-5px); box-shadow: 0 0 20px rgba(255, 215, 0, 0.15); }
    .mod-card-image { height: 150px; background-color: #222; display: flex; align-items: center; justify-content: center; padding: 20px; border-bottom: 1px solid #333; }
    .mod-card-image img { max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.4)); }
    .mod-card-content { padding: 20px; display: flex; flex-direction: column; flex-grow: 1; }
    .item-title { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; gap: 10px; }
    .item-title h3 { font-size: 1.25em; margin: 0; color: var(--white); line-height: 1.3; }
    .item-details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px 10px; margin-bottom: 25px; font-size: 0.85em; }
    .detail-row { display: flex; flex-direction: column; }
    .detail-row span:first-child { color: var(--silver); font-weight: 300; font-size: 0.9em; margin-bottom: 2px; }
    .detail-row span:last-child { color: var(--white); font-weight: 500; }
    .detail-row.rating span:last-child { color: var(--gold); }
    .detail-row.working-vote span:last-child { color: var(--green); }
    .detail-row.full-width { grid-column: 1 / -1; }
    .item-status-actions { display: flex; justify-content: space-between; align-items: center; padding-top: 15px; border-top: 1px solid #333; margin-top: auto; flex-wrap: wrap; gap: 15px; }
    .status-badge { display: inline-block; padding: 6px 14px; border-radius: 20px; font-size: 0.8em; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
    .status-live { background-color: var(--green); color: var(--white); }
    .status-pending, .status-processing { background-color: var(--gold); color: var(--black); }
    .status-rejected { background-color: var(--red); color: var(--white); }
    .item-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .item-actions a, .item-actions button { display: inline-block; padding: 6px 14px; border-radius: 6px; text-decoration: none; font-weight: 600; border: 1px solid var(--silver); color: var(--silver); background: transparent; transition: all 0.3s ease; font-size: 0.85em; cursor: pointer; font-family: inherit;}
    .item-actions a:hover, .item-actions button:hover { color: var(--white); border-color: var(--white); }
    .item-actions .delete-btn { border-color: rgba(229, 57, 53, 0.5); color: #e57373; }
    .item-actions .delete-btn:hover { background-color: var(--red); color: var(--white); border-color: var(--red); }
    .item-actions .edit-resubmit-btn { border-color: rgba(255, 215, 0, 0.5); color: #ffd54f; }
    .item-actions .edit-resubmit-btn:hover { background-color: var(--gold); color: var(--black); border-color: var(--gold); }
    .item-actions .view-btn { border-color: rgba(33, 150, 243, 0.5); color: #64b5f6; }
    .item-actions .view-btn:hover { background-color: var(--blue); color: var(--white); border-color: var(--blue); }
    
    @media (max-width: 768px) {
        .page-actions { flex-direction: column; align-items: flex-start; }
        .filter-tabs { width: 100%; justify-content: flex-start; margin-top: 10px; }
        .uploads-list { grid-template-columns: 1fr; }
        .item-status-actions { flex-direction: column; align-items: stretch; gap: 15px; }
        .item-actions { justify-content: flex-end; }
    }
</style>

<main>
    <div class="page-header">
        <div class="container">
            <h1>My <span>Uploads</span></h1>
        </div>
    </div>
    
    <div class="container">
        <div class="page-actions">
            <a href="/upload" class="upload-cta-button">Upload a New Mod</a>
            <div class="filter-tabs">
                <button class="filter-btn active" data-category="all">All</button>
                <button class="filter-btn" data-category="android">Android</button>
                <button class="filter-btn" data-category="ios-jailed">Jailed (IPA)</button>
                <button class="filter-btn" data-category="ios-jailbroken">Jailbroken (DEB)</button>
                <button class="filter-btn" data-category="windows">Windows</button>
                <button class="filter-btn" data-category="wordpress">WordPress</button>
            </div>
        </div>

        <div class="uploads-list">
            <% if(uploads && uploads.length > 0) { %>
                <% uploads.forEach(file => { %>
                    <!-- The data-category ensures the filter buttons work -->
                    <div class="upload-item" data-category="<%= file.category %>">
                        <div class="mod-card-image">
                            <img src="<%= file.iconUrl %>" alt="<%= file.name %> Icon">
                        </div>
                        <div class="mod-card-content">
                            <div class="item-title">
                                <h3><%= file.name %></h3>
                                <!-- CUSTOM COLOR PLATFORM TAG -->
                                <span class="platform-tag <%= file.category.replace('-jailed', '-ipa').replace('-jailbroken', '-deb') %>" style="padding: 4px 10px; border-radius: 6px; font-size: 0.75em; font-weight: 600; white-space: nowrap;">
                                    <%= file.category.toUpperCase().replace('-', ' ') %>
                                </span>
                            </div>
                            
                            <div class="item-details-grid">
                                <div class="detail-row">
                                    <span>Downloads:</span>
                                    <span><%= file.downloads.toLocaleString() %></span>
                                </div>
                                <div class="detail-row rating">
                                    <span>AVG Rating:</span>
                                    <span><%= file.averageRating.toFixed(1) %> ★</span>
                                </div>
                                <% const totalVotes = file.workingVoteCount + file.notWorkingVoteCount; %>
                                <% const workingPercentage = totalVotes > 0 ? ((file.workingVoteCount / totalVotes) * 100).toFixed(0) : 'N/A'; %>
                                <div class="detail-row working-vote">
                                    <span>Working Vote:</span>
                                    <span><%= workingPercentage %><%= totalVotes > 0 ? '%' : '' %></span>
                                </div>
                                <div class="detail-row">
                                    <span>Date Uploaded:</span>
                                    <span><%= file.createdAt.toLocaleDateString() %></span>
                                </div>
                                
                                <% if (file.status === 'rejected' && file.rejectionReason) { %>
                                    <div class="detail-row full-width">
                                        <span style="color: var(--red);">Reason for Rejection:</span>
                                        <span style="color: var(--silver); font-style: italic;"><%= file.rejectionReason %></span>
                                    </div>
                                <% } %>
                            </div>

                            <div class="item-status-actions">
                                <span class="status-badge status-<%= file.status %>">
                                    <%= file.status === 'processing' ? 'Processing...' : file.status %>
                                </span>
                                
                                <div class="item-actions">
                                    <% if (file.status === 'live') { %>
                                        <a href="/mods/<%= file._id %>" class="view-btn">View</a>
                                    <% } %>
                                    
                                    <!-- EDIT BUTTON -->
                                    <a href="/mods/<%= file._id %>/edit" class="edit-resubmit-btn">
                                        <%= file.status === 'rejected' ? 'Edit & Resubmit' : 'Edit' %>
                                    </a>
                                    
                                    <!-- DELETE BUTTON (Uses data-id to tell JS which mod to delete) -->
                                    <button class="delete-btn" data-id="<%= file._id %>">Delete</button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="text-align: center; width: 100%; color: var(--silver); grid-column: 1 / -1; padding: 40px;">
                    You haven't uploaded any mods yet.
                </p>
            <% } %>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- LIVE DELETE FUNCTIONALITY ---
        const deleteButtons = document.querySelectorAll('.delete-btn');
        deleteButtons.forEach(button => {
            button.addEventListener('click', async function(event) {
                const modId = this.dataset.id; // Get the ID from the button
                const confirmation = confirm('Are you sure you want to permanently delete this mod? This action cannot be undone.');
                
                if (confirmation) {
                    try {
                        // Send a POST request to our new backend route
                        const response = await fetch(`/mods/${modId}/delete`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            // Trigger the beautiful fade out animation
                            const itemToRemove = this.closest('.upload-item');
                            itemToRemove.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                            itemToRemove.style.opacity = '0';
                            itemToRemove.style.transform = 'scale(0.9)';
                            
                            // Remove from DOM after animation
                            setTimeout(() => {
                                itemToRemove.remove();
                            }, 500);
                        } else {
                            alert('Failed to delete the mod. Please try again later.');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        alert('An error occurred while deleting the mod.');
                    }
                }
            });
        });

        // --- Filter Tabs Logic ---
        const filterButtons = document.querySelectorAll('.filter-btn');
        const uploadItems = document.querySelectorAll('.upload-item');

        filterButtons.forEach(button => {
            button.addEventListener('click', function() {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                const category = this.dataset.category;

                uploadItems.forEach(item => {
                    if (category === 'all' || item.dataset.category.includes(category)) {
                        item.style.display = 'flex'; 
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        });
    });
</script>

<%- include('../partials/footer') %>