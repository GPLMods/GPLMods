<%- include('../partials/header') %>

<style>
    .hub-container { max-width: 800px; margin: 4rem auto; text-align: center; }
    .hub-container h1 { font-size: 2.8em; color: var(--white); margin-bottom: 10px; }
    .hub-container h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .hub-container p { color: var(--silver); font-size: 1.1em; margin-bottom: 3rem; }

    .notification-categories {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .category-card {
        background-color: var(--dark-gray);
        border: 1px solid #333;
        border-radius: 15px;
        padding: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        text-decoration: none;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .category-card:hover {
        transform: translateY(-5px);
        border-color: var(--gold);
        box-shadow: 0 10px 25px rgba(255, 215, 0, 0.1);
    }

    .category-info {
        display: flex;
        align-items: center;
        gap: 20px;
        text-align: left;
    }

    .category-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: var(--black);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8em;
        color: var(--gold);
        border: 2px solid #333;
    }

    .category-text h2 {
        color: var(--white);
        margin: 0 0 5px 0;
        font-size: 1.5em;
    }

    .category-text p {
        color: var(--silver);
        margin: 0;
        font-size: 0.95em;
    }

    .card-arrow {
        color: var(--silver);
        font-size: 1.5em;
        transition: transform 0.3s;
    }

    .category-card:hover .card-arrow {
        transform: translateX(5px);
        color: var(--gold);
    }

    /* The Red Badge for Categories */
    .cat-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        background-color: var(--red);
        color: var(--white);
        font-weight: bold;
        font-size: 0.85em;
        padding: 4px 10px;
        border-radius: 20px;
        box-shadow: 0 0 10px var(--glow-red);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    /* Hide the global badge initially, JS will show it if needed */
    #global-badge { display: none; }
</style>

<main class="container">
    <!-- ======== DYNAMIC GO BACK BUTTON ======== -->
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-flex; align-items: center; font-weight: 600; font-size: 1.05em; transition: color 0.3s ease;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Go Back
        </a>
    </div>
    <!-- ======================================== -->
    <div class="hub-container">
        <h1>Your <span>Notifications</span></h1>
        <p>Select a category below to view your alerts and updates.</p>

        <!-- ALL CARDS MUST BE INSIDE THIS DIV -->
        <div class="notification-categories">
            
            <!-- ✅ FIX: Logged-in Users Only -->
            <% if (user) { %>
                <!-- Category 1: Admin Responses (Personal) -->
                <a href="/notifications/admin-messages" class="category-card">
                    <div class="category-info">
                        <div class="category-icon" style="background: transparent; border: none;">
                            <lottie-player src="/animations/massage.json" background="transparent" speed="1" style="width: 80px; height: 80px; transform: scale(1.5);" loop autoplay></lottie-player>
                        </div>
                        <div class="category-text">
                            <h2>Admin Responses</h2>
                            <p>Direct messages, warnings, and support ticket replies.</p>
                        </div>
                    </div>
                    
                    <% if (typeof unreadPersonalCount !== 'undefined' && unreadPersonalCount > 0) { %>
                        <div class="cat-badge">
                            <%= unreadPersonalCount > 9 ? '9+' : unreadPersonalCount %> New
                        </div>
                    <% } else { %>
                        <i class="fas fa-chevron-right card-arrow"></i>
                    <% } %>
                </a>
            <% } %>

            <!-- Category 2: Site Updates (Global - Visible to Everyone) -->
            <a href="/notifications/site-updates" class="category-card" id="site-updates-card" data-total-updates="<%= typeof totalGlobalUpdates !== 'undefined' ? totalGlobalUpdates : 0 %>">
                <div class="category-info">
                    <div class="category-icon" style="background: transparent; border: none;">
                        <lottie-player src="/animations/update.json" background="transparent" speed="1" style="width: 80px; height: 80px; transform: scale(1.5);" loop autoplay></lottie-player>
                    </div>
                    <div class="category-text">
                        <h2>Site Updates</h2>
                        <p>Global announcements, new features, and patch notes.</p>
                    </div>
                </div>
                <div class="cat-badge" id="global-badge"></div>
                <i class="fas fa-chevron-right card-arrow" id="global-arrow"></i>
            </a>

            <!-- Category 3: New Uploads (24h - Visible to Everyone) -->
            <a href="/notifications/new-uploads" class="category-card" id="new-uploads-card">
                <div class="category-info">
                    <div class="category-icon" style="background: transparent; border: none;">
                        <lottie-player src="/animations/upload.json" background="transparent" speed="1" style="width: 80px; height: 80px; transform: scale(1.5);" loop autoplay></lottie-player>
                    </div>
                    <div class="category-text">
                        <h2>New Uploads (24h)</h2>
                        <p>Fresh mods added to the platform today.</p>
                    </div>
                </div>
                <div class="cat-badge" id="uploads-badge" style="display: none;"></div>
                <i class="fas fa-chevron-right card-arrow"></i>
            </a>

            <!-- Category 4: New Updates (24h - Visible to Everyone) -->
            <a href="/notifications/new-updates" class="category-card" id="new-updates-card">
                <div class="category-info">
                    <div class="category-icon" style="background: transparent; border: none;">
                        <lottie-player src="/animations/sync.json" background="transparent" speed="1" style="width: 80px; height: 80px; transform: scale(1.5);" loop autoplay></lottie-player>
                    </div>
                    <div class="category-text">
                        <h2>Recent Updates (24h)</h2>
                        <p>Existing mods that were updated today.</p>
                    </div>
                </div>
                <i class="fas fa-chevron-right card-arrow" id="mods-update-arrow"></i>
            </a>

            <!-- ✅ FIX: Logged-in Users Only -->
            <% if (user) { %>
                <!-- Category 5: Following Feed -->
                 <a href="/notifications/following" class="category-card" id="following-card">
                    <div class="category-info">
                        <div class="category-icon" style="background: transparent; border: none;">
                            <lottie-player src="/animations/group.json" background="transparent" speed="1" style="width: 80px; height: 80px; transform: scale(1.5);" loop autoplay></lottie-player>
                        </div>
                        <div class="category-text">
                            <h2>Following Updates</h2>
                            <p>Latest uploads and updates from members you follow.</p>
                        </div>
                    </div>
                    <div class="cat-badge" id="following-badge" style="display: none;"></div>
                    <i class="fas fa-chevron-right card-arrow"></i>
                </a>
            <% } %>

        </div> <!-- Closes .notification-categories -->
    </div> <!-- Closes .hub-container -->
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        
        // Helper function to setup independent badge logic for each card!
        function setupBadge(cardId, badgeId, arrowId, localStorageKey, currentCount) {
            const card = document.getElementById(cardId);
            const badge = document.getElementById(badgeId);
            const arrow = document.getElementById(arrowId);
            
            if (card && badge) {
                const lastSeen = parseInt(localStorage.getItem(localStorageKey) || '0', 10);
                const unread = currentCount - lastSeen;
                
                if (unread > 0) {
                    badge.textContent = (unread > 9 ? '9+' : unread) + ' New';
                    badge.style.display = 'flex';
                    if (arrow) arrow.style.display = 'none';
                }
                
                // When they click THIS SPECIFIC card, save the view to localStorage!
                card.addEventListener('click', () => {
                    localStorage.setItem(localStorageKey, currentCount.toString());
                });
            }
        }
        
        // Pass the EJS server variables safely into the JavaScript
        const totalUpdates = <%= typeof totalUpdatesCount !== 'undefined' ? totalUpdatesCount : 0 %>;
        const totalUploads = <%= typeof newUploadsCount !== 'undefined' ? newUploadsCount : 0 %>;
        const totalModsUpdates = <%= typeof newUpdatesCount !== 'undefined' ? newUpdatesCount : 0 %>;
        const totalFollowing = <%= typeof followingCount !== 'undefined' ? followingCount : 0 %>;

        // Initialize each card independently!
        setupBadge('site-updates-card', 'global-badge', 'global-arrow', 'lastSeenUpdates', totalUpdates);
        setupBadge('new-uploads-card', 'uploads-badge', 'uploads-arrow', 'lastSeenUploads', totalUploads);
        setupBadge('new-updates-card', 'mods-update-badge', 'mods-update-arrow', 'lastSeenModsUpd', totalModsUpdates);
        
        // For logged-in users only
        if (document.getElementById('following-card')) {
            setupBadge('following-card', 'following-badge', 'following-arrow', 'lastSeenFollowing', totalFollowing);
        }
    });
</script>

<%- include('../partials/footer') %>