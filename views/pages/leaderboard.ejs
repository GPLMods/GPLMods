<%- include('../partials/header') %>

<style>
    .lb-header { text-align: center; padding: 60px 20px 20px; }
    .lb-header h1 { font-size: 3em; color: var(--white); }
    .lb-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    
    .lb-controls { display: flex; flex-direction: column; gap: 20px; align-items: center; margin-bottom: 40px; }
    
    .lb-tabs { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; background: var(--dark-gray); padding: 10px; border-radius: 30px; border: 1px solid #333; }
    .lb-tab { padding: 10px 25px; border-radius: 20px; color: var(--silver); text-decoration: none; font-weight: bold; transition: all 0.3s ease; }
    .lb-tab:hover { color: var(--white); }
    .lb-tab.active { background: var(--gold); color: var(--black); box-shadow: 0 0 15px var(--glow-gold); }

    .time-tabs { display: flex; gap: 5px; }
    .time-tab { padding: 5px 15px; border-radius: 15px; border: 1px solid #444; color: var(--silver); text-decoration: none; font-size: 0.9em; transition: all 0.2s; }
    .time-tab.active { border-color: var(--gold); color: var(--gold); background: rgba(255,215,0,0.1); }

    .lb-container { max-width: 900px; margin: 0 auto 60px auto; background: var(--dark-gray); border-radius: 15px; border: 1px solid #333; padding: 20px; }
    
    .lb-item { display: flex; align-items: center; padding: 15px; border-bottom: 1px solid #222; transition: background 0.3s; border-radius: 10px; text-decoration: none; color: inherit; }
    .lb-item:hover { background: #222; }
    .lb-item:last-child { border-bottom: none; }

    /* ✅ FIX: Adjusted rank container to fit the Lottie animation */
    .lb-rank { width: 60px; display: flex; justify-content: center; align-items: center; margin-right: 15px; font-weight: bold; color: #555; }
    
    /* Removed the old text-color medals, adding glowing borders for top 3 instead */
    .lb-avatar { width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-right: 20px; border: 2px solid #444; }
    .rank-1 .lb-avatar { border-color: #FFD700; box-shadow: 0 0 15px var(--glow-gold); }
    .rank-2 .lb-avatar { border-color: #C0C0C0; box-shadow: 0 0 15px rgba(192,192,192,0.4); }
    .rank-3 .lb-avatar { border-color: #CD7F32; box-shadow: 0 0 15px rgba(205,127,50,0.4); }

    .lb-avatar { width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-right: 20px; border: 2px solid #444; }
    .rank-1 .lb-avatar { border-color: #FFD700; box-shadow: 0 0 10px var(--glow-gold); }

    .lb-info { flex-grow: 1; display: flex; flex-direction: column; }
    .lb-name { font-size: 1.2em; font-weight: bold; color: var(--white); }
    .lb-subtext { font-size: 0.85em; color: var(--silver); }
    
    .lb-score { font-size: 1.3em; font-weight: bold; color: var(--gold); }
    .lb-score-label { font-size: 0.7em; color: var(--silver); text-transform: uppercase; margin-left: 5px; }

    .role-badge { font-size: 0.7em; padding: 2px 8px; border-radius: 10px; margin-left: 10px; background: #333; color: var(--silver); text-transform: uppercase; }
    .role-admin { background: var(--red); color: white; }
    .role-distributor { background: var(--blue); color: white; }

</style>

<main>
    <div class="lb-header">
        <h1>Global <span>Leaderboards</span></h1>
        <p style="color: var(--silver);">The top 100 creators, files, and supporters in the GPL Community.</p>
    </div>

    <div class="container">
        <div class="lb-controls">
            <!-- Category Tabs -->
            <div class="lb-tabs">
                <a href="/leaderboard?category=uploaders&timeframe=<%= currentTimeframe %>" class="lb-tab <%= currentCategory === 'uploaders' ? 'active' : '' %>">Top Uploaders</a>
                <a href="/leaderboard?category=downloaded&timeframe=<%= currentTimeframe %>" class="lb-tab <%= currentCategory === 'downloaded' ? 'active' : '' %>">Most Downloaded</a>
                <a href="/leaderboard?category=followed" class="lb-tab <%= currentCategory === 'followed' ? 'active' : '' %>">Most Followed</a>
                <a href="/leaderboard?category=donators&timeframe=<%= currentTimeframe %>" class="lb-tab <%= currentCategory === 'donators' ? 'active' : '' %>">Top Donators</a>
            </div>

            <!-- Timeframe Tabs (Hidden for 'Followed' as it's an absolute metric) -->
            <% if (currentCategory !== 'followed') { %>
            <div class="time-tabs">
                <a href="/leaderboard?category=<%= currentCategory %>&timeframe=daily" class="time-tab <%= currentTimeframe === 'daily' ? 'active' : '' %>">Daily</a>
                <a href="/leaderboard?category=<%= currentCategory %>&timeframe=weekly" class="time-tab <%= currentTimeframe === 'weekly' ? 'active' : '' %>">Weekly</a>
                <a href="/leaderboard?category=<%= currentCategory %>&timeframe=monthly" class="time-tab <%= currentTimeframe === 'monthly' ? 'active' : '' %>">Monthly</a>
                <a href="/leaderboard?category=<%= currentCategory %>&timeframe=all-time" class="time-tab <%= currentTimeframe === 'all-time' ? 'active' : '' %>">All-Time</a>
            </div>
            <% } %>
        </div>

        <div class="lb-container">
            <% if (results && results.length > 0) { %>
                <% results.forEach((item, index) => { %>
                    <% const rank = index + 1; %>
                    
                    <!-- Link to user profile or mod page -->
                    <% const itemLink = item.link ? item.link : `/users/${item.name}`; %>

                    <a href="<%= itemLink %>" class="lb-item rank-<%= rank %>">
                        
                        <!-- ======== LOTTIE ANIMATED RANK BADGES ======== -->
                        <div class="lb-rank">
                            <% if(rank <= 10) { %>
                                <!-- For Ranks 1 to 10, it loads rank-1.json, rank-2.json, etc. -->
                                <lottie-player 
                                    src="/animations/rank-<%= rank %>.json" 
                                    background="transparent" 
                                    speed="1" 
                                    style="width: 55px; height: 55px; transform: scale(1.3);" 
                                    loop 
                                    autoplay>
                                </lottie-player>
                            <% } else { %>
                                <!-- Fallback text for ranks 11 to 100 -->
                                <span style="font-size: 1.2em; color: var(--silver);">#<%= rank %></span>
                            <% } %>
                        </div>
                        <!-- ============================================= -->
                        
                        <img src="<%= item.avatar %>" alt="Avatar" class="lb-avatar">
                        
                        <div class="lb-info">
                            <div style="display: flex; align-items: center;">
                                <span class="lb-name"><%= item.name %></span>
                                <% if (item.role && item.role !== 'member') { %>
                                    <span class="role-badge role-<%= item.role %>"><%= item.role %></span>
                                <% } %>
                            </div>
                            <% if (item.subtext) { %><span class="lb-subtext"><%= item.subtext %></span><% } %>
                        </div>
                        
                        <div class="lb-score">
                            <%= item.score %>
                            <% if (!item.isCurrency) { %>
                                <span class="lb-score-label">
                                    <%= currentCategory === 'uploaders' ? 'Mods' : (currentCategory === 'downloaded' ? 'DLs' : 'Followers') %>
                                </span>
                            <% } %>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 40px; color: var(--silver);">
                    <i class="fas fa-trophy" style="font-size: 3em; color: #444; margin-bottom: 15px; display: block;"></i>
                    <h3>No data available for this timeframe.</h3>
                    <p>Be the first to claim a spot on the leaderboard!</p>
                </div>
            <% } %>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>