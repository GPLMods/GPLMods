            <button id="openMembersModal" class="btn btn-secondary" style="background: transparent; border: 2px solid var(--gold); color: var(--gold); padding: 12px 30px; font-size: 1.1em; border-radius: 25px; transition: all 0.3s; cursor: pointer;">
                <i class="fas fa-users" style="margin-right: 8px;"></i> View Extended Team & Top Contributors
            </button>
        </div>
    </section>

    <!-- NEW: Social Media Platforms Section -->
    <section class="about-section">
        <h2 class="section-title">Connect With Us</h2>
        <p style="text-align: center; color: var(--silver); margin-bottom: 30px;">Join the conversation, report bugs, and request new mods on our official channels.</p>
        <div class="social-grid">
            <a href="https://discord.gg/frBQ2zTu7" target="_blank" class="social-card discord">
                <i class="fab fa-discord"></i> Discord Server
            </a>
            <a href="https://youtube.com/@gplmods" target="_blank" class="social-card youtube">
                <i class="fab fa-youtube"></i> YouTube Channel
            </a>
            <a href="https://github.com/GPLMods" target="_blank" class="social-card github">
                <i class="fab fa-github"></i> GitHub Repository
            </a>
