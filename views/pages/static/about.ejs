<%- include('../../../partials/header') %>

<style>
    /* --- ABOUT PAGE SPECIFIC STYLES --- */
    .page-header { text-align: center; padding: 60px 20px; }
    .page-header h1 { font-size: 3.5em; color: var(--white); margin-bottom: 10px; }
    .page-header h1 .gold { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .page-header h1 .silver { color: var(--silver); text-shadow: 0 0 10px var(--glow-silver); }
    .page-header p { font-size: 1.2em; color: var(--silver); max-width: 700px; margin: 15px auto 0 auto; line-height: 1.6; }

    .about-section { padding: 50px 0; border-bottom: 1px solid #222; }
    .about-section:last-of-type { border-bottom: none; }
    .section-title { text-align: center; font-size: 2.5em; margin-bottom: 40px; color: var(--white); }
    
    /* Core Principles */
    .feature-grid { display: grid; grid-template-columns: 1fr; gap: 40px; align-items: flex-start; }
    .feature-item { display: flex; align-items: flex-start; gap: 25px; background: var(--dark-gray); padding: 25px; border-radius: 15px; border: 1px solid #333; transition: transform 0.3s, border-color 0.3s; }
    .feature-item:hover { transform: translateY(-5px); border-color: var(--gold); }
    .feature-text h3 { font-size: 1.5em; margin-bottom: 10px; color: var(--white); }
    .feature-text p { color: var(--silver); line-height: 1.7; }

    /* Team Section */
    .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 30px; }
    .team-card { background-color: var(--dark-gray); padding: 25px; text-align: center; border-radius: 15px; border: 1px solid #333; transition: all 0.3s ease; }
    .team-card:hover { transform: translateY(-10px); border-color: var(--gold); box-shadow: 0 0 20px var(--glow-gold); }
    .team-card img { width: 100px; height: 100px; border-radius: 50%; border: 3px solid var(--gold); margin-bottom: 15px; object-fit: cover; }
    .team-card h4 { font-size: 1.3em; margin-bottom: 5px; color: var(--white); }
    .team-card span { color: var(--gold); font-weight: 600; font-size: 0.9em; }

    /* Extended Members Modal */
    .members-modal { display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,0.8); align-items: center; justify-content: center; backdrop-filter: blur(5px); }
    .members-modal-content { background: var(--dark-gray); border-top: 3px solid var(--gold); width: 90%; max-width: 600px; max-height: 80vh; overflow-y: auto; border-radius: 15px; padding: 30px; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .close-modal-btn { position: absolute; top: 20px; right: 20px; font-size: 2em; color: var(--silver); cursor: pointer; transition: color 0.2s; line-height: 1; }
    .close-modal-btn:hover { color: var(--red); }
    .extended-member-item { display: flex; align-items: center; justify-content: space-between; padding: 15px; border-bottom: 1px solid #333; }
    .extended-member-item:last-child { border-bottom: none; }
    .member-info { display: flex; align-items: center; gap: 15px; }
    .member-info img { width: 50px; height: 50px; border-radius: 50%; border: 2px solid var(--silver); }
    .member-socials a { color: var(--silver); font-size: 1.5em; margin-left: 10px; transition: color 0.2s; }
    .member-socials a:hover { color: var(--gold); }

    /* Social Media Section */
    .social-grid { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; }
    .social-card { display: flex; align-items: center; gap: 12px; background: var(--dark-gray); padding: 15px 30px; border-radius: 30px; border: 1px solid #333; color: var(--white); text-decoration: none; font-weight: 600; font-size: 1.1em; transition: all 0.3s ease; }
    .social-card.discord:hover { background: #5865F2; border-color: #5865F2; }
    .social-card.youtube:hover { background: #FF0000; border-color: #FF0000; }
    .social-card.github:hover { background: #333; border-color: #fff; }
    .social-card.telegram:hover { background: #0088cc; border-color: #0088cc; }

    /* Newsletter & CTA Section */
    .cta-section { background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%); border: 1px solid #333; text-align: center; padding: 50px 20px; margin: 40px 0 60px 0; border-radius: 15px; position: relative; overflow: hidden; }
    .newsletter-form { display: flex; max-width: 500px; margin: 25px auto 0 auto; background: var(--black); border-radius: 30px; border: 1px solid var(--gold); overflow: hidden; box-shadow: 0 0 15px rgba(255, 215, 0, 0.1); }
    .newsletter-form input { flex-grow: 1; background: transparent; border: none; padding: 15px 25px; color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; outline: none; }
    .newsletter-form button { background: var(--gold); color: var(--black); border: none; padding: 0 30px; font-weight: 700; cursor: pointer; transition: background 0.3s; font-family: 'Poppins', sans-serif; }
    .newsletter-form button:hover { background: #fff; }

    @media (min-width: 768px) {
        .feature-grid { grid-template-columns: 1fr 1fr; }
        .feature-item:last-child { grid-column: 1 / -1; max-width: 800px; margin: 0 auto; } /* Centers the 3rd feature beautifully */
    }
</style>

<main class="container">
    <div class="page-header">
        <h1>About <span class="gold">GPL</span> <span class="silver">Mods</span></h1>
        <p>Discover our core philosophy, meet the community behind the platform, and learn why your safety is our ultimate priority.</p>
    </div>
    
