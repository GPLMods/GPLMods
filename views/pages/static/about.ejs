        <!-- ✅ FIX: A dedicated spot to show the JSON success/error messages -->
        <div id="newsletter-message" style="margin-top: 15px; font-weight: bold; min-height: 24px; transition: color 0.3s;"></div>

        <div style="margin-top: 40px; border-top: 1px solid #333; padding-top: 30px;">
            <p style="color: var(--silver); margin-bottom: 15px;">Want to actively contribute to the platform?</p>
            <a href="/register" class="btn" style="background: transparent; color: var(--white); border: 1px solid #555; padding: 10px 25px; border-radius: 20px; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)';" onmouseout="this.style.borderColor='#555'; this.style.color='var(--white)';">Create an Account</a>
