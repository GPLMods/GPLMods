    </section>

    <!-- NEW & UPDATED: Newsletter & CTA Section -->
    <section class="cta-section">
        <h2 style="color: var(--gold); font-size: 2.2em; margin-bottom: 10px;">Never Miss an Update</h2>
        <p style="color: var(--silver); font-size: 1.1em;">Join our newsletter to receive the latest 100% working mods and community news straight to your inbox.</p>
        
        <!-- ✅ FIX: Changed to an ID-based form for AJAX, removed action/method -->
        <form id="about-newsletter-form" class="newsletter-form">
            <input type="email" id="newsletter-email" placeholder="Enter your email address..." required>
            <!-- Hidden input to tell your API where this came from -->
            <input type="hidden" id="newsletter-source" value="about-page">
            <button type="submit" id="newsletter-submit-btn">Subscribe</button>
