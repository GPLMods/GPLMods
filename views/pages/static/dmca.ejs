<%- include('../../partials/header') %>

<style>
    /* Specific styles for the DMCA Page to prevent conflicts */
    .dmca-page-header { text-align: center; padding: 60px 20px; }
    .dmca-page-header h1 { font-size: 3em; color: var(--white); }
    .dmca-page-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }

    .dmca-content-section { background-color: var(--dark-gray); padding: 40px; border-radius: 15px; max-width: 900px; margin: 0 auto 50px auto; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .dmca-content-section h2 { font-size: 1.8em; color: var(--gold); margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 10px; margin-top: 30px; }
    .dmca-content-section h2:first-child { margin-top: 0; }
    .dmca-content-section p, .dmca-content-section ul { color: var(--silver); margin-bottom: 15px; font-size: 1.05em; line-height: 1.7; }
    .dmca-content-section ul { list-style-position: inside; padding-left: 10px; }
    .dmca-content-section li { margin-bottom: 10px; }
    .dmca-content-section a { color: var(--gold); text-decoration: none; font-weight: 600; }
    .dmca-content-section a:hover { text-decoration: underline; }

    .dmca-form-container { margin-top: 40px; padding-top: 30px; border-top: 1px solid #333; }
    .dmca-form-container h2 { border-bottom: none; margin-bottom: 15px; margin-top: 0;}
    .dmca-form { display: flex; flex-direction: column; gap: 20px; }
    
    .dmca-form-group { display: flex; flex-direction: column; gap: 8px; text-align: left; }
    .dmca-form-group label { color: var(--silver); font-weight: 600; font-size: 0.95em; }
    .dmca-form-group input, .dmca-form-group textarea { 
        width: 100%; 
        padding: 14px 15px; 
        border-radius: 8px; 
        border: 1px solid #333; 
        background-color: var(--black); 
        color: var(--white); 
        font-family: 'Poppins', sans-serif;
        font-size: 1em; 
        outline: none; 
        transition: all 0.3s ease; 
    }
    .dmca-form-group input:focus, .dmca-form-group textarea:focus { 
        border-color: var(--gold); 
        box-shadow: 0 0 8px var(--glow-gold); 
    }
    
    .dmca-submit-btn { 
        background-color: var(--gold); 
        color: var(--black); 
        border: none; 
        padding: 15px 20px; 
        font-size: 1.1em; 
        font-weight: 700; 
        border-radius: 8px; 
        cursor: pointer; 
        transition: all 0.3s ease; 
        text-transform: uppercase;
        margin-top: 10px;
        box-shadow: 0 0 15px var(--glow-gold);
    }
    .dmca-submit-btn:hover { 
        transform: translateY(-3px);
        box-shadow: 0 0 25px var(--glow-gold); 
    }
    
    /* Alert Box Styling */
    .dmca-alert {
        display: none;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        font-weight: bold;
        text-align: center;
        font-size: 1.1em;
    }
    .dmca-alert.success { background-color: rgba(46, 204, 113, 0.1); border: 1px solid #2ecc71; color: #2ecc71; }
    .dmca-alert.error { background-color: rgba(255, 77, 77, 0.1); border: 1px solid #ff4d4d; color: #ff4d4d; }

    @media (max-width: 768px) {
        .dmca-page-header h1 { font-size: 2.2em; }
        .dmca-content-section { padding: 25px; }
    }
</style>

<main>
    <div class="dmca-page-header">
        <div class="container">
            <h1>DMCA & <span>Copyright Policy</span></h1>
        </div>
    </div>
    
    <div class="container">
        <div class="dmca-content-section">
            
            <!-- Dynamic Success/Error Message Container -->
            <div id="dmca-alert-box" class="dmca-alert"></div>

            <h2>Our Policy</h2>
            <p>GPL Mods ("GPL") respects the intellectual property rights of others and expects its users to do the same. In accordance with the Digital Millennium Copyright Act (DMCA), we will respond promptly to notices of alleged copyright infringement that are properly submitted to our Designated Copyright Agent.</p>
            
            <h2>Notification of Copyright Infringement</h2>
            <p>If you are a copyright owner or an agent thereof and believe that any content on our platform infringes upon your copyrights, you may submit a notification pursuant to the DMCA by providing our Copyright Agent with the following information in writing:</p>
            <ul>
                <li>A physical or electronic signature of a person authorized to act on behalf of the owner of an exclusive right that is allegedly infringed.</li>
                <li>Identification of the copyrighted work claimed to have been infringed, or, if multiple copyrighted works at a single online site are covered by a single notification, a representative list of such works at that site.</li>
                <li>Identification of the material that is claimed to be infringing or to be the subject of infringing activity and that is to be removed or access to which is to be disabled, and information reasonably sufficient to permit us to locate the material (please provide the specific URL(s) of the infringing content).</li>
                <li>Information reasonably sufficient to permit us to contact you, such as an address, telephone number, and, if available, an electronic mail address.</li>
                <li>A statement that you have a good faith belief that use of the material in the manner complained of is not authorized by the copyright owner, its agent, or the law.</li>
                <li>A statement that the information in the notification is accurate, and under penalty of perjury, that you are authorized to act on behalf of the owner of an exclusive right that is allegedly infringed.</li>
            </ul>

            <h2>How to Submit a Notice</h2>
            <p>Please send your completed DMCA notice to our Designated Copyright Agent at the following email address:</p>
            <p><a href="mailto:admin@gplmods.webredirect.org">admin@gplmods.webredirect.org</a></p>
            <p>Upon receipt of a valid infringement notification, we will take whatever action, in our sole discretion, we deem appropriate, including the removal of the challenged material from our platform.</p>

            <h2>Counter-Notification</h2>
            <p>If you believe that your content that was removed is not infringing, or that you have the authorization from the copyright owner, the copyright owner's agent, or pursuant to the law, to post and use the material, you may send a counter-notice to our Copyright Agent. Please be aware that you may be held liable for damages if you make a material misrepresentation in a counter-notice.</p>

            <div class="dmca-form-container">
                <h2>Submit a DMCA Notice</h2>
                <p style="margin-bottom: 20px;">Alternatively, you can quickly submit your DMCA takedown request using the form below. This goes directly to our administration queue.</p>
                
                <!-- Form action points to the backend route we already set up -->
                <form class="dmca-form" action="/dmca-request" method="POST">
                    <div class="dmca-form-group">
                        <label for="fullName">Your Full Name*</label>
                        <input type="text" id="fullName" name="fullName" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="email">Your Contact Email*</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="copyrightHolder">Name of Copyright Holder you represent*</label>
                        <input type="text" id="copyrightHolder" name="copyrightHolder" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="originalWorkUrl">URL to the original copyrighted work*</label>
                        <!-- Updated name attribute to originalWorkUrl -->
                        <input type="url" id="originalWorkUrl" name="originalWorkUrl" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="infringingUrl">URL(s) on GPL Mods you claim are infringing*</label>
                        <!-- Updated name attribute to infringingUrl -->
                        <textarea id="infringingUrl" name="infringingUrl" rows="4" required placeholder="Provide one URL per line"></textarea>
                    </div>
                    <div class="dmca-form-group">
                        <label for="signature">Electronic Signature (type your full name again)*</label>
                        <input type="text" id="signature" name="signature" required>
                    </div>
                    <button type="submit" class="dmca-submit-btn">Submit Request</button>
                </form>
            </div>
        </div>
    </div>
</main>

<script>
    // This script catches URL parameters (like ?success=...) from the backend 
    // and displays them beautifully in the UI box instead of an ugly pop-up alert.
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const alertBox = document.getElementById('dmca-alert-box');
        
        if (urlParams.has('error')) { 
            alertBox.textContent = urlParams.get('error');
            alertBox.className = 'dmca-alert error';
            alertBox.style.display = 'block';
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        if (urlParams.has('success')) { 
            alertBox.textContent = urlParams.get('success');
            alertBox.className = 'dmca-alert success';
            alertBox.style.display = 'block';
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>

<%- include('../../partials/footer') %>