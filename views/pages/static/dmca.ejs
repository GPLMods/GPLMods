<%- include('../../partials/header') %>

<style>
    /* Specific styles for the DMCA Page to prevent conflicts */
    .dmca-page-header { text-align: center; padding: 60px 20px; }
    .dmca-page-header h1 { font-size: 3em; color: var(--white); }
    .dmca-page-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }

    .dmca-content-section { background-color: var(--dark-gray); padding: 40px; border-radius: 15px; max-width: 900px; margin: 0 auto 50px auto; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .dmca-content-section h2 { font-size: 1.8em; color: var(--gold); margin-bottom: 20px; border-bottom: 1px solid #333; padding-bottom: 10px; margin-top: 30px; }
    .dmca-content-section h2:first-child { margin-top: 0; }
    .dmca-content-section p, .dmca-content-section ul { color: var(--silver); margin-bottom: 15px; font-size: 1.05em; line-height: 1.7; }
    .dmca-content-section ul { list-style-position: inside; padding-left: 10px; }
    .dmca-content-section li { margin-bottom: 10px; }
    .dmca-content-section a { color: var(--gold); text-decoration: none; font-weight: 600; }
    .dmca-content-section a:hover { text-decoration: underline; }

    .dmca-form-container { margin-top: 40px; padding-top: 30px; border-top: 1px solid #333; }
    .dmca-form-container h2 { border-bottom: none; margin-bottom: 15px; margin-top: 0;}
    .dmca-form { display: flex; flex-direction: column; gap: 20px; }
    
    .dmca-form-group { display: flex; flex-direction: column; gap: 8px; text-align: left; }
    .dmca-form-group label { color: var(--silver); font-weight: 600; font-size: 0.95em; }
    .dmca-form-group input, .dmca-form-group textarea { 
        width: 100%; 
        padding: 14px 15px; 
        border-radius: 8px; 
        border: 1px solid #333; 
        background-color: var(--black); 
        color: var(--white); 
        font-family: 'Poppins', sans-serif;
        font-size: 1em; 
        outline: none; 
        transition: all 0.3s ease; 
    }
    .dmca-form-group input:focus, .dmca-form-group textarea:focus { 
        border-color: var(--gold); 
        box-shadow: 0 0 8px var(--glow-gold); 
    }
    
    .dmca-submit-btn { 
        background-color: var(--gold); 
        color: var(--black); 
        border: none; 
        padding: 15px 20px; 
        font-size: 1.1em; 
        font-weight: 700; 
        border-radius: 8px; 
        cursor: pointer; 
        transition: all 0.3s ease; 
        text-transform: uppercase;
        margin-top: 10px;
        box-shadow: 0 0 15px var(--glow-gold);
    }
    .dmca-submit-btn:hover { 
        transform: translateY(-3px);
        box-shadow: 0 0 25px var(--glow-gold); 
    }
    
    /* Alert Box Styling */
    .dmca-alert {
        display: none;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        font-weight: bold;
        text-align: center;
        font-size: 1.1em;
    }
    .dmca-alert.success { background-color: rgba(46, 204, 113, 0.1); border: 1px solid #2ecc71; color: #2ecc71; }
    .dmca-alert.error { background-color: rgba(255, 77, 77, 0.1); border: 1px solid #ff4d4d; color: #ff4d4d; }

    /* Highlight box for the new policy */
    .policy-highlight {
        background-color: rgba(255, 215, 0, 0.05);
        border-left: 4px solid var(--gold);
        padding: 20px;
        border-radius: 0 8px 8px 0;
        margin-bottom: 25px;
    }

    /* Contact Box Styles */
    .contact-box { background: var(--black); border: 1px solid #333; padding: 20px; border-radius: 10px; margin-top: 30px; text-align: center; }
    .contact-box p { margin-bottom: 5px; font-size: 1em; }
/* ✅ FIX: Force long emails to wrap on small screens */
    .contact-box a {
        word-wrap: break-word;
        overflow-wrap: break-word;
        word-break: break-all;
        display: inline-block; /* Helps with layout consistency when wrapped */
        max-width: 100%; /* Ensures it never exceeds the container */
    }

    @media (max-width: 768px) {
        .dmca-page-header h1 { font-size: 2.2em; }
        .dmca-content-section { padding: 25px; }
    }
</style>

<main>
    <div class="dmca-page-header">
        <div class="container">
            <h1>DMCA & <span>Copyright Policy</span></h1>
        </div>
    </div>
    
    <div class="container">
        <div class="dmca-content-section">
            
            <!-- Dynamic Success/Error Message Container -->
            <div id="dmca-alert-box" class="dmca-alert"></div>

            <div class="policy-highlight">
                <p style="color: var(--white); font-weight: bold; margin-bottom: 10px;">Our Platform's Purpose & Safe Harbor</p>
                <p>GPL Mods is a community-driven directory. <strong>We do not create or host modifications ourselves.</strong> All files and links found on this website are uploaded and shared by our community members.</p>
                <p>Furthermore, content shared on this platform is distributed under the spirit of the GNU/GPL license for <strong>testing, evaluation, and educational purposes only.</strong> Because many developers do not provide trial versions, this platform allows users to evaluate software features. If you are satisfied with a product, we strongly encourage you to purchase the premium version directly from the official developer to support their work.</p>
            </div>

            <h2>Notification of Copyright Infringement</h2>
            <p>If you are the official copyright owner (or an authorized agent) and wish to request the removal of content submitted by a community member, you may submit a takedown request. <strong>We take false claims very seriously.</strong></p>
            
            <p>To process your request, you must provide proof that the content strictly belongs to you or the entity you represent. Our administration team may contact you via email to request additional information to verify your identity. This may include:</p>
            <ul>
                <li>Official company registration documents.</li>
                <li>Proof of domain ownership or software licensing rights.</li>
                <li>A short KYC (Know Your Customer) or verification process to ensure no unauthorized third party is filing a fraudulent complaint against your intellectual property.</li>
            </ul>

            <h2>How to Submit a Notice & Contact Us</h2>
            <p>Upon receipt of a valid and verified infringement notification, we will take appropriate action, including the prompt removal of the challenged material from our platform.</p>
            <p>You may submit your verified takedown request using the form at the bottom of this page, or by contacting our Designated Copyright Agent directly via email.</p>

            <div class="contact-box">
                <p>
                    <strong style="display: block; margin-bottom: 5px;">For DMCA & Takedown Notices:</strong> 
                    <a href="mailto:dmca@gplmods.webredirect.org">dmca@gplmods.webredirect.org</a>
                </p>
                <p>
                    <strong style="display: block; margin-bottom: 5px;">For Privacy & Legal inquiries:</strong> 
                    <a href="mailto:support@gplmods.webredirect.org">support@gplmods.webredirect.org</a>
                </p>
                <p>
                    <strong style="display: block; margin-bottom: 5px;">For General Help:</strong> 
                    <a href="mailto:help@gplmods.webredirect.org">help@gplmods.webredirect.org</a>
                </p>
                
                <hr style="border: none; border-top: 1px solid #333; margin: 15px 0;">
                
                <p style="color: var(--gold); font-weight: bold; margin-bottom: 5px;">Support & Processing Hours</p>
                <p style="font-size: 0.9em; color: var(--silver);">(Timezone: GMT+5:30 / IST)</p>
                <p style="margin-top: 10px;">Monday to Friday</p>
                <p><strong>Morning:</strong> 8:00 AM to 10:00 AM</p>
                <p><strong>Evening:</strong> 6:00 PM to 10:00 PM</p>
            </div>

            <div class="dmca-form-container">
                <h2>Submit a DMCA Notice</h2>
                <p style="margin-bottom: 20px;">Use the form below to submit your initial takedown request directly to our administration queue. Please ensure all contact information is accurate so our team can follow up for verification.</p>
                
                <form class="dmca-form" action="/dmca-request" method="POST">
                    <div class="dmca-form-group">
                        <label for="fullName">Your Full Name*</label>
                        <input type="text" id="fullName" name="fullName" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="email">Official Company Email*</label>
                        <input type="email" id="email" name="email" required placeholder="name@yourcompany.com">
                    </div>
                    <div class="dmca-form-group">
                        <label for="copyrightHolder">Name of Copyright Holder you represent*</label>
                        <input type="text" id="copyrightHolder" name="copyrightHolder" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="originalWorkUrl">URL to the original copyrighted work*</label>
                        <input type="url" id="originalWorkUrl" name="originalWorkUrl" required>
                    </div>
                    <div class="dmca-form-group">
                        <label for="infringingUrl">URL(s) on GPL Mods you claim are infringing*</label>
                        <textarea id="infringingUrl" name="infringingUrl" rows="4" required placeholder="Provide one URL per line"></textarea>
                    </div>
                    <div class="dmca-form-group">
                        <label for="signature">Electronic Signature (type your full name again)*</label>
                        <input type="text" id="signature" name="signature" required>
                    </div>
                    <button type="submit" class="dmca-submit-btn">Submit Request for Verification</button>
                </form>
            </div>
        </div>
    </div>
</main>


<script>
    // This script catches URL parameters (like ?success=...) from the backend 
    // and displays them beautifully in the UI box instead of an ugly pop-up alert.
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const alertBox = document.getElementById('dmca-alert-box');
        
        if (urlParams.has('error')) { 
            alertBox.textContent = urlParams.get('error');
            alertBox.className = 'dmca-alert error';
            alertBox.style.display = 'block';
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        if (urlParams.has('success')) { 
            alertBox.textContent = urlParams.get('success');
            alertBox.className = 'dmca-alert success';
            alertBox.style.display = 'block';
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
</script>

<%- include('../../partials/footer') %>