<%- include('../../partials/header') %>

<style>
    .donate-wrapper { max-width: 700px; margin: 60px auto; background-color: var(--dark-gray); padding: 50px 40px; border-radius: 15px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.4); border-top: 4px solid var(--gold); }
    .donate-wrapper h1 { color: var(--white); font-size: 2.8em; margin-bottom: 15px; }
    .donate-wrapper h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .donate-wrapper p { color: var(--silver); line-height: 1.8; font-size: 1.1em; margin-bottom: 30px; }
    
    /* --- NEW: Currency Switcher Styles --- */
    .currency-selector { margin-bottom: 30px; display: inline-flex; align-items: center; gap: 10px; background: var(--black); padding: 10px 20px; border-radius: 25px; border: 1px solid #333; }
    .currency-selector label { color: var(--silver); font-weight: 600; font-size: 0.9em; }
    .currency-selector select { background: transparent; color: var(--gold); border: none; outline: none; font-family: 'Poppins', sans-serif; font-weight: bold; cursor: pointer; font-size: 1em; }
    /* ------------------------------------- */

    .donation-options { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-bottom: 20px; }
    .donation-btn { 
        background-color: transparent; border: 2px solid var(--gold); color: var(--gold); 
        padding: 15px 30px; font-size: 1.4em; font-weight: 700; border-radius: 10px; 
        cursor: pointer; transition: all 0.3s ease; min-width: 140px; font-family: 'Poppins', sans-serif;
    }
    .donation-btn:hover { background-color: var(--gold); color: var(--black); box-shadow: 0 0 20px var(--glow-gold); transform: translateY(-5px); }
</style>

<main class="container">
    <div class="donate-wrapper">
        <h1>Support <span>GPL Mods</span></h1>
        <p>
            If you find this site useful, please consider making a small donation. Your support helps cover our heavy server costs, maintenance, and allows us to continue building new features for the community!
        </p>

        <!-- ======== NEW: Currency Switcher HTML ======== -->
        <div class="currency-selector">
            <label for="currency-select">Currency:</label>
            <select id="currency-select">
                <option value="INR" selected>₹ INR</option>
                <option value="USD">$ USD</option>
                <option value="EUR">€ EUR</option>
                <option value="GBP">£ GBP</option>
            </select>
        </div>
        <!-- ============================================== -->

        <div id="donation-form" class="donation-options">
            <!-- 
                We use data attributes to store the raw value for each currency.
                The 'data-amount' is the value sent to the server (we'll standardize on sending the base unit, e.g., cents/paise, or let the server handle conversion if preferred. For this UI, we just update the display text).
            -->
            <button class="donation-btn" data-inr="400" data-usd="5" data-eur="4.50" data-gbp="4">
                <span class="currency-symbol">₹</span><span class="price-value">400</span>
            </button>
            <button class="donation-btn" data-inr="850" data-usd="10" data-eur="9" data-gbp="8">
                <span class="currency-symbol">₹</span><span class="price-value">850</span>
            </button>
            <button class="donation-btn" data-inr="1700" data-usd="20" data-eur="18" data-gbp="16">
                <span class="currency-symbol">₹</span><span class="price-value">1700</span>
            </button>
        </div>
        
        <p id="error-message" style="color: var(--red); margin-top: 15px; font-weight: bold;"></p>
        <p style="font-size: 0.9em; color: #666; margin-top: 20px;"><i class="fas fa-lock"></i> Payments are securely processed by Cashfree.</p>
    </div>
</main>

<!-- Note: For production Cashfree SDK, ensure you use the correct script URL provided by Cashfree docs if it differs from the sandbox one -->
<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Currency Switcher Logic ---
        const currencySelect = document.getElementById('currency-select');
        const donationButtons = document.querySelectorAll('.donation-btn');
        
        const symbols = {
            'INR': '₹',
            'USD': '$',
            'EUR': '€',
            'GBP': '£'
        };

        currencySelect.addEventListener('change', function() {
            const selectedCurrency = this.value;
            const symbol = symbols[selectedCurrency];

            donationButtons.forEach(btn => {
                // Update the symbol
                btn.querySelector('.currency-symbol').textContent = symbol;
                // Fetch and update the price value based on the selected currency
                const newPrice = btn.getAttribute(`data-${selectedCurrency.toLowerCase()}`);
                if (newPrice) {
                    btn.querySelector('.price-value').textContent = newPrice;
                }
            });
        });

        // --- 2. Cashfree Payment Logic ---
        const cashfree = Cashfree({ mode: "sandbox" }); // Change to production later
        const errorMessage = document.getElementById('error-message');

        donationButtons.forEach(button => {
            button.addEventListener('click', function() {
                // Get the *currently displayed* price value and currency to send to the server
                const amount = this.querySelector('.price-value').textContent;
                const currency = currencySelect.value;
                const originalHTML = this.innerHTML;

                errorMessage.textContent = ""; 
                this.disabled = true;
                this.textContent = "Wait...";
                this.style.backgroundColor = "var(--gold)";
                this.style.color = "var(--black)";

                // Important: Your backend route '/create-cashfree-order' will need to be updated
                // to handle the 'currency' field in addition to 'amount' if you want Cashfree
                // to process the transaction in different currencies.
                fetch('/create-cashfree-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount: amount, currency: currency })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.payment_session_id) {
                        cashfree.checkout({ paymentSessionId: data.payment_session_id, redirectTarget: "_self" });
                    } else {
                        throw new Error(data.error || 'Could not create payment order.');
                    }
                })
                .catch(err => {
                    errorMessage.textContent = 'Integration pending or server error.';
                    this.disabled = false;
                    this.innerHTML = originalHTML;
                    this.style.backgroundColor = "transparent";
                    this.style.color = "var(--gold)";
                });
            });
        });
    });
</script>

<%- include('../../partials/footer') %>