<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPL Mods - Service Unavailable</title>
    <!-- Add the Lottie player script -->
    <script src="https://unpkg.com/@lottiefiles/lottie-player@latest/dist/lottie-player.js"></script>
    <style>
        :root { --black: #0a0a0a; --dark-grey: #1a1a1a; --white: #f5f5f5; --gold: #FFD700; --red: #e53935; --glow-red: rgba(229, 57, 53, 0.5); }
        body { background-color: var(--black); color: var(--white); font-family: 'Poppins', sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .container { text-align: center; padding: 3rem; background-color: var(--dark-grey); border-top: 4px solid var(--red); border-radius: 12px; max-width: 600px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        h1 { font-size: 2.5rem; color: var(--red); margin-bottom: 15px; margin-top: 0; }
        p { font-size: 1.1rem; color: #aaa; line-height: 1.6; }
    </style>
</head>
<body>
    <div class="container">
        <!-- ✅ UPGRADE: Lottie Error Animation (Looping) -->
        <div style="display: flex; justify-content: center; margin-bottom: 10px;">
            <lottie-player src="/animations/error.json" background="transparent" speed="1" style="width: 150px; height: 150px; filter: drop-shadow(0 0 15px var(--glow-red));" loop autoplay></lottie-player>
        </div>
        
        <h1><%= title %></h1>
        <p><%- message.replace(/\n/g, '<br>') %></p>
    </div>
</body>
</html>