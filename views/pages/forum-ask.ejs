<%- include('../partials/header') %>

<!-- Quill.js Theme (Snow) -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<style>
    .ask-container { max-width: 900px; margin: 4rem auto; background-color: var(--dark-gray); padding: 40px; border-radius: 15px; border: 1px solid #333; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-top: 4px solid var(--blue); }
    .form-group { margin-bottom: 25px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: var(--silver); }
    .form-group input, .form-group select { width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1em; font-family: 'Poppins', sans-serif; outline: none; }
    .form-group input:focus, .form-group select:focus { border-color: var(--blue); }
    
    /* Quill Editor Custom Styling for Dark Mode */
    .ql-toolbar.ql-snow { background-color: #222; border-color: #333; border-top-left-radius: 8px; border-top-right-radius: 8px; }
    .ql-container.ql-snow { border-color: #333; border-bottom-left-radius: 8px; border-bottom-right-radius: 8px; min-height: 250px; font-family: 'Poppins', sans-serif; font-size: 1em; color: var(--white); }
    .ql-snow .ql-stroke { stroke: var(--silver); }
    .ql-snow .ql-fill, .ql-snow .ql-stroke.ql-fill { fill: var(--silver); }
    .ql-snow .ql-picker { color: var(--silver); }
    .ql-editor.ql-blank::before { color: #666; font-style: normal; }

    .submit-btn { width: 100%; background-color: var(--blue); color: var(--white); padding: 15px; font-size: 1.2em; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 15px rgba(33, 150, 243, 0.4); margin-top: 20px; }
    .submit-btn:hover { transform: translateY(-3px); box-shadow: 0 0 25px rgba(33, 150, 243, 0.6); }

    /* --- NEW: Custom Dropdown Styles --- */
    .custom-select-wrapper { position: relative; user-select: none; width: 100%; }
    .custom-select { position: relative; display: flex; flex-direction: column; background: var(--black); border: 1px solid #333; border-radius: 8px; cursor: pointer; padding: 12px 15px; color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; transition: border-color 0.3s; }
    .custom-select-wrapper.open .custom-select { border-color: var(--blue); border-bottom-left-radius: 0; border-bottom-right-radius: 0; box-shadow: 0 0 10px rgba(33, 150, 243, 0.3); }
    .custom-select-arrow { position: absolute; right: 15px; top: 50%; transform: translateY(-50%); transition: transform 0.3s; color: var(--silver); }
    .custom-select-wrapper.open .custom-select-arrow { transform: translateY(-50%) rotate(180deg); color: var(--blue); }
    .custom-options { position: absolute; display: none; top: 100%; left: 0; right: 0; background: var(--black); border: 1px solid var(--blue); border-top: none; border-radius: 0 0 8px 8px; z-index: 10; max-height: 200px; overflow-y: auto; box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
    .custom-select-wrapper.open .custom-options { display: block; }
    .custom-option { padding: 12px 15px; color: var(--silver); cursor: pointer; transition: all 0.2s; font-family: 'Poppins', sans-serif; }
    .custom-option:hover { background-color: rgba(33, 150, 243, 0.2); color: var(--white); }
    .custom-option.selected { color: var(--blue); font-weight: bold; }
</style>

<main class="container">
    <div class="ask-container">
        <h1 style="color: var(--white); font-size: 2.5em; margin-bottom: 5px;">Ask the <span style="color: var(--blue);">Community</span></h1>
        <p style="color: var(--silver); margin-bottom: 30px;">Get help with mods, report bugs, or share your knowledge.</p>

        <form action="/community/ask" method="POST" id="askForm">
            <div class="form-group">
                <label for="title">Issue Title*</label>
                <input type="text" id="title" name="title" placeholder="e.g., How do I install this Windows mod?" required autocomplete="off">
            </div>

            <!-- ✅ UPDATED: Custom Category Dropdown -->
            <div class="form-group">
                <label for="category">Category*</label>
                
                <!-- The hidden native select -->
                <select id="category" name="category" style="display: none;" required>
                    <option value="" disabled selected>Select an option...</option>
                    <option value="mod-help">Mod Installation/Help</option>
                    <option value="bug-report">Bug Report</option>
                    <option value="request">Mod Request</option>
                    <option value="tutorial">Guide / Tutorial</option>
                    <option value="general">General Discussion</option>
                </select>

                <!-- The Custom UI Wrapper -->
                <div class="custom-select-wrapper" id="wrapper-category">
                    <div class="custom-select">
                        <span class="selected-text">Select an option...</span>
                        <i class="fas fa-chevron-down custom-select-arrow"></i>
                    </div>
                    <div class="custom-options">
                        <div class="custom-option" data-value="mod-help">Mod Installation/Help</div>
                        <div class="custom-option" data-value="bug-report">Bug Report</div>
                        <div class="custom-option" data-value="request">Mod Request</div>
                        <div class="custom-option" data-value="tutorial">Guide / Tutorial</div>
                        <div class="custom-option" data-value="general">General Discussion</div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Describe your issue in detail*</label>
                <!-- This div becomes the Quill Editor -->
                <div id="editor-container"></div>
                <!-- Hidden input to store the HTML for submission -->
                <input type="hidden" name="content" id="hiddenContent" required>
            </div>

            <button type="submit" class="submit-btn">Post to Forum</button>
        </form>
    </div>
</main>

<!-- Quill.js Library -->
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        
        // --- 1. Custom Dropdown Logic ---
        function setupCustomSelect(wrapperId, nativeSelectId) {
            const wrapper = document.getElementById(wrapperId);
            const nativeSelect = document.getElementById(nativeSelectId);
            if (!wrapper || !nativeSelect) return;
            
            const customSelect = wrapper.querySelector('.custom-select');
            const selectedText = wrapper.querySelector('.selected-text');
            const optionsContainer = wrapper.querySelector('.custom-options');

            customSelect.addEventListener('click', (e) => {
                // Close any other open dropdowns first (if you add more later)
                document.querySelectorAll('.custom-select-wrapper.open').forEach(w => { 
                    if (w !== wrapper) w.classList.remove('open'); 
                });
                wrapper.classList.toggle('open');
                e.stopPropagation(); 
            });

            optionsContainer.addEventListener('click', (e) => {
                const optionEl = e.target.closest('.custom-option');
                if (!optionEl) return;
                
                // Update UI text
                selectedText.textContent = optionEl.textContent;
                // Update hidden select value
                nativeSelect.value = optionEl.getAttribute('data-value');
                
                // Update styling
                wrapper.querySelectorAll('.custom-option').forEach(opt => opt.classList.remove('selected'));
                optionEl.classList.add('selected');
                wrapper.classList.remove('open');
            });
        }
        
        setupCustomSelect('wrapper-category', 'category');

        // Close dropdown if clicking outside
        document.addEventListener('click', () => {
            document.querySelectorAll('.custom-select-wrapper.open').forEach(w => w.classList.remove('open'));
        });


        // --- 2. Initialize Quill Editor ---
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Provide code snippets, links, and as much detail as possible...',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'color': [] }, { 'background': [] }],
                    ['link', 'clean']
                ]
            }
        });

        // --- 3. Handle Form Submission & Validation ---
        const form = document.getElementById('askForm');
        form.addEventListener('submit', function(e) {
            
            // Validate Custom Dropdown
            const categorySelect = document.getElementById('category');
            if (!categorySelect.value) {
                e.preventDefault();
                alert('Please select a category for your post.');
                return;
            }

            // Validate Quill Editor Content
            const contentHtml = quill.root.innerHTML;
            if (contentHtml === '<p><br></p>' || contentHtml.trim() === '') {
                e.preventDefault();
                alert('Please provide a description for your issue.');
                return;
            }

            // Put HTML into hidden input so backend can save it
            document.getElementById('hiddenContent').value = contentHtml;
        });
    });
</script>

<%- include('../partials/footer') %>