<%- include('../partials/header') %>

<style>
    .settings-container { max-width: 800px; margin: 2rem auto 4rem auto; }
    .settings-section { background: var(--dark-gray); border: 1px solid #333; border-radius: 12px; padding: 30px; margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; transition: box-shadow 0.3s ease; }
    .settings-section:hover { box-shadow: 0 5px 20px rgba(0,0,0,0.4); }
    .settings-info h3 { margin: 0 0 8px 0; color: var(--white); font-size: 1.4em; display: flex; align-items: center; gap: 10px; }
    .settings-info p { margin: 0; color: var(--silver); font-size: 1em; line-height: 1.5; max-width: 500px; }
    
    .btn-danger-outline { background: transparent; border: 2px solid var(--red); color: var(--red); padding: 12px 25px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: 0.3s; font-family: 'Poppins', sans-serif; font-size: 1em; }
    .btn-danger-outline:hover { background: var(--red); color: var(--white); box-shadow: 0 0 15px var(--glow-red); }
</style>

<main class="container">
    <div class="settings-container">
        
        <div style="text-align: center; padding: 20px 0 40px;">
            <h1 style="color: var(--white); font-size: 2.8em; margin-bottom: 10px;">Account <span style="color: var(--gold); text-shadow: 0 0 15px var(--glow-gold);">Settings</span></h1>
        </div>

        <!-- ✅ Use a back action so this only returns when the user presses Go Back -->
        <div style="margin-bottom: 30px;">
            <button type="button" class="btn btn-secondary" style="background: transparent; border: 2px solid #333; color: var(--silver); padding: 8px 20px; border-radius: 20px; text-decoration: none; transition: all 0.3s ease; cursor: pointer;" onmouseover="this.style.borderColor='var(--silver)'; this.style.color='var(--white)';" onmouseout="this.style.borderColor='#333'; this.style.color='var(--silver)';" onclick="history.back();">
                <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Back to Dashboard
            </button>
        </div>

        <!-- 2FA Settings (RESTORED) -->
        <div class="settings-section">
            <div class="settings-info">
                <h3><i class="fas fa-shield-alt" style="color: var(--gold);"></i> Two-Factor Auth (2FA)</h3>
                <p>Add an extra layer of security to your account.</p>
            </div>
            <form action="<%= user.twoFactorEnabled ? '/account/2fa/disable' : '/account/2fa/setup' %>" method="<%= user.twoFactorEnabled ? 'POST' : 'GET' %>" style="margin: 0;">
                <label class="switch">
                    <input type="checkbox" onChange="this.form.submit()" <%= user.twoFactorEnabled ? 'checked' : '' %>>
                    <span class="slider round"></span>
                </label>
            </form>
        </div>

        <!-- Newsletter Settings -->
        <div class="settings-section">
            <div class="settings-info">
                <h3><i class="fas fa-newspaper" style="color: var(--blue);"></i> Newsletter Subscription</h3>
                <p>Receive updates about exclusive new mods and platform news directly to your inbox.</p>
            </div>
            <div>
                <% if (user.isSubscribedToNewsletter) { %>
                    <!-- Assuming you have this route built -->
                    <form action="/account/newsletter" method="POST" style="margin: 0;">
                        <input type="hidden" name="subscribe" value="false">
                        <button type="submit" class="btn btn-secondary" style="border-color: var(--silver); color: var(--silver);">Unsubscribe</button>
                    </form>
                <% } else { %>
                    <button type="button" id="open-newsletter-modal" class="btn btn-primary" style="background: var(--blue); color: var(--white); border: none; box-shadow: 0 0 15px rgba(33, 150, 243, 0.4);">Subscribe Now</button>
                <% } %>
            </div>
        </div>

        <!-- Account Actions (Danger Zone) -->
        <div class="settings-section" style="border-color: rgba(229, 57, 53, 0.5); background-color: rgba(229, 57, 53, 0.05); margin-top: 40px;">
            <div class="settings-info">
                <h3 style="color: var(--red);"><i class="fas fa-exclamation-triangle"></i> Danger Zone</h3>
                <p>Log out of your current session or permanently request account deletion.</p>
            </div>
            <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                <button type="button" id="logout-btn" class="btn-danger-outline"><i class="fas fa-sign-out-alt" style="margin-right: 8px;"></i> Log Out</button>
                <button type="button" class="btn btn-primary" style="background: var(--red); color: var(--white); border: none; box-shadow: 0 0 15px var(--glow-red); font-size: 1em; padding: 12px 25px;" id="open-delete-modal-btn">Delete Account</button>
            </div>
        </div>
    </div>
</main>

<!-- Newsletter Modal -->
<div id="newsletter-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 40px 30px; border-radius: 15px; border-top: 4px solid var(--blue); text-align: center; box-shadow: 0 15px 40px rgba(0,0,0,0.6);">
        <i class="fas fa-envelope-open-text" style="font-size: 3.5em; color: var(--blue); margin-bottom: 20px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px; font-size: 1.8em;">Subscribe to Newsletter</h2>
        <p style="color: var(--silver); margin-bottom: 25px; line-height: 1.6;">Enter your email to receive weekly updates on top mods. We never spam, and you can unsubscribe at any time.</p>
        <form action="/account/newsletter" method="POST">
            <input type="hidden" name="subscribe" value="true">
            <input type="email" name="email" value="<%= user.email %>" required style="width: 100%; padding: 15px; border-radius: 8px; border: 1px solid #444; background: var(--black); color: white; margin-bottom: 25px; outline: none; font-family: 'Poppins', sans-serif; font-size: 1.05em;" placeholder="your@email.com">
            <div style="display: flex; gap: 15px; justify-content: center;">
                <button type="submit" class="btn btn-primary" style="background: var(--blue); color: white; border: none; padding: 12px 25px; font-size: 1em;">Confirm</button>
                <button type="button" id="cancel-newsletter-btn" class="btn btn-secondary" style="padding: 12px 25px; font-size: 1em;">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- ======== CUSTOM LOGOUT MODAL ======== -->
<div id="logout-modal-container" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); color: var(--white); padding: 40px 30px; text-align: center; border-radius: 15px; max-width: 400px; width: 90%; border-top: 4px solid var(--gold); box-shadow: 0 15px 40px rgba(0,0,0,0.6);">
        <i class="fas fa-sign-out-alt" style="font-size: 3.5em; color: var(--gold); margin-bottom: 20px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px; font-size: 1.8em;">Ready to leave?</h2>
        <p style="margin-bottom: 30px; color: var(--silver); line-height: 1.6;">
            Are you sure you want to log out of your account? You will need to enter your credentials next time you visit.
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <a href="/logout" class="btn btn-primary" style="background-color: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 25px; font-weight: bold; text-decoration: none; box-shadow: 0 0 15px var(--glow-gold);">Yes, Log Out</a>
            <button type="button" class="btn btn-secondary" id="cancelLogoutBtn" style="background-color: transparent; color: var(--silver); border: 2px solid var(--silver); padding: 12px 30px; border-radius: 25px; font-weight: bold; cursor: pointer;">Cancel</button>
        </div>
    </div>
</div>

<!-- ======== CUSTOM SECURE DELETE MODAL ======== -->
<div id="delete-modal-container" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); color: var(--white); padding: 40px 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 4px solid var(--red); box-shadow: 0 15px 40px rgba(0,0,0,0.6);">
        
        <!-- STEP 1: Warning -->
        <div id="delete-step-1">
            <i class="fas fa-exclamation-triangle" style="font-size: 3.5em; color: var(--red); margin-bottom: 20px;"></i>
            <h2 style="color: var(--red); margin-bottom: 15px; font-size: 1.8em;">Delete Account?</h2>
            <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
                Are you absolutely sure? This action is permanent. We will send an email with a 6-digit confirmation code to verify this request.
            </p>
            
            <form action="/account/delete" method="POST" id="delete-account-form">
                <div style="background: rgba(0,0,0,0.3); padding: 15px; border-radius: 8px; border: 1px solid #333; margin-bottom: 25px;">
                    <label style="display: flex; align-items: center; justify-content: center; gap: 12px; cursor: pointer; margin: 0;">
                        <input type="checkbox" id="preserve-mods" name="preserveMods" value="true" style="width: 20px; height: 20px; accent-color: var(--gold);">
                        <span style="color: var(--white); font-weight: 500;">Preserve my uploaded mods.</span>
                    </label>
                </div>
                
                <div style="display: flex; gap: 15px; justify-content: center;">
                    <button type="submit" class="btn btn-primary" style="background-color: var(--red); color: var(--white); border: none; box-shadow: 0 0 15px var(--glow-red); padding: 12px 25px;">Yes, Send Code</button>
                    <button type="button" class="btn btn-secondary cancelDeleteBtn" style="padding: 12px 25px;">Cancel</button>
                </div>
            </form>
        </div>

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Helper to animate modals
    function openModal(modal) {
        if (!modal) return;
        modal.style.display = 'flex';
        setTimeout(() => modal.classList.add('show'), 10);
    }
    function closeModal(modal) {
        if (!modal) return;
        modal.classList.remove('show');
        setTimeout(() => modal.style.display = 'none', 200);
    }

    // Newsletter Modal
    const newsModal = document.getElementById('newsletter-modal');
    const openNewsBtn = document.getElementById('open-newsletter-modal');
    if (openNewsBtn) openNewsBtn.addEventListener('click', () => openModal(newsModal));
    document.getElementById('cancel-newsletter-btn')?.addEventListener('click', () => closeModal(newsModal));

    // Logout Modal
    const logoutModal = document.getElementById('logout-modal-container');
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutBtn) logoutBtn.addEventListener('click', () => openModal(logoutModal));
    document.getElementById('cancelLogoutBtn')?.addEventListener('click', () => closeModal(logoutModal));

    // Delete Modal
    const deleteModal = document.getElementById('delete-modal-container');
    const openDeleteBtn = document.getElementById('open-delete-modal-btn');
    if (openDeleteBtn) openDeleteBtn.addEventListener('click', () => openModal(deleteModal));
    
    document.querySelectorAll('.cancelDeleteBtn').forEach(btn => {
        btn.addEventListener('click', () => closeModal(deleteModal));
    });

    // Close Modals on outside click
    window.addEventListener('click', (e) => {
        if (e.target === newsModal) closeModal(newsModal);
        if (e.target === logoutModal) closeModal(logoutModal);
        if (e.target === deleteModal) closeModal(deleteModal);
    });
});
</script>

<%- include('../partials/footer') %>