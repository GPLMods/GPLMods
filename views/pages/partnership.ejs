<%- include('../partials/header') %>

<style>
    .partnership-container { max-width: 900px; margin: 4rem auto; padding: 3rem; background-color: var(--dark-gray); border-radius: 15px; border-top: 4px solid var(--gold); box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .partnership-header { text-align: center; margin-bottom: 3rem; }
    .partnership-header h1 { font-size: 2.8em; color: var(--white); margin-bottom: 10px; }
    .partnership-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .partnership-header p { color: var(--silver); font-size: 1.1em; line-height: 1.6; }
    
    .benefits-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 3rem; }
    .benefit-card { background: var(--black); padding: 20px; border-radius: 10px; border: 1px solid #333; }
    .benefit-card h3 { color: var(--gold); margin-bottom: 10px; font-size: 1.2em; display: flex; align-items: center; gap: 10px; }
    .benefit-card p { color: var(--silver); font-size: 0.95em; margin: 0; }

    .form-section-title { color: var(--white); border-bottom: 1px solid #333; padding-bottom: 10px; margin: 30px 0 20px 0; font-size: 1.5em; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); }
    .form-group input, .form-group select { width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; transition: all 0.3s ease; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }
    
    .checkbox-group { display: flex; align-items: flex-start; gap: 15px; background: rgba(229, 57, 53, 0.1); padding: 20px; border-radius: 8px; border: 1px solid rgba(229, 57, 53, 0.3); margin-bottom: 25px; }
    .checkbox-group input[type="checkbox"] { width: 20px; height: 20px; margin-top: 3px; cursor: pointer; }
    .checkbox-group label { color: #ffadad; font-size: 0.95em; line-height: 1.5; cursor: pointer; margin: 0; }

    .submit-btn { width: 100%; background-color: var(--gold); color: var(--black); padding: 18px; font-size: 1.2em; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 0 15px var(--glow-gold); }
    .submit-btn:hover { transform: translateY(-3px); box-shadow: 0 0 25px var(--glow-gold); }

    .status-box { text-align: center; padding: 40px; background: var(--black); border-radius: 10px; border: 1px solid #333; }
    .status-box h2 { color: var(--gold); margin-bottom: 15px; }

    @media (max-width: 768px) { .benefits-grid { grid-template-columns: 1fr; } }
</style>

<main class="container">
    <div class="partnership-container">
        <div class="partnership-header">
            <h1>Distributor <span>Partnership</span></h1>
            <p>Are you a Telegram channel owner, website admin, or mod creator? Partner with GPL Mods to distribute your content, monetize your links, and grow your audience.</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div style="padding: 15px; background-color: rgba(229, 57, 53, 0.1); color: var(--red); border: 1px solid var(--red); border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold;"><%= error %></div>
        <% } %>
        <% if (typeof message !== 'undefined' && message) { %>
            <div style="padding: 15px; background-color: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid #2ecc71; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold;"><%= message %></div>
        <% } %>

        <% if (existingApplication) { %>
            <!-- Show Status if they already applied -->
            <div class="status-box">
                <h2>Application Status: <span style="color: var(--white); text-transform: uppercase;"><%= existingApplication.status %></span></h2>
                <p style="color: var(--silver); font-size: 1.1em;">
                    <% if (existingApplication.status === 'pending' || existingApplication.status === 'under-review') { %>
                        Your application is currently being reviewed by our team. We will contact you via the admin social link you provided.
                    <% } else if (existingApplication.status === 'approved') { %>
                        Congratulations! Your account has been upgraded to Distributor status. You can now use monetized links when uploading mods.
                    <% } else { %>
                        Unfortunately, your application was not approved at this time.
                    <% } %>
                </p>
            </div>
        <% } else { %>
            <!-- Show the Application Form -->
            <div class="benefits-grid">
                <div class="benefit-card">
                    <h3><i class="fas fa-money-bill-wave"></i> Monetize Your Links</h3>
                    <p>Bypass our standard cloud storage and use your own Linkvertise, 10drives, or paid-to-download links to generate revenue directly.</p>
                </div>
                <div class="benefit-card">
                    <h3><i class="fas fa-shield-alt"></i> Trusted Organization Badge</h3>
                    <p>Receive a special "Verified Distributor" badge on your public profile and all your uploaded mods, increasing user trust.</p>
                </div>
                <div class="benefit-card">
                    <h3><i class="fas fa-share-alt"></i> Promote Your Channels</h3>
                    <p>Add your official Telegram, Discord, YouTube, and Website links directly to your GPL Mods public profile.</p>
                </div>
                <div class="benefit-card">
                    <h3><i class="fas fa-user-shield"></i> Priority Support</h3>
                    <p>Distributors receive priority review times for their uploads and direct communication channels with GPL Mods administration.</p>
                </div>
            </div>

            <form action="/partnership/apply" method="POST">
                <h2 class="form-section-title">Organization Details</h2>
                
                <div class="form-group">
                    <label for="organizationName">Organization / Channel Name*</label>
                    <input type="text" id="organizationName" name="organizationName" placeholder="e.g., Elite Android Mods" required>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="primaryDistributionPlatform">Primary Platform*</label>
                        <select id="primaryDistributionPlatform" name="primaryDistributionPlatform" required>
                            <option value="" disabled selected>Select platform...</option>
                            <option value="Telegram Channel">Telegram Channel</option>
                            <option value="Website">Website</option>
                            <option value="Discord Server">Discord Server</option>
                            <option value="YouTube Channel">YouTube Channel</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="platformUrl">Link to Primary Platform*</label>
                        <input type="url" id="platformUrl" name="platformUrl" placeholder="https://t.me/..." required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="monetizationMethod">Which monetization service(s) do you plan to use?*</label>
                    <input type="text" id="monetizationMethod" name="monetizationMethod" placeholder="e.g., Linkvertise, 10drives, MediaFire" required>
                </div>

                <h2 class="form-section-title">Admin Contact (Private)</h2>
                <p style="color: var(--silver); font-size: 0.9em; margin-top: -10px; margin-bottom: 20px;">We need a direct way to contact the owner for verification and safety checks.</p>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label for="adminContactName">Your Real Name / Alias*</label>
                        <input type="text" id="adminContactName" name="adminContactName" required>
                    </div>
                    <div class="form-group">
                        <label for="adminSocialLink">Direct Contact Link (Telegram/Discord)*</label>
                        <input type="url" id="adminSocialLink" name="adminSocialLink" placeholder="https://t.me/your_username" required>
                    </div>
                </div>

                <h2 class="form-section-title">Public Social Links (Optional)</h2>
                <p style="color: var(--silver); font-size: 0.9em; margin-top: -10px; margin-bottom: 20px;">These will be displayed on your GPL Mods public profile.</p>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="form-group">
                        <label><i class="fab fa-telegram" style="color: #0088cc;"></i> Telegram Channel</label>
                        <input type="url" name="socialTelegram" placeholder="https://t.me/...">
                    </div>
                    <div class="form-group">
                        <label><i class="fab fa-discord" style="color: #5865F2;"></i> Discord Server</label>
                        <input type="url" name="socialDiscord" placeholder="https://discord.gg/...">
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-globe" style="color: var(--silver);"></i> Website</label>
                        <input type="url" name="socialWebsite" placeholder="https://...">
                    </div>
                    <div class="form-group">
                        <label><i class="fab fa-youtube" style="color: #FF0000;"></i> YouTube</label>
                        <input type="url" name="socialYoutube" placeholder="https://youtube.com/...">
                    </div>
                </div>

                <div class="checkbox-group">
                    <input type="checkbox" id="agreedToTerms" name="agreedToTerms" required>
                    <label for="agreedToTerms">
                        <strong>Safety & Compliance Agreement:</strong> I understand that as a Distributor, I am responsible for the safety of the files I link to. I agree that GPL Mods administrators may request direct, un-monetized links to my files at any time for VirusTotal scanning and manual verification. Failure to comply or distributing malware will result in an immediate, permanent ban of my organization.
                    </label>
                </div>

                <button type="submit" class="submit-btn">Submit Application</button>
            </form>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>