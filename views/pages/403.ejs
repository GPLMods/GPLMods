<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>403 Forbidden - GPL Mods</title>
 <link rel="icon" type="image/png" href="/favicon.png">
 <link rel="apple-touch-icon" href="/favicon.png">

    <!-- Link to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- Link to our dedicated stylesheet for error pages -->
    <link rel="stylesheet" href="/css/error-pages.css">
</head>
<body>

    <main class="error-container container">
        <div class="error-code">403</div>
        <h1 class="error-title">Access <span>Denied</span></h1>
        <p class="error-message">You do not have the necessary permissions to view this page. If you believe this is an error, please try logging in or contact support.</p>
        
        <!-- Updated the link to point to the root of your site -->
        <!-- ✅ FIX: Updated button classes and styles to match the golden theme -->
<a href="<%= user ? '/home' : '/' %>" class="btn" style="margin-top: 2rem; display: inline-block; background: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 25px; font-weight: bold; text-decoration: none; box-shadow: 0 0 15px var(--glow-gold); transition: transform 0.3s ease;">Go to Homepage</a>
    </main>

</body>
</html>