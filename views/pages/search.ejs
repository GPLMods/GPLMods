<%- include('../partials/header') %>

<main>
    <section class="page-header">
        <div class="container">
            <h1>Search Results for "<span class="query"><%= query %></span>"</h1>
        </div>
    </section>

    <div class="container">
        <section class="filter-section">
            <div class="filter-controls">
                <label for="platform-filter">Platform:</label>
                <select id="platform-filter" name="platform">
                    <option value="all">All Platforms</option>
                    <option value="windows">Windows</option>
                    <option value="android">Android</option>
                    <option value="ios-jailed">IPA</option>
                    <option value="ios-jailbroken">DEB</option>
                    <option value="wordpress">WordPress</option>
                </select>
                <label for="sort-filter">Sort by:</label>
                <select id="sort-filter" name="sort">
                    <option value="newest">Newest</option>
                    <option value="downloads">Most Downloads</option>
                    <option value="rating">Highest Rating</option>
                </select>
            </div>
            <div class="results-count">
                <!-- Will be updated by JS -->
                <span>Showing <%= results.length %> of <%= totalResults %> results</span>
            </div>
        </section>

        <!-- Only show the grid if there are results -->
        <% if(results.length > 0) { %>
            <section class="mod-grid" id="search-results-grid">
                <!-- EJS Loop to dynamically create mod cards -->
                <% results.forEach(file => { %>
                    <a href="/mods/<%= file._id %>" class="mod-card-link" data-platform="<%= file.category %>">
                        <div class="mod-card">
                            
                            <!-- NEW: Certification Tag -->
                            <% if (file.certification === 'certified') { %>
                                <div class="app-feature-tag">✔ Certified</div>
                            <% } else if (file.certification === 'community-tested') { %>
                                <div class="app-feature-tag" style="background-color: var(--silver);">Community Tested</div>
                            <% } %>
                            
                            <!-- NEW: Version Tag -->
                            <div class="mod-type-tag"><%= file.version %></div>
                            
                            <!-- NEW: Image Container Logic -->
                            <div class="mod-card-image">
                                <img src="<%= file.iconUrl %>" alt="<%= file.name %>">
                            </div>
                            
                            <div class="mod-card-content">
                                <h3><%= file.name %></h3>
                                <p><%= file.modDescription.substring(0, 50) %>...</p> 
                                
                                <div class="rating">
                                    <div class="stars-outer">
                                        <div class="stars-inner" style="width: <%= (file.averageRating / 5) * 100 %>%;"></div>
                                    </div>
                                    <span class="rating-text"><%= file.averageRating.toFixed(1) %></span>
                                </div>

                                <!-- NEW: Platform Tag -->
                                <div class="card-footer">
                                    <span class="platform-tag <%= file.category.replace('-jailed', '-ipa').replace('-jailbroken', '-deb') %>">
                                        <%= file.category.toUpperCase().replace('-', ' ') %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </section>
        <% } %>

        <!-- Show the "No Results" message if there are no results -->
        <% if(results.length === 0) { %>
            <section class="no-results" id="no-results-message">
                <h2>No Mods Found</h2>
                <p>We couldn't find any mods matching your search. Please try a different keyword.</p>
            </section>
        <% } %>

        <!-- Pagination (dynamically generated) -->
        <nav class="pagination">
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="/search?q=<%= query %>&page=<%= i %>" class="<%= currentPage === i ? 'active' : '' %>">
                    <%= i %>
                </a>
            <% } %>
        </nav>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const platformFilter = document.getElementById('platform-filter');
        const sortFilter = document.getElementById('sort-filter');
        
        // Pre-select the dropdowns based on the current URL
        platformFilter.value = '<%= currentPlatform %>';
        sortFilter.value = '<%= currentSort %>';

        function applyFilters() {
            const platform = platformFilter.value;
            const sort = sortFilter.value;
            const query = '<%= query %>';
            
            // Construct the new URL with the selected filters
            // We reset to page=1 whenever a filter is changed
            window.location.href = `/search?q=${encodeURIComponent(query)}&platform=${platform}&sort=${sort}&page=1`;
        }
        
        platformFilter.addEventListener('change', applyFilters);
        sortFilter.addEventListener('change', applyFilters);
    });
</script>

<%- include('../partials/footer') %>