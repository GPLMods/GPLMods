<%- include('../partials/header') %>

<!-- ✅ ADD QUILL.JS STYLES AND SCRIPT -->
<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>

<style>
    /* Your custom theme styles are now integrated */
    :root {
        --black: #0a0a0a;
        --dark-gray: #1a1a1a;
        --white: #ffffff;
        --gold: #FFD700;
        --silver: #c0c0c0;
        --glow-gold: rgba(255, 215, 0, 0.5);
        --red: #e53935;
    }
    /* General body and container styles */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Poppins', sans-serif; background-color: var(--black); color: var(--white); line-height: 1.6; }
    .container { width: 90%; max-width: 1200px; margin: auto; padding: 20px 0; }

    /* Main form container */
    .upload-form-container {
        background-color: var(--dark-gray);
        padding: 30px;
        border-radius: 15px;
        max-width: 800px;
        margin: 2rem auto;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* Form Header Text */
    .upload-form-container h2 {
        text-align: center;
        font-size: 2.5em;
        margin-bottom: 1rem;
    }
    .upload-form-container h2 span {
        color: var(--gold);
        text-shadow: 0 0 15px var(--glow-gold);
    }
    .upload-form-container p {
        text-align: center;
        font-size: 1.1em;
        color: var(--silver);
        margin-bottom: 2rem;
    }
    
    /* Fieldset and Legend for Structure */
    .form-section {
        border: 1px solid #333;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }
    .form-section legend {
        padding: 0 10px;
        margin-left: 15px;
        font-size: 1.3em;
        font-weight: 600;
        color: var(--gold);
    }

    /* Form Groups and Inputs */
    .form-group {
        margin-bottom: 25px;
        position: relative; /* Essential for custom dropdowns */
    }
    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--silver);
    }
    .form-group input[type="text"],
    .form-group input[type="url"],
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 12px 15px;
        border-radius: 8px;
        border: 1px solid #333;
        background-color: var(--black);
        color: var(--white);
        font-size: 1em;
        font-family: 'Poppins', sans-serif;
        transition: all 0.3s ease;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
        outline: none;
        border-color: var(--gold);
        box-shadow: 0 0 10px var(--glow-gold);
    }
    .form-group textarea {
        min-height: 120px;
        resize: vertical;
    }

    /* --- CUSTOM SELECT DROPDOWN CSS --- */
    .custom-select-wrapper {
        position: relative;
        user-select: none;
        width: 100%;
    }
    .custom-select {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 15px;
        background-color: var(--black);
        border: 1px solid #333;
        border-radius: 8px;
        cursor: pointer;
        color: var(--silver);
        font-size: 1em;
        transition: all 0.3s ease;
    }
    /* When the dropdown is open */
    .custom-select-wrapper.open .custom-select {
        border-color: var(--gold);
        box-shadow: 0 0 10px var(--glow-gold);
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
    }
    .custom-select-wrapper.open .custom-select-arrow {
        transform: rotate(180deg);
        color: var(--gold);
    }
    /* The dropdown menu */
    .custom-options {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background-color: var(--dark-gray);
        border: 1px solid var(--gold);
        border-top: none;
        border-radius: 0 0 8px 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        z-index: 100;
        display: none; /* Hidden by default */
        max-height: 250px;
        overflow-y: auto;
    }
    .custom-select-wrapper.open .custom-options {
        display: block; /* Shown when open */
    }
    .custom-option {
        padding: 12px 15px;
        cursor: pointer;
        color: var(--white);
        transition: background-color 0.2s;
        border-bottom: 1px solid #2a2a2a;
    }
    .custom-option:last-child { border-bottom: none; }
    .custom-option:hover { background-color: var(--black); color: var(--gold); }
    .custom-option.selected { background-color: var(--black); color: var(--gold); font-weight: bold; }
    /* Disabled state for custom select */
    .custom-select-wrapper.disabled .custom-select {
        opacity: 0.5;
        cursor: not-allowed;
        background-color: #111;
    }
    .custom-select-wrapper.disabled .custom-options {
        display: none !important;
    }
    /* ------------------------------------------- */

    /* Icon Preview Section */
    .icon-upload-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 30px;
        padding: 20px;
        border: 2px dashed #333;
        border-radius: 15px;
        background-color: rgba(0,0,0,0.2);
    }
    .icon-preview {
        width: 100px;
        height: 100px;
        background-color: var(--black);
        border-radius: 20px;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid var(--gold);
        overflow: hidden;
    }
    .icon-preview img {
        width: 100%;
        height: 100%;
        object-fit: contain; 
        display: none;
    }
    .icon-preview span {
        color: #444;
        font-size: 0.8em;
        text-align: center;
    }

    /* Custom File Input Styles */
    .file-input-wrapper {
        position: relative;
        display: block;
        width: 100%;
    }
    input[type="file"] {
        display: none;
    }
    .file-input-label {
        display: block;
        padding: 12px 20px;
        background: transparent;
        color: var(--gold);
        border: 2px solid var(--gold);
        border-radius: 8px;
        cursor: pointer;
        text-align: center;
        font-size: 1em;
        transition: all 0.3s ease;
    }
    .file-input-label:hover {
        background: var(--gold);
        color: var(--black);
        box-shadow: 0 0 15px var(--glow-gold);
    }
    .file-name {
        display: block;
        margin-top: 10px;
        color: var(--silver);
        font-size: 0.9em;
        text-align: center;
    }

    /* Screenshot & Video Previews */
    .preview-container {
        margin-top: 15px;
        background-color: var(--black);
        padding: 15px;
        border: 1px solid #333;
        border-radius: 8px;
        display: none; 
    }
    #screenshotPreviewContainer {
        column-count: 2;
        column-gap: 15px;
    }
    #screenshotPreviewContainer img {
        width: 100%;
        height: auto;
        border-radius: 8px;
        margin-bottom: 15px;
        break-inside: avoid; 
        display: block;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }
    .video-preview-wrapper {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 */
        height: 0;
        overflow: hidden;
        border-radius: 4px;
        width: 100%;
    }
    .video-preview-wrapper iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }
    
    .draft-button {
        background: transparent;
        color: var(--silver);
        border: 2px solid #555;
        padding: 15px 20px;
        border-radius: 8px;
        font-size: 1.1em;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        flex: 1; 
    }
    .draft-button:hover {
        border-color: var(--gold);
        color: var(--gold);
    }
    /* Submit Button */
    .submit-button {
        display: block;
        width: 100%;
        background: var(--gold);
        color: var(--black);
        padding: 15px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 1.2em;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 0 15px var(--glow-gold);
        margin-top: 0;
        flex: 2;
    }
    .submit-button:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }

    /* Force Quill Editors to be responsive */
    .ql-toolbar, .ql-container {
        max-width: 100% !important;
        box-sizing: border-box !important;
    }
    .ql-editor {
        word-wrap: break-word !important;
        overflow-wrap: break-word !important;
        word-break: break-word !important;
        max-width: 100% !important;
        padding: 12px 10px !important; 
    }
    .upload-form-container {
        max-width: 100%;
        overflow-x: hidden;
    }

    /* Custom styles for Quill */
    .ql-toolbar.ql-snow {
        background-color: #333;
        border-color: #444;
        border-radius: 8px 8px 0 0;
    }
    .ql-container.ql-snow {
        background-color: var(--black);
        border-color: #444;
        border-radius: 0 0 8px 8px;
        color: var(--white);
        font-family: 'Poppins', sans-serif;
        font-size: 1em;
        min-height: 250px; 
    }
    .ql-editor.ql-blank::before { color: #888; }
    .ql-snow .ql-stroke { stroke: var(--silver); }
    .ql-snow .ql-fill { fill: var(--silver); }
    .ql-snow .ql-picker { color: var(--silver); }
</style>

<div class="container">
    <div class="upload-form-container">
        <h2>Upload Your Mod <span>- Details</span></h2>
        <p>Step 2 of 2: Your file <strong><%= filename %></strong> is ready. Please provide the details below.</p>

        <form action="/upload-finalize/<%= fileId %>" method="POST" enctype="multipart/form-data" id="mainUploadForm">
            <!-- HIDDEN INPUTS -->
            <input type="hidden" name="fileKey" value="<%= fileKey %>">
            <input type="hidden" name="originalFilename" value="<%= filename %>">
            <input type="hidden" name="fileSize" value="<%= filesize %>">

            <fieldset class="form-section">
                <legend>Core Details</legend>

                <!-- Icon Upload -->
                <div class="icon-upload-container">
                    <label>Mod Icon*</label>
                    <div class="icon-preview" id="iconPreviewBox">
                        <img id="iconImage" src="" alt="Icon Preview" style="display:none;">
                        <span id="iconPlaceholder">Preview</span>
                    </div>
                    <div style="max-width: 250px;">
                        <input type="file" id="modIcon" name="softwareIcon" accept="image/*" required>
                        <label for="modIcon" class="file-input-label">Choose Icon</label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="modName">Mod Name*</label>
                    <input type="text" id="modName" name="modName" value="<%= defaultName %>" placeholder="e.g., Roblox or Minecraft" required autocomplete="off">
                </div>

                <div class="form-group">
                    <label for="developerName">Official Developer / Company</label>
                    <input type="text" id="developerName" name="developerName" placeholder="e.g., Supercell or Mojang" autocomplete="off">
                </div>

                <!-- Platform Dropdown -->
                <div class="form-group">
                    <label>Platform*</label>
                    <select id="modPlatform" name="modPlatform" required style="display: none;">
                        <option value="" disabled selected>Select a platform...</option>
                        <option value="android">Android</option>
                        <option value="ios-jailed">iOS - Jailed (IPA)</option>
                        <option value="ios-jailbroken">iOS - Jailbroken (DEB)</option>
                        <option value="windows">Windows</option>
                        <option value="wordpress">WordPress</option>
                    </select>
                    
                    <div class="custom-select-wrapper" id="platformWrapper">
                        <div class="custom-select">
                            <span class="selected-text">Select a platform...</span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <div class="custom-options">
                            <div class="custom-option" data-value="android">Android</div>
                            <div class="custom-option" data-value="ios-jailed">iOS - Jailed (IPA)</div>
                            <div class="custom-option" data-value="ios-jailbroken">iOS - Jailbroken (DEB)</div>
                            <div class="custom-option" data-value="windows">Windows</div>
                            <div class="custom-option" data-value="wordpress">WordPress</div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="ageRating">Age Rating*</label>
                    
                    <!-- 1. Hide the native select -->
                    <select id="ageRating" name="ageRating" required style="display: none;">
                        <option value="NA" <%= (typeof file !== 'undefined' && file.ageRating === 'NA') ? 'selected' : '' %>>Not Rated (N/A)</option>
                        <option value="3+" <%= (typeof file !== 'undefined' && file.ageRating === '3+') ? 'selected' : '' %>>3+ (Everyone)</option>
                        <option value="7+" <%= (typeof file !== 'undefined' && file.ageRating === '7+') ? 'selected' : '' %>>7+ (Low Violence)</option>
                        <option value="12+" <%= (typeof file !== 'undefined' && file.ageRating === '12+') ? 'selected' : '' %>>12+ (Moderate Violence)</option>
                        <option value="16+" <%= (typeof file !== 'undefined' && file.ageRating === '16+') ? 'selected' : '' %>>16+ (Strong Violence)</option>
                        <option value="18+" <%= (typeof file !== 'undefined' && file.ageRating === '18+') ? 'selected' : '' %>>18+ (Adults Only)</option>
                    </select>

                    <!-- 2. Add the custom wrapper HTML -->
                    <div class="custom-select-wrapper" id="ageRatingWrapper">
                        <div class="custom-select">
                            <span class="selected-text">
                                <% if (typeof file !== 'undefined' && file.ageRating) { %>
                                    <% if (file.ageRating === '3+') { %> 3+ (Everyone)
                                    <% } else if (file.ageRating === '7+') { %> 7+ (Low Violence)
                                    <% } else if (file.ageRating === '12+') { %> 12+ (Moderate Violence)
                                    <% } else if (file.ageRating === '16+') { %> 16+ (Strong Violence)
                                    <% } else if (file.ageRating === '18+') { %> 18+ (Adults Only)
                                    <% } else { %> Not Rated (N/A) <% } %>
                                <% } else { %>
                                    Not Rated (N/A)
                                <% } %>
                            </span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <div class="custom-options">
                            <div class="custom-option" data-value="NA">Not Rated (N/A)</div>
                            <div class="custom-option" data-value="3+">3+ (Everyone)</div>
                            <div class="custom-option" data-value="7+">7+ (Low Violence)</div>
                            <div class="custom-option" data-value="12+">12+ (Moderate Violence)</div>
                            <div class="custom-option" data-value="16+">16+ (Strong Violence)</div>
                            <div class="custom-option" data-value="18+">18+ (Adults Only)</div>
                        </div>
                    </div>
                </div>

                <!-- Category Dropdown -->
                <div class="form-group">
                    <label>Category*</label>
                    <select id="modCategory" name="modCategory" required disabled style="display: none;">
                        <option value="" disabled selected>Select a platform first...</option>
                    </select>

                    <div class="custom-select-wrapper disabled" id="categoryWrapper">
                        <div class="custom-select">
                            <span class="selected-text">Select a platform first...</span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <!-- Options will be dynamically populated here -->
                        <div class="custom-options" id="categoryOptionsContainer"></div>
                    </div>
                </div>

                <!-- ======== NEW: DEPENDENCIES SECTION (WITH CUSTOM WRAPPER) ======== -->
                <div class="form-group" id="arch-group" style="display: none; background: rgba(255, 215, 0, 0.05); padding: 20px; border-radius: 8px; border: 1px solid #333; margin-top: 15px;">
                    <label style="color: var(--gold);"><i class="fas fa-microchip"></i> Architecture Support <span id="arch-req-star" style="color: var(--red); display: none;">*</span></label>
                    <p style="font-size: 0.85em; color: var(--silver); margin-bottom: 10px;">Select all hardware architectures this file supports.</p>
                    
                    <div class="custom-select-wrapper" id="archWrapper">
                        <div class="custom-select" id="archCustomSelect">
                            <span class="selected-text" id="archSelectedText">Select architectures...</span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <div class="custom-options" id="archOptionsContainer">
                            <!-- Multi-select checkboxes will be dynamically populated here -->
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="minOsVersion">Minimum Required OS Version <span id="os-req-star" style="color: var(--red); display: none;">*</span></label>
                    <input type="text" id="minOsVersion" name="minOsVersion" placeholder="e.g., iOS 14.0, Android 8.0, Windows 10">
                </div>
                <!-- =================================================================== -->

                <div class="form-group">
                    <label for="modVersion">Mod Version*</label>
                    <input type="text" id="modVersion" name="modVersion" value="<%= defaultVersion %>" placeholder="e.g., 1.26.1.1" required autocomplete="off">
                </div>
            </fieldset>
            
            <fieldset class="form-section">
                <legend>Descriptions</legend>

                <div class="form-group">
                    <label for="modDescription">Mod Description*</label>
                    <textarea id="modDescription" name="modDescription" style="display:none;" required></textarea>
                    <div id="editor-modDescription"></div>
                </div>

                <div class="form-group">
                    <label for="modFeatures">Mod Features* (One per line)</label>
                    <textarea id="modFeatures" name="modFeatures" style="display:none;" required></textarea>
                    <div id="editor-modFeatures"></div>
                </div>

                <div class="form-group">
                    <label for="officialDescription">Official Description (Optional)</label>
                    <textarea id="officialDescription" name="officialDescription" style="display:none;"></textarea>
                    <div id="editor-officialDescription"></div>
                </div>

                 <div class="form-group">
                    <label for="importantNote">Important Note / Installation Instructions (Optional)</label>
                    <textarea id="importantNote" name="importantNote" style="display:none;"></textarea>
                    <div id="editor-importantNote"></div>
                </div>
                
                <div class="form-group">
                    <label for="whatsNew">What's New (Optional)</label>
                    <textarea id="whatsNew" name="whatsNew" style="display:none;"></textarea>
                    <div id="editor-whatsNew"></div>
                </div>
            </fieldset>

                <!-- ======== DIRECT IPA / REPO LINK ======== -->
                <div class="form-group" id="ipa-link-group" style="display: none; background: rgba(0, 122, 255, 0.1); padding: 20px; border-radius: 8px; border: 1px solid #007AFF; margin-bottom: 25px;">
                    <label for="ipaDirectDownloadUrl" style="color: var(--white);"><i class="fab fa-apple"></i> Direct App / Repo Link (1-Click Install) <span style="color: var(--gold); font-size: 0.8em; font-weight: normal;">Optional</span></label>
                    <input type="url" id="ipaDirectDownloadUrl" name="ipaDirectDownloadUrl" placeholder="e.g., Dropbox URL or Repo URL (https://...)">
                    <span style="font-size: 0.85em; color: var(--silver); display: block; margin-top: 5px;">For iOS: Enables TrollStore / Sileo / Zebra install buttons for Premium users.</span>
                </div>

            <!-- ONLY SHOW TO DISTRIBUTORS AND ADMINS -->
            <% if (user && (user.role === 'distributor' || user.role === 'admin')) { %>
                <fieldset class="form-section">
                    <legend>Security Scan Overrides</legend>
                    <p style="color: var(--silver); font-size: 0.9em; margin-bottom: 15px;">Provide direct links to file scans (e.g., MalwareBazaar, VirusTotal File Scan) if the automated URL scanner cannot reach the actual file.</p>
                    
                    <div class="form-group">
                        <label for="manualFileScanUrl">Manual File Scan URL (Optional)</label>
                        <input type="url" id="manualFileScanUrl" name="manualFileScanUrl" placeholder="https://virustotal.com/gui/file/...">
                    </div>
                    
                    <div class="form-group">
                        <label for="manualSiteScanUrl">Manual Site Scan URL (Optional)</label>
                        <input type="url" id="manualSiteScanUrl" name="manualSiteScanUrl" placeholder="https://virustotal.com/gui/url/...">
                    </div>
                </fieldset>
            <% } %>

            <fieldset class="form-section">
                <legend>Media & Metadata</legend>
                <div class="form-group">
                    <label for="tags">Tags (Optional, comma-separated)</label>
                    <input type="text" id="tags" name="tags" placeholder="strategy, multiplayer, offline" autocomplete="off">
                </div>

                <div class="form-group">
                    <label>Mod Screenshots* (1-4 images)</label>
                    <div class="file-input-wrapper">
                        <input type="file" id="screenshots" name="screenshots" accept="image/png, image/jpeg" multiple required>
                        <label for="screenshots" class="file-input-label">Choose Screenshots</label>
                        <span class="file-name" id="screenshotFileName">No files selected</span>
                    </div>
                    <div class="preview-container" id="screenshotPreviewContainer"></div>
                </div>

                <div class="form-group">
                    <label for="videoUrl">Video URL (Optional)</label>
                    <input type="url" id="videoUrl" name="videoUrl" placeholder="https://www.youtube.com/watch?v=..." autocomplete="off">
                    <div class="preview-container" id="videoPreviewContainer"></div>
                </div>
            </fieldset>
            
            <input type="hidden" name="actionType" id="actionType" value="submit">

            <div class="button-group">
                <button type="button" class="draft-button" id="saveDraftBtn">Save Draft</button>
                <button type="button" class="submit-button" id="submitModBtn">Submit Mod for Review</button>
            </div>
        </form>
    </div>
</div>

<!-- ======== CONFIRMATION MODALS ======== -->

<!-- Submit Confirmation Modal -->
<div id="submit-confirm-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--gold); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-paper-plane" style="font-size: 3em; color: var(--gold); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Submit Mod?</h2>
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            Are you sure you want to submit this mod for review? You will not be able to edit the core details again until an admin approves or rejects it.
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" class="btn btn-primary" id="confirmSubmitBtn" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: var(--gold); color: var(--black); border: none; cursor: pointer;">Yes, Submit</button>
            <button type="button" class="btn btn-secondary" onclick="closeConfirmModal('submit-confirm-modal')" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: transparent; border: 2px solid var(--silver); color: var(--silver); cursor: pointer;">Cancel</button>
        </div>
    </div>
</div>

<!-- Draft Confirmation Modal -->
<div id="draft-confirm-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--silver); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-save" style="font-size: 3em; color: var(--silver); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Save Draft?</h2>
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            Your progress will be saved. You can return to this page later from your "My Uploads" dashboard to finish and submit the mod.
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" class="btn btn-primary" id="confirmDraftBtn" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: var(--silver); color: var(--black); border: none; cursor: pointer;">Save Draft</button>
            <button type="button" class="btn btn-secondary" onclick="closeConfirmModal('draft-confirm-modal')" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: transparent; border: 2px solid #555; color: var(--silver); cursor: pointer;">Cancel</button>
        </div>
    </div>
</div>

<div id="status-alert-box" class="alert-msg" style="display: none; width: 100%; max-width: 800px; margin: 0 auto 20px auto;"></div>

<script>
// Helper to control the Error/Success Alert Box
function showStatusAlert(message, type) {
    const alertBox = document.getElementById('status-alert-box');
    if (!alertBox) return;

    alertBox.textContent = message;
    if (type === 'error') {
        alertBox.className = 'status-banner rejected'; 
        alertBox.style.backgroundColor = 'rgba(229, 57, 53, 0.1)';
        alertBox.style.color = 'var(--red)';
        alertBox.style.border = '1px solid var(--red)';
    } else {
        alertBox.className = 'status-banner'; 
        alertBox.style.backgroundColor = 'rgba(46, 204, 113, 0.1)';
        alertBox.style.color = '#2ecc71';
        alertBox.style.border = '1px solid #2ecc71';
    }
    alertBox.style.display = 'block';
    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

window.closeConfirmModal = function(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.classList.remove('show');
        setTimeout(() => { modal.style.display = 'none'; }, 200);
    }
}

document.addEventListener('DOMContentLoaded', () => {

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('error')) showStatusAlert(urlParams.get('error'), 'error'); 
    if (urlParams.has('success')) showStatusAlert(urlParams.get('success'), 'success'); 

    // ==========================================
    // 1. UI ELEMENTS & BASIC LOGIC
    // ==========================================
    const modIcon = document.getElementById('modIcon');
    const iconImage = document.getElementById('iconImage');
    const iconPlaceholder = document.getElementById('iconPlaceholder');
    const screenshotsInput = document.getElementById('screenshots');
    const screenshotFileNameSpan = document.getElementById('screenshotFileName');
    const screenshotPreviewContainer = document.getElementById('screenshotPreviewContainer');
    const videoUrlInput = document.getElementById('videoUrl');
    const videoPreviewContainer = document.getElementById('videoPreviewContainer');

    // Live icon preview
    if (modIcon) {
        modIcon.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    iconImage.src = e.target.result;
                    iconImage.style.display = 'block';
                    if(iconPlaceholder) iconPlaceholder.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        });
    }

    // Screenshot Preview Logic
    if (screenshotsInput) {
        screenshotsInput.addEventListener('change', function() {
            const files = this.files;
            if (screenshotPreviewContainer) screenshotPreviewContainer.innerHTML = '';
            
            if (files.length > 0) {
                if (screenshotPreviewContainer) screenshotPreviewContainer.style.display = 'block'; 
                if (screenshotFileNameSpan) screenshotFileNameSpan.textContent = files.length + ' file(s) selected';
                
                Array.from(files).slice(0, 4).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        if (screenshotPreviewContainer) screenshotPreviewContainer.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                });
            } else {
                if (screenshotPreviewContainer) screenshotPreviewContainer.style.display = 'none'; 
                if (screenshotFileNameSpan) screenshotFileNameSpan.textContent = 'No files selected';
            }
        });
    }

    // Video Preview Logic
    function getYouTubeId(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length === 11) ? match[2] : null;
    }

    if (videoUrlInput && videoPreviewContainer) {
        videoUrlInput.addEventListener('input', function() {
            const videoId = getYouTubeId(this.value);
            if (videoId) {
                videoPreviewContainer.style.display = 'block'; 
                videoPreviewContainer.innerHTML = `<div class="video-preview-wrapper"><iframe src="//www.youtube.com/embed/${videoId}" frameborder="0" allowfullscreen></iframe></div>`;
            } else {
                videoPreviewContainer.style.display = 'none'; 
                videoPreviewContainer.innerHTML = '';
            }
        });
    }

    // ==========================================
    // 2. CUSTOM SELECT LOGIC (DYNAMIC)
    // ==========================================
    
    const platformWrapper = document.getElementById('platformWrapper');
    const nativePlatformSelect = document.getElementById('modPlatform');
    const categoryWrapper = document.getElementById('categoryWrapper');
    const nativeCategorySelect = document.getElementById('modCategory');
    const categoryOptionsContainer = document.getElementById('categoryOptionsContainer');
    
    const ageRatingWrapper = document.getElementById('ageRatingWrapper');
    const nativeAgeRatingSelect = document.getElementById('ageRating');

    // Multi-select for Architectures (New)
    const archWrapper = document.getElementById('archWrapper');
    const archCustomSelect = document.getElementById('archCustomSelect');

    function setupCustomSelect(wrapper, nativeSelect) {
        if (!wrapper || !nativeSelect) return;
        
        const customSelect = wrapper.querySelector('.custom-select');
        const selectedText = wrapper.querySelector('.selected-text');
        
        // Toggle open/close
        customSelect.addEventListener('click', function(e) {
            if (wrapper.classList.contains('disabled')) return;
            e.stopPropagation();
            
            // Close others
            document.querySelectorAll('.custom-select-wrapper').forEach(w => {
                if (w !== wrapper) w.classList.remove('open');
            });
            
            wrapper.classList.toggle('open');
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });

        const optionsContainer = wrapper.querySelector('.custom-options');
        if (optionsContainer) {
            optionsContainer.addEventListener('click', function(e) {
                if (e.target.classList.contains('custom-option')) {
                    e.stopPropagation();
                    const value = e.target.getAttribute('data-value');
                    const text = e.target.textContent;

                    selectedText.textContent = text;
                    selectedText.style.color = 'var(--white)';
                    nativeSelect.value = value;
                    
                    // Dispatch change event to trigger dependent logic
                    nativeSelect.dispatchEvent(new Event('change'));

                    // Manage selected state
                    wrapper.querySelectorAll('.custom-option').forEach(opt => opt.classList.remove('selected'));
                    e.target.classList.add('selected');

                    wrapper.classList.remove('open');
                }
            });
        }
    }

    // Setup toggling for Architecture Multi-Select specifically
    if (archCustomSelect && archWrapper) {
        archCustomSelect.addEventListener('click', function(e) {
            e.stopPropagation();
            // Close others
            document.querySelectorAll('.custom-select-wrapper').forEach(w => {
                if (w !== archWrapper) w.classList.remove('open');
            });
            archWrapper.classList.toggle('open');
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });
    }

    // Initialize single-selects
    setupCustomSelect(platformWrapper, nativePlatformSelect);
    setupCustomSelect(categoryWrapper, nativeCategorySelect);
    setupCustomSelect(ageRatingWrapper, nativeAgeRatingSelect);

    // Apply the 'selected' class to the correct custom option on load
    if (nativeAgeRatingSelect && ageRatingWrapper) {
        const currentValue = nativeAgeRatingSelect.value;
        if (currentValue) {
            const optionToSelect = ageRatingWrapper.querySelector(`.custom-option[data-value="${currentValue}"]`);
            if (optionToSelect) {
                optionToSelect.classList.add('selected');
            }
        }
    }

    // Close all when clicking outside
    document.addEventListener('click', function() {
        document.querySelectorAll('.custom-select-wrapper').forEach(wrapper => {
            wrapper.classList.remove('open');
        });
    });

    // --- Dynamic Category Population Logic ---
    const categoriesByPlatform = {
        android:['Game - Action', 'Game - Adventure', 'Game - Puzzle', 'Game - RPG', 'App - Productivity', 'App - Social', 'App - Tools', 'Other'],
        'ios-jailed':['Game - Action', 'Game - Adventure', 'Game - Puzzle', 'Game - RPG', 'App - Productivity', 'App - Social', 'App - Tools', 'Other'],
        'ios-jailbroken':['Tweak', 'Theme', 'Utility', 'Widget', 'Other'],
        windows:['Software - Utility', 'Software - Multimedia', 'Software - Security', 'Software - Development', 'Game', 'Other'],
        wordpress:['Plugin - SEO', 'Plugin - Security', 'Plugin - E-commerce', 'Plugin - Page Builder', 'Theme - Portfolio', 'Theme - E-commerce', 'Theme - Blog', 'Other']
    };

    function populateCategories() {
        if (!nativePlatformSelect || !nativeCategorySelect || !categoryOptionsContainer || !categoryWrapper) return;
        
        const selectedPlatform = nativePlatformSelect.value;
        const categories = categoriesByPlatform[selectedPlatform] ||[];
        
        nativeCategorySelect.innerHTML = '';
        categoryOptionsContainer.innerHTML = '';
        
        const customSelectedText = categoryWrapper.querySelector('.selected-text');

        if (categories.length > 0) {
            nativeCategorySelect.disabled = false;
            categoryWrapper.classList.remove('disabled');
            customSelectedText.textContent = 'Select a category...';
            customSelectedText.style.color = 'var(--silver)';
            
            let nativeDefault = document.createElement('option');
            nativeDefault.text = 'Select a category...';
            nativeDefault.value = '';
            nativeDefault.disabled = true;
            nativeDefault.selected = true;
            nativeCategorySelect.add(nativeDefault);

            categories.forEach(function(category) {
                const catValue = category.toLowerCase().replace(/ /g, '-');
                
                let option = document.createElement('option');
                option.text = category;
                option.value = catValue;
                nativeCategorySelect.add(option);
                
                let customOpt = document.createElement('div');
                customOpt.className = 'custom-option';
                customOpt.setAttribute('data-value', catValue);
                customOpt.textContent = category;
                categoryOptionsContainer.appendChild(customOpt);
            });
        } else {
            nativeCategorySelect.disabled = true;
            categoryWrapper.classList.add('disabled');
            customSelectedText.textContent = 'Select a platform first...';
            customSelectedText.style.color = 'var(--silver)';
        }
    }

    // --- Fixed & Updated Event Listener for Platform Change ---
    if (nativePlatformSelect) {
        nativePlatformSelect.addEventListener('change', function() {
            // 1. Populate standard Categories
            populateCategories();
            
            const selectedPlatform = this.value;

            // ====================================================
            // 2. DEPENDENCY / ARCHITECTURE / OS LOGIC
            // ====================================================
            const archMap = {
                'android':['arm64-v8a', 'armeabi-v7a', 'x86_64', 'x86'],
                'windows':['x86-64', 'x64', 'x86'],
                'ios-jailed':['arm64', 'arm64e', 'armv7 / armv7s', 'Apple Silicon Mac (arm64)', 'Intel Mac (x86-64)'],
                'ios-jailbroken':['arm64', 'arm64e', 'armv7 / armv7s', 'Apple Silicon Mac (arm64)', 'Intel Mac (x86-64)']
            };

            const archGroup = document.getElementById('arch-group');
            const archOptionsContainer = document.getElementById('archOptionsContainer');
            const archSelectedText = document.getElementById('archSelectedText');
            
            const archReqStar = document.getElementById('arch-req-star');
            const osReqStar = document.getElementById('os-req-star');
            const minOsInput = document.getElementById('minOsVersion');
            const ipaLinkGroup = document.getElementById('ipa-link-group');
            

            // ✅ DISPLAY CORRECT ARCHITECTURE CHECKBOXES
            if (archMap[selectedPlatform]) {
                archGroup.style.display = 'block';
                archOptionsContainer.innerHTML = ''; // Clear old checkboxes
                archSelectedText.textContent = 'Select architectures...';
                archSelectedText.style.color = 'var(--silver)';
                
                archMap[selectedPlatform].forEach(arch => {
                    const label = document.createElement('label');
                    label.className = 'custom-option';
                    label.style.display = 'flex';
                    label.style.alignItems = 'center';
                    label.style.gap = '10px';
                    label.style.cursor = 'pointer';
                    
                    const checkbox = document.createElement('input');
                    checkbox.type = 'checkbox';
                    checkbox.name = 'architectures';
                    checkbox.value = arch;
                    checkbox.style.accentColor = 'var(--gold)';
                    checkbox.style.width = '16px';
                    checkbox.style.height = '16px';
                    checkbox.style.cursor = 'pointer';
                    
                    // Stop dropdown closing when toggling checkboxes
                    label.addEventListener('click', function(e) {
                        e.stopPropagation(); 
                    });
                    
                    checkbox.addEventListener('change', function() {
                        const checkedBoxes = archOptionsContainer.querySelectorAll('input[type="checkbox"]:checked');
                        if (checkedBoxes.length === 0) {
                            archSelectedText.textContent = 'Select architectures...';
                            archSelectedText.style.color = 'var(--silver)';
                        } else if (checkedBoxes.length === 1) {
                            archSelectedText.textContent = checkedBoxes[0].value;
                            archSelectedText.style.color = 'var(--white)';
                        } else {
                            archSelectedText.textContent = `${checkedBoxes.length} architectures selected`;
                            archSelectedText.style.color = 'var(--white)';
                        }
                    });

                    label.appendChild(checkbox);
                    label.appendChild(document.createTextNode(arch));
                    archOptionsContainer.appendChild(label);
                });
            } else {
                archGroup.style.display = 'none';
            }

            // ✅ ENFORCE JAILBREAK REQUIREMENTS
            if (selectedPlatform === 'ios-jailbroken') {
                if(archReqStar) archReqStar.style.display = 'inline';
                if(osReqStar) osReqStar.style.display = 'inline';
                if(minOsInput) minOsInput.required = true;
            } else {
                if(archReqStar) archReqStar.style.display = 'none';
                if(osReqStar) osReqStar.style.display = 'none';
                if(minOsInput) minOsInput.required = false;
            }

            // ✅ DISPLAY DIRECT IPA LINK FIELD IF IOS
            if (selectedPlatform.startsWith('ios')) {
                if(ipaLinkGroup) ipaLinkGroup.style.display = 'block';
            } else {
                if(ipaLinkGroup) ipaLinkGroup.style.display = 'none';
            }
        });

        // Auto-Select based on Smart Guess from backend
        const preSelectedPlatform = "<%= typeof defaultPlatform !== 'undefined' ? defaultPlatform : '' %>";
        if (preSelectedPlatform) {
            const optionToSelect = platformWrapper.querySelector(`.custom-option[data-value="${preSelectedPlatform}"]`);
            if(optionToSelect) {
                optionToSelect.click();
            }
        }
    }

    // ==========================================
    // 3. QUILL RICH TEXT EDITORS & SUBMISSION
    // ==========================================
    const toolbarOptions = [['bold', 'italic', 'underline', 'strike'],[{ 'list': 'ordered'}, { 'list': 'bullet' }],['clean']];

    let quillDesc, quillFeat, quillOff, quillNew, quillNote;

    if (document.getElementById('editor-modDescription')) quillDesc = new Quill('#editor-modDescription', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-modFeatures')) quillFeat = new Quill('#editor-modFeatures', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-officialDescription')) quillOff = new Quill('#editor-officialDescription', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-whatsNew')) quillNew = new Quill('#editor-whatsNew', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-importantNote')) quillNote = new Quill('#editor-importantNote', { theme: 'snow', modules: { toolbar: toolbarOptions } });

    function syncQuillData() {
        if(quillDesc) document.getElementById('modDescription').value = quillDesc.root.innerHTML === '<p><br></p>' ? '' : quillDesc.root.innerHTML;
        if(quillFeat) document.getElementById('modFeatures').value = quillFeat.root.innerHTML === '<p><br></p>' ? '' : quillFeat.root.innerHTML;
        if(quillOff) document.getElementById('officialDescription').value = quillOff.root.innerHTML === '<p><br></p>' ? '' : quillOff.root.innerHTML;
        if(quillNew) document.getElementById('whatsNew').value = quillNew.root.innerHTML === '<p><br></p>' ? '' : quillNew.root.innerHTML;
        if(quillNote) document.getElementById('importantNote').value = quillNote.root.innerHTML === '<p><br></p>' ? '' : quillNote.root.innerHTML;
    }

    const saveDraftBtn = document.getElementById('saveDraftBtn');
    const submitModBtn = document.getElementById('submitModBtn');
    const actionTypeInput = document.getElementById('actionType');
    const mainForm = document.getElementById('mainUploadForm');
    const draftModal = document.getElementById('draft-confirm-modal');
    const submitModal = document.getElementById('submit-confirm-modal');

    if (saveDraftBtn && draftModal) {
        saveDraftBtn.addEventListener('click', (e) => {
            e.preventDefault();
            syncQuillData(); 
            draftModal.style.display = 'flex';
            setTimeout(() => draftModal.classList.add('show'), 10);
        });
    }

    if (submitModBtn && mainForm && submitModal) {
        submitModBtn.addEventListener('click', (e) => {
            e.preventDefault();
            syncQuillData();
            
            let hasError = false;

            // 1. Validate Dropdowns Custom UI
            if (!nativePlatformSelect.value) {
                if (platformWrapper) {
                    platformWrapper.querySelector('.custom-select').style.borderColor = 'var(--red)';
                    platformWrapper.querySelector('.custom-select').style.boxShadow = '0 0 10px rgba(229, 57, 53, 0.5)';
                }
                hasError = true;
            }
            if (!nativeCategorySelect.value || nativeCategorySelect.disabled) {
                if (categoryWrapper) {
                    categoryWrapper.querySelector('.custom-select').style.borderColor = 'var(--red)';
                    categoryWrapper.querySelector('.custom-select').style.boxShadow = '0 0 10px rgba(229, 57, 53, 0.5)';
                }
                hasError = true;
            }

            // 2. Validate Architecture required conditions
            if (nativePlatformSelect.value === 'ios-jailbroken') {
                const checkedArchs = document.querySelectorAll('input[name="architectures"]:checked');
                if (checkedArchs.length === 0) {
                    if (archWrapper) {
                        archWrapper.querySelector('.custom-select').style.borderColor = 'var(--red)';
                        archWrapper.querySelector('.custom-select').style.boxShadow = '0 0 10px rgba(229, 57, 53, 0.5)';
                    }
                    hasError = true;
                }
            }

            // 3. Check native visible fields
            if (!mainForm.checkValidity() || hasError) {
                mainForm.reportValidity();
                if(hasError) showStatusAlert('Please fill out all required custom dropdowns.', 'error');
                return;
            }
            
            // 4. Check Quill hidden fields
            if (!document.getElementById('modDescription').value.trim()) {
                showStatusAlert('Error: Mod Description is required.', 'error'); return;
            }
            if (!document.getElementById('modFeatures').value.trim()) {
                showStatusAlert('Error: Mod Features are required.', 'error'); return;
            }

            // Proceed
            actionTypeInput.value = 'submit';
            submitModal.style.display = 'flex';
            setTimeout(() => submitModal.classList.add('show'), 10);
        });
    }

    document.getElementById('confirmSubmitBtn').addEventListener('click', () => {
        actionTypeInput.value = 'submit';
        mainForm.submit();
    });

    document.getElementById('confirmDraftBtn').addEventListener('click', () => {
        actionTypeInput.value = 'draft';
        mainForm.submit();
    });
});
</script>
<%- include('../partials/footer') %>