<%- include('../partials/header') %>

<style>
    /* ✅ FIX: Reusing the exact styles from upload.ejs for perfect consistency */
    .upload-container { 
        max-width: 700px; 
        margin: 4rem auto; 
        padding: 3rem 2rem; 
        background-color: var(--dark-gray); 
        border-radius: 12px; 
        text-align: center;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .form-group { text-align: left; margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); }
    .form-group input[type="text"], .form-group input[type="url"], .form-group textarea {
        width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333;
        background-color: var(--black); color: var(--white); font-size: 1.1em;
        font-family: 'Poppins', sans-serif; transition: all 0.3s ease; outline: none;
    }
    .form-group input:focus, .form-group textarea:focus { border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }
    .form-group textarea { min-height: 120px; resize: vertical; }
    
    .file-input-label { 
        display: inline-block; padding: 15px 30px; background: transparent; 
        color: var(--gold); border: 2px dashed var(--gold); border-radius: 8px; 
        cursor: pointer; transition: all 0.3s ease; font-size: 1.2em; 
        margin-bottom: 1rem; width: 100%; text-align: center;
    }
    .file-input-label:hover { background: rgba(255, 215, 0, 0.1); }
    
    .submit-button { 
        display: block; width: 100%; background: var(--gold); color: var(--black); 
        padding: 15px 20px; border-radius: 8px; font-weight: 700; font-size: 1.2em; 
        border: none; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 15px var(--glow-gold); 
        margin-top: 2rem; 
    }
    .submit-button:hover { transform: translateY(-2px); box-shadow: 0 0 25px var(--glow-gold); }
    .submit-button:disabled { background-color: #555; color: #aaa; cursor: not-allowed; box-shadow: none; transform: none; }
    
    #file-name-display { margin-top: 15px; color: var(--white); font-weight: 600; font-size: 1.1em; text-align: center; }
    
    /* --- LIVE PROGRESS BAR STYLES --- */
    .progress-wrapper { display: none; margin-top: 25px; text-align: left; }
    .progress-container { width: 100%; background-color: var(--black); border: 1px solid #444; border-radius: 8px; height: 25px; overflow: hidden; position: relative; }
    .progress-bar { height: 100%; width: 0%; background-color: var(--gold); transition: width 0.2s ease; display: flex; align-items: center; justify-content: center; color: var(--black); font-weight: bold; font-size: 0.85em; white-space: nowrap; }
    .status-text { color: var(--silver); margin-top: 10px; font-size: 0.95em; text-align: center; }
    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
    .processing-pulse { animation: pulse 1.5s infinite; }
</style>

<div class="container">
    <div class="upload-container">
        <h2 style="color: var(--white); margin-bottom: 10px; font-size: 2.2em;">Update <span style="color: var(--gold); text-shadow: 0 0 15px var(--glow-gold);"><%= parentFile.name %></span></h2>
        <p style="color: var(--silver); margin-bottom: 2.5rem;">Uploading a new version will make this file the primary download.</p>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background-color: rgba(229, 57, 53, 0.1); color: var(--red); border: 1px solid var(--red); padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold;"><%= error %></div>
        <% } %>

        <!-- ✅ FIX: Added Distributor / Admin UI Logic -->
        <% if (user && (user.role === 'distributor' || user.role === 'admin')) { %>
            <p style="color: var(--silver); margin-bottom: 1.5rem;">
                <span style="color: var(--gold); font-weight: bold;">★ <%= user.role === 'admin' ? 'Admin' : 'Distributor' %> Account Active ★</span><br>
                Choose your update method below.
            </p>
            
            <div style="display: flex; gap: 10px; justify-content: center; margin-bottom: 25px;">
                <button type="button" class="btn btn-primary" id="btn-show-link" style="flex: 1; padding: 10px;">Paste External Link(s)</button>
                <button type="button" class="btn btn-secondary" id="btn-show-file" style="flex: 1; padding: 10px;">Upload to Cloud</button>
            </div>

            <!-- External Link Form -->
            <form action="/mods/<%= parentFile._id %>/add-version" method="POST" id="distributorUploadForm">
                
                <!-- We need these text fields for BOTH options -->
                <div class="form-group">
                    <label for="softwareVersion">New Version Number*</label>
                    <input type="text" id="softwareVersion" name="softwareVersion" placeholder="e.g., 2.2.0" required autocomplete="off">
                </div>
                <div class="form-group">
                    <label for="whatsNew">What's New in this Version? (Optional)</label>
                    <textarea id="whatsNew" name="whatsNew" placeholder="List the changes, bug fixes, or new features in this update."></textarea>
                </div>

                <div class="form-group" style="text-align: left; margin-bottom: 15px; margin-top: 30px;">
                    <div class="checkbox-group" style="display: flex; align-items: center; gap: 10px;">
                        <label class="switch">
                            <input type="checkbox" id="isMultiPartDistributor" name="isMultiPart" value="true">
                            <span class="slider round"></span>
                        </label>
                        <label for="isMultiPartDistributor" style="margin-bottom: 0; cursor: pointer; color: var(--silver); font-weight: 600;">This update requires multiple download links (Multi-Part)</label>
                    </div>

                    <div id="single-link-group" class="form-group" style="margin-top: 15px;">
                        <label for="externalUrl">External Download Link*</label>
                        <input type="url" id="externalUrl" name="externalUrl" placeholder="https://linkvertise.com/..." required>
                    </div>
                    
                    <div id="multi-link-group" class="form-group" style="display: none; margin-top: 15px;">
                        <label>Add Download Parts (Min 2)*</label>
                        <div id="parts-container">
                            <input type="url" name="partUrls[]" placeholder="Part 1 URL..." style="margin-bottom: 10px;">
                            <input type="url" name="partUrls[]" placeholder="Part 2 URL..." style="margin-bottom: 10px;">
                        </div>
                        <button type="button" id="add-part-btn" class="btn btn-secondary" style="padding: 5px 15px; font-size: 0.9em; margin-top: 5px;">+ Add Another Part</button>
                    </div>

                    <div class="form-group" style="margin-top: 15px;">
                        <label for="originalFilename">File Name (for display purposes)*</label>
                        <input type="text" id="originalFilename" name="originalFilename" required value="<%= parentFile.name %>_Update">
                    </div>
                </div>

                <button type="submit" class="submit-button" id="distributorSubmitBtn">Publish Update</button>
            </form>
            
            <!-- Standard File Upload Form (Hidden initially) -->
            <form action="/mods/<%= parentFile._id %>/add-version" method="POST" enctype="multipart/form-data" id="initialUploadForm" style="display: none;">
                
                <!-- Text fields for file upload -->
                <div class="form-group">
                    <label for="softwareVersion2">New Version Number*</label>
                    <input type="text" id="softwareVersion2" name="softwareVersion" placeholder="e.g., 2.2.0" required autocomplete="off">
                </div>
                <div class="form-group">
                    <label for="whatsNew2">What's New in this Version? (Optional)</label>
                    <textarea id="whatsNew2" name="whatsNew" placeholder="List the changes, bug fixes, or new features in this update."></textarea>
                </div>

                <p style="color: var(--silver); margin: 2rem 0 1rem 0; font-size: 0.9em;">Max File Size: Unlimited</p>
                <div class="form-group">
                    <label for="modFile" class="file-input-label" id="drop-zone">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2em; display: block; margin-bottom: 10px;"></i>
                        Click to Choose New File
                    </label>
                    <input type="file" id="modFile" name="modFile" required style="display:none;" data-limit="999999999999">
                    <div id="file-name-display">No file selected</div>
                </div>
                
                <div class="progress-wrapper" id="progressWrapper">
                    <div class="progress-container"><div class="progress-bar" id="progressBar">0%</div></div>
                    <p class="status-text" id="statusText">Starting upload...</p>
                </div>
                <button type="submit" class="submit-button" id="submitBtn">Upload New Version</button>
            </form>

        <% } else { %>
            <!-- ========================================== -->
            <!-- STANDARD USER UPLOAD FORM (File Upload)    -->
            <!-- ========================================== -->
            <% 
                let limitText = (user && user.membership === 'premium') ? "1 GB" : "300 MB";
                let limitBytes = (user && user.membership === 'premium') ? 1073741824 : 314572800; 
            %>
            
            <form action="/mods/<%= parentFile._id %>/add-version" method="POST" enctype="multipart/form-data" id="initialUploadForm">
                
                <div class="form-group">
                    <label for="softwareVersion">New Version Number*</label>
                    <input type="text" id="softwareVersion" name="softwareVersion" placeholder="e.g., 2.2.0" required autocomplete="off">
                </div>
                <div class="form-group">
                    <label for="whatsNew">What's New in this Version? (Optional)</label>
                    <textarea id="whatsNew" name="whatsNew" placeholder="List the changes, bug fixes, or new features in this update."></textarea>
                </div>

                <p style="color: var(--gold); font-weight: bold; margin: 2rem 0 1rem 0;">Max File Size: <%= limitText %></p>
                
                <div class="form-group">
                    <label for="modFile" class="file-input-label" id="drop-zone">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 2em; display: block; margin-bottom: 10px;"></i>
                        Click to Choose New File
                    </label>
                    <!-- ✅ FIX: Passed the size limits correctly to the input -->
                    <input type="file" id="modFile" name="modFile" required style="display:none;" data-limit="<%= limitBytes %>">
                    <div id="file-name-display">No file selected</div>
                </div>
                
                <div class="progress-wrapper" id="progressWrapper">
                    <div class="progress-container"><div class="progress-bar" id="progressBar">0%</div></div>
                    <p class="status-text" id="statusText">Starting upload...</p>
                </div>

                <button type="submit" class="submit-button" id="submitBtn">Upload New Version</button>
            </form>
        <% } %>
    </div>
</div>

<!-- ======== NEW: CUSTOM ERROR MODAL ======== -->
<div id="error-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 400px; width: 90%; border-top: 3px solid var(--red); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-exclamation-triangle" style="font-size: 3em; color: var(--red); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Upload Error</h2>
        <p id="error-modal-msg" style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;"></p>
        <button type="button" class="btn btn-primary" onclick="closeErrorModal()" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; font-size: 1.1em; background-color: var(--red); border: none;">Okay</button>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    // Helper to control the Error Modal
    function showErrorModal(message) {
        document.getElementById('error-modal-msg').textContent = message;
        const modal = document.getElementById('error-modal');
        modal.style.display = 'flex';
        setTimeout(() => modal.classList.add('show'), 10);
    }
    function closeErrorModal() {
        const modal = document.getElementById('error-modal');
        modal.classList.remove('show');
        setTimeout(() => modal.style.display = 'none', 200);
    }

    document.addEventListener('DOMContentLoaded', () => {
        // --- 1. Role-Based Size Limit Check & Live Progress Bar ---
        const fileInput = document.getElementById('modFile');
        const fileNameDisplay = document.getElementById('file-name-display');
        const form = document.getElementById('initialUploadForm');
        const submitBtn = document.getElementById('submitBtn');
        const dropZone = document.getElementById('drop-zone');
        const progressWrapper = document.getElementById('progressWrapper');
        const progressBar = document.getElementById('progressBar');
        const statusText = document.getElementById('statusText');

        if (fileInput && form && dropZone) {
            fileInput.addEventListener('change', function() {
                if (this.files && this.files.length > 0) {
                    const file = this.files[0];
                    const sizeInMB = (file.size / (1024 * 1024)).toFixed(2);
                    const maxLimit = parseInt(this.getAttribute('data-limit') || '999999999999', 10);
                    
                    if (file.size > maxLimit) {
                        showErrorModal(`File is too large! Your limit is ${maxLimit === 314572800 ? '300 MB' : '1 GB'}.`);
                        this.value = ''; 
                        fileNameDisplay.textContent = 'No file selected';
                        dropZone.style.borderColor = 'var(--red)';
                        dropZone.style.backgroundColor = 'rgba(229, 57, 53, 0.05)';
                        return;
                    }

                    fileNameDisplay.textContent = `Ready: ${file.name} (${sizeInMB} MB)`;
                    dropZone.style.borderColor = 'var(--gold)';
                    dropZone.style.backgroundColor = 'rgba(255, 215, 0, 0.05)';
                }
            });

            // ✅ FIX: AJAX Form Submission for TRUE End-to-End Live Progress
            form.addEventListener('submit', function(e) {
                e.preventDefault(); 
                if (fileInput.files.length === 0) return showErrorModal("Please select a file.");
                
                // Get the extra fields
                const softwareVersion = document.getElementById(form.querySelector('input[name="softwareVersion"]').id).value;
                const whatsNew = document.getElementById(form.querySelector('textarea[name="whatsNew"]').id).value;

                if (!softwareVersion) return showErrorModal("Please provide the new version number.");

                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Uploading...';
                progressWrapper.style.display = 'block';
                progressBar.style.width = '0%';
                progressBar.textContent = '0%';
                progressBar.classList.remove('processing-pulse');
                statusText.innerHTML = 'Uploading file to server...';

                const formData = new FormData();
                formData.append('modFile', fileInput.files[0]);
                formData.append('softwareVersion', softwareVersion);
                formData.append('whatsNew', whatsNew);
                
                const uploadId = 'up_' + Date.now();
                formData.append('uploadId', uploadId);

                const socket = io();
                socket.on(`b2_progress_${uploadId}`, (data) => {
                    const totalPercent = 50 + Math.round(data.percent / 2);
                    progressBar.style.width = totalPercent + '%';
                    progressBar.textContent = totalPercent + '%';
                    statusText.innerHTML = `Transferring to Cloud Storage: ${data.loaded} MB / ${data.total} MB...`;
                    
                    if (data.percent === 100) {
                        progressBar.classList.add('processing-pulse');
                        statusText.innerHTML = 'Finalizing update... Almost done!';
                    }
                });

                const xhr = new XMLHttpRequest();
                xhr.open('POST', form.action, true);

                // --- 1. The Progress Tracking (Fixed) ---
                xhr.upload.addEventListener('progress', function(event) {
                    if (event.lengthComputable) {
                        // The file uploading to YOUR server (RAM) is the first 50%
                        const percentComplete = Math.round((event.loaded / event.total) * 50);
                        progressBar.style.width = percentComplete + '%';
                        progressBar.textContent = percentComplete + '%';

                        if (percentComplete === 50) {
                            statusText.innerHTML = 'Securing file in memory... connecting to cloud.';
                        } else {
                            statusText.innerHTML = `Uploading to Server RAM: ${percentComplete * 2}%`;
                        }
                    }
                });

                // --- 2. The Success/Redirect Handler (Fixed) ---
                xhr.onload = function() {
                    if (xhr.status >= 200 && xhr.status < 400) {
                        // ✅ FIX: Force the browser to parse the response as JSON
                        try {
                            const res = JSON.parse(xhr.responseText);
                            
                            if (res.success && res.redirectUrl) {
                                // IMPORTANT: We must redirect to the NEW URL provided by the server!
                                window.location.href = res.redirectUrl; 
                            } else {
                                showErrorModal(res.message || 'Upload finished, but server did not provide a redirect URL.');
                                resetUI();
                            }
                        } catch(e) {
                            // If JSON parsing fails completely, the server might have crashed
                            // or returned an HTML error page instead of JSON.
                            console.error("Failed to parse server response:", xhr.responseText);
                            showErrorModal('Server returned an unexpected response. Please check your uploads dashboard.');
                            resetUI();
                        }
                    } else {
                        // Server returned a 400 or 500 error code
                        try {
                            const res = JSON.parse(xhr.responseText);
                            showErrorModal(res.message || 'Upload failed.');
                        } catch(e) {
                            showErrorModal(`Server error (${xhr.status}). The file might be too large.`);
                        }
                        resetUI();
                    }
                };

                xhr.onerror = function() { 
                    showErrorModal('A network error occurred. Please check your internet connection.'); 
                    resetUI(); 
                };
                
                // 3. Finally, send the data!
                xhr.send(formData);

            function resetUI() {
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Upload New Version';
                progressWrapper.style.display = 'none';
                progressBar.classList.remove('processing-pulse');
            }
        }

        // --- 2. Distributor Form Toggles ---
        const btnShowLink = document.getElementById('btn-show-link');
        const btnShowFile = document.getElementById('btn-show-file');
        const distLinkLib = document.getElementById('distributorUploadForm');
        
        if (btnShowLink && btnShowFile && distLinkLib && form) {
            btnShowLink.addEventListener('click', () => {
                btnShowLink.classList.replace('btn-secondary', 'btn-primary');
                btnShowFile.classList.replace('btn-primary', 'btn-secondary');
                distLinkLib.style.display = 'block';
                form.style.display = 'none';
            });
            btnShowFile.addEventListener('click', () => {
                btnShowFile.classList.replace('btn-secondary', 'btn-primary');
                btnShowLink.classList.replace('btn-primary', 'btn-secondary');
                form.style.display = 'block';
                distLinkLib.style.display = 'none';
            });
        }

        // --- 3. Distributor Multi-Part Link Logic ---
        const multiPartCheckbox = document.getElementById('isMultiPartDistributor');
        if (multiPartCheckbox) {
            const singleLinkGroup = document.getElementById('single-link-group');
            const multiLinkGroup = document.getElementById('multi-link-group');
            const singleInput = document.getElementById('externalUrl');
            const partsContainer = document.getElementById('parts-container');
            const addPartBtn = document.getElementById('add-part-btn');

            multiPartCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    singleLinkGroup.style.display = 'none';
                    singleInput.required = false;
                    multiLinkGroup.style.display = 'block';
                    partsContainer.querySelectorAll('input').forEach(i => i.required = true);
                } else {
                    singleLinkGroup.style.display = 'block';
                    singleInput.required = true;
                    multiLinkGroup.style.display = 'none';
                    partsContainer.querySelectorAll('input').forEach(i => i.required = false);
                }
            });

            let partCount = 2;
            addPartBtn.addEventListener('click', () => {
                partCount++;
                const newInput = document.createElement('input');
                newInput.type = 'url';
                newInput.name = 'partUrls[]';
                newInput.placeholder = `Part ${partCount} URL...`;
                newInput.style.cssText = 'width: 100%; margin-bottom: 10px; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1.1em; outline: none;';
                newInput.required = true;
                partsContainer.appendChild(newInput);
            });
        }
    });
</script>

<%- include('../partials/footer') %>