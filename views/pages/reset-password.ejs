<%- include('../partials/header') %>

<style>
    /* Styling to match your login/register theme */
    .auth-container { 
        width: 100%;
        max-width: 450px;
        background-color: var(--dark-gray); 
        margin: 4rem auto;
        padding: 40px; 
        border-radius: 15px; 
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .auth-container h2 { 
        text-align: center;
        color: var(--white);
        font-size: 1.8em; 
        margin-bottom: 25px; 
    }
    .auth-container h2 span { color: var(--gold); }
    
    .form-group { margin-bottom: 20px; text-align: left; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); font-size: 0.95em; }
    .form-group input { 
        width: 100%; padding: 12px 15px; border-radius: 8px; 
        border: 1px solid #333; background-color: var(--black); 
        color: var(--white); font-size: 1em; font-family: 'Poppins', sans-serif;
        transition: all 0.3s ease; 
    }
    .form-group input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }
    
    .submit-button { 
        display: block; width: 100%; background: var(--gold); color: var(--black); 
        padding: 14px 20px; border-radius: 8px; font-size: 1.1em; font-weight: 700; 
        border: none; cursor: pointer; transition: all 0.3s ease; margin-top: 10px;
    }
    .submit-button:hover { transform: translateY(-2px); box-shadow: 0 0 20px var(--glow-gold); }
    
    #reset-error {
        display: none; background-color: rgba(255, 77, 77, 0.1); border: 1px solid #ff4d4d; 
        color: #ff4d4d; padding: 10px; border-radius: 8px; margin-bottom: 20px; font-weight: bold; text-align: center;
    }
</style>

<main class="container">
    <div class="auth-container">
        <h2>Reset <span>Password</span></h2>
        
        <!-- Error Message Box -->
        <div id="reset-error"></div>

        <form action="/reset-password/<%= token %>" method="POST">
            <div class="form-group">
                <label for="password">New Password</label>
                <input type="password" id="password" name="password" placeholder="Enter your new password" required minlength="6">
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirm New Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Re-enter your new password" required minlength="6">
            </div>
            <button type="submit" class="submit-button">Set New Password</button>
        </form>
    </div>
</main>

<script>
    // This script catches URL parameters (like ?error=Passwords do not match) from the backend
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const errorBox = document.getElementById('reset-error');
        
        if (urlParams.has('error')) { 
            errorBox.textContent = urlParams.get('error');
            errorBox.style.display = 'block';
        }
    });
</script>

<%- include('../partials/footer') %>