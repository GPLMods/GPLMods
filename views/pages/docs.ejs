<%- include('../partials/header') %>

<style>
    /* GitBook-Inspired Layout */
    .docs-layout {
        display: flex;
        min-height: calc(100vh - 80px);
        background-color: var(--black);
        border-top: 1px solid #222;
    }

    /* --- SIDEBAR STYLES --- */
    .docs-sidebar {
        width: 300px;
        background-color: var(--dark-gray);
        border-right: 1px solid #222;
        padding: 30px 20px;
        overflow-y: auto;
        position: sticky;
        top: 80px; 
        height: calc(100vh - 80px);
    }
    
    .docs-sidebar h3 { color: var(--silver); font-size: 0.85em; text-transform: uppercase; letter-spacing: 1px; margin: 20px 0 10px 0; padding-left: 10px; }
    .docs-sidebar h3:first-child { margin-top: 0; }
    .docs-sidebar ul { list-style: none; padding: 0; margin: 0; }
    .docs-sidebar li a { display: block; color: #aaa; text-decoration: none; padding: 10px 15px; border-radius: 8px; font-size: 0.95em; transition: all 0.2s ease; margin-bottom: 2px; }
    .docs-sidebar li a:hover { background-color: rgba(255, 215, 0, 0.05); color: var(--gold); }
    .docs-sidebar li a.active { background-color: rgba(255, 215, 0, 0.1); color: var(--gold); font-weight: 600; border-left: 3px solid var(--gold); }

    /* --- MAIN CONTENT STYLES --- */
    .docs-content-area {
        flex-grow: 1;
        padding: 50px 60px;
        max-width: 900px; 
        margin: 0 auto;
        
        /* ✅ THE MAGIC FIX: Prevents <pre> blocks from blowing out the flex layout */
        min-width: 0; 
        width: 100%;
    }

    .docs-content-area h1 { 
        font-size: 2.8em; 
        color: var(--white); 
        margin-bottom: 10px; 
        line-height: 1.25; 
        word-wrap: break-word;
        overflow-wrap: break-word;
    }
    
    .docs-content-area .meta { 
        color: var(--silver); 
        font-size: 0.9em; 
        margin-bottom: 30px; 
        padding-bottom: 20px; 
        line-height: 1.5;
    }

    /* ✅ NEW: Featured Image Style */
    .docs-featured-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 40px;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    /* Rich Text Formatting */
    .rich-content { 
        color: #ccc; 
        font-size: 1.1em; 
        line-height: 1.8; 
        word-wrap: break-word;
        overflow-wrap: break-word;
    }
    .rich-content h2 { color: var(--gold); margin-top: 40px; margin-bottom: 15px; font-size: 1.8em; border-bottom: 1px solid #222; padding-bottom: 10px;}
    .rich-content h3 { color: var(--white); margin-top: 30px; margin-bottom: 10px; }
    .rich-content p { margin-bottom: 20px; }
    .rich-content a { color: var(--gold); text-decoration: underline; }
    .rich-content ul, .rich-content ol { margin-bottom: 20px; padding-left: 20px; }
    .rich-content li { margin-bottom: 8px; }
    .rich-content img { max-width: 100%; border-radius: 8px; margin: 20px 0; border: 1px solid #333; }
    
    /* ✅ FIXED: Code Block Scrolling */
    .rich-content pre { 
        background-color: #111; 
        padding: 20px; 
        border-radius: 8px; 
        border: 1px solid #333; 
        margin-bottom: 20px; 
        
        /* Forces horizontal scrolling on mobile instead of page breaking */
        max-width: 100%;
        overflow-x: auto; 
        white-space: pre; 
    }
    
    /* Beautiful Scrollbar for Code Blocks */
    .rich-content pre::-webkit-scrollbar { height: 8px; }
    .rich-content pre::-webkit-scrollbar-track { background: #1a1a1a; border-radius: 4px; }
    .rich-content pre::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 4px; }

    .rich-content code { background-color: #222; padding: 2px 6px; border-radius: 4px; font-family: monospace; color: var(--gold); }
    .rich-content pre code { background-color: transparent; padding: 0; color: #a5d6ff; }
    .rich-content blockquote { border-left: 4px solid var(--gold); margin: 0 0 20px 0; padding: 15px 20px; background-color: rgba(255, 215, 0, 0.05); color: var(--silver); font-style: italic; border-radius: 0 8px 8px 0; }

    /* Mobile Toggle */
    .mobile-docs-toggle { display: none; background: var(--dark-gray); color: var(--gold); padding: 15px 20px; width: 100%; text-align: left; border: none; border-bottom: 1px solid #333; font-weight: bold; font-size: 1.1em; cursor: pointer; }

    @media (max-width: 992px) {
        .docs-layout { flex-direction: column; }
        .mobile-docs-toggle { display: block; }
        .docs-sidebar { width: 100%; height: auto; position: static; display: none; border-right: none; border-bottom: 1px solid #222; }
        .docs-sidebar.show { display: block; }
        .docs-content-area { padding: 30px 20px; }
    }

    @media (max-width: 768px) {
        .docs-content-area h1 { font-size: 2em; margin-bottom: 10px; }
        .docs-content-area .meta { font-size: 0.85em; padding-bottom: 15px; margin-bottom: 20px; }
        .rich-content { font-size: 1em; }
    }
</style>

<div class="docs-layout">
    <!-- ======== DYNAMIC GO BACK BUTTON ======== -->
    <div style="margin-bottom: 20px;">
        <a href="javascript:history.back()" style="color: var(--silver); text-decoration: none; display: inline-flex; align-items: center; font-weight: 600; font-size: 1.05em; transition: color 0.3s ease;" onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--silver)'">
            <i class="fas fa-arrow-left" style="margin-right: 8px;"></i> Go Back
        </a>
    </div>
    <!-- ======================================== -->
    
    <!-- Mobile Menu Toggle -->
    <button class="mobile-docs-toggle" id="docsMenuToggle">
        <i class="fas fa-bars" style="margin-right: 10px;"></i> Documentation Menu
    </button>

    <!-- ======== SIDEBAR NAVIGATION ======== -->
    <aside class="docs-sidebar" id="docsSidebar">
        <% if (sidebarStructure && sidebarStructure.length > 0) { %>
            <% sidebarStructure.forEach(category => { %>
                <!-- Category Title -->
                <h3><%= category.name %></h3>
                <ul>
                    <!-- Pages within this category -->
                    <% category.pages.forEach(page => { %>
                        <li>
                            <a href="/docs/<%= page.slug %>" class="<%= (currentPage && currentPage.slug === page.slug) ? 'active' : '' %>">
                                <%= page.title %>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            <% }) %>
        <% } else { %>
            <p style="color: #666; padding: 10px;">No documentation created yet.</p>
        <% } %>
    </aside>

    <!-- ======== MAIN CONTENT AREA ======== -->
    <div class="docs-content-area">
        <% if (currentPage) { %>
            <h1><%= currentPage.title %></h1>
            
            <div class="meta">
                Last updated: <%= new Date(currentPage.updatedAt).toLocaleDateString() %>
                <% if (currentPage.category) { %> | Category: <span style="color: var(--gold);"><%= currentPage.category.name %></span> <% } %>
            </div>

            <!-- ======== NEW: FEATURED IMAGE ======== -->
            <% if (currentPage.featuredImageUrl) { %>
                <img src="<%= currentPage.featuredImageUrl %>" alt="<%= currentPage.title %> Cover" class="docs-featured-image">
            <% } %>
            <!-- ===================================== -->
            
            <div class="rich-content">
                <%- currentPage.content %>
            </div>
            
        <% } else { %>
            <div style="text-align: center; padding: 100px 0;">
                <lottie-player src="<%= cdnUrl %>/animations/docs.json" background="transparent" speed="1" style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(225, 225, 225, 0.5));" autoplay></lottie-player>
                <h1 style="color: #555;">Welcome to GPL Docs</h1>
                <p style="color: #666;">Please select an article from the sidebar.</p>
            </div>
        <% } %>
    </div>
    
</div>

<script>
    // Simple toggle for mobile sidebar
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('docsMenuToggle');
        const sidebar = document.getElementById('docsSidebar');
        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    });
</script>

<%- include('../partials/footer') %>