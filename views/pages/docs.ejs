<%- include('../partials/header') %>

<style>
    /* GitBook-Inspired Layout */
    .docs-layout {
        display: flex;
        min-height: calc(100vh - 80px); /* Fill screen minus header */
        background-color: var(--black);
        border-top: 1px solid #222;
    }

    /* --- SIDEBAR STYLES --- */
    .docs-sidebar {
        width: 300px;
        background-color: var(--dark-gray);
        border-right: 1px solid #222;
        padding: 30px 20px;
        overflow-y: auto;
        position: sticky;
        top: 80px; /* Adjust based on your header height */
        height: calc(100vh - 80px);
    }
    
    .docs-sidebar h3 {
        color: var(--silver);
        font-size: 0.85em;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 20px 0 10px 0;
        padding-left: 10px;
    }
    .docs-sidebar h3:first-child { margin-top: 0; }

    .docs-sidebar ul { list-style: none; padding: 0; margin: 0; }
    
    .docs-sidebar li a {
        display: block;
        color: #aaa;
        text-decoration: none;
        padding: 10px 15px;
        border-radius: 8px;
        font-size: 0.95em;
        transition: all 0.2s ease;
        margin-bottom: 2px;
    }
    
    .docs-sidebar li a:hover {
        background-color: rgba(255, 215, 0, 0.05);
        color: var(--gold);
    }
    
    /* The active page highlight */
    .docs-sidebar li a.active {
        background-color: rgba(255, 215, 0, 0.1);
        color: var(--gold);
        font-weight: 600;
        border-left: 3px solid var(--gold);
    }

    /* --- MAIN CONTENT STYLES --- */
    .docs-content-area {
        flex-grow: 1;
        padding: 50px 60px;
        max-width: 900px; /* Readability cap */
        margin: 0 auto;
    }

    .docs-content-area h1 { font-size: 2.8em; color: var(--white); margin-bottom: 10px; }
    .docs-content-area .meta { color: var(--silver); font-size: 0.9em; margin-bottom: 40px; border-bottom: 1px solid #333; padding-bottom: 20px; }
    
    /* Rich Text Formatting (Crucial for AdminJS output) */
    .rich-content { color: #ccc; font-size: 1.1em; line-height: 1.8; }
    .rich-content h2 { color: var(--gold); margin-top: 40px; margin-bottom: 15px; font-size: 1.8em; }
    .rich-content h3 { color: var(--white); margin-top: 30px; margin-bottom: 10px; }
    .rich-content p { margin-bottom: 20px; }
    .rich-content a { color: var(--gold); text-decoration: underline; }
    .rich-content ul, .rich-content ol { margin-bottom: 20px; padding-left: 20px; }
    .rich-content li { margin-bottom: 8px; }
    .rich-content img { max-width: 100%; border-radius: 8px; margin: 20px 0; border: 1px solid #333; }
    .rich-content code { background-color: #222; padding: 2px 6px; border-radius: 4px; font-family: monospace; color: var(--gold); }
    .rich-content pre { background-color: #111; padding: 20px; border-radius: 8px; overflow-x: auto; border: 1px solid #333; margin-bottom: 20px; }
    .rich-content pre code { background-color: transparent; padding: 0; color: #a5d6ff; }
    .rich-content blockquote { border-left: 4px solid var(--gold); margin: 0 0 20px 0; padding: 10px 20px; background-color: #1a1a1a; color: var(--silver); font-style: italic; }

    /* Mobile Toggle */
    .mobile-docs-toggle { display: none; background: var(--dark-gray); color: var(--gold); padding: 15px 20px; width: 100%; text-align: left; border: none; border-bottom: 1px solid #333; font-weight: bold; font-size: 1.1em; cursor: pointer; }

    @media (max-width: 992px) {
        .docs-layout { flex-direction: column; }
        .mobile-docs-toggle { display: block; }
        .docs-sidebar { 
            width: 100%; height: auto; position: static; display: none; 
            border-right: none; border-bottom: 1px solid #222; 
        }
        .docs-sidebar.show { display: block; }
        .docs-content-area { padding: 30px 20px; }
    }
</style>

<div class="docs-layout">
    
    <!-- Mobile Menu Toggle -->
    <button class="mobile-docs-toggle" id="docsMenuToggle">
        <i class="fas fa-bars" style="margin-right: 10px;"></i> Documentation Menu
    </button>

    <!-- ======== SIDEBAR NAVIGATION ======== -->
    <aside class="docs-sidebar" id="docsSidebar">
        <% if (sidebarStructure && sidebarStructure.length > 0) { %>
            <% sidebarStructure.forEach(category => { %>
                <!-- Category Title -->
                <h3><%= category.name %></h3>
                <ul>
                    <!-- Pages within this category -->
                    <% category.pages.forEach(page => { %>
                        <li>
                            <a href="/docs/<%= page.slug %>" class="<%= (currentPage && currentPage.slug === page.slug) ? 'active' : '' %>">
                                <%= page.title %>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            <% }) %>
        <% } else { %>
            <p style="color: #666; padding: 10px;">No documentation created yet.</p>
        <% } %>
    </aside>

    <!-- ======== MAIN CONTENT AREA ======== -->
    <div class="docs-content-area">
        <% if (currentPage) { %>
            <h1><%= currentPage.title %></h1>
            <div class="meta">
                Last updated: <%= new Date(currentPage.updatedAt).toLocaleDateString() %>
                <% if (currentPage.category) { %> | Category: <%= currentPage.category.name %> <% } %>
            </div>
            
            <!-- The Rich Text content from AdminJS is injected here -->
            <div class="rich-content">
                <%- currentPage.content %>
            </div>
            
        <% } else { %>
            <div style="text-align: center; padding: 100px 0;">
                <!-- ======== CUSTOM LOTTIE DOCS ANIMATION (PLAY ONCE) ======== -->
            <lottie-player 
                src="/animations/docs.json" 
                background="transparent" 
                speed="1" 
                style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(225, 225, 225, 0.5));" 
               autoplay>
            </lottie-player>
            <!-- ========================================================== -->     
                <h1 style="color: #555;">Welcome to GPL Docs</h1>
                <p style="color: #666;">Please select an article from the sidebar.</p>
            </div>
        <% } %>
    </div>
    
</div>

<script>
    // Simple toggle for mobile sidebar
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('docsMenuToggle');
        const sidebar = document.getElementById('docsSidebar');
        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('show');
            });
        }
    });
</script>

<%- include('../partials/footer') %>