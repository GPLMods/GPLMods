<%- include('../partials/header') %>

<main>
    <section class="page-header" style="border-bottom: 1px solid var(--dark-gray); padding-bottom: 30px;">
        <div class="container">
            <h1 style="font-size: 2.5em; color: var(--white); margin-bottom: 10px;">
                <i class="fas fa-file-upload" style="color: var(--green); margin-right: 15px;"></i>New <span style="color: var(--green); text-shadow: 0 0 15px rgba(67, 160, 71, 0.5);">Uploads</span>
            </h1>
            <p style="color: var(--silver); font-size: 1.1em;">Fresh mods added to the platform within the last 24 hours.</p>
        </div>
    </section>

    <div class="container" style="margin-top: 40px; margin-bottom: 60px;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <a href="/notifications" class="btn btn-secondary" style="border-color: #333; color: var(--silver);">
                <i class="fas fa-arrow-left"></i> Back to Hub
            </a>
            <span style="color: var(--silver); font-weight: bold;"><%= files.length %> New Uploads Today</span>
        </div>

        <% if (files && files.length > 0) { %>
            <!-- Reusing the standard universal mod grid layout -->
        <section class="mod-grid">
            <% files.forEach(file => { %>
                <%- include('../partials/mod-card', { file: file, showUploaderInfo: true }) %>
            <% }) %>
        </section>
        <% } else { %>
            <div style="text-align: center; padding: 60px 20px; background-color: var(--dark-gray); border-radius: 15px; border: 1px solid #333;">
                <!-- ======== CUSTOM LOTTIE EMPTY BOX ANIMATION (PLAY ONCE) ======== -->
            <lottie-player 
                src="<%= cdnUrl %>/animations/box.json" 
                background="transparent" 
                speed="1" 
                style="width: 120px; height: 120px; margin: 0 auto 15px auto; filter: drop-shadow(0 0 15px rgba(225, 225, 225, 0.5));" 
               autoplay>
            </lottie-player>
            <!-- ========================================================== -->     
                <h2 style="color: var(--white); margin-bottom: 10px;">No New Uploads Yet</h2>
                <p style="color: var(--silver); font-size: 1.1em;">Check back later! Our community is always working on new content.</p>
                <a href="/upload" class="btn" style="margin-top: 20px; display: inline-block; background: var(--gold); color: var(--black); padding: 12px 30px; border-radius: 25px; font-weight: bold; box-shadow: 0 0 15px var(--glow-gold);">Upload a Mod</a>
            </div>
        <% } %>
    </div>
</main>
<%- include('../partials/video-ad-modal') %>
<%- include('../partials/footer') %>