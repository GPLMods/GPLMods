<%- include('../partials/header') %>

<style>
    .membership-wrapper { max-width: 600px; margin: 60px auto; background-color: var(--dark-gray); padding: 50px 40px; border-radius: 15px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.4); border-top: 4px solid var(--gold); }
    .membership-wrapper h1 { color: var(--white); font-size: 2.8em; margin-bottom: 15px; }
    .membership-wrapper h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .membership-wrapper p { color: var(--silver); line-height: 1.8; font-size: 1.1em; margin-bottom: 40px; }
    
    .premium-btn { 
        width: 100%; display: block; background-color: var(--gold); color: var(--black); 
        padding: 18px 20px; font-size: 1.3em; font-weight: 800; border-radius: 10px; 
        border: none; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 15px var(--glow-gold); 
        font-family: 'Poppins', sans-serif; text-transform: uppercase; letter-spacing: 1px;
    }
    .premium-btn:hover { transform: translateY(-5px); box-shadow: 0 0 25px var(--glow-gold); }
</style>

<main class="container">
    <div class="membership-wrapper">
        <h1>Go <span>Premium!</span></h1>
        <p>Unlock a completely ad-free experience, get access to lightning-fast ⚡ upload & download servers, and support the community.</p>
        
        <div id="payment-form">
            <div id="error-message" style="color: var(--red); padding: 10px 0; min-height: 20px; font-weight: bold;"></div>

            <button id="submit-button" class="premium-btn">
                Purchase Lifetime ($10.00)
            </button>
        </div>
        <p style="font-size: 0.9em; color: #666; margin-top: 20px;"><i class="fas fa-lock"></i> Secured by Cashfree Payments.</p>
    </div>
</main>

<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cashfree = new Cashfree();
        const submitButton = document.getElementById('submit-button');
        const errorMessage = document.getElementById('error-message');

        submitButton.addEventListener('click', function(event) {
            event.preventDefault();
            this.disabled = true;
            const originalText = this.textContent;
            this.textContent = 'Preparing Checkout...';
            errorMessage.textContent = ''; 

            fetch('/create-membership-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.payment_session_id) {
                    cashfree.checkout({ payment_session_id: data.payment_session_id, redirectTarget: "_self" });
                } else {
                    throw new Error(data.error || 'Server error.');
                }
            })
            .catch(err => {
                errorMessage.textContent = 'Integration pending. Please try again later.';
                this.disabled = false;
                this.textContent = originalText;
            });
        });
    });
</script>

<%- include('../partials/footer') %>