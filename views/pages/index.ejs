<%- include('../partials/header') %>

<main class="container" style="padding-top: 100px; text-align: center;">
    <h1>Homepage Test</h1>
    <p>If you see your avatar in the header above, the backend is working perfectly!</p>
    
    <div style="margin-top: 50px; padding: 20px; background: #222; border: 1px solid #444; border-radius: 10px;">
        <h3>Debug Info:</h3>
        <% if (user) { %>
            <p style="color: #43a047;">User is LOGGED IN. Username: <%= user.username %></p>
            <p>Avatar URL: <%= user.signedAvatarUrl %></p>
        <% } else { %>
            <p style="color: #e53935;">User is NOT logged in.</p>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>