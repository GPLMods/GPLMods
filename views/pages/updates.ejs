<%- include('../partials/header') %>

<style>
    .updates-header { text-align: center; padding: 60px 20px 40px; }
    .updates-header h1 { font-size: 3em; color: var(--white); }
    .updates-header h1 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    
    .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 30px; margin-bottom: 60px; }
    .blog-card { background-color: var(--dark-gray); border-radius: 15px; padding: 30px; border: 1px solid #333; transition: all 0.3s ease; display: flex; flex-direction: column; cursor: pointer; }
    .blog-card:hover { transform: translateY(-8px); border-color: var(--gold); box-shadow: 0 10px 25px rgba(255, 215, 0, 0.15); }
    
    .blog-meta { color: var(--gold); font-size: 0.85em; font-weight: 700; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px; }
    .blog-title { color: var(--white); font-size: 1.6em; margin-bottom: 15px; line-height: 1.3; }
    .blog-excerpt { color: var(--silver); font-size: 1em; flex-grow: 1; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .read-more { color: var(--gold); font-weight: 600; text-decoration: none; align-self: flex-start; display: flex; align-items: center; gap: 5px; }
    
    /* Blog Reading Modal */
    .blog-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 2000; background: rgba(0,0,0,0.85); align-items: center; justify-content: center; backdrop-filter: blur(5px); }
    .blog-modal-content { background-color: var(--dark-gray); width: 90%; max-width: 750px; max-height: 85vh; overflow-y: auto; border-radius: 15px; padding: 40px; position: relative; border-top: 3px solid var(--gold); box-shadow: 0 15px 40px rgba(0,0,0,0.5); }
    .close-blog { position: absolute; top: 20px; right: 25px; font-size: 2.5em; color: var(--silver); cursor: pointer; line-height: 1; transition: color 0.3s; }
    .close-blog:hover { color: var(--red); }
    
    .full-blog-date { color: var(--gold); font-weight: 600; margin-bottom: 10px; display: block; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9em; }
    .full-blog-title { font-size: 2.5em; color: var(--white); margin-bottom: 25px; line-height: 1.2; }
    .full-blog-body { color: var(--silver); line-height: 1.8; font-size: 1.1em; }
    .full-blog-body p { margin-bottom: 15px; }
</style>

<main class="container">
    <div class="updates-header">
        <h1>Site News & <span>Updates</span></h1>
    </div>

    <div class="blog-grid">
        <% announcements.forEach((announcement, index) => { %>
            <div class="blog-card" onclick="openBlogModal(<%= index %>)">
                <div class="blog-meta"><%= announcement.createdAt.toLocaleDateString() %> • By <%= announcement.author %></div>
                <h2 class="blog-title"><%= announcement.title %></h2>
                <div class="blog-excerpt"><%- announcement.content %></div>
                <span class="read-more">Read Full Update <i class="fas fa-arrow-right"></i></span>
            </div>
            
            <!-- Hidden Data for Modal Injection -->
            <div id="blog-data-<%= index %>" style="display:none;">
                <span class="d-date"><%= announcement.createdAt.toLocaleDateString() %> • By <%= announcement.author %></span>
                <span class="d-title"><%= announcement.title %></span>
                <div class="d-content"><%- announcement.content.replace(/\n/g, '<br>') %></div>
            </div>
        <% }) %>
    </div>
</main>

<!-- The Reading Modal -->
<div id="blogModal" class="blog-modal">
    <div class="blog-modal-content">
        <span class="close-blog" onclick="closeBlogModal()">&times;</span>
        <span class="full-blog-date" id="modalDate"></span>
        <h2 class="full-blog-title" id="modalTitle"></h2>
        <div class="full-blog-body" id="modalBody"></div>
    </div>
</div>

<script>
    const modal = document.getElementById('blogModal');
    
    function openBlogModal(index) {
        const dataDiv = document.getElementById('blog-data-' + index);
        document.getElementById('modalDate').innerHTML = dataDiv.querySelector('.d-date').innerHTML;
        document.getElementById('modalTitle').innerHTML = dataDiv.querySelector('.d-title').innerHTML;
        document.getElementById('modalBody').innerHTML = dataDiv.querySelector('.d-content').innerHTML;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
    }
    
    function closeBlogModal() {
        modal.style.display = 'none';
        document.body.style.overflow = 'auto'; // Restore scrolling
    }
    
    // Close on outside click
    window.onclick = function(event) {
        if (event.target == modal) closeBlogModal();
    }
</script>

<%- include('../partials/footer') %>