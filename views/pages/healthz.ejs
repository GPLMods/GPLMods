// --- ADVANCED DIAGNOSTIC CONSOLE (Admin Only) ---
app.get('/healthz', ensureAuthenticated, ensureAdmin, async (req, res) => {
    
    // 1. Gather Basic Server Info
    const healthData = {
        status: 'UP',
        timestamp: new Date().toISOString(),
        uptime: formatUptime(process.uptime()),
        nodeVersion: process.version,
        memoryUsage: process.memoryUsage(),
        environment: process.env.NODE_ENV || 'development',
        services: {
            database: { status: 'UNKNOWN', details: null },
            storage: { status: 'UNKNOWN', details: null },
            virustotal: { status: 'UNKNOWN', details: null }
        },
        warnings: []
    };

    try {
        // 2. Check MongoDB Connection
        try {
            const dbState = mongoose.connection.readyState;
            if (dbState === 1) {
                healthData.services.database.status = 'CONNECTED';
                healthData.services.database.details = `Connected to Atlas`;
            } else {
                healthData.services.database.status = 'DISCONNECTED';
                healthData.warnings.push(`MongoDB state is: ${dbState}`);
                healthData.status = 'DEGRADED';
            }
        } catch (dbErr) {
            healthData.services.database.status = 'ERROR';
            healthData.warnings.push(`MongoDB Error: ${dbErr.message}`);
            healthData.status = 'DEGRADED';
        }

        // 3. Check Backblaze B2 (S3 Client)
        try {
            if (!s3Client) throw new Error("s3Client is not initialized.");
            
            const command = new ListObjectsV2Command({
                Bucket: process.env.B2_BUCKET_NAME,
                MaxKeys: 1
            });
            
            // Use a short timeout so a hanging B2 connection doesn't freeze the page
            const b2Promise = s3Client.send(command);
            const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error("B2 Connection Timeout")), 5000));
            
            await Promise.race([b2Promise, timeoutPromise]);
            
            healthData.services.storage.status = 'CONNECTED';
            healthData.services.storage.details = `Bucket: ${process.env.B2_BUCKET_NAME}`;
        } catch (b2Err) {
            healthData.services.storage.status = 'ERROR';
            healthData.warnings.push(`Backblaze B2 Error: ${b2Err.message}`);
            healthData.status = 'DEGRADED';
        }

        // 4. Check VirusTotal API
        try {
            if (!process.env.VIRUSTOTAL_API_KEY || process.env.VIRUSTOTAL_API_KEY.length < 32) {
                throw new Error("API Key is missing or invalid.");
            }
            healthData.services.virustotal.status = 'CONFIGURED';
            healthData.services.virustotal.details = 'API Key is present.';
        } catch (vtErr) {
            healthData.services.virustotal.status = 'ERROR';
            healthData.warnings.push(`VirusTotal Error: ${vtErr.message}`);
        }

        // 5. Final Status Calculation
        if (healthData.warnings.length > 0 && healthData.status === 'UP') {
            healthData.status = 'DEGRADED';
        }

        res.render('pages/admin/healthz', { health: healthData });

    } catch (criticalError) {
        // If the entire route crashes for an unforeseen reason, log it and send a generic 500
        console.error("CRITICAL ERROR IN /HEALTHZ ROUTE:", criticalError);
        res.status(500).send("Critical error loading health dashboard. Check server logs.");
    }
});