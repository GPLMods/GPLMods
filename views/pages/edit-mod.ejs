<%- include('../partials/header') %>

<!-- ✅ ADD QUILL.JS STYLES AND SCRIPT -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<style>
    /* Reusing your standard form styles */
    .upload-form-container { max-width: 800px; margin: 2rem auto; padding: 30px; background-color: var(--dark-gray); border: 1px solid #333; border-radius: 15px; }
    .upload-form-container h2 { text-align: center; font-size: 2.5em; margin-bottom: 1rem; color: var(--white); }
    .upload-form-container h2 span { color: var(--gold); text-shadow: 0 0 15px var(--glow-gold); }
    .form-section { border: 1px solid #333; border-radius: 8px; padding: 20px; margin-bottom: 30px; }
    .form-section legend { padding: 0 10px; margin-left: 15px; font-size: 1.3em; font-weight: 600; color: var(--gold); }
    .form-group { margin-bottom: 25px; position: relative; } /* Added position: relative for custom dropdowns */
    .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: var(--silver); }
    .form-group input[type="text"], .form-group input[type="url"], .form-group select, .form-group textarea { width: 100%; padding: 12px 15px; border-radius: 8px; border: 1px solid #333; background-color: var(--black); color: var(--white); font-size: 1em; font-family: 'Poppins', sans-serif; transition: all 0.3s ease; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); }
    .form-group textarea { min-height: 120px; resize: vertical; }
    
    .icon-upload-container { display: flex; flex-direction: column; align-items: center; margin-bottom: 30px; padding: 20px; border: 2px dashed #333; border-radius: 15px; background-color: rgba(0,0,0,0.2); }
    .icon-preview { width: 100px; height: 100px; background-color: var(--black); border-radius: 20px; margin-bottom: 15px; display: flex; align-items: center; justify-content: center; border: 2px solid var(--gold); overflow: hidden; }
    .icon-preview img { width: 100%; height: 100%; object-fit: contain; }
    
    .file-input-wrapper { position: relative; display: inline-block; width: 100%; }
    input[type="file"] { display: none; }
    .file-input-label { display: block; padding: 12px 20px; background: transparent; color: var(--gold); border: 2px solid var(--gold); border-radius: 8px; cursor: pointer; text-align: center; font-size: 1em; transition: all 0.3s ease; }
    .file-input-label:hover { background: var(--gold); color: var(--black); box-shadow: 0 0 15px var(--glow-gold); }
    
    .preview-container { margin-top: 15px; border-radius: 8px; background-color: var(--black); padding: 15px; border: 1px solid #333; display: none; }
    #screenshotPreviewContainer { column-count: 2; column-gap: 15px; }
    #screenshotPreviewContainer img { width: 100%; height: auto; border-radius: 8px; margin-bottom: 15px; break-inside: avoid; display: block; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
    
    .submit-button { display: block; width: 100%; background: var(--gold); color: var(--black); padding: 15px 20px; border-radius: 8px; font-size: 1.2em; font-weight: 700; border: none; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 0 15px var(--glow-gold); margin-top: 20px; }
    .submit-button:hover { transform: translateY(-5px); box-shadow: 0 0 25px var(--glow-gold); }

    .status-banner { text-align: center; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold; }
    .status-banner.rejected { background-color: rgba(229, 57, 53, 0.1); border: 1px solid var(--red); color: var(--red); }

    /* Custom styles to make Quill match our dark theme */
    .ql-toolbar.ql-snow { background-color: #333; border-color: #444; border-radius: 8px 8px 0 0; }
    .ql-container.ql-snow { background-color: var(--black); border-color: #444; border-radius: 0 0 8px 8px; color: var(--white); font-family: 'Poppins', sans-serif; font-size: 1em; min-height: 250px; }
    .ql-editor.ql-blank::before { color: #888; }
    .ql-snow .ql-stroke { stroke: var(--silver); }
    .ql-snow .ql-fill { fill: var(--silver); }
    .ql-snow .ql-picker { color: var(--silver); }
    
    /* --- Force Quill Editors to be responsive on mobile --- */
    .ql-toolbar, .ql-container { max-width: 100% !important; box-sizing: border-box !important; }
    .ql-editor { word-wrap: break-word !important; overflow-wrap: break-word !important; word-break: break-word !important; max-width: 100% !important; padding: 12px 10px !important; }
    .upload-form-container { max-width: 100%; overflow-x: hidden; }

    /* --- ✅ NEW: CUSTOM SELECT DROPDOWN CSS --- */
    .custom-select-wrapper { position: relative; user-select: none; width: 100%; }
    .custom-select { position: relative; display: flex; align-items: center; justify-content: space-between; padding: 15px; background-color: var(--black); border: 1px solid #333; border-radius: 8px; cursor: pointer; color: var(--silver); font-size: 1em; transition: all 0.3s ease; }
    .custom-select-wrapper.open .custom-select { border-color: var(--gold); box-shadow: 0 0 10px var(--glow-gold); border-bottom-left-radius: 0; border-bottom-right-radius: 0; }
    .custom-select-wrapper.open .custom-select-arrow { transform: rotate(180deg); color: var(--gold); }
    .custom-options { position: absolute; top: 100%; left: 0; right: 0; background-color: var(--dark-gray); border: 1px solid var(--gold); border-top: none; border-radius: 0 0 8px 8px; box-shadow: 0 10px 20px rgba(0,0,0,0.5); z-index: 100; display: none; max-height: 250px; overflow-y: auto; }
    .custom-select-wrapper.open .custom-options { display: block; }
    .custom-option { padding: 12px 15px; cursor: pointer; color: var(--white); transition: background-color 0.2s; border-bottom: 1px solid #2a2a2a; }
    .custom-option:last-child { border-bottom: none; }
    .custom-option:hover { background-color: var(--black); color: var(--gold); }
    .custom-option.selected { background-color: var(--black); color: var(--gold); font-weight: bold; }
    .custom-select-wrapper.disabled .custom-select { opacity: 0.5; cursor: not-allowed; background-color: #111; }
    .custom-select-wrapper.disabled .custom-options { display: none !important; }
</style>

<div class="container">
    <div class="upload-form-container">
        
        <h2>
            Edit 
            <span style="color: var(--gold); text-shadow: 0 0 15px var(--glow-gold);">
                <%= file.isVariant ? 'Variant: ' : 'Mod: ' %><%= file.name %>
            </span>
        </h2>
        
        <% if (file.isVariant) { %>
            <div class="status-banner" style="background-color: rgba(33, 150, 243, 0.1); border: 1px solid var(--blue); color: var(--blue);">
                <i class="fas fa-info-circle"></i> You are editing a Variant of an existing app. The App Icon, Official Description, and Tags are managed by the original uploader.
            </div>
        <% } %>
        
        <% if (file.status === 'rejected' && file.rejectionReason) { %>
            <div class="status-banner rejected">
                ⚠️ Mod Rejected: <%= file.rejectionReason %>
                <br><span style="font-size: 0.85em; font-weight: normal; color: var(--silver);">Fix the issues below and submit to return to the review queue.</span>
            </div>
        <% } %>

        <form action="/mods/<%= file._id %>/edit" method="POST" enctype="multipart/form-data" id="details-form">
            
            <fieldset class="form-section">
                <legend>Core Details</legend>

                <% if (!file.isVariant) { %>
                <div class="icon-upload-container">
                    <label>Mod Icon</label>
                    <div class="icon-preview" id="iconPreviewBox">
                        <img id="iconImage" src="<%= file.iconUrl %>" alt="Icon Preview" style="display:block;">
                    </div>
                    <div style="max-width: 250px; text-align: center;">
                        <input type="file" id="modIcon" name="softwareIcon" accept="image/*">
                        <label for="modIcon" class="file-input-label">Change Icon (Optional)</label>
                    </div>
                </div>
                <% } %>

                <div class="form-group">
                    <label for="modName">Mod Name*</label>
                    <input type="text" id="modName" name="modName" value="<%= file.name %>" <%= file.isVariant ? 'readonly style="opacity:0.7; cursor:not-allowed;"' : 'required' %>>
                </div>

                <div class="form-group">
                    <label for="developerName">Official Developer / Company</label>
                    <input type="text" id="developerName" name="developerName" value="<%= file.developer !== 'N/A' ? file.developer : '' %>">
                </div>

                <!-- ✅ FIXED: Platform Custom Dropdown -->
                <div class="form-group">
                    <label>Platform*</label>
                    <!-- Hidden Native Select -->
                    <select id="modPlatform" name="modPlatform" required style="display: none;">
                        <option value="" disabled <%= !file.category ? 'selected' : '' %>>Select a platform...</option>
                        <option value="android" <%= file.category === 'android' ? 'selected' : '' %>>Android</option>
                        <option value="ios-jailed" <%= file.category === 'ios-jailed' ? 'selected' : '' %>>iOS - Jailed (IPA)</option>
                        <option value="ios-jailbroken" <%= file.category === 'ios-jailbroken' ? 'selected' : '' %>>iOS - Jailbroken (DEB)</option>
                        <option value="windows" <%= file.category === 'windows' ? 'selected' : '' %>>Windows</option>
                        <option value="wordpress" <%= file.category === 'wordpress' ? 'selected' : '' %>>WordPress</option>
                    </select>
                    
                    <!-- Custom UI -->
                    <div class="custom-select-wrapper" id="platformWrapper">
                        <div class="custom-select">
                            <span class="selected-text"><%= file.category ? file.category.toUpperCase() : 'Select a platform...' %></span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <div class="custom-options">
                            <div class="custom-option <%= file.category === 'android' ? 'selected' : '' %>" data-value="android">Android</div>
                            <div class="custom-option <%= file.category === 'ios-jailed' ? 'selected' : '' %>" data-value="ios-jailed">iOS - Jailed (IPA)</div>
                            <div class="custom-option <%= file.category === 'ios-jailbroken' ? 'selected' : '' %>" data-value="ios-jailbroken">iOS - Jailbroken (DEB)</div>
                            <div class="custom-option <%= file.category === 'windows' ? 'selected' : '' %>" data-value="windows">Windows</div>
                            <div class="custom-option <%= file.category === 'wordpress' ? 'selected' : '' %>" data-value="wordpress">WordPress</div>
                        </div>
                    </div>
                </div>

                <!-- ✅ FIXED: Category Custom Dropdown -->
                <div class="form-group">
                    <label>Sub-Category*</label>
                    <select id="modCategory" name="modCategory" required disabled style="display: none;">
                        <option value="<%= file.platforms[0] || '' %>" selected><%= file.platforms[0] || 'Select category...' %></option>
                    </select>

                    <div class="custom-select-wrapper disabled" id="categoryWrapper">
                        <div class="custom-select">
                            <span class="selected-text"><%= file.platforms[0] || 'Select a platform first...' %></span>
                            <i class="fas fa-chevron-down custom-select-arrow"></i>
                        </div>
                        <div class="custom-options" id="categoryOptionsContainer"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="modVersion">Mod Version*</label>
                    <input type="text" id="modVersion" name="modVersion" value="<%= file.version !== 'Draft' ? file.version : '' %>" required>
                </div>
            </fieldset>
            
            <fieldset class="form-section">
                <legend>Descriptions</legend>

                <div class="form-group">
                    <label for="modDescription">Mod Description*</label>
                    <textarea id="modDescription" name="modDescription" style="display:none;" required><%- file.modDescription %></textarea>
                    <div id="editor-modDescription"><%- file.modDescription %></div>
                </div>

                <div class="form-group">
                    <label for="modFeatures">Mod Features* (One per line)</label>
                    <textarea id="modFeatures" name="modFeatures" style="display:none;" required><%- file.modFeatures %></textarea>
                    <div id="editor-modFeatures"><%- file.modFeatures %></div>
                </div>

                <% if (!file.isVariant) { %>
                <div class="form-group">
                    <label for="officialDescription">Official Description (Optional)</label>
                    <textarea id="officialDescription" name="officialDescription" style="display:none;"><%- file.officialDescription %></textarea>
                    <div id="editor-officialDescription"><%- file.officialDescription %></div>
                </div>
                <% } %>

                <div class="form-group">
                    <label for="importantNote">Important Note / Installation Instructions (Optional)</label>
                    <textarea id="importantNote" name="importantNote" style="display:none;"><%- file.importantNote %></textarea>
                    <div id="editor-importantNote"><%- file.importantNote %></div>
                </div>
                
                <div class="form-group">
                    <label for="whatsNew">What's New (Optional)</label>
                    <textarea id="whatsNew" name="whatsNew" style="display:none;"><%- file.whatsNew %></textarea>
                    <div id="editor-whatsNew"><%- file.whatsNew %></div>
                </div>
            </fieldset>

            <fieldset class="form-section">
                <legend>Media & Metadata</legend>
                
                <% if (!file.isVariant) { %>
                    <div class="form-group">
                        <label for="tags">Tags (Optional, comma-separated)</label>
                        <input type="text" id="tags" name="tags" value="<%= file.tags ? file.tags.join(', ') : '' %>">
                    </div>
                <% } %>

                <div class="form-group">
                    <label>Mod Screenshots (Upload to replace existing)</label>
                    <div class="file-input-wrapper">
                        <input type="file" id="screenshots" name="screenshots" accept="image/png, image/jpeg" multiple>
                        <label for="screenshots" class="file-input-label">Replace Screenshots (Optional)</label>
                        <span class="file-name" id="screenshotFileName" style="display:block; margin-top: 10px; color: var(--silver); text-align: center;">Leave empty to keep current screenshots</span>
                    </div>
                    
                    <div class="preview-container" id="screenshotPreviewContainer" style="<%= file.screenshotUrls.length > 0 ? 'display:block;' : 'display:none;' %>">
                        <% file.screenshotUrls.forEach(url => { %>
                            <img src="<%= url %>" alt="Current Screenshot">
                        <% }) %>
                    </div>
                </div>

                <div class="form-group">
                    <label for="videoUrl">Video URL (Optional)</label>
                    <input type="url" id="videoUrl" name="videoUrl" value="<%= file.videoUrl || '' %>">
                </div>
            </fieldset>
            
            <input type="hidden" name="actionType" id="actionType" value="submit">

            <div class="button-group" style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="button" class="btn btn-secondary" id="saveDraftBtn" style="flex: 1; padding: 15px; border-radius: 8px; font-weight: bold; border-color: #555; color: var(--silver); background: transparent;">Save as Draft</button>
                
                <button type="button" class="submit-button" id="submitModBtn" style="flex: 2; margin-top: 0;">
                    <%= file.status === 'rejected' ? 'Resubmit for Review' : 'Save & Publish Changes' %>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ======== DYNAMIC STATUS MESSAGE BOX ======== -->
<div id="status-alert-box" class="alert-msg" style="display: none; width: 100%; max-width: 800px; margin: 0 auto 20px auto;"></div>

<!-- ======== CONFIRMATION MODALS ======== -->
<div id="submit-confirm-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--gold); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-paper-plane" style="font-size: 3em; color: var(--gold); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Submit Changes?</h2>
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            Are you sure you want to submit these changes? 
            <% if (file.status === 'rejected') { %>
                This will send the mod back to the admin queue for re-review.
            <% } else { %>
                These updates will be visible immediately.
            <% } %>
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" class="btn btn-primary" id="confirmSubmitBtn" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: var(--gold); color: var(--black); border: none; cursor: pointer;">Yes, Submit</button>
            <button type="button" class="btn btn-secondary" onclick="closeConfirmModal('submit-confirm-modal')" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: transparent; border: 2px solid var(--silver); color: var(--silver); cursor: pointer;">Cancel</button>
        </div>
    </div>
</div>

<div id="draft-confirm-modal" class="policy-modal">
    <div class="policy-modal-content" style="background-color: var(--dark-gray); padding: 30px; text-align: center; border-radius: 15px; max-width: 450px; width: 90%; border-top: 3px solid var(--silver); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <i class="fas fa-save" style="font-size: 3em; color: var(--silver); margin-bottom: 15px;"></i>
        <h2 style="color: var(--white); margin-bottom: 15px;">Save Draft?</h2>
        <p style="margin-bottom: 25px; color: var(--silver); line-height: 1.6;">
            Your progress will be saved, but the mod will be marked as a Draft and taken offline until you submit it.
        </p>
        <div style="display: flex; gap: 15px; justify-content: center;">
            <button type="button" class="btn btn-primary" id="confirmDraftBtn" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: var(--silver); color: var(--black); border: none; cursor: pointer;">Save Draft</button>
            <button type="button" class="btn btn-secondary" onclick="closeConfirmModal('draft-confirm-modal')" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: bold; background-color: transparent; border: 2px solid #555; color: var(--silver); cursor: pointer;">Cancel</button>
        </div>
    </div>
</div>

<script>
// Helper to control the Error/Success Alert Box
function showStatusAlert(message, type) {
    const alertBox = document.getElementById('status-alert-box');
    if (!alertBox) return;
    alertBox.textContent = message;
    if (type === 'error') {
        alertBox.className = 'status-banner rejected'; 
        alertBox.style.backgroundColor = 'rgba(229, 57, 53, 0.1)';
        alertBox.style.color = 'var(--red)';
        alertBox.style.border = '1px solid var(--red)';
    } else {
        alertBox.className = 'status-banner'; 
        alertBox.style.backgroundColor = 'rgba(46, 204, 113, 0.1)';
        alertBox.style.color = '#2ecc71';
        alertBox.style.border = '1px solid #2ecc71';
    }
    alertBox.style.display = 'block';
    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

window.closeConfirmModal = function(modalId) {
    const modal = document.getElementById(modalId);
    if (modal) {
        modal.classList.remove('show');
        setTimeout(() => { modal.style.display = 'none'; }, 200);
    }
}

document.addEventListener('DOMContentLoaded', () => {

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('error')) showStatusAlert(urlParams.get('error'), 'error'); 
    if (urlParams.has('success')) showStatusAlert(urlParams.get('success'), 'success'); 

    // ==========================================
    // 1. UI ELEMENTS & BASIC LOGIC
    // ==========================================
    const modIcon = document.getElementById('modIcon');
    const iconImage = document.getElementById('iconImage');
    const screenshotsInput = document.getElementById('screenshots');
    const screenshotFileNameSpan = document.getElementById('screenshotFileName');
    const screenshotPreviewContainer = document.getElementById('screenshotPreviewContainer');

    if (modIcon) {
        modIcon.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => { iconImage.src = e.target.result; iconImage.style.display = 'block'; }
                reader.readAsDataURL(this.files[0]);
            }
        });
    }

    if (screenshotsInput) {
        screenshotsInput.addEventListener('change', function() {
            const files = this.files;
            if (screenshotPreviewContainer) screenshotPreviewContainer.innerHTML = ''; 
            if (files.length > 0) {
                if (screenshotPreviewContainer) screenshotPreviewContainer.style.display = 'block'; 
                if (screenshotFileNameSpan) screenshotFileNameSpan.textContent = files.length + ' new file(s) selected';
                Array.from(files).slice(0, 4).forEach(file => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        if (screenshotPreviewContainer) screenshotPreviewContainer.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                });
            } else {
                if (screenshotPreviewContainer) screenshotPreviewContainer.style.display = 'none';
            }
        });
    }

    // ==========================================
    // 2. CUSTOM SELECT LOGIC (DYNAMIC)
    // ==========================================
    const platformWrapper = document.getElementById('platformWrapper');
    const nativePlatformSelect = document.getElementById('modPlatform');
    const categoryWrapper = document.getElementById('categoryWrapper');
    const nativeCategorySelect = document.getElementById('modCategory');
    const categoryOptionsContainer = document.getElementById('categoryOptionsContainer');

    function setupCustomSelect(wrapper, nativeSelect) {
        if (!wrapper || !nativeSelect) return;
        const customSelect = wrapper.querySelector('.custom-select');
        const selectedText = wrapper.querySelector('.selected-text');
        
        customSelect.addEventListener('click', function(e) {
            if (wrapper.classList.contains('disabled')) return;
            e.stopPropagation();
            document.querySelectorAll('.custom-select-wrapper').forEach(w => {
                if (w !== wrapper) w.classList.remove('open');
            });
            wrapper.classList.toggle('open');
            this.style.borderColor = '';
            this.style.boxShadow = '';
        });

        const optionsContainer = wrapper.querySelector('.custom-options');
        if (optionsContainer) {
            optionsContainer.addEventListener('click', function(e) {
                if (e.target.classList.contains('custom-option')) {
                    e.stopPropagation();
                    const value = e.target.getAttribute('data-value');
                    const text = e.target.textContent;

                    selectedText.textContent = text;
                    selectedText.style.color = 'var(--white)';
                    nativeSelect.value = value;
                    nativeSelect.dispatchEvent(new Event('change'));

                    wrapper.querySelectorAll('.custom-option').forEach(opt => opt.classList.remove('selected'));
                    e.target.classList.add('selected');
                    wrapper.classList.remove('open');
                }
            });
        }
    }

    setupCustomSelect(platformWrapper, nativePlatformSelect);
    setupCustomSelect(categoryWrapper, nativeCategorySelect);

    document.addEventListener('click', function() {
        document.querySelectorAll('.custom-select-wrapper').forEach(wrapper => wrapper.classList.remove('open'));
    });

    // --- Dynamic Category Population Logic ---
    const categoriesByPlatform = {
        android:['Game - Action', 'Game - Adventure', 'Game - Puzzle', 'Game - RPG', 'App - Productivity', 'App - Social', 'App - Tools', 'Other'],
        'ios-jailed':['Game - Action', 'Game - Adventure', 'Game - Puzzle', 'Game - RPG', 'App - Productivity', 'App - Social', 'App - Tools', 'Other'],
        'ios-jailbroken':['Tweak', 'Theme', 'Utility', 'Widget', 'Other'],
        windows:['Software - Utility', 'Software - Multimedia', 'Software - Security', 'Software - Development', 'Game', 'Other'],
        wordpress:['Plugin - SEO', 'Plugin - Security', 'Plugin - E-commerce', 'Plugin - Page Builder', 'Theme - Portfolio', 'Theme - E-commerce', 'Theme - Blog', 'Other']
    };

    function populateCategories() {
        if (!nativePlatformSelect || !nativeCategorySelect || !categoryOptionsContainer || !categoryWrapper) return;
        
        const selectedPlatform = nativePlatformSelect.value;
        const categories = categoriesByPlatform[selectedPlatform] ||[];
        const currentCategory = "<%= (file.platforms && file.platforms.length > 0) ? file.platforms[0] : '' %>"; 

        nativeCategorySelect.innerHTML = '';
        categoryOptionsContainer.innerHTML = '';
        const customSelectedText = categoryWrapper.querySelector('.selected-text');

        if (categories.length > 0) {
            nativeCategorySelect.disabled = false;
            categoryWrapper.classList.remove('disabled');
            customSelectedText.textContent = 'Select a category...';
            customSelectedText.style.color = 'var(--silver)';
            
            let nativeDefault = document.createElement('option');
            nativeDefault.text = 'Select a category...';
            nativeDefault.value = '';
            nativeDefault.disabled = true;
            if (!currentCategory) nativeDefault.selected = true;
            nativeCategorySelect.add(nativeDefault);

            categories.forEach(function(category) {
                const catValue = category.toLowerCase().replace(/ /g, '-');
                
                let option = document.createElement('option');
                option.text = category;
                option.value = catValue;
                nativeCategorySelect.add(option);
                
                let customOpt = document.createElement('div');
                customOpt.className = 'custom-option';
                customOpt.setAttribute('data-value', catValue);
                customOpt.textContent = category;
                categoryOptionsContainer.appendChild(customOpt);
            });
            
            // Set the selected custom option if a current category exists
            if (currentCategory) {
                const optToSelect = categoryOptionsContainer.querySelector(`.custom-option[data-value="${currentCategory}"]`);
                if (optToSelect) {
                    optToSelect.classList.add('selected');
                    customSelectedText.textContent = optToSelect.textContent;
                    customSelectedText.style.color = 'var(--white)';
                    nativeCategorySelect.value = currentCategory;
                }
            }

        } else {
            nativeCategorySelect.disabled = true;
            categoryWrapper.classList.add('disabled');
            customSelectedText.textContent = 'Select a platform first...';
            customSelectedText.style.color = 'var(--silver)';
        }
    }

    if (nativePlatformSelect) {
        nativePlatformSelect.addEventListener('change', populateCategories);
        const preSelectedPlatform = "<%= file.category || '' %>"; 
        if (preSelectedPlatform) {
            const optionToSelect = platformWrapper.querySelector(`.custom-option[data-value="${preSelectedPlatform}"]`);
            if(optionToSelect) optionToSelect.click(); 
        }
    }

    // ==========================================
    // 3. QUILL RICH TEXT EDITORS & SUBMISSION
    // ==========================================
    const toolbarOptions = [['bold', 'italic', 'underline', 'strike'], [{ 'list': 'ordered'}, { 'list': 'bullet' }],['clean']];

    let quillDesc, quillFeat, quillOff, quillNew, quillNote;

    if (document.getElementById('editor-modDescription')) quillDesc = new Quill('#editor-modDescription', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-modFeatures')) quillFeat = new Quill('#editor-modFeatures', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-officialDescription')) quillOff = new Quill('#editor-officialDescription', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-whatsNew')) quillNew = new Quill('#editor-whatsNew', { theme: 'snow', modules: { toolbar: toolbarOptions } });
    if (document.getElementById('editor-importantNote')) quillNote = new Quill('#editor-importantNote', { theme: 'snow', modules: { toolbar: toolbarOptions } });

    function syncQuillData() {
        if(quillDesc) document.getElementById('modDescription').value = quillDesc.root.innerHTML === '<p><br></p>' ? '' : quillDesc.root.innerHTML;
        if(quillFeat) document.getElementById('modFeatures').value = quillFeat.root.innerHTML === '<p><br></p>' ? '' : quillFeat.root.innerHTML;
        if(quillOff) document.getElementById('officialDescription').value = quillOff.root.innerHTML === '<p><br></p>' ? '' : quillOff.root.innerHTML;
        if(quillNew) document.getElementById('whatsNew').value = quillNew.root.innerHTML === '<p><br></p>' ? '' : quillNew.root.innerHTML;
        if(quillNote) document.getElementById('importantNote').value = quillNote.root.innerHTML === '<p><br></p>' ? '' : quillNote.root.innerHTML;
    }

    const saveDraftBtn = document.getElementById('saveDraftBtn');
    const submitModBtn = document.getElementById('submitModBtn');
    const actionTypeInput = document.getElementById('actionType');
    const mainForm = document.getElementById('details-form');
    const draftModal = document.getElementById('draft-confirm-modal');
    const submitModal = document.getElementById('submit-confirm-modal');

    if (saveDraftBtn && draftModal) {
        saveDraftBtn.addEventListener('click', (e) => {
            e.preventDefault();
            syncQuillData(); 
            draftModal.style.display = 'flex';
            setTimeout(() => draftModal.classList.add('show'), 10);
        });
    }

    if (submitModBtn && mainForm && submitModal) {
        submitModBtn.addEventListener('click', (e) => {
            e.preventDefault();
            syncQuillData();
            
            let hasError = false;

            if (!nativePlatformSelect.value) {
                platformWrapper.querySelector('.custom-select').style.borderColor = 'var(--red)';
                hasError = true;
            }
            if (!nativeCategorySelect.value || nativeCategorySelect.disabled) {
                categoryWrapper.querySelector('.custom-select').style.borderColor = 'var(--red)';
                hasError = true;
            }

            if (!mainForm.checkValidity() || hasError) {
                mainForm.reportValidity();
                if(hasError) alert('Please select a platform and category.');
                return;
            }
            
            const descInput = document.getElementById('modDescription');
            const featInput = document.getElementById('modFeatures');
            
            if (descInput && !descInput.value.trim()) { showStatusAlert('Error: Mod Description is required.', 'error'); return; }
            if (featInput && !featInput.value.trim()) { showStatusAlert('Error: Mod Features are required.', 'error'); return; }

            submitModal.style.display = 'flex';
            setTimeout(() => submitModal.classList.add('show'), 10);
        });
    }

    if (document.getElementById('confirmDraftBtn') && mainForm) {
        document.getElementById('confirmDraftBtn').addEventListener('click', () => {
            if(actionTypeInput) actionTypeInput.value = 'draft'; 
            mainForm.querySelectorAll('[required]').forEach(el => el.removeAttribute('required'));
            document.getElementById('confirmDraftBtn').textContent = 'Saving...';
            mainForm.submit(); 
        });
    }

    if (document.getElementById('confirmSubmitBtn') && mainForm) {
        document.getElementById('confirmSubmitBtn').addEventListener('click', () => {
            if(actionTypeInput) actionTypeInput.value = 'submit'; 
            document.getElementById('confirmSubmitBtn').textContent = 'Submitting...';
            mainForm.submit(); 
        });
    }
});
</script>

<%- include('../partials/footer') %>